static void GAP_Evt_Callback(struct gap_ble_evt* p_evt)
{
    if (p_evt->evt_code == GAP_EVT_ADV_END)
    {
        DEBUG_log(("ble: advend"));

        (*evt_callback)(BLE_ADV_END);

    }
    else if (p_evt->evt_code == GAP_EVT_CONNECTED)
    {
        DEBUG_log(("ble: connection"));

#ifdef BLE_RECONNECT_IN_ERR
        disconnect_sleep_bit = 0x01;
#endif
        check_pair_state = 0;
        _isConnected = 1;
        _update_en = 0;
        _latency_mode = 0;
        //Storage_Init();

#ifdef CONFIG_RPOBE_OS
        att_c_start();
        probe_os = 0;
#endif
        (*evt_callback)(BLE_CONNECTED);
    }
    
    else if (p_evt->evt_code == GAP_EVT_PAIRING_START)
    {
        check_pair_state = 0x01;
        DBGPRINTF(("GAP_EVT_PAIRING_START\r\n"));//該事件表示藍牙鏈接後，配對流程開始了
    //    led_slow_blink_start();//开始闪烁
     //   (*evt_callback)(BLE_DISCONNECTED);
    }

    else if (p_evt->evt_code == GAP_EVT_DISCONNECTED)
    {
        // DEBUG_log("ble: GAP_EVT_DISCONNECTED(%02x)", p_evt->evt.disconn_evt.reason);
        if(p_evt->evt.disconn_evt.reason == 0x13 && check_pair_state == 0x01)
        {
            // switch_target_device_idx = _device_idx;
            //DEBUG_log("IOS_Pair_flag = %d\r\n",IOS_Pair_flag);
            if (IOS_Pair_flag == 1)
            {
                DEBUG_log("GO_TO_lunxun");
                _set_evt(USER_ST,SYS_SWITCH_CHANNEL);   
            }
            else if(IOS_Pair_flag == 0)
            {
                _set_evt(SYS_ST,SYS_PAIRING);
                DEBUG_log("GO_TO_PAIRING");
            }
        }
        check_pair_state = 0;
#ifdef BLE_RECONNECT_IN_ERR
        if(p_evt->evt.disconn_evt.reason == 0x3e)
        {
            disconnect_sleep_bit = 0x01;
        }
#endif
        _isConnected = 0;
        _hid_protocol_mode = HID_REPORT_PROTOCOL_MODE;
        _latency_mode = 0;
#ifdef CONFIG_RPOBE_OS
            probe_os = 0;
        #endif
        //ble_set_trigger_adv_reset(1);
        

        (*evt_callback)(BLE_DISCONNECTED);
    }
    else if (p_evt->evt_code == GAP_EVT_ATT_HANDLE_CONFIGURE)
    {
        DEBUG_log("ble: GAP_EVT_ATT_HANDLE_CONFIGURE");
        #ifdef POLLING_BLEADV_ENABLE
        direct_adv_cnt=0;
        direct_adv_st=0;
        write_addr_data=0;
        #endif
        
#ifdef BLE_RECONNECT_IN_ERR
        disconnect_sleep_bit |= 0x10;//断连睡眠标志
#endif

        if (evt_callback)
            (*evt_callback)(BLE_NOTIFY_ENABLE);

//------------------------------------------------------------------------------------				
#ifdef CONFIG_RPOBE_OS

        if (probe_os == 0)
        {
            uint16_t start_hdl = 0x0001, end_hdl = 0xffff;
            uint16_t value = DEVICE_INFORMATION;
            DEBUG_log(("ble: probe_os"));
            
            probe_os = 1;
            att_c_find_by_type_value_req(start_hdl, end_hdl, GATT_UUID_PRIMARY_SERVICE, sizeof(value), (uint8_t*)&value, ble_att_c_evt_handler_probe_os);
        }

#endif

    }
    else if (p_evt->evt_code == GAP_EVT_ENC_START)
    {


        struct gap_update_params update;
        pxi_gap_s_link_parameters_get(&link_params);

        if ((link_params.interval != CONNECTION_INTERVAL_MIN) || (link_params.interval != CONNECTION_INTERVAL_MAX) || (link_params.latency != CONNECTION_LATENCY))
        {

            update.updateitv_min = CONNECTION_INTERVAL_MIN;
            update.updateitv_max = CONNECTION_INTERVAL_MAX;
            update.updatelatency = CONNECTION_LATENCY;
            update.updatesvto = CONNECTION_SVTO;
            // DEBUG_log(">pxi_gap_s_connection_update");
            pxi_gap_s_connection_update(&update);
            // DEBUG_log("<pxi_gap_s_connection_update");
            _update_en = 1;
            IOS_Pair_flag = 1;
        }

        timer_enable(NOTIFY_TIMER_ID,_notify_flag_cb,NOTIFY_TIMER_LONG,1);
        (*evt_callback)(BLE_NOTIFY_ENABLE);


        (*evt_callback)(BLE_START_ENC);
    }
    else if (p_evt->evt_code == GAP_EVT_L2CAP_UPDATE_RSP)
    {
        if ((p_evt->evt.l2cap_update_rsp_evt.result == 0x0001) && (_update_en == 1))
        {
            struct gap_update_params update;

            update.updateitv_min = IOS_CONNECTION_INTERVAL_MIN;
            update.updateitv_max = IOS_CONNECTION_INTERVAL_MAX;
            update.updatelatency = IOS_CONNECTION_LATENCY;
            update.updatesvto = IOS_CONNECTION_SVTO;
            DEBUG_log(">pxi_gap_s_connection_update2");
            pxi_gap_s_connection_update(&update);
            DEBUG_log(">pxi_gap_s_connection_update3");
            _update_en = 2;
        }
    }
    else if (p_evt->evt_code == GAP_EVT_ATT_READ)
        _ble_gatt_read(p_evt->evt.att_read_evt);

    else if (p_evt->evt_code == GAP_EVT_ATT_WRITE)
        _ble_gatt_write(p_evt->evt.att_write_evt);

    else if (p_evt->evt_code == GAP_EVT_PASSKEY_REQ)
    {
        DEBUG_log(("Passkey Req"));

        if (evt_callback)
            (*evt_callback)(BLE_PASSKEY_REQ);
    }
    else if (p_evt->evt_code == GAP_EVT_FLASH_WRITE_DONE)
    {
        if(p_evt->evt.flash_operation_st == FLASH_WRITE_BONDING_INFO_DONE)
        {
            if (pairing_state_get() > 0) {
                #ifdef POLLING_BLEADV_ENABLE
                write_addr_data=1;
                #endif
                pairing_state_clr((pairing_state_t)(GENERAL_PAIR | SWIFT_PAIR));

                _current_addr++;
                // DBGPRINTF(("write _current_addr (%02X)\r\n", _current_addr));
				#ifdef FN_LOCK
                KeyboardConfig.FN_Lock_flag[_device_idx] = 1;
                // INFO_log("2222222KeyboardConfig.FN_Lock_flag[%d] = 1\n",_device_idx);
				#endif
                pxi_gap_s_profile_data_write(2 + _device_idx, 1, &_current_addr);

            #ifdef CONFIG_ENABLE_TOUCH

                // 不是回连状态下，需要打开触控板
                touch_flag = 1;
                touchpad_switch = 1;        // 触摸板开关，默认开启
                check_touch_status();
            #endif
            }
        }
        #ifdef POLLING_BLEADV_ENABLE
        if(p_evt->evt.flash_operation_st == FLASH_WRITE_USER_PROFILE_DONE)
        {
            if (write_addr_data==1&&has_bond_adv==0){
                write_addr_data=0;
                identify_system_type(1);
            }
        }
        #endif

    }
    else if (p_evt->evt_code == GAP_EVT_PAIRING_COMP)
    {
        DBG("GAP_EVT_PAIRING_COMP status is %d reason is %x \n",p_evt->evt.pairing_comp_evt.status,p_evt->evt.pairing_comp_evt.reason);
 /*      if (p_evt->evt.pairing_comp_evt.status == 1){
            DBG("pxi_bm_s_bond_info_save \n");
            pxi_bm_s_bond_info_save();
        }
*/
        if (p_evt->evt.pairing_comp_evt.status == 0x01){
            DBG("pxi_bm_s_bond_info_save \n");
            // 保存配对信息
            pxi_bm_s_bond_info_save();
        }

    }
}

void ble_adv_start(pairing_state_t pair)
{
    Berry_wang_flag=0;
    if (pair > 0)
    {
        DBG("update dev_addr \n");
        pairing_state_set(pair);            // 设置配对状态
        _ble_update_dev_addr(1);            // 更新设备地址
        _ble_set_adv_param(1);               // 设置广播参数
    }
    else
    {
        pairing_state_clr((pairing_state_t)(GENERAL_PAIR | SWIFT_PAIR));   // 清除通用配对和快速配对状态
        ble_check_bond_and_set_param(1);     // 检查绑定并设置参数
    }
    pxi_gap_s_adv_start();                  // 启动广播
    WARN_log(("ble_adv_start"));
}

void ble_disconnect_adv_start(){
