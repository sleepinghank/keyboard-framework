extern uint8_t _factory_reset_pending;  // 恢复出厂设置标志

static uint8_t reset_ch __attribute__((unused)) = 0;  // 预留：通道重置标志


void ble_switch_channel(void)
{
    //调用之前一定会修改switch_target_device_idx变量，目标信道
    // if (switch_target_device_idx >= MAXIMUM_NUM_OF_BOND_DEVICES) {
    //     return;
    // }
    // _device_idx = switch_target_device_idx;
    // switch_target_device_idx = MAXIMUM_NUM_OF_BOND_DEVICES;
    // INFO_log("切换设备索引_device_idx = %d",_device_idx);
    //写入信道号
    CS_IN();
    // pxi_gap_s_profile_data_write(1, 1, &_device_idx);
    //设置当前设备的地址信息
    pxi_bm_s_bond_manager_idx_set(_device_idx);
    CS_OUT();
    //读取此信道号的ble地址
    pxi_gap_s_profile_data_read(2 + _device_idx, 1, &_current_addr);
    // DEBUG_log("读取channel switch to [%d] curr[%d]", _device_idx, _current_addr);    // 更新 BLE 设备地址
    _ble_update_dev_addr(0);
    //选择通道绑定的系统
    //keycode_type = KeyboardConfig.system_type;
    // DEBUG_log(" system_type[%d] = %d",_device_idx,keycode_type);
    my_leds.num_lock = 0;
    my_leds.caps_lock = 0;
    // 启动广播
    #ifdef POLLING_BLEADV_ENABLE
    direct_adv_cnt=0;
    direct_adv_st=0;
    #endif

    ble_adv_start(NO_PAIR);
    // DEBUG_log("addr:0x%0x-0x%0x-0x%0x-0x%0x-0x%0x-0x%0x", _dev_addr.addr[0], _dev_addr.addr[1], _dev_addr.addr[2], _dev_addr.addr[3], _dev_addr.addr[4], _dev_addr.addr[5]);
    DEBUG_log("Complete the switch\n");
    
}


void ble_resetting_channel(void)
{
    //调用之前一定会修改switch_target_device_idx变量，目标信道
    // if (switch_target_device_idx >= MAXIMUM_NUM_OF_BOND_DEVICES) {
    //     return;
    // }

    // _device_idx = switch_target_device_idx;
    // switch_target_device_idx = MAXIMUM_NUM_OF_BOND_DEVICES;

    //写入信道号
    // pxi_gap_s_profile_data_write(1, 1, &_device_idx);
    //设置信道
    pxi_bm_s_bond_manager_idx_set(_device_idx);
    //读取此信道号的ble地址
    pxi_gap_s_profile_data_read(2 + _device_idx, 1, &_current_addr);
    DBG("channel switch to [%d] curr[%d]\r\n", _device_idx, _current_addr);

    // 恢复出厂设置后生成新的随机地址，防止主机通过 IRK 识别设备
    if (_factory_reset_pending) {
        uint8_t random_offset = (uint8_t)(timer_get_system_ms() & 0x1F);  // 0-31
        _current_addr += random_offset + 32;
        pxi_gap_s_profile_data_write(2 + _device_idx, 1, &_current_addr);
        _factory_reset_pending = 0;
    }


    DBGPRINTF(("dev_addr1[%02X:%02X:%02X:%02X:%02X:%02X]\r\n",_dev_addr.addr[0],_dev_addr.addr[1],_dev_addr.addr[2],_dev_addr.addr[3],_dev_addr.addr[4],_dev_addr.addr[5]));
    
    // keycode_type = KeyboardConfig.system_type;
//     my_leds.num_lock = 0;
    my_leds.caps_lock = 0;
    
    // 初始化自定义广播参数
    ble_adv_params_init();
    
    #ifdef POLLING_BLEADV_ENABLE
    direct_adv_cnt=0;
    direct_adv_st=0;
    #endif


    ble_adv_start(GENERAL_PAIR);
    DBGPRINTF(("addr_after_ble_adv_start[%02X:%02X:%02X:%02X:%02X:%02X]\r\n",
        _dev_addr.addr[0], _dev_addr.addr[1], _dev_addr.addr[2],
        _dev_addr.addr[3], _dev_addr.addr[4], _dev_addr.addr[5]));
    Check_led_ble();
}

