#include "event_flags.h"
#include "debug.h"
#include "ble.h"

static uint32_t _ble_evt = 0;
static uint32_t _sys_evt = 0;
static uint32_t _user_evt = 0;

void _set_evt(uint8_t st, uint32_t evt)
{
    CS_IN();
    if (st == BLE_ST)
        _ble_evt |= evt;
    else if (st == SYS_ST)
        _sys_evt |= evt;
    else if (st == USER_ST)
         _user_evt |= evt;
    CS_OUT();
}

uint8_t _check_evt(uint8_t st, uint32_t evt)
{
    if (st == BLE_ST)
    {
        if ((_ble_evt & evt) == evt)
            return 1;
        else
            return 0;
    }
    else if (st == SYS_ST)
    {
        if ((_sys_evt & evt) == evt)
            return 1;
        else
            return 0;
    } 
    else
    {
        if ((_user_evt & evt) == evt)
            return 1;
        else
            return 0;
    }
}

void _clr_evt(uint8_t st, uint32_t evt)
{
    CS_IN();
    if (st == BLE_ST)
        _ble_evt &= (~evt);
    else if (st == SYS_ST)
        _sys_evt &= (~evt);
    else if (st == USER_ST)
        _user_evt &= (~evt);
    CS_OUT();
}

uint8_t get_evt(void)
{
    if((_ble_evt == 0)&&(_sys_evt == 0 )&&(_user_evt == 0))
    {
        return 0;
    }
    else{
        return 1;
    }
}
