/******************************************************************************
 * @brief 检查电源状态函数
 * @details 检查电源状态并根据状态执行相应操作
 * @param None
 * @return None
 ******************************************************************************/
static void check_power_status(void)
{
    uint8_t power_status = 0;

    power_status = get_power_flag();
    // DEBUG_log("check_power_status: power_status = %d\n", power_status);

    if (power_status == 0x37) {
        pxi_gap_s_disconnect();
        // DEBUG_log("check_power_status: power_status = 0\n");
    } else {
        // DEBUG_log("check_power_status: power_status = 1\n");
    }
}

/******************************************************************************
 * @brief 电源关闭任务函数
 * @details 处理电源关闭相关的任务，包括系统事件检查和电源状态检查
 * @param None
 * @return None
 ******************************************************************************/
void power_down_task(void)
{
    if (iic_cb_flag == 1) {
        iic_cb_flag = 0;

        if (_check_evt(SYS_ST, SYS_POWER_DOWN)) {
            _clr_evt(SYS_ST, SYS_POWER_DOWN);
            _set_evt(SYS_ST, SYS_PD_WAKEUP);
        } else if (u_timer_check_enabled(kb_timer_id) == 1) {   /* Leave Sleep Mode */
            INFO_log("power_down_task: success check sleep timer\n");
            _gpio_wakup_mode(0);
            _set_evt(SYS_ST, SYS_SLP_WAKEUP);
        } else {
            reset_powerdown_timeout();
            reset_sleep_timeout();
        }

        check_power_status();
        Lock_Screen_drict();
    } else {
        return;
    }
}

