{
    uint8_t i = 0;

    _misc_ctrl->SS_RDY_CLR = 1;

    _misc_ctrl->SS_BUF[addr] = data;

    while (1)
    {
        for (i = 0; i < 10; i++)
            __asm volatile (" NOP");

        if (_misc_ctrl->SS_RDY == 1)
            break;
    }
}

