<file path="PAR2860/ota/ota_imp.c">
#define  _OTA_IMP_C

#include "ota.h"
#include "ble.h"
#include "ota_imp.h"
#include "HID_OVER_GATT_KEYBOARD_OTA_Profile_PTP.h"
//#include "HID_OVER_GATT_KEYBOARD_OTA_Profile_PTP_MS.h"
#include "debug.h"
#include <string.h>
#include "kb_para_profile.h"

#define CONFIG_MTU_FOUR_ALIGH

static uint8_t ota_imp_spec_check(struct cmd_fw_ota_init_new* p_cmd)
{
    struct gap_update_params update;

    //DBG("##p_cmd->ota_setting = %d\n", p_cmd->ota_setting);

    //check ota process setting
    if (p_cmd->ota_setting != OTA_MAIN_FW)
        return OTA_PROCESS_ILLEGAL;

    //check fw length
    if ((p_cmd->fw_length <= 0) || (p_cmd->fw_length > (512 * 1024)))
        return OTA_FW_OUT_OF_BOUNDS;

    update.updateitv_min = OTA_MIN_CONN_INTERVAL;
    update.updateitv_max = OTA_MAX_CONN_INTERVAL;
    update.updatelatency = OTA_SLAVE_LATENCY;
    update.updatesvto = OTA_CONN_SUP_TIMEOUT;
    pxi_gap_s_connection_update(&update);

    pxi_att_c_mtu_req(247);
    DBG("OTA_SPEC_CHECK_OK\n");
    return OTA_SPEC_CHECK_OK;
}

static uint16_t ota_imp_mtu(void)
{
    uint16_t mtu = pxi_att_c_get_mtu_size();

#ifdef CONFIG_MTU_FOUR_ALIGH
    mtu = (mtu - 3) & 0xFFFFFFFC;
#else
    mtu = (mtu - 3);
#endif

    return mtu;
}

static uint8_t ota_imp_notify(uint8_t sz, uint8_t* p_data)
{
    return ble_tx_data(OTA_READ_WRITE_IDX, sz, p_data);
}

static void ota_imp_disconnect(uint8_t reason)
{
    if (reason == OTA_RESET)
        pxi_system_reset();
    else if (reason == OTA_UPDATE_DONE)
        pxi_system_reset();
    else if (reason == OTA_CODE_JUMP)
        ble_disconnect();
}

static void ota_imp_get_info(struct ret_fw_info_get* info)
{
    struct ota_fw_info fw_info;

    pxi_code_info_read(fw_info.fw_version, fw_info.fw_desc, \
                           &fw_info.fw_size, &fw_info.fw_checksum);

    DBGHEXDUMP("FwVer", fw_info.fw_version, 5);
    DBGHEXDUMP("Desc", fw_info.fw_desc, 32);
    DBG("FW size:%lu checksum:%x \n", fw_info.fw_size, fw_info.fw_checksum);

    memcpy(info->version, fw_info.fw_version, 5);
    info->checksum = fw_info.fw_checksum;
}

static uint8_t ota_imp_create_object(uint32_t offset)
{
    pxi_pmu_vote_not_sleep();
    return pxi_ota_code_erase_object(offset);
}

static uint8_t ota_imp_fw_write(uint32_t offset, uint32_t len, uint8_t* p_buf)
{
    uint8_t ret=0;
    if(len>0xffff)
    {
        ret += pxi_code_write(offset,0xffff,p_buf);
        ret += pxi_code_write(offset+0xffff,(uint16_t)(len-0xffff),p_buf+0xffff);
    }
    else
    {
        ret = pxi_code_write(offset,(uint16_t)len,p_buf);
    }
    return ret;
}

void ota_imp_init(void)
{
    ota_spec_check_cb = ota_imp_spec_check;
    ota_upgrade_cb = pxi_code_update;
    ota_mtu_cb = ota_imp_mtu;
    ota_notify_cb = ota_imp_notify;
    ota_fw_write_cb = ota_imp_fw_write;
    ota_erase_object_cb = ota_imp_create_object;
    ota_disconnect_cb = ota_imp_disconnect;
    ota_get_info_cb = ota_imp_get_info;
}
</file>

