#include "kb_hid_report.h"
#include "kb_combo_engine.h"
#include "kb_sys_action.h"

// ========== 触摸板 ==========
#include "touch_ctrl.h"

// ========== 电源管理 ==========
#include "sleep.h"                
#include "wakeup.h"
