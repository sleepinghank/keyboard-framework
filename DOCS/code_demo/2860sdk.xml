#define _QUEUE_C_

#include "queue.h"
#include <string.h>

static uint8_t QueueBuf[NUM_OF_QUEUE][SIZE_OF_QUEUE];
static uint16_t QueueHead;
static uint16_t QueueTail;

uint8_t queue_buf_full(void)
{
	return (((QueueHead + 1) % NUM_OF_QUEUE) == QueueTail);
}
	
uint8_t queue_buf_empty(void)
{
	return QueueHead == QueueTail;
}

uint8_t init_queue(void) 
{	
	QueueHead = QueueTail = 0 ;
	
	memset(QueueBuf ,0x00 ,(NUM_OF_QUEUE*SIZE_OF_QUEUE));

	return 1 ;
}

uint8_t en_queue(uint8_t *srcPtr, uint8_t len)
{
	if(!queue_buf_full()) 
	{		
		memcpy(&QueueBuf[QueueHead][0], srcPtr, len);
		
		QueueHead = (QueueHead + 1) % NUM_OF_QUEUE;

		return 1;
	}
	else
		return 0;
}

uint8_t de_queue(uint8_t *dstPtr)
{

	if(!queue_buf_empty()) 
	{
		memcpy(dstPtr, &QueueBuf[QueueTail][0], (QueueBuf[QueueTail][0] + 1));

		QueueTail = (QueueTail + 1) % NUM_OF_QUEUE;

		return 1;
	}
	else
		return 0;
}
