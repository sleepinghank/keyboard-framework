void _ble_update_dev_addr(uint8_t inc)
{
    uint8_t tmp1;
    uint8_t tmp2;
    

    tmp1 = ((_addr_1_base & 0x1f) + ((_current_addr + inc) & 0x1f)) & 0x1f;
    tmp2 = (((_addr_1_base >> 5) & 0x07) + _device_idx) & 0x07;
    _dev_addr.addr[1] = tmp1 | (tmp2 << 5);
    //更新后的设备地址设置到蓝牙中
    pxi_gap_s_ble_address_set(&_dev_addr);
}


