static int8_t keyboard_shortcut_bitmap_read_cb(void* value, uint16_t* len){
    uint8_t* data = (uint8_t*)value;

    data[0] = (uint8_t)(KEYBOARD_SHORTCUT_ROW_NUM);
    data[1] = (uint8_t)(KEYBOARD_SHORTCUT_COL_NUM);
    data[2] = (uint8_t)(SystemConfig.ai_key_func_idx & 0x80);
    data[3] = 0;

    DEBUG_log("ROW:%d,COL:%d,keyboard_shortcut_bitmap: 0x%02X\n", KEYBOARD_SHORTCUT_ROW_NUM,KEYBOARD_SHORTCUT_COL_NUM,(uint8_t)(SystemConfig.ai_key_func_idx & 0x80));

    *len = 4; // 设置长度为4字节
    return 0;
}

// 键盘预设快捷键BITMAP写入回调
static int8_t keyboard_shortcut_bitmap_write_cb(const void* value, uint16_t len){
    const uint8_t* data = (const uint8_t*)value;

    if(len < 4)
    {
        DEBUG_log("keyboard_shortcut_bitmap_write_cb: len < 4\n");
        return -1;
    }
    //抛弃前2个字节
    //读取BITMAP
    keyboard_shortcut_bitmap = (data[2] << 8) | data[3];
    if ((keyboard_shortcut_bitmap & 0x8000) == 0x8000) {
        // 如果启用BIT15，表示启用键盘预设快捷键功能，将BIT15设为1
        SystemConfig.ai_key_func_idx |= 0x80;
    } else {
        // 如果不启用BIT15，表示禁用键盘预设快捷键功能，将BIT15设为0
        SystemConfig.ai_key_func_idx &= ~0x80;
    }
    reset_powerdown_timeout();
    _set_evt(USER_ST, SYS_STORAGE_WRITE);
    return 0;
}

// 键盘预设快捷键读取回调
static int8_t keyboard_shortcut_read_cb(void* value, uint16_t* len){
    uint8_t* data = (uint8_t*)value;

    // 循环16次处理每个快捷键
    for(uint8_t i = 0; i < 16; i++) {
        uint8_t row = 0;
        uint8_t col = i;
        uint8_t func = keyboard_shortcut[row][col];

        // 组装数据
        uint16_t shortcut_data = (row << 12) | (col << 7) | func;

        // 写入2个字节的数据
        data[i*2] = (shortcut_data >> 8) & 0xFF;
        data[i*2 + 1] = shortcut_data & 0xFF;

        DEBUG_log("Shortcut %d: row=%d, col=%d, func=%d\n", i, row, col, func);
    }

    *len = 32; // 设置长度为32字节(16个快捷键 * 2字节)
    return 0;
}

// 键盘预设快捷键写入回调
static int8_t keyboard_shortcut_write_cb(const void* value, uint16_t len){
    const uint8_t* data = (const uint8_t*)value;

    // 检查数据长度是否有效
    if(len % 2 != 0 || len > 32) {
        DEBUG_log("Invalid data length: %d\n", len);
        return -1;
    }

    // 计算快捷键数量
    uint8_t shortcut_count = len / 2;

    // 循环处理每个快捷键,最多16个
    for(uint8_t i = 0; i < shortcut_count && i < 16; i++) {
        // 读取2个字节的数据
        uint16_t shortcut_data = (data[i*2] << 8) | data[i*2 + 1];

        // 解析数据
        uint8_t row = (shortcut_data >> 12) & 0x0F;     // bit15 ~ bit12为行坐标
        uint8_t col = (shortcut_data >> 7) & 0x1F;      // bit11 ~ bit7为列坐标
        uint8_t func = shortcut_data & 0x7F;            // bit6 ~ bit0为功能编号

        // 存储到keyboard_shortcut数组
        keyboard_shortcut[row][col] = func;

        DEBUG_log("Shortcut %d: row=%d, col=%d, func=%d\n", i, row, col, func);
    }
    // 将SystemConfig.ai_key_func_idx 低15个bit 设置为 keyboard_shortcut[0][0] 的值
    SystemConfig.ai_key_func_idx = 0x80; // 清除
    SystemConfig.ai_key_func_idx |= (keyboard_shortcut[0][0] & 0x7F); // 设置低15BIT为keyboard_shortcut[0][0]的值
    reset_powerdown_timeout();
    _set_evt(USER_ST, SYS_STORAGE_WRITE);
    return 0;
}

// 全局TAG写入成功回调函数
void tag_write_success_cb(const uint8_t* tags, uint16_t tag_count){
    uint16_t processed_len = 0;
    uint16_t tag = 0;
    uint16_t temp8t = 0;
    while(processed_len < tag_count) {

        if (tags[processed_len] > 0xbf) {
            tag = (tags[processed_len] << 8) | tags[processed_len + 1];
            processed_len += 2;
        } else {
            tag = tags[processed_len];
            processed_len += 1;
        }

        switch (tag) {
            case TAG_ID_TOUCHPAD_SWITCH:
                DEBUG_log("Touchpad switch: %d\n", touchpad_switch);
                touch_flag = (touchpad_switch == 0) ? 1 : 0; // 触摸板开关 1 开 0 关

                if (u_timer_check_enabled(kb_timer_id)==1){
                    _gpio_wakup_mode(0);
                    _set_evt(SYS_ST, SYS_SLP_WAKEUP);
                }
                reset_powerdown_timeout();
                // 触摸板开关
                #ifdef CONFIG_ENABLE_TOUCH
                change_touch_status();
                #endif
                break;
            case TAG_ID_SHUTDOWN_TIME:
                DEBUG_log("Shutdown time: %d\n", shutdown_time);
                // 关机时间 更改 SystemConfig 中关机时间，并将_pd_cnt_th 设置为关机时间 最高位为0表示秒，最高位为1表示分钟，范围为0-32767，0为不关机
                SystemConfig.shutdown_time = shutdown_time;
                set_shutdown_time(SystemConfig.shutdown_time);
                _set_evt(USER_ST, SYS_STORAGE_WRITE);
                break;
#ifdef KEYCODE_BKLED
            case TAG_ID_LED_OFF_TIME:
                DEBUG_log("Backlight off time: %d\n", led_off_time);
                SystemConfig.led_off_time = led_off_time;
                back_sleep_state(BACKLIGHT_SET_ON);
                set_led_off_time(SystemConfig.led_off_time);
                reset_powerdown_timeout();
                _set_evt(USER_ST, SYS_STORAGE_WRITE);
                break;
            case TAG_ID_LED_SWITCH:
                DEBUG_log("Backlight switch: %d\n", led_switch);
                // 背光灯开关
                if (led_switch)
                {
                    if (backlight_brightness == 0){
                        backlight_brightness = 10;
                        #if DESCENDING_MODE
                        temp8t = ((PERSENT_NUM - backlight_brightness) * BACKLIGHT_HIGH) / PERSENT_NUM;
                        #else
                        temp8t = (((backlight_brightness *PERSENT_NUM) / 60)*BACKLIGHT_HIGH) / PERSENT_NUM;
                        #endif
                        KeyboardConfig.backlight_brightness = temp8t; // 恢复背光灯亮度为默认值
                        push_backlight_change();
                    }
                    else if(backlight_brightness <= 60)
                    {
                        temp8t = (((backlight_brightness *PERSENT_NUM) / 60)*BACKLIGHT_HIGH) / PERSENT_NUM;
                    }
                    else
                    {
                        temp8t = (( backlight_brightness) * BACKLIGHT_HIGH) / PERSENT_NUM;
                    }
                    // #if DESCENDING_MODE
                    // temp8t = ((PERSENT_NUM - backlight_brightness) * BACKLIGHT_HIGH) / PERSENT_NUM;
                    // #else
                    // temp8t = (((backlight_brightness *PERSENT_NUM) / 60)*BACKLIGHT_HIGH) / PERSENT_NUM;
                    // #endif
                    KeyboardConfig.backlight_brightness = temp8t; // 恢复背光灯亮度为默认值
                    KeyboardConfig.brightne_percent = backlight_brightness;
                    SystemConfig.led_switch = 1;
                    back_sleep_state(BACKLIGHT_SET_ON);
                }
                else
                {
                    KeyboardConfig.backlight_brightness = BACKLIGHT_OFF; // 关闭背光
                    SystemConfig.led_switch = 0;
                    backlight_disable();
                }
                reset_powerdown_timeout();
                _set_evt(USER_ST, SYS_STORAGE_WRITE);
                break;
            case TAG_ID_LED_BRIGHTNESS:
                #if DESCENDING_MODE
                temp8t = ((PERSENT_NUM - backlight_brightness) * BACKLIGHT_HIGH) / PERSENT_NUM;
                #else
                temp8t = (( backlight_brightness + 30) * BACKLIGHT_MAX) / PERSENT_NUM;
                #endif
                KeyboardConfig.backlight_brightness = temp8t;
                KeyboardConfig.brightne_percent = backlight_brightness;
                // 背光灯亮度
                backlight_set_brightness(KeyboardConfig.backlight_brightness);
                reset_backlight_timeout();
                reset_powerdown_timeout();
                _set_evt(USER_ST, SYS_STORAGE_WRITE);
                break;
            case TAG_ID_LED_COLOR:
                DEBUG_log("Backlight color: 0x%02X\n", KeyboardConfig.backlight_color);
                back_sleep_state(BACKLIGHT_SET_ON);
                // 背光灯颜色
                backlight_set_color(KeyboardConfig.backlight_color);
                reset_backlight_timeout();
                reset_powerdown_timeout();
                _set_evt(USER_ST, SYS_STORAGE_WRITE);
                break;
#endif
#ifdef CONFIG_ENABLE_TOUCH
            case TAG_ID_TOUCH_REPORT_RATE:
                // 触摸报告率
                INFO_log("change touch_report_rate: %d",touch_report_rate);
                break;
#endif
            default:
                break;
        }

    }

}

void set_all_system_value(void){
    uint8_t temp = 0;
    uint8_t need_write = 0;
    never_power_down_flag = 0;
    never_backlight_flag = 0;
    if (SystemConfig.shutdown_time == 0xffff)
    {
        need_write = 1;
        SystemConfig.shutdown_time = shutdown_time;
    } else {
        shutdown_time = SystemConfig.shutdown_time;
    }
    DEBUG_log("SystemConfig.shutdown_time:%d",SystemConfig.shutdown_time);
    if (SystemConfig.led_off_time == 0xffff)
    {
        need_write = 1;
        SystemConfig.led_off_time = led_off_time;
    } else {
        led_off_time = SystemConfig.led_off_time;
    }
    if (SystemConfig.ai_key_func_idx == 0xff){
        need_write = 1;
        SystemConfig.ai_key_func_idx = ((keyboard_shortcut_bitmap & 0x8000)>>8) & keyboard_shortcut[0][0];
    } else {
        DEBUG_log("SystemConfig.ai_key_func_idx:%d",SystemConfig.ai_key_func_idx);
        keyboard_shortcut_bitmap = (SystemConfig.ai_key_func_idx & 0x80) << 8;
        keyboard_shortcut[0][0] = (SystemConfig.ai_key_func_idx & 0x7f);
    }
#ifdef CONFIG_ENABLE_TOUCH
    if (SystemConfig.touch_gesture_switch_bitmap == 0xffff|| ((SystemConfig.touch_gesture_switch_bitmap & 0xfff)  > 0) ){
        need_write = 1;
        SystemConfig.touch_gesture_switch_bitmap = touch_gesture_switch_bitmap;
    } else {
        touch_gesture_switch_bitmap = SystemConfig.touch_gesture_switch_bitmap;
    }
    for (temp = 0; temp < 4; temp++)
    {
        if (SystemConfig.touch_gesture_shortcut[temp] == 0xff)
        {
            need_write = 1;
            SystemConfig.touch_gesture_shortcut[temp] = touch_gesture_shortcut[15 - temp];
        } else {
            touch_gesture_shortcut[15 - temp] = SystemConfig.touch_gesture_shortcut[temp];
        }
    }
#endif
    led_switch = SystemConfig.led_switch;
    #if DESCENDING_MODE
    backlight_brightness = (BACKLIGHT_HIGH - KeyboardConfig.backlight_brightness) * PERSENT_NUM / BACKLIGHT_HIGH;
    #else
    // int original_value = (KeyboardConfig.backlight_brightness * PERSENT_NUM) / BACKLIGHT_HIGH;

    // // 计算缩放比例：60/150 = 2/5
    // int adjusted_value = (original_value * 60) / PERSENT_NUM;  // 或者 (original_value * 2) / 5

    // backlight_brightness = adjusted_value;
    backlight_brightness = KeyboardConfig.brightne_percent;
    #endif

    // 值域校验，修正异常值
    if (validate_system_config(&SystemConfig)) {
        INFO_log("set_all_system_value: SystemConfig validated, some fields fixed");
        need_write = 1;
    }

    set_shutdown_time(SystemConfig.shutdown_time);
    set_led_off_time(SystemConfig.led_off_time);
    if (need_write == 1)
    {
        _set_evt(USER_ST, SYS_STORAGE_WRITE);
    }
}

// ===== 设置所有TAG默认值的函数 =====
// ===== 设置所有TAG默认值的函数 =====
void set_all_tags_to_default(void) 
{
    // 系统相关变量默认值
    max_mtu = _OTA_ReadMaxMTU();                // 最大支持的MTU
    current_mtu =  _OTA_ReadMTU();            // 当前的MTU
    touchpad_switch = 1;        // 触摸板开关，默认开启
    battery_calibration_status = 0; // 电池电量校准完成状态

    // 键盘预设快捷键默认值
    keyboard_shortcut_bitmap = 0; // 键盘预设快捷键启用BITMAP
    memset(keyboard_shortcut, 0, sizeof(keyboard_shortcut)); // 键盘预设快捷键

    // 设备配置相关变量默认值
    sleep_time = 30;           // 待机时间，默认30秒
    shutdown_time = 0x8000 | (POWER_DOWN_INTERVAL / 60);         // 关机时间，默认不关机
#ifdef KEYCODE_BKLED
    led_off_time = BACKLIGHT_POWER_DOWN_INTERVAL ;         // 背光灯关闭时间，默认60秒
    led_switch = 1;            // 背光灯开关，默认开启
#endif
#ifdef CONFIG_ENABLE_TOUCH
    touch_gesture_support = 0xF000;  // 触摸板支持的自定义手势
    touch_gesture_switch_bitmap = 0x0000; // 触摸板手势开关位图
    memset(touch_gesture_shortcut, 0, sizeof(touch_gesture_shortcut)); // 触摸板手势快捷键

    // 触摸板手势快捷键
    touch_gesture_shortcut[15] = gesture_func[0];
    touch_gesture_shortcut[14] = gesture_func[1];
    touch_gesture_shortcut[13] = gesture_func[2];
    touch_gesture_shortcut[12] = gesture_func[3];


    touch_report_rate = 100;     // 触摸板上报率
#endif

#ifdef KEYCODE_BKLED
    // 键盘配置默认值
    backlight_brightness = 20; // 背光灯亮度，默认50%
#endif
    // KeyboardConfig.backlight_color = 0;    // 背光灯颜色，默认白色
    DEBUG_log("shutdown_time:%d",shutdown_time);
    DEBUG_log("All tags have been set to default values\n");
}

// 如果背光变化则主动推送
void push_backlight_change(void)
{
    uint8_t data[3];
    uint8_t len = 0;
    #if DESCENDING_MODE
    backlight_brightness = (BACKLIGHT_HIGH - KeyboardConfig.backlight_brightness) * PERSENT_NUM / BACKLIGHT_HIGH;
    #else
    int original_value = (KeyboardConfig.backlight_brightness * PERSENT_NUM) / BACKLIGHT_HIGH;

    // 计算缩放比例：60/150 = 2/5
    int adjusted_value = (original_value * 60) / PERSENT_NUM;  // 或者 (original_value * 2) / 5

    backlight_brightness = adjusted_value;
    KeyboardConfig.brightne_percent = backlight_brightness;
    SystemConfig.led_switch = 1;
    led_switch = SystemConfig.led_switch;
    #endif
    if(ble_check_notify_enable(INATECK_OTA_READ_WRITE_IDX) != 1){
        DEBUG_log("ble_check_notify_enable = 0 backlight_brightness:%d\n",backlight_brightness);
        return;
    }
    DEBUG_log("push_backlight_change..........%d\n",backlight_brightness);

    data[len++] = TAG_ID_LED_SWITCH;
    data[len++] = TAG_ID_LED_BRIGHTNESS;
    data[len++] = TAG_ID_LED_COLOR;
   _set_evt(USER_ST, SYS_STORAGE_WRITE);
   Tag_PushTags(data, len);
}

// 如果触摸板开关变化则主动推送
void push_touchpad_switch_change(void)
{
    uint8_t data[2];
    uint8_t len = 0;
    if(ble_check_notify_enable(INATECK_OTA_READ_WRITE_IDX) != 1){
        DEBUG_log("ble_check_notify_enable != 1 \n");
        return;
    }
    DEBUG_log("push_touchpad_switch_change..........\n");

    data[len++] = TAG_ID_TOUCHPAD_SWITCH;
    Tag_PushTags(data, len);
}

//如果电池电量校准完成则主动推送
void push_battery_calibration_status_change(void)
{
    uint8_t data[2];
    uint8_t len = 0;
    if(ble_check_notify_enable(INATECK_OTA_READ_WRITE_IDX) != 1){
        DEBUG_log("ble_check_notify_enable != 1 \n");
        return;
    }
    DEBUG_log("push_battery_calibration_status_change..........\n");

    data[len++] = TAG_ID_BATTERY_CALIBRATION_STATUS >> 8;
    data[len++] = TAG_ID_BATTERY_CALIBRATION_STATUS & 0xFF;

    Tag_PushTags(data, len);
}
