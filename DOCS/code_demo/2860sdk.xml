#include "ext_mcu_comm.h"
#include "battery.h"
#include "sleep.h"
#include "gpio_config.h"
#include "timer_task.h"


uint8_t wakeup_flag = 0;

void _pd_wakeup_task(void)
{

#ifdef CONFIG_UART_ENABLE
    pxi_32m_clock_enable(true);
    pad_mux_write(UART_TXD,PIN_SEL_UART_TXD0);
    dbg_init();
#endif

#ifdef POLLING_BLEADV_ENABLE
    direct_adv_cnt=0;
    direct_adv_st=0;
    has_bond_adv=0;
#endif

    /* 主机发送中断控制从机唤醒复位 */
    pad_mux_write(IIC_SDA_PIN, PIN_SEL_GPIO);
    for (int i = 0; i < 100; i++) {
        gpo_config(IIC_SDA_PIN, GPO_HIGH);
        pxi_delay_us(100);
        gpo_config(IIC_SDA_PIN, GPO_LOW);
        pxi_delay_us(100);
        gpo_config(IIC_SDA_PIN, GPO_HIGH);
    }

    /* 禁用IIC中断 */
    gpi_disable_int(IIC_INT_PIN);

    CS_IN();
    get_kb_rpt();
    CS_OUT();

    CS_IN();
    ble_init();
    CS_OUT();
    _gpio_init();
    _system_init();
    soft_iic_init();

#if defined(CONFIG_ENABLE_ADC) || defined(CONFIG_ENABLE_BATTERY_LEVEL)
    reset_adc_first_sampling();  // 重置背光初始化状态，等电量查询后再决定
    safe_battery_query();          // 通过队列异步查询，查询完成后 battery_post_query 处理背光
#endif

    // 深度睡眠唤醒后需要重新初始化 timer_task
    task_init();
    timer_event_init();
    INFO_log(("_pd_wakeup_process"));

#ifdef CONFIG_BETA_ENABLE
    WARN_log(("ble_adv_start(GENERAL_PAIR);\r\n"));
    ble_adv_start(GENERAL_PAIR);
#else
    WARN_log("ble_adv_start(NO_PAIR)");
    ble_adv_start(NO_PAIR);
#endif
    wakeup_flag = 1;
    {
        struct gap_wakeup_config pw_cfg;
        memset(&pw_cfg,0,sizeof(pw_cfg));
        pw_cfg.wakeup_type = SLEEP_WAKEUP;
        pw_cfg.timer_wakeup_en = 1;
        pw_cfg.gpi_wakeup_en = 1;
        pw_cfg.gpi_wakeup_cfg = _touch_pin_wakeup;
        pxi_pmu_wakeup_config(&pw_cfg);
    }

    Storage_user_read();//读取背光灯亮度跟颜色

    CS_IN();
    system_sleep_notify(0);

    pxi_delay_ms(10);

    /* 判断配对是否存在数据并设置LED状态 */
    Check_led_ble();

    pxi_delay_ms(10);

    /* 根据大写锁定状态控制LED */
    if (my_leds.caps_lock == 1) {
        led_control(caps_led, 1);
    }

    pxi_delay_ms(10);

#ifdef CONFIG_ENABLE_TOUCH
        // 触摸板锁
    _set_evt(USER_ST, SYS_CHECK_TOUCH_STATUS);
#endif
    CS_OUT();
}

void _slp_wakeup_task(void)
{
    DEBUG_log("slp_wakeup_task\r\n");


#ifdef BLE_RECONNECT_IN_ERR
    // 如果处于回连等待状态，清理回连状态
    if ((disconnect_sleep_bit & 0x80) == 0x80) {
        extern uint8_t disconnect_reconnect_timer_id;
        if (disconnect_reconnect_timer_id != TIMER_ID_INVALID) {
            u_timer_clear(disconnect_reconnect_timer_id);
            disconnect_reconnect_timer_id = TIMER_ID_INVALID;
        }
        _set_evt(SYS_ST, SYS_PAIRING);
        ble_adv_stop();  // 停止回连广播
        disconnect_sleep_bit = 0;  // 清除所有标志
        INFO_log("Wake up during reconnect");
    }
#endif
    u_timer_enable(kb_timer_id);  // 重新启用键盘扫描任务
    u_timer_disable(lpo_timer_id);  // 关闭 LPO 校准任务
    reset_sleep_timeout();
    reset_powerdown_timeout();

// #ifdef KEYCODE_BKLED
//     //背光灯初始化
//     if(get_battery_level() > 20)
//     {
//         back_sleep_state(1);
//     }
// #endif

    _set_evt(SYS_ST, SYS_LEAVE_SLA_LCY);

    _check_gpadc_val();
}


#ifdef BLE_RECONNECT_IN_ERR
void disconnet_wake_up(void)
{
    // 重新初始化 BLE
    CS_IN();
    ble_init();
    CS_OUT();

    _system_init();  // 时钟等系统级初始化

    // 重置休眠超时（防止回连期间进入休眠）
    reset_sleep_timeout();
    reset_powerdown_timeout();
    sleep_flag = 0;

    #ifdef POLLING_BLEADV_ENABLE
    direct_adv_cnt = 0;
    direct_adv_st = 0;
    has_bond_adv = 0;
    disconnect_sleep_bit = 0x01;
    #endif

    // 启动 100ms 回连超时定时器
    extern uint8_t disconnect_reconnect_timer_id;
    extern void disconnect_reconnect_timeout_cb(void);
    disconnect_reconnect_timer_id = u_timer_out_soft(
        disconnect_reconnect_timeout_cb,
        100,  // 100ms 超时，默认广播间隔
        1      // 执行1次
    );

    // 使用定向回连广播（强制，因为异常断连时必有绑定信息）
    ble_disconnect_adv_start();
    Check_led_ble();

    INFO_log("Disconnect wake up, reconnecting for 100ms");
}
#endif
