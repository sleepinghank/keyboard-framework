//
// Created by hank on 2024/9/12.
// Optimized based on ARCHITECTURE_DESIGN.md
//

#include "timer_task.h"
#include "timer.h"  // 硬件定时器API
#include "timer_count.h"  // 溢出安全的时间比较宏
#include "debug.h"  // 日志输出
#include "debug_log.h"
#include <string.h>
#include "gpio.h"

/* ============================ 内部常量定义 ============================ */
#define TIMER_INTERVAL_IDLE       5000  // 无任务时的低功耗间隔(2秒)

// 精度控制常量
#define SHORT_TASK_THRESHOLD_MS   1000  // 短任务阈值：<1000ms 精确调度，不量化
#define LONG_TASK_QUANTIZE_MS     100   // 长任务量化粒度：四舍五入到此值的倍数

// 内部错误码（用于 timer_error_handler）
#define TIMER_ERR_INTERVAL_TOO_SMALL  10   // 定时间隔 < 4ms
#define TIMER_ERR_GCD_TOO_SMALL       11   // 任务GCD < 4ms

// 临界区保护宏（防止 ISR 和主循环竞态）
#define TIMER_ENTER_CRITICAL()  uint32_t _primask = __get_PRIMASK(); __disable_irq()
#define TIMER_EXIT_CRITICAL()   __set_PRIMASK(_primask)

/* ============================ 定时器全局状态 ============================ */
typedef struct {
    // 硬件定时器配置
    int timer_id;                      // 硬件定时器ID (使用TIMER_0)
    uint32_t current_interval;         // 当前硬件定时器间隔 (ms)

    // 系统时间戳
    uint32_t system_ms;                // 系统运行毫秒数 (定时器触发时累加)

    // 间隔计算缓存
    uint32_t period_gcd;               // 所有任务周期的 GCD（缓存）
    volatile uint8_t recalc_needed;    // 需要重新计算间隔标志（ISR设置，主循环清除）

    // 统计信息
    uint32_t total_ticks;              // 总tick计数 (用于调试)
    uint32_t switch_count;             // 间隔切换次数
} timer_state_t;

/* ============================ 辅助函数声明 ============================ */
// 计算两个整数的最大公因数 (GCD) - 欧几里得算法
static uint32_t gcd(uint32_t a, uint32_t b) {
    while (b != 0) {
        uint32_t temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

/* ============================ 错误处理 ============================ */
static void timer_error_handler(int error) {
    // TODO: 根据实际平台实现错误处理
    // 可以记录日志、触发断言或其他处理
    (void)error;  // 避免未使用警告
}
/* ============================ 全局变量 ============================ */

// 任务控制块数组 (使用绝对时间戳机制)
typedef struct {
    uint8_t run        : 1;  // 任务就绪标志，待执行
    uint8_t enabled    : 1;  // 任务使能标志
    uint8_t soft       : 1;  // 软定时标志（间隔切换时可重置，不要求精确衔接）
    uint8_t reserved   : 5;  // 预留位
    uint32_t next_run_time;  // 下次执行的绝对时间戳 (ms)
    uint32_t task_time;      // 任务定时间隔 (ms)
    uint8_t  exec_count;     // 剩余执行次数 (0x80=无限循环)
    uint8_t  init_exec_count; // 初始执行次数 (用于 reset 时恢复)
    TimeTaskCb callback;     // 任务回调函数
} task_ctrl_t;

static volatile task_ctrl_t g_tasks[TASK_NUM_MAX];

// 定时器全局状态
static volatile timer_state_t g_timer_state = {
    .timer_id = TIMER_0,  // 使用TIMER_0
    .current_interval = TIMER_INTERVAL_IDLE,
    .system_ms = 0,
    .period_gcd = TIMER_INTERVAL_IDLE,
    .recalc_needed = 0,
    .total_ticks = 0,
    .switch_count = 0
};

// 内部函数声明
static void modify_task(TimeTaskCb task_do, uint32_t task_time, uint8_t do_cnt, uint16_t i, uint8_t soft);
static void recalculate_and_switch_interval(void);

/* ============================ 核心算法实现 ============================ */

/**
 * @brief 基于硬件定时器计数器计算已过时间
 * @return 已过时间 (ms)
 * @note 硬件定时器是递减模式：从设定值递减到 0 触发中断
 */
static uint32_t timer_get_elapsed_ms(void)
{
    // 计算定时器设定值 (interval ticks)
    uint32_t interval_ticks = (uint32_t)((uint64_t)g_timer_state.current_interval * 32768 / 1000);

    // 读取当前计数值（递减中，从 interval_ticks 递减到 0）
    uint32_t current_ticks = timer_get_tick(g_timer_state.timer_id);

    // 已过 ticks = 设定值 - 当前值
    uint32_t elapsed_ticks = (current_ticks <= interval_ticks)
                              ? (interval_ticks - current_ticks)
                              : 0;

    // 转换为 ms (32.768KHz)
    // elapsed_ms = elapsed_ticks * 1000 / 32768
    // 优化: elapsed_ms = (elapsed_ticks * 125) >> 12
    uint32_t elapsed_ms = (elapsed_ticks * 125) >> 12;

    return elapsed_ms;
}

/**
 * @brief 更改硬件定时器间隔
 * @note 使用硬件定时器API设置新的间隔
 */
static void change_timer_interval(void){
    // 计算定时器计数值 (基于32.768KHz时钟源)
    // interval_ms * 32.768 = ticks
    uint32_t timer_ticks = (uint32_t)((uint64_t)g_timer_state.current_interval * 32768 / 1000);

    // 禁用定时器 (如果已启用)
    if (timer_check_enabled(g_timer_state.timer_id)) {
        timer_disable(g_timer_state.timer_id);
    }
    DBG("[TIMER] switch interval to %d ms (%d ticks)\r\n", g_timer_state.current_interval, timer_ticks);
    // 重新启用定时器
    timer_enable(g_timer_state.timer_id, task_schedule, timer_ticks, 1);
}

/**
 * @brief 计算所有任务周期的 GCD
 * @return 周期 GCD，无任务时返回 TIMER_INTERVAL_IDLE
 */
static uint32_t calculate_period_gcd(void) {
    uint32_t gcd_value = 0;

    for (uint8_t i = 0; i < TASK_NUM_MAX; i++) {
        if (!g_tasks[i].enabled) continue;

        if (gcd_value == 0) {
            gcd_value = g_tasks[i].task_time;
        } else {
            gcd_value = gcd(gcd_value, g_tasks[i].task_time);
        }
    }

    return (gcd_value == 0) ? TIMER_INTERVAL_IDLE : gcd_value;
}

/**
 * @brief 量化剩余时间
 * @param remaining 原始剩余时间 (ms)
 * @param task_time 任务周期 (ms)
 * @return 量化后的剩余时间，0 表示已过期（不参与 GCD 计算）
 *
 * 简化策略:
 * - 已过期（remaining=0）：返回 0，表示跳过
 * - 短周期任务（<1000ms）：精确调度，不量化
 * - 长周期任务（>=1000ms）：四舍五入到 100ms
 */
static uint32_t quantize_remaining(uint32_t remaining, uint32_t task_time) {
    // 已过期，返回 0 表示不参与 GCD 计算
    if (remaining == 0) {
        return 0;
    }

    // 短周期任务：不量化
    if (task_time < SHORT_TASK_THRESHOLD_MS) {
        return remaining;
    }

    // 长周期任务：四舍五入到 100ms
    uint32_t quantized = ((remaining + (LONG_TASK_QUANTIZE_MS / 2)) / LONG_TASK_QUANTIZE_MS) * LONG_TASK_QUANTIZE_MS;

    // 确保不小于最小间隔
    return (quantized < TIMER_INTERVAL_MIN_MS) ? TIMER_INTERVAL_MIN_MS : quantized;
}

/**
 * @brief 基于剩余时间计算最优定时间隔
 * @param current_time 当前精确时间（system_ms + elapsed）
 * @return 最优定时器间隔 (ms)
 *
 * 简化算法:
 * 1. 计算每个任务的剩余时间
 * 2. 短任务不量化，长任务四舍五入到 100ms
 * 3. 计算所有量化后剩余时间的 GCD
 */
static uint32_t calculate_interval_from_remaining(uint32_t current_time) {
    uint32_t gcd_value = 0;
    uint8_t task_count = 0;
    uint8_t expired_count = 0;

    for (uint8_t i = 0; i < TASK_NUM_MAX; i++) {
        if (!g_tasks[i].enabled) continue;
        task_count++;

        // 计算剩余时间
        int32_t remaining_signed = (int32_t)(g_tasks[i].next_run_time - current_time);
        uint32_t remaining = (remaining_signed <= 0) ? 0 : (uint32_t)remaining_signed;

        // 软定时：用任务周期替代剩余时间参与 GCD 计算（降低中断频率）
        // 硬定时：用量化后的剩余时间（保证精确触发）
        uint32_t quantized;
        if (g_tasks[i].soft && remaining > 0) {
            quantized = g_tasks[i].task_time;
        } else {
            quantized = quantize_remaining(remaining, g_tasks[i].task_time);
        }

        // 跳过已过期任务（quantized=0）
        if (quantized == 0) {
            expired_count++;
            continue;
        }

        // 计算 GCD
        if (gcd_value == 0) {
            gcd_value = quantized;
        } else {
            gcd_value = gcd(gcd_value, quantized);
        }
    }

    // 无活动任务
    if (task_count == 0) {
        g_timer_state.period_gcd = TIMER_INTERVAL_IDLE;
        return TIMER_INTERVAL_IDLE;
    }

    // 所有任务都已过期，使用最小间隔尽快触发
    if (gcd_value == 0) {
        gcd_value = TIMER_INTERVAL_MIN_MS;
    }

    // GCD 兜底
    if (gcd_value < TIMER_INTERVAL_MIN_MS) {
        gcd_value = TIMER_INTERVAL_MIN_MS;
    }

    // 缓存
    g_timer_state.period_gcd = calculate_period_gcd();

    return gcd_value;
}

/* ============================ 系统初始化 ============================ */

/**
 * @brief 任务初始化
 * @note 初始化定时器系统，计算初始间隔并启动硬件定时器
 * @return 错误码 (TIMER_OK表示成功)
 */
uint8_t task_init(void){
    // DBG("[TIMER] ========== timer_task init start ==========\r\n");

    // 初始化所有任务为禁用状态
    for (uint8_t i = 0; i < TASK_NUM_MAX; i++) {
        g_tasks[i].enabled = 0;
        g_tasks[i].run = 0;
        g_tasks[i].next_run_time = 0;
        g_tasks[i].task_time = 0;
        g_tasks[i].exec_count = 0;
        g_tasks[i].init_exec_count = 0;
        g_tasks[i].callback = NULL;
        g_tasks[i].soft = 0;
    }

    // 初始化定时器状态
    g_timer_state.timer_id = TIMER_0;  // 使用TIMER_0
    g_timer_state.current_interval = TIMER_INTERVAL_IDLE;
    g_timer_state.system_ms = 0;
    g_timer_state.period_gcd = TIMER_INTERVAL_IDLE;
    g_timer_state.recalc_needed = 0;
    g_timer_state.total_ticks = 0;
    g_timer_state.switch_count = 0;

    // DBG("[TIMER] init: TIMER_0, interval=%dms, max_tasks=%d\r\n",TIMER_INTERVAL_IDLE, TASK_NUM_MAX);

    // 设置并启动硬件定时器TIMER_0
    change_timer_interval();

    // DBG("[TIMER] ========== timer_task init complete ==========\r\n");

    return TIMER_OK;
}


/**
 * @brief 任务处理函数，主循环中调用
 * @note 执行所有就绪的任务，并在需要时禁用已完成的任务
 */
void _timer_task(void){
    // 遍历所有任务
    for (uint8_t i = 0; i < TASK_NUM_MAX; i++) {
        if (g_tasks[i].enabled && g_tasks[i].run) {
            // 执行回调函数
            if (g_tasks[i].callback != NULL) {
                g_tasks[i].callback();
            }

            // 清除运行标志
            g_tasks[i].run = 0;

            // 限次任务执行完毕，彻底释放槽位
            if (g_tasks[i].exec_count == 0) {
                // DBG("[TIMER] task[%d] complete, clear\r\n", i);
                u_timer_clear(i);
            }
        }
    }

}

/**
 * @brief 任务调度函数 - 在硬件定时器ISR中调用（极简版）
 *
 * 职责（保持最小化，减少中断占用时间）:
 * 1. 累加系统毫秒数
 * 2. 检查任务到期，设置 run 标志
 * 3. 设置 recalc_needed 标志（有任务到期时）
 *
 * 复杂的间隔重新计算移至主循环 _timer_task() 中处理
 */
void task_schedule(void){
    // 累加系统毫秒数
    g_timer_state.system_ms += g_timer_state.current_interval;
    g_timer_state.total_ticks++;

    // GPIO 调试
    // gpo_config(GPIO_15, (g_timer_state.total_ticks & 1) ? GPO_HIGH : GPO_LOW);

    // 遍历所有任务，只做到期检测和标志设置
    for (uint8_t i = 0; i < TASK_NUM_MAX; i++) {
        if (!g_tasks[i].enabled) {
            continue;
        }

        // 使用 timer_count.h 中的宏检查是否到期（自动处理溢出）
        if (timer_expired32(g_timer_state.system_ms, g_tasks[i].next_run_time)) {
            // 任务到期，设置运行标志
            g_tasks[i].run = 1;
            // if (i ==0){
            //     gpo_config(GPIO_16, (g_timer_state.total_ticks & 1) ? GPO_HIGH : GPO_LOW);
            // }
            // 更新下次执行时间（绝对时间）
            g_tasks[i].next_run_time += g_tasks[i].task_time;


            // 处理执行次数（0x80 为无限循环）
            if (g_tasks[i].exec_count != 0x80 && g_tasks[i].exec_count > 0) {
                g_tasks[i].exec_count--;
            }

            // 标记需要重新计算间隔（next_run_time 变化可能影响最优 GCD）
            g_timer_state.recalc_needed = 1;
        }
    }
}

/**
 * @brief 重新计算并切换定时器间隔
 * @note 基于剩余时间计算最优间隔，同步系统时间，避免时间丢失
 *
 * 调用时机:
 * 1. 任务增删/修改时（立即生效）
 * 2. 主循环中检测到 recalc_needed 标志时（延迟处理）
 */
static void recalculate_and_switch_interval(void) {
    // Step 1: 获取精确当前时间（同步硬件计数器已过时间）
    // 临界区保护：防止 ISR 在读取过程中修改 system_ms
    uint32_t elapsed_ms;
    uint32_t current_time;
    TIMER_ENTER_CRITICAL();
    elapsed_ms = timer_get_elapsed_ms();
    current_time = g_timer_state.system_ms + elapsed_ms;
    TIMER_EXIT_CRITICAL();

    // DBG("[TIMER] === recalc start: sys_ms=%d, elapsed=%d, cur=%d ===\r\n", g_timer_state.system_ms, elapsed_ms, current_time);

    // Step 2: 基于当前时间和剩余时间计算最优间隔
    uint32_t optimal_interval = calculate_interval_from_remaining(current_time);

    // Step 3: 检查是否需要切换
    if (optimal_interval == g_timer_state.current_interval &&
        timer_check_enabled(g_timer_state.timer_id)) {
        // DBG("[TIMER] === no change needed ===\r\n");
        return;  // 无需切换
    }

    // Step 4: 同步系统时间（关键：不丢失已过时间）
    g_timer_state.system_ms = current_time;

    // Step 4.5: 软定时任务在间隔变更时重置计时（不要求精确衔接）
    for (uint8_t i = 0; i < TASK_NUM_MAX; i++) {
        if (g_tasks[i].enabled && g_tasks[i].soft) {
            g_tasks[i].next_run_time = current_time + g_tasks[i].task_time;
        }
    }

    // Step 5: 更新并重启定时器
    DBG("[TIMER] === SWITCH: %dms->%dms, sync_sys=%d, cnt=%d ===\r\n",g_timer_state.current_interval, optimal_interval,current_time, g_timer_state.switch_count + 1);

    g_timer_state.current_interval = optimal_interval;
    g_timer_state.switch_count++;
    change_timer_interval();
}

/* ============================ 内部辅助函数 ============================ */

/**
 * @brief 修改任务配置 (内部函数)
 * @param task_do 任务回调函数
 * @param task_time 任务定时间隔 (ms)
 * @param do_cnt 执行次数 (0x80表示无限循环)
 * @param i 任务索引
 */
static void modify_task(TimeTaskCb task_do, uint32_t task_time, uint8_t do_cnt, uint16_t i, uint8_t soft) {
    // 参数校验
    if (i >= TASK_NUM_MAX) {
        return;
    }

    // 运行时检查最小间隔
    if (task_time < TIMER_INTERVAL_MIN_MS) {
        timer_error_handler(TIMER_ERR_INTERVAL_TOO_SMALL);
        task_time = TIMER_INTERVAL_MIN_MS;  // 降级处理
    }

    // 配置任务
    g_tasks[i].callback = task_do;
    g_tasks[i].task_time = task_time;
    g_tasks[i].exec_count = do_cnt;
    g_tasks[i].init_exec_count = do_cnt;  // 保存初始执行次数
    g_tasks[i].run = 0;
    g_tasks[i].enabled = 1;
    g_tasks[i].soft = soft;

    // 设置下次执行时间（使用精确当前时间）
    // 临界区保护：防止 ISR 修改 system_ms
    TIMER_ENTER_CRITICAL();
    uint32_t current_time = g_timer_state.system_ms + timer_get_elapsed_ms();
    TIMER_EXIT_CRITICAL();
    g_tasks[i].next_run_time = current_time + task_time;

    // 调试: 任务配置日志
    DBG("[TIMER] modify[%d]: period=%d, next=%d, sys=%d\r\n", i, task_time, g_tasks[i].next_run_time, g_timer_state.system_ms);
}

/* ============================ 公共API函数 ============================ */

/**
 * @brief 创建限定执行次数的定时任务
 * @param task_do 任务回调函数
 * @param task_time 执行间隔 (ms), 必须 >= 4ms
 * @param do_cnt 执行次数 (1-255), 0x80表示无限循环
 * @return 任务ID (0-15), 或 0xFF表示失败
 */
uint8_t u_timer_out(TimeTaskCb task_do, uint32_t task_time, uint8_t do_cnt)
{
    uint8_t timer_id = 0xFF;

    // 查找空闲任务槽
    for (uint8_t i = 0; i < TASK_NUM_MAX; i++) {
        if (!g_tasks[i].enabled && g_tasks[i].init_exec_count == 0) {
            modify_task(task_do, task_time, do_cnt, i, 0);
            timer_id = i;
            break;
        }
    }

    // 如果成功创建任务，重新计算定时器间隔并立即切换
    if (timer_id != 0xFF) {
        // DBG("[TIMER] create[%d]: period=%d, cnt=%d\r\n", timer_id, task_time, do_cnt);
        recalculate_and_switch_interval();
    } else {
        WARN_log("[TIMER] create FAILED: no free slot\r\n");
    }

    return timer_id;
}

/**
 * @brief 创建循环执行的定时任务
 * @param task_do 任务回调函数
 * @param task_time 执行间隔 (ms), 必须 >= 4ms
 * @return 任务ID (0-15), 或 0xFF表示失败
 */
uint8_t u_timer(TimeTaskCb task_do, uint32_t task_time)
{
    return u_timer_out(task_do, task_time, 0x80);
}

/**
 * @brief 创建软定时的限次任务（间隔切换时不要求精确衔接）
 * @param task_do 任务回调函数
 * @param task_time 执行间隔 (ms)
 * @param do_cnt 执行次数 (0x80表示无限循环)
 * @return 任务ID (0-15), 或 0xFF表示失败
 */
uint8_t u_timer_out_soft(TimeTaskCb task_do, uint32_t task_time, uint8_t do_cnt)
{
    uint8_t timer_id = 0xFF;

    for (uint8_t i = 0; i < TASK_NUM_MAX; i++) {
        if (!g_tasks[i].enabled && g_tasks[i].init_exec_count == 0) {
            modify_task(task_do, task_time, do_cnt, i, 1);
            timer_id = i;
            break;
        }
    }

    if (timer_id != 0xFF) {
        recalculate_and_switch_interval();
    } else {
        WARN_log("[TIMER] create soft FAILED: no free slot\r\n");
    }

    return timer_id;
}

/**
 * @brief 创建软定时的循环任务（间隔切换时不要求精确衔接）
 * @param task_do 任务回调函数
 * @param task_time 执行间隔 (ms)
 * @return 任务ID (0-15), 或 0xFF表示失败
 */
uint8_t u_timer_soft(TimeTaskCb task_do, uint32_t task_time)
{
    return u_timer_out_soft(task_do, task_time, 0x80);
}

/**
 * @brief 修改已存在任务的配置
 * @param task_id 任务ID
 * @param task_do 任务回调函数
 * @param task_time 新的定时间隔 (ms)
 * @param do_cnt 执行次数
 * @return 错误码 (TIMER_OK表示成功)
 */
uint8_t u_timer_out_modify(uint16_t task_id, TimeTaskCb task_do, uint32_t task_time, uint8_t do_cnt){
    if (task_id >= TASK_NUM_MAX){
        return TIMER_ERROR_INVALID_ID;
    }

    modify_task(task_do, task_time, do_cnt, task_id, g_tasks[task_id].soft);
    recalculate_and_switch_interval();

    return TIMER_OK;
}

/**
 * @brief 修改已存在任务的配置 (无限循环版本)
 * @param task_id 任务ID
 * @param task_do 任务回调函数
 * @param task_time 新的定时间隔 (ms)
 * @return 错误码 (TIMER_OK表示成功)
 */
uint8_t u_timer_modify(uint16_t task_id, TimeTaskCb task_do, uint32_t task_time){
    return u_timer_out_modify(task_id, task_do, task_time, 0x80);
}

/**
 * @brief 重置任务计时器 (从头开始计时)
 * @param task_id 任务ID
 * @return 错误码 (TIMER_OK表示成功)
 * @note 对于已完成的任务（exec_count=0），会自动重新启用并恢复初始执行次数
 */
uint8_t u_timer_reset(uint16_t task_id){
    if (task_id >= TASK_NUM_MAX){
        return TIMER_ERROR_INVALID_ID;
    }

    // 检查任务是否有效（有回调函数）
    if (g_tasks[task_id].callback == NULL) {
        return TIMER_ERROR_INVALID_ID;
    }

    uint8_t was_disabled = !g_tasks[task_id].enabled;

    // 如果任务已禁用，重新启用
    if (was_disabled) {
        g_tasks[task_id].enabled = 1;
        // 恢复初始执行次数
        if (g_tasks[task_id].exec_count == 0) {
            g_tasks[task_id].exec_count = g_tasks[task_id].init_exec_count;
        }
    }

    g_tasks[task_id].run = 0;

    // 使用精确当前时间设置下次执行时间（只读一次 elapsed_ms）
    TIMER_ENTER_CRITICAL();
    uint32_t current_time = g_timer_state.system_ms + timer_get_elapsed_ms();
    TIMER_EXIT_CRITICAL();
    g_tasks[task_id].next_run_time = current_time + g_tasks[task_id].task_time;

    // DBG("[TIMER] reset[%d]: cur=%d, next=%d\r\n", task_id, current_time, g_tasks[task_id].next_run_time);

    // 重新启用任务后需要重新计算定时器间隔（在 next_run_time 之后，避免 elapsed_ms 被重复累加）
    if (was_disabled) {
        recalculate_and_switch_interval();
    }

    return TIMER_OK;
}

/**
 * @brief 禁用任务 (保留配置)
 * @param task_id 任务ID
 * @return 错误码 (TIMER_OK表示成功)
 */
uint8_t u_timer_disable(uint16_t task_id){
    if (task_id >= TASK_NUM_MAX){
        return TIMER_ERROR_INVALID_ID;
    }

    DBG("[TIMER] disable[%d]\r\n", task_id);
    g_tasks[task_id].enabled = 0;
    g_tasks[task_id].run = 0;

    // 重新计算定时器间隔
    recalculate_and_switch_interval();

    return TIMER_OK;
}

/**
 * @brief 清除任务 (完全删除)
 * @param task_id 任务ID
 * @return 错误码 (TIMER_OK表示成功)
 */
uint8_t u_timer_clear(uint16_t task_id){
    if (task_id >= TASK_NUM_MAX){
        return TIMER_ERROR_INVALID_ID;
    }
    g_tasks[task_id].next_run_time = 0;
    g_tasks[task_id].task_time = 0;
    g_tasks[task_id].exec_count = 0;
    g_tasks[task_id].init_exec_count = 0;
    g_tasks[task_id].callback = NULL;
    g_tasks[task_id].soft = 0;
    return u_timer_disable(task_id);
}

/**
 * @brief 检查任务是否使能
 * @param task_id 任务ID
 * @return 1: 使能, 0: 未使能
 */
uint8_t u_timer_check_enabled(uint16_t task_id){
    if (task_id >= TASK_NUM_MAX){
        return 0;
    }
    return g_tasks[task_id].enabled;
}

/* ============================ 辅助API函数 ============================ */

/**
 * @brief 获取当前定时器间隔
 * @return 当前定时器间隔 (ms)
 */
uint32_t timer_task_get_interval(void){
    return g_timer_state.current_interval;
}

/**
 * @brief 获取当前定时器间隔 (兼容性接口)
 * @return 当前定时器间隔 (ms)
 */
uint16_t task_get_current_interval(void){
    return (uint16_t)timer_task_get_interval();
}

/**
 * @brief 获取系统运行时间
 * @return 系统运行毫秒数 (自task_init()以来)
 * @note 32位ms计数器可支持约49.7天，溢出后从0重新开始
 */
uint32_t timer_get_system_ms(void){
    return g_timer_state.system_ms;
}

/**
 * @brief 获取定时器统计信息
 * @param total_ticks 总tick计数
 * @param switch_count 间隔切换次数
 */
void timer_get_stats(uint32_t *total_ticks, uint32_t *switch_count){
    if (total_ticks != NULL) {
        *total_ticks = g_timer_state.total_ticks;
    }
    if (switch_count != NULL) {
        *switch_count = g_timer_state.switch_count;
    }
}

/**
 * @brief 启用已禁用的任务
 * @param task_id 任务ID
 * @return 错误码 (TIMER_OK表示成功)
 * @note 对于已完成的任务（exec_count=0），会自动恢复初始执行次数
 */
uint8_t u_timer_enable(uint16_t task_id){
    if (task_id >= TASK_NUM_MAX){
        return TIMER_ERROR_INVALID_ID;
    }

    if (g_tasks[task_id].callback != NULL && !g_tasks[task_id].enabled) {
        g_tasks[task_id].enabled = 1;
        g_tasks[task_id].run = 0;

        // 使用精确当前时间设置下次执行时间
        TIMER_ENTER_CRITICAL();
        uint32_t current_time = g_timer_state.system_ms + timer_get_elapsed_ms();
        TIMER_EXIT_CRITICAL();
        g_tasks[task_id].next_run_time = current_time + g_tasks[task_id].task_time;

        // 恢复初始执行次数
        if (g_tasks[task_id].exec_count == 0) {
            g_tasks[task_id].exec_count = g_tasks[task_id].init_exec_count;
        }

        // DBG("[TIMER] enable[%d]: cur=%d, next=%d\r\n", task_id, current_time, g_tasks[task_id].next_run_time);

        // 重新计算定时器间隔
        recalculate_and_switch_interval();
        return TIMER_OK;
    }

    return TIMER_ERROR_INVALID_ID;
}

/**
 * @brief 检查 timer_task 是否有待执行任务
 * @return 1 有任务待执行，0 无待执行任务
 */
uint8_t timer_task_is_busy(void)
{
    for (uint8_t i = 0; i < TASK_NUM_MAX; i++) {
        if (g_tasks[i].enabled && g_tasks[i].run) {
            return 1;  // 有任务待执行
        }
    }
    return 0;
}

/**
 * @brief 停止所有定时器任务并关闭硬件定时器
 * @details 用于深度休眠和关机前，彻底关闭定时器系统
 *          1. 遍历清除所有任务（使用 u_timer_clear 确保配置清空）
 *          2. 关闭硬件定时器
 * @note 唤醒后需要调用 task_init() 重新初始化
 */
void timer_task_stop_all(void)
{
    uint8_t i;

    // 1. 清除所有软件任务
    for (i = 0; i < TASK_NUM_MAX; i++) {
        if (g_tasks[i].callback != NULL) {
            u_timer_clear(i);
        }
    }

    // 2. 关闭硬件定时器
    timer_disable(g_timer_state.timer_id);
}

/* ============================ 文件结束 ============================ */
/*
 * 架构优化总结 (v2.0 - 剩余时间 GCD + 智能量化):
 *
 * 1. 核心改进 - 基于剩余时间的精确调度
 *    - 切换时同步 system_ms，不丢失已过时间
 *    - 计算所有任务剩余时间的 GCD 作为定时间隔
 *    - 硬件定时器触发时间对齐到任务到期点
 *    - 解决了任务切换时的精度丢失问题
 *
 * 2. 智能量化策略
 *    - 短周期任务（<1000ms）：精确调度，不量化
 *    - 长周期任务（>=1000ms）：允许向上对齐到基准粒度
 *    - 避免剩余时间 GCD 过小导致高频中断
 *    - 兼顾精度和功耗
 *
 * 3. ISR 最小化
 *    - ISR 只做时间累加和标志设置
 *    - 复杂的间隔计算移至主循环
 *    - 减少中断占用时间，提高系统响应性
 *    - 使用 recalc_needed 标志延迟处理
 *
 * 4. 主循环调度
 *    - _timer_task() 执行任务回调
 *    - timer_check_and_adjust() 处理延迟的间隔调整
 *    - 避免在中断中调用 change_timer_interval()
 *
 * 5. 时间同步机制
 *    - 切换时: system_ms += timer_get_elapsed_ms()
 *    - 任务的 next_run_time 基于真实流逝时间
 *    - 无时间丢失，保证任务按时触发
 *
 * 6. 场景示例
 *    - 2s idle 运行 1.5s 后启动 5s 背光任务:
 *      同步 system_ms = 1500
 *      idle 剩余 500ms -> 量化到 1000ms（长任务）
 *      背光剩余 5000ms（已对齐）
 *      GCD = 1000ms
 *      结果: idle 在 2500ms 触发（误差 500ms，可接受）
 *            背光在 6500ms 精确触发
 *
 * 使用示例:
 *
 *   // 初始化
 *   task_init();
 *
 *   // 创建任务
 *   uint8_t key_id = u_timer(key_board_task, 5);    // 5ms 精确调度
 *   uint8_t led_id = u_timer(led_blink_task, 2000); // 2s 允许量化
 *
 *   // 主循环
 *   while(1) {
 *       _timer_task();  // 执行就绪任务 + 间隔调整
 *   }
 */
