{
    _hpwm_ctrl->START = 1;

}

void high_speed_pwm_stop(void)
{
    _hpwm_ctrl->STOP = 1;
}
void high_speed_pwm_enable_interrupt(hi_pwm_irq_cb_type cb)
{
    _hpwm_ctrl->INTEN  = HI_PWM_INT_ALL;
    irq_cb = cb;
    NVIC_EnableIRQ(HPWM_IRQn);

}
void high_speed_pwm_disable_interrupt(void)
