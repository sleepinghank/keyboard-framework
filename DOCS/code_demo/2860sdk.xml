#include "ble.h"
#include "event_flags.h"
#include "indicator_led.h"
#include "ext_mcu_comm.h"

#ifdef  CONFIG_ENABLE_ADC
uint8_t bat_level = 0x00;
static uint8_t _adc_first_sampling = 0; // 标记是否为第一次采样
#endif

#ifdef  CONFIG_ENABLE_ADC

// 当前是否已正确获取电量
uint8_t is_bat_level_valid(void){
    return bat_level != 0x00;
}

uint8_t get_battery_level(void){
    if (bat_level > 100){
        return 100;
    }
    return bat_level;
}

// 重置启动初始化状态（唤醒时调用，允许 Backlight_Init1 重新执行）
void reset_adc_first_sampling(void)
{
    _adc_first_sampling = 0;
}

// 电量查询后统一处理（由队列查询和立即查询共同调用）
void battery_post_query(void)
{
    
    if (_adc_first_sampling == 0) {
        if (!is_bat_level_valid()) {
            return; // 电量无效，等待下一次查询
        }
        // 首次采样完成，允许 Backlight_Init1 执行
        _adc_first_sampling = 1;
        DEBUG_log("battery_post_query: bat_level = %d", bat_level);
        // 启动/唤醒阶段：首次电量有效后初始化背光（内部有 init_done 保护）
        backlight_init_once();
        return;
    }


    // 低电量背光保护
    if (get_battery_level() <= GPADC_ADC_LOW_BATTERY) {
        _backlight_flag = 1;
        back_sleep_state(0);
    }
}

// 立即查询电量（仅用于唤醒/校准等需要同步结果的场景）
void _check_gpadc_val(void)
{
    battery_query();
    battery_post_query();
    return;
}

static uint8_t Bat_num(void)
{
    uint8_t Num = 0;
    if(bat_level >= 75){
        Num = 4;
    }else if (75 > bat_level && bat_level >= 50){
        Num = 3;
    }else if (50 > bat_level && bat_level >= 25){
        Num = 2;
    }else{
        Num = 1;
    }
    INFO_log("Num %d", Num);
    return Num;
}
void bat_led(void)
{
    uint8_t level_bars = Bat_num();
    LED_SetStateN(power_led, LED_FLICKER, level_bars);
}

#endif
</file>

