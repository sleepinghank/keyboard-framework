    OTA_FW_OUT_OF_BOUNDS = 2,           ///< OTA firmware size out of bound
    OTA_PROCESS_ILLEGAL = 3,            ///< Illegal OTA process
    OTA_RECONNECT = 4,                  ///< Inform OTA app do reconnect
    OTA_FW_IMG_VERSION_ERROR = 5,       ///< Spec check ok
