static uint32_t _int_gpio_pin = 0; 

void _gpio_init(void)
{
    int i;
    for(i=0; i<=31; i++)
    {
        switch(i)
        {
#ifdef CONFIG_32K_XTAL
        case 5:
        case 6:
            /* XO */
            pad_mux_write(GPIO_5,PIN_SEL_ANALOG);
            pad_mux_write(GPIO_6,PIN_SEL_ANALOG);
            pad_pull_config(GPIO_5,GPI_NO_PULL);
            pad_pull_config(GPIO_6,GPI_NO_PULL);
            pad_input_configure(GPIO_5,0);
