    union cmd_parm cmdparm;
};

/// @brief Return paremeter of HCI command
struct evt_command_complete
{
    uint8_t opcode;
    union ret_parm ret_param;
};

/// @brief Event parameter
union  evt_parm
{
    struct evt_command_complete evt_command_complete;
};

/// @brief HCI event
