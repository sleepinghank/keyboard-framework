uint8_t _backlight_flag = 0;

void _check_task_state(uint8_t keyboard_st,uint8_t touch_st)
{

    // 背光休眠时间需要比 IDLE休眠时间短
    if (!(((keyboard_st == 0)|| ble_check_notify_enabled() == 0) && is_matrix_empty() == 1 && is_bouncing_over() == 1))
    {
        //INFO_log("KEYBOARD reset all timeout\r\n");
        backlight_reset();
        reset_backlight_timeout();
    } 
    
    if (!((ble_is_connected()) && ble_check_notify_enabled() && (keyboard_st == 0) && (touch_st == 0)
            && (ota_check() == 0) && (_OTA_GetStartFlag() == 0)/*&& pxi_get_latency() != 0 */&& is_matrix_empty() == 1 && is_bouncing_over() == 1 /*&& (pxi_hw_check_tx_fifo_empty() == 1)*/))
    {
        // INFO_log("TOUCH reset all timeout\r\n");
        reset_sleep_timeout();
        reset_powerdown_timeout();
    }
}

uint8_t _check_idle(void)
{
    // 1. 检查事件队列
    if (get_evt() != 0)
        return 0;

    // 2. 检查 OTA 状态
    if ((ota_check() != 0) || (_OTA_GetStartFlag() != 0))
        return 0;

    // 3. 检查触摸板是否繁忙
    // #ifdef CONFIG_ENABLE_TOUCH
    // if (touch_is_busy())
    //     return 0;
    // #endif

    // 4. 检查 I2C 命令队列是否繁忙
    if (iic_queue_is_busy())
        return 0;

    // 5. 检查 timer_task 是否有待执行任务
    if (timer_task_is_busy())
        return 0;

    return 1;  // 所有条件满足，可进入 idle
}

static void power_down_gpio_config(void)
{
#ifdef CONFIG_ENABLE_TOUCH
    /* 配置触摸按键GPIO为输出低电平 */
    pad_mux_write(TOUCH_BUTTON_GPIO, PIN_SEL_GPIO);
    gpo_config(TOUCH_BUTTON_GPIO, GPO_LOW);
#endif

    pad_mux_write(IIC_INT_PIN, PIN_SEL_GPIO);
    gpi_config(IIC_INT_PIN, GPI_PULL_UP,GPI_NOT_INVERTED);
    /* 配置I2C中断引脚和GPIO状态 */
    gpi_enable_int(IIC_INT_PIN, LEVEL_TRIGGER, POL_FALLING_LOW, _gpio_cb);

    pad_mux_write(IIC_SDA_PIN, PIN_SEL_GPIO);
    //gpo_config(IIC_SDA_PIN, GPO_HIGH);
    gpi_config(IIC_SDA_PIN, GPI_PULL_UP,GPI_NOT_INVERTED);

    pad_mux_write(IIC_SCL_PIN, PIN_SEL_GPIO);
    //gpo_config(IIC_SCL_PIN, GPO_HIGH);
    gpi_config(IIC_SCL_PIN, GPI_PULL_UP,GPI_NOT_INVERTED);
}

void _system_power_down(void)
{
    struct gap_bond_dev bonds_device;
    uint32_t wakeup_io = 0;
    CS_IN();

    #ifdef POLLING_BLEADV_ENABLE
    direct_adv_cnt=0;
    direct_adv_st=0;
    has_bond_adv=0;
    #else
    disconnect_sleep_bit = 0;
    #endif

    gpi_disable_int(IIC_INT_PIN);

    system_sleep_notify(15);
    pxi_delay_ms(5);

    timer_task_stop_all();  // 停止所有定时器任务并关闭硬件定时器

    pairing_state_clr((pairing_state_t)(GENERAL_PAIR | SWIFT_PAIR));

    my_leds.num_lock = 0;
    my_leds.caps_lock = 0;

    WARN_log(">>>system_power_down");

#ifdef CONFIG_ENABLE_TOUCH
    close_touchpad();
#endif

    if (pxi_bm_s_bond_info_get(&bonds_device) == 1)
    {
        IOS_Pair_flag = 1;
    }else
    {
        IOS_Pair_flag = 0;
    }
    power_down_gpio_config();

    /* 获取唤醒IO配置 */
    wakeup_io = _io_pin_wakeup;

    DEBUG_log("wakup mode");
    _gpio_wakup_mode(1);

    /* 添加I2C中断引脚到唤醒源 */
    wakeup_io |= U32BIT(IIC_INT_PIN);
    DEBUG_log("_io_pin_wakeup=0x%02x\n", wakeup_io);

    {
        struct gap_wakeup_config pw_cfg;
        memset(&pw_cfg,0,sizeof(struct gap_wakeup_config));

        pw_cfg.wakeup_type = SLEEP_WAKEUP;
        pw_cfg.timer_wakeup_en = 0;
        pw_cfg.gpi_wakeup_en = 1;
        pw_cfg.gpi_wakeup_cfg = wakeup_io;

        pxi_pmu_wakeup_config(&pw_cfg);
    }

    WARN_log("<<<system_power_down");

#if CONFIG_ENABLE_WDT == ENABLE
    /* 停止看门狗 */
    wdt_stop();
#endif

    pxi_system_deep_sleep();

#if CONFIG_ENABLE_WDT == ENABLE
    /* 系统唤醒后重新启动看门狗 */
    wdt_open();
    wdt_clear();
#endif

    CS_OUT();

}
