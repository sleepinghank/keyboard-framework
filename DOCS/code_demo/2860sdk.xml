    iic_cmd_enqueue(&cmd);
}

/******************************************************************************
 * @brief 检查 I2C 命令队列是否繁忙
 * @return 1 队列有待处理命令，0 队列为空
 ******************************************************************************/
uint8_t iic_queue_is_busy(void)
{
    return !iic_cmd_queue_empty();
}

#define MAX_CMD_PER_LOOP  3
#define MAX_CMD_RETRY     3  // 命令重入队最大次数，超限后丢弃

/******************************************************************************
 * @brief IIC命令队列处理函数
 * @details 在主循环中定期调用，处理命令队列中的命令
 * @param None
 * @return None
 * @note 每次最多处理3个命令，避免阻塞主循环
 ******************************************************************************/
void iic_cmd_queue_process(void)
{
    IIC_Cmd_t cmd;
    uint8_t processed = 0;

    while (iic_cmd_dequeue(&cmd) && processed++ < MAX_CMD_PER_LOOP) {
        uint8_t retry = 0;
        uint8_t success = 0;

        for (retry = 0; retry < 3 && !success; retry++) {
            switch (cmd.type) {
                case IIC_CMD_LED:
                success =led_control(cmd.param1, cmd.param2);
                    break;
                case IIC_CMD_TOUCH:
                    touch_able_control(cmd.param1);
                    success = 1;
                    break;
                case IIC_CMD_SLEEP:
                    system_sleep_notify(cmd.param1);
                    success = 1;
                    break;
                case IIC_CMD_RGB_COLOR:
                    set_rgb_color(cmd.param1);
                    success = 1;
                    break;
                case IIC_CMD_RGB_BRIGHTNESS:
                    set_rgb_brightness(cmd.param1);
                    success = 1;
                    break;
                case IIC_CMD_BATTERY_QUERY:
                    battery_query();
                    battery_post_query();
                    success = 1;
                    break;
                default:
                    // DEBUG_log("UNKNOW IIC COMMAND: %d", cmd.type);
                    success = 1;
                    break;
            }
            if (!success) pxi_delay_ms(10);
        }

        if (!success) {
            if (cmd.retry_count < MAX_CMD_RETRY) {
                cmd.retry_count++;
                iic_cmd_enqueue(&cmd);
            } else {
                ERROR_log("IIC cmd type=%d failed after %d retries, discarded", cmd.type, MAX_CMD_RETRY);
            }
            break;
        }
    }
}
