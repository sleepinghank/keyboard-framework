#define ROM_BB_RF_WRITE_ADDR        ((uint32_t *)0x000061e5)
#define BBRFWrite                   ((void (*)(uint8_t addr, uint8_t data))ROM_BB_RF_WRITE_ADDR)


//定义HardFault处理函数
void HardFault_Handler(void) {
    DEBUG_log(("HardFault_Handler"));
    pxi_system_reset();
}

int main(void)
{
    uint16_t count = 0;
    struct gap_bond_dev bonds_device;

    __disable_irq();

    keycode_type = IOS;
#ifdef CONFIG_UART_ENABLE
    pxi_32m_clock_enable(true);
    //pad_mux_write(UART_RXD,PIN_SEL_UART_RXD0);
    pad_mux_write(UART_TXD,PIN_SEL_UART_TXD0);
    dbg_init();
#endif
    pxi_delay_ms(1000);
    ble_set_evt_callback(&_ble_evt_callback);
    ble_init();
    _system_init();
    _gpio_init();
    soft_iic_init();
    
    set_all_tags_to_default();
    Storage_Init();
    LED_init();
    _keyboard_hid_init();
    // 初始化 timer_task 并创建所有定时器
    task_init();
    timer_event_init();           // 统一初始化所有定时器（替代原有的分散创建）
    safe_battery_query();


#ifdef CONFIG_ENABLE_TOUCH
    open_touchpad();
#else
     // 触摸板引脚配置为低电平，确保触摸板处于关闭状态
    gpo_config(TOUCH_BUTTON_GPIO, GPO_LOW);
    safe_touch_able_control(TOUCH_OFF);
    gpo_config(TOUCH_SDA, GPO_LOW);
    gpo_config(TOUCH_SCL, GPO_LOW);
    gpo_config(TOUCH_INT, GPO_LOW);
#endif

    if (pxi_bm_s_bond_info_get(&bonds_device) == 1)
    { 
        IOS_Pair_flag = 1;
    }else
    {
        IOS_Pair_flag = 0;
    }
    
    ble_adv_start(NO_PAIR);

#ifdef INATECK_ORIGIN_ENABLE
	_Origin_init();
#endif
    
    ota_imp_init();
    _OTA_Init();
    Tag_Init(tag_write_success_cb);
    set_all_system_value();

    __enable_irq();

#if CONFIG_ENABLE_WDT == ENABLE
    wdt_open();
#endif

    Check_led_ble();
    {
        struct gap_wakeup_config pw_cfg;
        memset(&pw_cfg,0,sizeof(pw_cfg));
        pw_cfg.wakeup_type = SLEEP_WAKEUP;
        pw_cfg.timer_wakeup_en = 1;
        pw_cfg.gpi_wakeup_en = 1;
        pw_cfg.gpi_wakeup_cfg = _touch_pin_wakeup;
        pxi_pmu_wakeup_config(&pw_cfg);
    }

    while (1)
    {
        _sys_evt_pmu_task();

#ifdef CONFIG_ENABLE_TOUCH
        _touch_evt_task();
#endif

        _sys_evt_task();

        _ble_evt_task();

        _timer_task();  // 执行 timer_task 中的到期任务

        ble_task();

        iic_cmd_queue_process();

        power_down_task();

        #if CONFIG_ENABLE_WDT == ENABLE
        wdt_clear();
        #endif

        if(count < 1400) count++;
        else
        {
            count = 0;
            _OTA_ScheduledTask();
        }
        
    }

}
