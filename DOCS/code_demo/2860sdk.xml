/// @brief 更改触摸板关机状态
void change_touch_status(void){

    // 触摸板锁
    if(touch_flag != 0)
    {
        touch_flag = 0;
        touchpad_switch = 0;
        if (_touch_pd_cnt == 0 ){
            // 开启触摸板关机延迟
            _touch_pd_cnt = _touch_pd_cnt_th;
        }
    }
    else
    {
        touch_flag = 1;
        touchpad_switch = 1;
        _touch_pd_cnt = 0;
        _set_evt(USER_ST, SYS_CHECK_TOUCH_STATUS);
    }
}
/// @brief 检查触摸板状态
void check_touch_status(void){
#ifdef CONFIG_ENABLE_TOUCH
//    DBG("check_touch_status touch_flag:%d touch_en:%d\r\n",touch_flag,touch_en);

    if(touch_flag != 0)
    {
        //touchpad_switch = 1;
        bayes_mode_init(&KB04122_13A_model);

        if (touch_en == 3 || touch_en == 0){
        //     // 关机状态下重启
        //     touch_resume();
        // } else {
             // 检查是否处于开机状态。如果不是，开机
            // set_distance_thresholds(&g_distance_thresholds);
            safe_touch_able_control(TOUCH_ON);
            gpo_config(TOUCH_BUTTON_GPIO, GPO_LOW);

            pxi_delay_ms(10);
            touch_power_on_with_params(params,sizeof(params) / sizeof(params[0]));
            // touch_power_on();
            // DEBUG_log("7");
            // u_timer_enable(U_TIMER6, touch_watchdog_check, 5000, 1);
        }
    }
    else
    {
        // 检查是否处于关机状态。如果不是，关机
        //if (touch_en == 1){
            touch_power_off();
            gpo_config(TOUCH_BUTTON_GPIO, GPO_LOW);
            safe_touch_able_control(TOUCH_OFF);
            gpo_config(TOUCH_SDA, GPO_LOW);
            gpo_config(TOUCH_SCL, GPO_LOW);
            gpo_config(TOUCH_INT, GPO_LOW);
        //}
    }
#endif
}

void open_touchpad(void){
#ifdef CONFIG_ENABLE_TOUCH
    touch_flag = 1;
    check_touch_status();
#endif
}
void close_touchpad(void){
#ifdef CONFIG_ENABLE_TOUCH
    touch_flag = 0;
    check_touch_status();
#endif
}

uint8_t _check_touch_data(void){
#ifdef CONFIG_ENABLE_TOUCH
    // 触摸板关机延迟检查
    if (_touch_pd_cnt > 0){
        _touch_pd_cnt--;
        if(_touch_int_flag > 0){
            _touch_int_flag = 0;
            pct1336_clear_int();
        }
        DEBUG_log("_touch_pd_cnt=%d",_touch_pd_cnt);
        end_touchpad_input();
        if (_touch_pd_cnt == 0){
            // 到时间了，检查触摸板开关状态
            _set_evt(USER_ST, SYS_CHECK_TOUCH_STATUS);
        }
        return 0;
    }
    if (connect_isolation_count > 0){
        connect_isolation_count --;
        DEBUG_log("connect_isolation_count=%d",connect_isolation_count);
        return 0;
    }
    return touch_timer_task();
#else
    return 0;
#endif
}


void _touch_evt_task(void){
#ifdef CONFIG_ENABLE_TOUCH
    if (_touch_pd_cnt <= 0){
        touch_evt_task();
    }
#endif
}

/// @brief 检查触摸板锁定状态并开关触摸板
void check_touch_lock(void){
    #ifdef CONFIG_ENABLE_TOUCH
    if (touch_flag){
        touch_power_on();
    } else {
        touch_power_off();
    }
    #endif
}

/**
 * @brief 检查触摸板是否繁忙
 * @return 1 繁忙（有中断待处理或正在延迟计数），0 空闲
 */
uint8_t touch_is_busy(void)
{
#ifdef CONFIG_ENABLE_TOUCH
    // 检查是否有触摸中断待处理
    if (get_touch_scan_time() > 0)
        return 1;

    // 检查是否在关机延迟期间
    if (_touch_pd_cnt > 0)
        return 1;

    return 0;
#else
    return 0;
#endif
}
