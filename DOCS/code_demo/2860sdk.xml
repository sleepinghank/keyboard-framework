        #endif

        if (has_bond_adv == 1 && wakeup_flag == 1){
            uint8_t buf[KEYBOARD_REPORT_SZ + 1] = {0};
            buf[0] = KB_F13;

            kb_tx_data(ble_get_report_idx(), KEYBOARD_REPORT_SZ, &buf[0]);

            buf[0] = 0;

            kb_tx_data(ble_get_report_idx(), KEYBOARD_REPORT_SZ, &buf[0]);
        }
        wakeup_flag = 0;
        
    }
#ifdef CONFIG_ENABLE_TOUCH
#ifdef CONFIG_ENABLE_PTP
    else if (evt.hdl == TOUCHPAD_FEATURE_REPORT_VALUE_HANDLE){
        if (TP_mode == 0){
            TP_mode = 3;
        }   
        DEBUG_log("Ipad_sleep: (%02x) (%02x)",evt.data[0],evt.data[1]);
    }
    // else if (evt.hdl == MAXCOUNT_REPORT_VALUE_HANDLE){
    //     if (TP_mode == 0){
    //         TP_mode = 3;
    //     }
    //     DEBUG_log("Ipad_sleep: (%02x) (%02x)",evt.data[0],evt.data[1]);
        
    // }
    // else if(evt.hdl == SURBTNSWITCH_REPORT_VALUE_HANDLE)
    // {
    //     INFO_log("OnOff:(%02x)(%02x)",evt.data[0],evt.data[1]);
    //     PTP_SelRpt = evt.data[0];
