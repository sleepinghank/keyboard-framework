static void ble_att_c_evt_handler_probe_os(void* evt)
{
    struct attc_ble_evt* att_evt = (struct attc_ble_evt*)evt;

    if (att_evt->attc_code == ATT_ERR_RSP)
    {
        if (att_evt->attc_ptr->AttErrRsp.opcode == ATT_FIND_BY_TYPE_VALUE_REQ)
        {
            WARN_log("OS_ANDROID ");
            keycode_type = ANDROID;
			// KeyboardConfig.system_type = keycode_type;
            // INFO_log("KeyboardConfig.system_type[%d] = %d\n",_device_idx,keycode_type);
            // _set_evt(USER_ST, SYS_STORAGE_WRITE);
            #ifdef CONFIG_ENABLE_TOUCH
            set_touch_mode(TOUCH_MODE_MOUSE);
			#endif

            identify_system_type(2);
        }
    }

    if (att_evt->attc_code == ATT_FIND_BY_TYPE_VALUE_RSP)
    {

        //struct att_read_by_group_type_rsp* rsp  = (struct att_read_by_group_type_rsp* ) &att_evt->attc_ptr->AttReadByGroupTypeRsp;
        uint16_t start_hdl = 0x0001, end_hdl = 0xffff, type_sz  = 2, uuid = 0;

        /* Enqueue att client cmd for get device name */
        uuid =  PNP_ID_UUID;
        att_c_read_by_type_req(start_hdl, end_hdl, type_sz, (uint8_t*)&uuid, ble_att_c_evt_handler_probe_os);

        /* Enqueue att client cmd for get model number */
        uuid = MODEL_NUMBER_STRING_UUID;
        att_c_read_by_type_req(start_hdl, end_hdl, type_sz, (uint8_t*)&uuid, ble_att_c_evt_handler_probe_os);

    }

    if (att_evt->attc_code == ATT_READ_BY_TYPE_RSP)
    {

//        uint8_t len = att_evt->attc_ptr->AttReadByTypeRsp.length;
        struct att_read_by_type_pair_val* pair  = (struct att_read_by_type_pair_val* ) &att_evt->attc_ptr->AttReadByTypeRsp.pair;
//        DBGHEXDUMP("pair->val", pair->val, len);

        if (pair->val[0] == 0x01 &&
                pair->val[1] == 0x06)
        {
            WARN_log("OS_WINDOWS ");
            keycode_type = WINDOWS;
            // KeyboardConfig.system_type = keycode_type;
            // INFO_log("KeyboardConfig.system_type[%d] = %d\n",_device_idx,keycode_type);
            // _set_evt(USER_ST, SYS_STORAGE_WRITE);
			#ifdef CONFIG_ENABLE_TOUCH
            set_touch_mode(TOUCH_MODE_MOUSE);        
			#endif
            identify_system_type(2);
            // _set_evt(USER_ST, SYS_IDENTIFY_SYSTEM);
        }
        else if (pair->val[0] == 0x69 && // i
                 pair->val[1] == 0x50) // p
        {
            WARN_log("OS_IOS ");
            keycode_type = IOS;
            // KeyboardConfig.system_type = keycode_type;
            // INFO_log("KeyboardConfig.system_type[%d] = %d\n",_device_idx,keycode_type);
            // _set_evt(USER_ST, SYS_STORAGE_WRITE);
            #ifdef CONFIG_ENABLE_TOUCH
            set_touch_mode(TOUCH_MODE_MOUSE);
			#endif
            identify_system_type(2);
            // _set_evt(USER_ST, SYS_IDENTIFY_SYSTEM);
        }
        else if (pair->val[0] == 0x4d && // m
                 pair->val[1] == 0x61) // a
        {
            WARN_log("OS_MAC ");
            keycode_type = MAC;
            // KeyboardConfig.system_type = keycode_type;
            // INFO_log("KeyboardConfig.system_type[%d] = %d\n",_device_idx,keycode_type);
            // _set_evt(USER_ST, SYS_STORAGE_WRITE);
            #ifdef CONFIG_ENABLE_TOUCH
            set_touch_mode(TOUCH_MODE_MOUSE);
			#endif
            identify_system_type(2);
            // _set_evt(USER_ST, SYS_IDENTIFY_SYSTEM);
        }

    }
#endif
}

