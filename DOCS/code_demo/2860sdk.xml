#include "event_flags.h"
#include "timer_event.h"
#include "sys_event.h"         // _sys_timer_task 声明

#include "kb_para_profile.h"
#include "kb_scan.h"
#include "timer.h"
#include "ble.h"
#include "timer_task.h"
#include "gpio_config.h"
#include "backlight.h"
#include "debug.h"
#include "debug_log.h"
#include "pxi_par2860_ble_lib.h"
#include "ext_mcu_comm.h"


uint8_t notify_enable_flag = 0;

// ========== 系统核心定时器 ID ==========
uint8_t kb_timer_id = TIMER_ID_INVALID;  // 键盘扫描定时器（外部可访问）

// ========== 电源管理定时器 ID ==========
uint8_t lpo_timer_id = TIMER_ID_INVALID;  // LPO 校准定时器

// ========== 超时定时器 ID ==========
static uint8_t backlight_timeout_timer_id = TIMER_ID_INVALID;
static uint8_t sleep_timeout_timer_id = TIMER_ID_INVALID;
static uint8_t powerdown_timeout_timer_id = TIMER_ID_INVALID;

// 控制标志（从 sleep.c 引用）
uint8_t never_power_down_flag = 0; // 为1 时永不关机
uint8_t never_backlight_flag = 0;  // 为1 时永不关闭背光灯
uint8_t sleep_flag = 0;

// 前向声明回调函数
static void backlight_timeout_callback(void);
static void sleep_timeout_callback(void);
static void powerdown_timeout_callback(void);

#ifdef CONFIG_LPO_CALIBRATION
#define LPO_CALI_THRESHOLD_TH 90
static void sleep_lpo_callback(void);
#endif

void _notify_flag_cb(void)
{
    notify_enable_flag = 1;
    timer_disable(NOTIFY_TIMER_ID);
}

/* ============================ timer_task 回调函数 ============================ */

/**
 * @brief 背光超时回调 - 在定时器到期时调用
 */
static void backlight_timeout_callback(void)
{
    DEBUG_log("[TIMEOUT] backlight timeout, turning off\r\n");
    back_sleep_state(0);  // 关闭背光
    // backlight_timeout_timer_id = 0xFF;  // 槽位将被 u_timer_clear 释放
    u_timer_disable(backlight_timeout_timer_id);
}

#ifdef CONFIG_LPO_CALIBRATION
static void sleep_lpo_callback(void)
{
    // DEBUG_log("sleep_lpo_callback\r\n");
    pxi_sys_32k_lpo_calibration();
    safe_battery_query();
}
#endif

/**
 * @brief 休眠超时回调 - IDLE 超时后触发
 */
static void sleep_timeout_callback(void)
{
    INFO_log("[TIMEOUT] sleep timeout, entering sleep mode\r\n");
    sleep_timeout_timer_id = 0xFF;  // 槽位将被 u_timer_clear 释放

    // 关闭kb_timer_id 定时器
    u_timer_disable(kb_timer_id);

    _gpio_wakup_mode(1);
    _set_evt(SYS_ST, SYS_ENTER_SLA_LCY);
    
    timer_disable(TIMER_1);
    timer_disable(TIMER_2);
#ifdef CONFIG_LPO_CALIBRATION
    if (lpo_timer_id == 0xFF) {
        // 定时器已销毁，重新创建
        lpo_timer_id = u_timer_soft(sleep_lpo_callback, SEC_TO_MS(LPO_CALI_THRESHOLD_TH));
    } else {
        u_timer_reset(lpo_timer_id);
    }
#endif
}

/**
 * @brief 关机超时回调 - 长时间无操作后触发
 */
static void powerdown_timeout_callback(void)
{
    // powerdown_timeout_timer_id = 0xFF;  // 槽位将被 u_timer_clear 释放
    u_timer_disable(powerdown_timeout_timer_id);
    if (never_power_down_flag == 0) {
        // INFO_log("[TIMEOUT] powerdown timeout, disconnecting BLE\r\n");
        sleep_flag = 1;
        ble_disconnect();
    }
}




#ifdef BLE_RECONNECT_IN_ERR
uint8_t disconnect_sleep_bit = 0;//断连睡眠标志
uint8_t disconnect_reconnect_timer_id = 0xFF;  // 回连超时定时器ID，0xFF表示无效
void disconnect_reconnect_timeout_cb(void)
{
    if ((disconnect_sleep_bit & 0x80) == 0x80) {
        INFO_log("Reconnect timeout, power down");
        disconnect_sleep_bit = 0;
        _set_evt(SYS_ST, SYS_POWER_DOWN);
        disconnect_reconnect_timer_id = 0xFF;  // 重置为无效ID
    }
}
#endif
/* ============================ timer_task 统一初始化 ============================ */

/**
 * @brief 统一初始化所有定时器
 * @note 集中管理所有定时器创建
 */
void timer_event_init(void)
{
    // 1. 创建键盘扫描定时器（核心任务）
    kb_timer_id = u_timer_soft(_sys_timer_task, KEY_SCAN_INTERVAL_MS);
    if (kb_timer_id == TIMER_ID_INVALID) {
        ERROR_log("[TIMER] Failed to create keyboard timer\r\n");
    }

    sleep_timeout_timer_id = u_timer_out_soft(sleep_timeout_callback,SEC_TO_MS(IDLE_INTERVAL), 1);

    if (sleep_timeout_timer_id == 0xFF) {
        ERROR_log("[TIMEOUT] Failed to create sleep timer\r\n");
        return;
    }

    backlight_timeout_timer_id = TIMER_ID_INVALID;
    lpo_timer_id = TIMER_ID_INVALID;  // LPO 校准定时器
    powerdown_timeout_timer_id = TIMER_ID_INVALID;

    #ifdef KEYCODE_BKLED
        u_timer_out_soft(safe_battery_query, 500, 2);  // 500ms/1000ms 各再查一次电量，查询完成后自动调用 Backlight_Init1
    #endif
    // INFO_log("[TIMER] timer_event_init complete: kb=%d, sleep=%d\r\n", kb_timer_id, sleep_timeout_timer_id);
}

/* ============================ timer_task 重置函数 ============================ */

/**
 * @brief 重置背光超时定时器 - 有操作时调用
 */
void reset_backlight_timeout(void)
{
    DEBUG_log("never_backlight_flag: %d\r\n", never_backlight_flag);
    if (never_backlight_flag)
    {
        return;
    }

    if (backlight_timeout_timer_id == 0xFF) {
        // 定时器已销毁，重新创建，考虑到背光关闭后可能会重新打开。
        backlight_timeout_timer_id = u_timer(backlight_timeout_callback,
                                                  SEC_TO_MS(BACKLIGHT_POWER_DOWN_INTERVAL));
        DEBUG_log("[TIMEOUT] backlight timer re-created: id=%d\r\n", backlight_timeout_timer_id);
    } else {
        DEBUG_log("[TIMEOUT] backlight timer reset\r\n");
        u_timer_reset(backlight_timeout_timer_id);
    }
}

/**
 * @brief 重置休眠超时定时器 - 有按键/触摸操作时调用
 */
void reset_sleep_timeout(void)
{
    if (sleep_timeout_timer_id == 0xFF) {
        // 定时器已销毁，重新创建
        sleep_timeout_timer_id = u_timer_out_soft(sleep_timeout_callback,
                                              SEC_TO_MS(IDLE_INTERVAL), 1);
        // // DEBUG_log("[TIMEOUT] sleep timer re-created: id=%d\r\n", sleep_timeout_timer_id);
    } else {
        u_timer_reset(sleep_timeout_timer_id);
        // // DEBUG_log("[TIMEOUT] sleep timer reset\r\n");
    }
}

/**
 * @brief 重置关机超时定时器
 */
void reset_powerdown_timeout(void)
{
    if (never_power_down_flag) return;

    if (powerdown_timeout_timer_id == 0xFF) {
        // 定时器已销毁，重新创建
        powerdown_timeout_timer_id = u_timer(powerdown_timeout_callback,
                                                  SEC_TO_MS(POWER_DOWN_INTERVAL));
        // // DEBUG_log("[TIMEOUT] powerdown timer re-created: id=%d\r\n", powerdown_timeout_timer_id);
    } else {
        u_timer_reset(powerdown_timeout_timer_id);
        // // DEBUG_log("[TIMEOUT] powerdown timer reset\r\n");
    }
}

/* ============================ 超时时间设置函数 ============================ */

/**
 * @brief 设置关机时间
 * @param time 时间值，最高位为1表示分钟，为0表示秒；0表示永不关机
 */
void set_shutdown_time(uint16_t time)
{
    // 设置永不关机标志
    never_power_down_flag = (time == 0) ? 1 : 0;

    // 计算新的超时时间
    uint32_t timeout_ms;
    if (time & 0x8000) {
        // 最高位为1表示分钟
        uint16_t minutes = (time & 0x7fff);
        // 下限 5 分钟，上限 1440 分钟（24小时）
        if (minutes < 5) minutes = 5;
        if (minutes > 1440) minutes = 1440;
        timeout_ms = (uint32_t)minutes * 60 * 1000;
    } else {
        // 最高位为0表示秒
        uint32_t seconds = time;
        // 下限 300 秒（5分钟）
        if (seconds < 300) seconds = 300;
        timeout_ms = seconds * 1000;
    }
    
    // 更新定时器（防御：定时器未创建时先创建）
    if (powerdown_timeout_timer_id == 0xFF) {
        powerdown_timeout_timer_id = u_timer(powerdown_timeout_callback, timeout_ms);
        if (powerdown_timeout_timer_id == 0xFF) {
            ERROR_log("[TIMEOUT] Failed to create powerdown timer in set_shutdown_time\r\n");
            return;
        }
        // INFO_log("[TIMEOUT] powerdown timer created in set_shutdown_time: id=%d\r\n", powerdown_timeout_timer_id);
    } else {
        u_timer_modify(powerdown_timeout_timer_id,
                          powerdown_timeout_callback,
                          timeout_ms);
    }

    if (never_power_down_flag) {
        u_timer_disable(powerdown_timeout_timer_id);
        // INFO_log("[TIMEOUT] powerdown timer disabled by set_shutdown_time\r\n");
    }
}

/**
 * @brief 设置背光灯关闭时间
 * @param time 时间值，最高位为1表示分钟，为0表示秒；0表示永不关闭
 */
void set_led_off_time(uint16_t time)
{
    // 设置永不关闭背光灯标志
    never_backlight_flag = (time == 0) ? 1 : 0;

    // 计算新的超时时间
    uint32_t timeout_ms;
    if (time & 0x8000) {
        // 最高位为1表示分钟
        uint16_t minutes = (time & 0x7fff);
        if (minutes == 0) minutes = 1;
        if (minutes > 1440) minutes = 1440;  // 上限 24 小时
        timeout_ms = (uint32_t)minutes * 60 * 1000;
    } else {
        // 最高位为0表示秒
        uint32_t seconds = time;
        if (seconds == 0) seconds = 5;  // 最少 5 秒
        timeout_ms = seconds * 1000;
    }
    // DEBUG_log("[TIMEOUT] set_led_off_time: time=0x%04x, timeout_ms=%d, never_backlight_flag=%d\r\n",time, timeout_ms, never_backlight_flag);
    // 更新定时器（防御：定时器未创建时先创建）
    if (backlight_timeout_timer_id == 0xFF) {
        backlight_timeout_timer_id = u_timer(backlight_timeout_callback, timeout_ms);
        if (backlight_timeout_timer_id == 0xFF) {
            ERROR_log("[TIMEOUT] Failed to create backlight timer in set_led_off_time\r\n");
            return;
        }
        // INFO_log("[TIMEOUT] backlight timer created in set_led_off_time: id=%d\r\n", backlight_timeout_timer_id);
    } else {
        u_timer_modify(backlight_timeout_timer_id,
                          backlight_timeout_callback,
                          timeout_ms);
    }

    if (never_backlight_flag) {
        u_timer_disable(backlight_timeout_timer_id);
        // INFO_log("[TIMEOUT] backlight timer disabled by set_led_off_time\r\n");
    }
}
