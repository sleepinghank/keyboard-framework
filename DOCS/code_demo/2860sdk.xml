//发送数据到蓝牙主机
static void _ble_gatt_read(struct gap_att_read_evt evt)
{
    uint8_t str[10] = {0};

    if (evt.uuid == OTA_READ_WRITE_UUID)
    {
        uint8_t sz = 0;
        uint8_t rsp[sizeof(struct hci_evt)] = {0};

        if (ota_init_check())
        {
            ota_rsp(rsp, &sz);
            pxi_gap_s_gatt_read_rsp_set(sz, rsp);
        }
    }
    else if (evt.uuid == INATECK_OTA_READ_WRITE_UUID)
    {

        #ifdef INATECK_ORIGIN_ENABLE
        uint8_t sz = 0;
        uint8_t rsp[sizeof(origin_cmd_resp)] = {0};
        if (_Origin_Command_Check())
        {
            _Origin_Rsp(rsp, &sz);
            pxi_gap_s_gatt_read_rsp_set((sz - evt.offset), rsp + evt.offset);
        }
        #endif
    }


    else if (evt.uuid == PERIPHERAL_PREFERRED_CONNECTION_PARAMETERS_UUID)
    {
        uint8_t gatt_buf[] = { CONNECTION_INTERVAL_MIN & 0x00ff, CONNECTION_INTERVAL_MIN >> 8,
                               CONNECTION_INTERVAL_MAX & 0x00ff, CONNECTION_INTERVAL_MAX >> 8,
                               CONNECTION_LATENCY & 0x00ff, CONNECTION_LATENCY >> 8,
                               CONNECTION_SVTO & 0x00ff, CONNECTION_SVTO >> 8
                             };

        uint8_t gatt_buf_sz = sizeof(gatt_buf);
        pxi_gap_s_gatt_read_rsp_set(gatt_buf_sz, gatt_buf);
    }

    else  if (evt.uuid == DEVICE_NAME_UUID)
    {
        uint8_t dev_name_sz = strlen(ProductModel);
        uint8_t dev_name[MAX_ADV_DATA_SZ] = {0};
        memcpy(&dev_name[0], (const uint8_t*)ProductModel, strlen(ProductModel));

        pxi_gap_s_gatt_read_rsp_set(dev_name_sz, dev_name);
    }
    else if (evt.uuid == MANUFACTURER_NAME_STRING_UUID)
        pxi_gap_s_gatt_read_rsp_set(strlen(MANUFACTURER_NAME_STRING), (uint8_t*)MANUFACTURER_NAME_STRING);
    else if (evt.uuid == MODEL_NUMBER_STRING_UUID)
        pxi_gap_s_gatt_read_rsp_set(strlen(FirmwareCode), (uint8_t*)FirmwareCode);
    else if (evt.uuid == SERIAL_NUMBER_STRING_UUID)
    {
        //软件版本号
        str[0] = ((SoftwareVersion >> 16) & 0xff) + '0';
        str[1] = '.';
        str[2] = ((SoftwareVersion >> 8) & 0xff) + '0';
        str[3] = '.';
        str[4] = (SoftwareVersion & 0xff) + '0';
        str[5] = 0;
        pxi_gap_s_gatt_read_rsp_set(5, str);
    }
        
    else if (evt.uuid == HARDWARE_REVISION_STRING_UUID)
    {
        //硬件版本号
        str[0] = ((HardwareVersion >> 16) & 0xff) + '0';
        str[1] = '.';
        str[2] = ((HardwareVersion >> 8) & 0xff) + '0';
        str[3] = '.';
        str[4] = (HardwareVersion & 0xff) + '0';
        str[5] = 0;

        pxi_gap_s_gatt_read_rsp_set(5, str);
    }

    else if (evt.uuid == SOFTWARE_REVISION_STRING_UUID)
    {
        char softwareVersionString[30] = {0};
        sprintf(softwareVersionString, "%s_%s_%02d%02d%02d", ExternalCode, CountryCode, SoftwareVersion >> 16, (SoftwareVersion >> 8) & 0xFF, SoftwareVersion & 0xFF);
        pxi_gap_s_gatt_read_rsp_set((strlen(softwareVersionString) - evt.offset), (uint8_t*)(softwareVersionString + evt.offset));
    }
        
    else if (evt.uuid == FIRMWARE_REVISION_STRING_UUID)
    {
        //协议版本号
        str[0] = ((ProtocolVersion >> 16) & 0xff) + '0';
        str[1] = '.';
        str[2] = ((ProtocolVersion >> 8) & 0xff) + '0';
        str[3] = '.';
        str[4] = (ProtocolVersion & 0xff) + '0';
        str[5] = 0;

        pxi_gap_s_gatt_read_rsp_set(5, str);
    }
        
    else if (evt.uuid == PNP_ID_UUID)
    { 
        uint8_t gatt_buf[] = { PNP_VENDOR_ID_SOURCE,
                               PNP_VENDOR_ID & 0x00ff, PNP_VENDOR_ID >> 8,
                               PNP_PRODUCT_ID & 0x00ff, PNP_PRODUCT_ID >> 8,
                               PNP_PRODUCT_VERSION & 0x00ff, PNP_PRODUCT_VERSION >> 8
                             };

        uint8_t gatt_buf_sz = sizeof(gatt_buf);

        pxi_gap_s_gatt_read_rsp_set(gatt_buf_sz, gatt_buf); 
    }
    else if (evt.uuid == REPORT_MAP_UUID)
    {
        // uint16_t _report_map_sz = sizeof(ReportMap_Mouse);
        
        //DEBUG_log("--------------------------....Get Report Map");
        pxi_gap_s_gatt_read_rsp_set((_report_map_sz - evt.offset), kb_hid_report_map + evt.offset);
        check_pair_state = 0x01;
