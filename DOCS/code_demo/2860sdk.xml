/* IIC命令队列机制 */
/* 命令类型定义 */
typedef enum {
    IIC_CMD_LED,           /* LED控制命令 */
    IIC_CMD_TOUCH,         /* 触摸控制命令 */
    IIC_CMD_SLEEP,         /* 睡眠控制命令 */
    IIC_CMD_RGB_COLOR,     /* RGB颜色控制命令 */
    IIC_CMD_RGB_BRIGHTNESS,/* RGB亮度控制命令 */
    IIC_CMD_BATTERY_QUERY, /* 电池查询命令 */
    /* 可扩展其他命令类型 */
} IIC_CMD_TYPE;

/* 命令结构体 */
typedef struct {
    IIC_CMD_TYPE type;     /* 命令类型 */
    uint8_t param1;        /* 参数1 */
    uint8_t param2;        /* 参数2 */
    uint8_t param3;        /* 参数3 */
    uint8_t retry_count;   /* 重入队重试计数 */
} IIC_Cmd_t;

#define IIC_CMD_QUEUE_SIZE 255
static IIC_Cmd_t iic_cmd_queue[IIC_CMD_QUEUE_SIZE];
static uint8_t iic_cmd_head = 0, iic_cmd_tail = 0;

/******************************************************************************
 * @brief IIC命令入队函数
 * @details 将IIC命令添加到命令队列中
 * @param cmd 要入队的命令指针
 * @return None
 ******************************************************************************/
static void iic_cmd_enqueue(const IIC_Cmd_t *cmd)
{
    uint8_t next = (iic_cmd_tail + 1) % IIC_CMD_QUEUE_SIZE;
    if (next != iic_cmd_head) { /* 队列未满 */
        iic_cmd_queue[iic_cmd_tail] = *cmd;
        iic_cmd_tail = next;
    } else {
        ERROR_log("IIC命令队列已满,丢弃命令 type=%d", cmd->type);
    }
}

/******************************************************************************
 * @brief 判断命令队列是否为空
 * @details 检查命令队列是否为空
 * @param None
 * @return uint8_t 1表示空，0表示非空
 ******************************************************************************/
static inline uint8_t iic_cmd_queue_empty(void)
{
    return iic_cmd_head == iic_cmd_tail;
}

/******************************************************************************
 * @brief IIC命令出队函数
 * @details 从命令队列中取出一个命令
 * @param cmd 存储出队命令的指针
 * @return uint8_t 1表示成功出队，0表示队列为空
 ******************************************************************************/
static inline uint8_t iic_cmd_dequeue(IIC_Cmd_t *cmd)
{
    if (iic_cmd_queue_empty()) return 0;
    *cmd = iic_cmd_queue[iic_cmd_head];
    iic_cmd_head = (iic_cmd_head + 1) % IIC_CMD_QUEUE_SIZE;
    return 1;
}

/* 队列安全封装接口 */
/* 业务层以后调用这些接口而不是直接调用led_control等 */

/******************************************************************************
 * @brief 安全的LED控制接口
 * @details 将LED控制命令安全地添加到命令队列
 * @param index LED索引
 * @param value LED控制值
 * @return None
 ******************************************************************************/
void safe_led_control(uint8_t index, uint8_t value)
{
    IIC_Cmd_t cmd = {IIC_CMD_LED, index, value, 0, 0};
    iic_cmd_enqueue(&cmd);
    // DEBUG_log("safe_led_control: index = %d, value = %d\n", index, value);
}

