static void key_code_refresh()
{
    uint8_t i = 0;

    /* delete key from keycode list */
    for (i = 0; i < _break_sz; i++)
        del(_break_key_arr[i], _key_code_list);

    /* add new key to keycode list */
    for (i = 0; i < _make_sz; i++)
        add(_make_key_arr[i], _key_code_list);

    #ifdef CONFIG_ENABLE_TOUCH
    if(_make_sz>0 || _break_sz>0){
        if (_break_key_arr[0] != S_TOUCH_BUTTON && _make_key_arr[0] != S_TOUCH_BUTTON){
            set_kb_break_cnt(KEYBOARD_CNT_MS(400));
        }
        // display(_key_code_list);
    }
    #endif

}

static void debounce_proc(key_update_st_t _keyUpdateSt)
{
    if (_keyUpdateSt == GHOST_KEY)
        return;

    /* Increase Make list_t Cycle 增加list_t循环*/
    increase_cycle(_make_list);

    /* Increase Break list_t Cycle 增加Break list_t循环*/
    increase_cycle(_break_list);

    if (_keyUpdateSt == KEY_UPDATE)
    {
        uint8_t i = 0, j = 0, idx = 0;

        for (i = 0; i < NUM_OF_COLS; i++)
        {
            idx = i * NUM_OF_ROWS;
            
            for (j = 0; j < 8; j++)
            {
                if ((_matrix_update[i] & BIT(j)) == BIT(j))  // key update
                {
                    uint16_t keyCode = _keyboard_lookup_table[idx + j];
                    if (keyCode == KB_NO_EVT)
                        continue;

                    if ((_matrix[i] & BIT(j)) == BIT(j))
                    {
                        /* key press */
                        if (find_key(_break_list, keyCode))
                        {                          
                            del(keyCode, _break_list);           
                        }
                        else
                        { 
                            add(keyCode, _make_list);
                        }
                    }
                    else
                    {
                        
                        /* key release */
                        if (find_key(_make_list, keyCode))
                        {
                            del(keyCode, _make_list);                            
                        }
                        else
                        {
                        add(keyCode, _break_list);              
                        }
                    }
                }
            }
        }
    }
//按键汇报
    pop_key(_make_list, _make_key_arr, &_make_sz, MAKE_DEBOUNCE_CYCLE);

    if (_make_sz > 0){
        DBGHEXDUMP("\r\n***make\r\n", (uint8_t*)_make_key_arr, _make_sz);
    }

    pop_key(_break_list, _break_key_arr, &_break_sz, BREAK_DEBOUNCE_CYCLE);

    if (_break_sz > 0){
        DBGHEXDUMP("\r\n***break\r\n", (uint8_t*)_break_key_arr, _break_sz);
    }

    key_code_refresh();
}


static void report_update_proc(key_update_st_t _keyUpdateSt)
{
    node_t* current = _key_code_list->head;
    uint8_t qwerty_key_idx = 0;
    uint16_t media_key_array[15];
    uint8_t media_key_array_idx = 0;

    is_extend = 0;
    memset(media_key_array, 0x00, sizeof(media_key_array));
    memset((uint8_t*)&my_kb_rpt, 0x00, sizeof(my_kb_rpt));

    if (current == NULL ) {
        current = _key_code_list_extend->head;
        is_extend = 1;
    }  
    if (_keyUpdateSt != GHOST_KEY)
    {
        un_normal_key = 0;
        un_modifier_key = 0;
        while (current != NULL)
        {
            uint16_t key_code = current->data.key_code;

            if (current->data.is_report == 0) {
                // INFO_log("is not report:%d",key_code);
                goto NEXT;
            }
            if (is_extend == 1){
                if (find_activate_key(_key_code_list,key_code) == 1){
                    // INFO_log("find activate is not report:%d",key_code);
                    goto NEXT;
                }
            }
            if ((key_code >= KB_A && key_code <= KB_R_GUI))
            {   
                // INFO_log("Nkey_code:%d",key_code);
                if (key_code >= KB_L_CTRL && key_code <= KB_R_GUI)
                {
                    if (is_extend != 1){
                        un_modifier_key = 1;
                        // DEBUG_log("un_modifier_key");
                    }
                    /* Modifier key */
                    my_kb_rpt.nkey_report.modifier_keys[0] |= (1 << (key_code - KB_L_CTRL));
                }
                else
                {
                    current->data.report_type = NORMAL_RPT;
                    // 普通键不能由组合键返回的扩展键触发
                    if (is_extend != 1){
                        un_normal_key = 1;
                        // DEBUG_log("un_normal_key");
                    }
                    if (qwerty_key_idx >= QWERTY_KEY_SZ)
                        goto NEXT;

                    my_kb_rpt.nkey_report.non_modifier_keys[qwerty_key_idx++] = key_code;
                }
            }
            
            else if ((key_code & M_KEY_TYPE) == M_KEY_TYPE)
            {
                // INFO_log("Mkey_code:%d",key_code);
                media_key_array[media_key_array_idx++] = key_code;
                my_kb_rpt.mkey_report.media_key_code = (key_code ^ M_KEY_TYPE);                                                           // Search
            }
            else if ((key_code & C_KEY_TYPE) == C_KEY_TYPE)
            {
               /* Combo key */
               
            }
            else if ((key_code & S_KEY_TYPE) == S_KEY_TYPE)
            {
                /* Special key */
                if (key_code == S_FN_KEY){}

            }
        NEXT:
            current = current->next;

            if (current == NULL && active_event == 1 && is_extend == 0) {
                current = _key_code_list_extend->head;
                is_extend = 1;
            }       
        }
        // INFO_log("8");
    }
    else
    {
        /* Ghost Key Error */
        memset((uint8_t*)&my_kb_rpt, 0x00, sizeof(my_kb_rpt));
        memcpy(my_kb_rpt.nkey_report.normal_keys, _ghost_key_err, \
               KEYBOARD_REPORT_SZ);
        DEBUG_hex("Ghost Key Error", (uint8_t*)&my_kb_rpt.nkey_report.normal_keys, \
                   KEYBOARD_REPORT_SZ);
    }

   if (FN_st == 1 && ((un_normal_key == 1 || un_modifier_key == 1) && active_fn_combo == 0)){
       
       // 地球键
       #ifdef EARTH
       my_kb_rpt.mkey_report.media_key_code = (M_EARTH ^ M_KEY_TYPE);
       combinations_flag = 0;
       #endif
    //    DEBUG_log("...........地球扫描%d\r\n",combinations_flag);
   }

    if (memcmp((uint8_t*)&old_kb_rpt.mkey_report.media_key, \
               (uint8_t*)&my_kb_rpt.mkey_report.media_key, MEDIA_KEY_REPORT_SZ) != 0)
    {
        my_kb_rpt.mkey_report.update = 1;

        memcpy((uint8_t*)&old_kb_rpt.mkey_report.media_key, \
               (uint8_t*)&my_kb_rpt.mkey_report.media_key, MEDIA_KEY_REPORT_SZ);
        DEBUG_hex("mkey_report", (uint8_t*)&my_kb_rpt.mkey_report.media_key, \
                   MEDIA_KEY_REPORT_SZ);
    }

    if (memcmp((uint8_t*)&old_kb_rpt.nkey_report.normal_keys, \
               (uint8_t*)&my_kb_rpt.nkey_report.normal_keys, \
               KEYBOARD_REPORT_SZ) != 0)
    {
        my_kb_rpt.nkey_report.update = 1;
        memcpy((uint8_t*)&old_kb_rpt.nkey_report.normal_keys, \
               (uint8_t*)&my_kb_rpt.nkey_report.normal_keys, KEYBOARD_REPORT_SZ);

        DEBUG_hex("nkey_report", (uint8_t*)&my_kb_rpt.nkey_report.normal_keys, \
                   KEYBOARD_REPORT_SZ);
    }
    if (media_key_array_idx > 1)
    {
        uint8_t i = 0;

        for (i = 0; i < media_key_array_idx - 1; i++)
            del(media_key_array[i], _key_code_list);
    }
}

// 针对配合光标可以连续选中的键 放开
uint8_t find_only_shift_ctrl(void){
    uint8_t shift_ctrl = 0;
    node_t* current = _key_code_list->head;
    if (current != NULL)
    {
        uint16_t key_code = current->data.key_code;
        if (key_code == KB_L_SHIFT || key_code == KB_R_SHIFT || key_code == KB_L_CTRL || key_code == KB_R_CTRL || key_code == KB_L_ALT || key_code == KB_R_ALT){
            // SHIFT 通用
            shift_ctrl=1;
        }  else if ((keycode_type == IOS || keycode_type ==MAC)  && (  key_code == KB_R_GUI || key_code == KB_L_GUI)){
            // KB_R_GUI 对应苹果 command键
            shift_ctrl=1;
        }  else {
            return 0;
        }
        current = current->next;
    } else {
        return 1;
    }
    // 只支持单按键
    // if (current != NULL){
    //     return 0;
    // }
    return shift_ctrl;
}

void get_kb_rpt(void)
{
    key_update_st_t k_st = NO_KEY_UPDATE;
    k_st = key_matrix_proc();
    if(k_st != GHOST_KEY){
        debounce_proc(k_st);
        combo_task(k_st);
        #ifdef MCS_GESTURE
        if (SystemConfig.touch_gesture_switch_bitmap & BIT(16-act_gesture)){
            uint8_t shortcut_idx = SystemConfig.touch_gesture_shortcut[act_gesture - 1];
            DEBUG_log("act_gesture = %d,shortcut_idx = %d", act_gesture,shortcut_idx);
            if (shortcut_idx < FUNC_COUNT){
                KeyHandlerFunc handler = func_handlers[shortcut_idx];
                if (NULL != handler)
                {
                    skip_inactive_keys(handler);
                }
            }

        }
        #endif
        report_update_proc(k_st);
    }

    // 清空所有扩展键
    del_all_child(_key_code_list_extend);
    #ifdef MCS_GESTURE
    act_gesture = GESTURE_UNKNOWN;
    #endif
}
