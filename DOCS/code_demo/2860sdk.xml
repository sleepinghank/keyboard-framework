static void _ble_set_adv_param(uint8_t type)
{
    struct gap_adv_params adv_params;

    adv_params.type = ADV_IND;
    adv_params.channel = 0x07;
    adv_params.interval = 0x1a;

    #ifdef POLLING_BLEADV_ENABLE
    has_bond_adv=0;
    if (type==1)
    {
        if ((pairing_state_get() & SWIFT_PAIR) == SWIFT_PAIR)
        {
            adv_params.timeout = ble_adv_params.swift_pair_adv_timeout;
            // WARN_log("Swift Pair ADV timeout: %d", ble_adv_params.swift_pair_adv_timeout);
        }
        else
        {
            adv_params.timeout = ble_adv_params.general_pair_adv_timeout;
            // WARN_log("General Pair ADV timeout: %d", ble_adv_params.general_pair_adv_timeout);
        }
    }
    else
    {
        if (direct_adv_cnt>=20)
        {
            adv_params.timeout = 0x02;
            // DBGPRINTF(("General Pair ADV 2\r\n"));
        }else{
            adv_params.timeout = 0x01;
            // DBGPRINTF(("General Pair ADV 1\r\n"));
        }
    }
    #else
    if ((pairing_state_get() & SWIFT_PAIR) == SWIFT_PAIR)
    {
        adv_params.timeout = ble_adv_params.swift_pair_adv_timeout;
        WARN_log("Swift Pair ADV timeout: %d", ble_adv_params.swift_pair_adv_timeout);
    }
    else
    {
        adv_params.timeout = ble_adv_params.general_pair_adv_timeout;
        WARN_log("General Pair ADV timeout: %d", ble_adv_params.general_pair_adv_timeout);
    }
    #endif

    adv_params.hop_interval = 0x1c;
    adv_params.policy = 0x00;

    pxi_gap_s_adv_parameters_set(&adv_params);

    adv_data[0x02] = 0x05;

    _ble_set_adv_data();
}

//检查是否有绑定信息，如果有就使用不可发现可连接的定向回连。如果没有就使用可发现可连接的非定向广播
static void  ble_check_bond_and_set_param(uint8_t type)
{
    struct gap_bond_dev bonds_device;
    struct gap_adv_params adv_params;
    Berry_wang_flag=0;
    //获取绑定信息
    if (pxi_bm_s_bond_info_get(&bonds_device) == 1)
    {
        #ifdef POLLING_BLEADV_ENABLE
        has_bond_adv = 1;
        direct_adv_st=1;
        #endif

        //有绑定信息，使用定向广播
        if (bonds_device.addr.type == PUBLIC_ADDRESS_TYPE)
        {
            adv_params.type = ADV_DIRECT_IND;

            memcpy(&adv_params.peer_addr, &bonds_device.addr, sizeof(struct gap_ble_addr));
            adv_params.channel = 0x07;
            adv_params.interval = 0x00;

            #ifdef POLLING_BLEADV_ENABLE
            if (type!=1&&direct_adv_cnt>=20){
                adv_params.timeout = 0x01;
            }
            else
            {
                adv_params.timeout = 0x02;
            }
            #else
            adv_params.timeout = ble_adv_params.direct_adv_timeout;
            #endif

            adv_params.hop_interval = 0x03;
            adv_params.policy = 0x03;            
            INFO_log(("ADV_DIRECT_IND"));
        }
        else
        {
			// Berry_wang_flag=1;
            adv_params.type = ADV_IND;
            adv_params.channel = 0x07;
            adv_params.interval = 0x1A;
            #ifdef POLLING_BLEADV_ENABLE
            if (type!=1&&direct_adv_cnt>=20){
                adv_params.timeout = 0x01;
            }else
            {
                adv_params.timeout = 0x02;
            }
            #else
            adv_params.timeout = ble_adv_params.reconn_adv_timeout;
            #endif

            adv_params.hop_interval = 0x1c;
            adv_params.policy = 0x00;
            INFO_log(("Reconnect ADV"));
        }
        //0x04 -> 不可发现  -0x05> 可发现
        adv_data[0x02] = 0x04;
        // WARN_log("有绑定信息，使用定向广播");
        if (type==1){
            safe_led_control(ble_ch1_led , LED_STATE_SLOW_BLINK);
        }
        pxi_gap_s_adv_parameters_set(&adv_params);
        pxi_gap_s_adv_data_set(adv_data, 0, 0, 0);
    }
    else
    {
        #ifdef POLLING_BLEADV_ENABLE
        direct_adv_st=0;
        has_bond_adv=0;
        #endif

        //没有绑定信息，使用非定向广播
        pairing_state_set((pairing_state_t)(GENERAL_PAIR));
        _ble_update_dev_addr(1);
//       DBGPRINTF(("Swift Pair ADV"));
        // Berry_wang_flag=1;
        adv_params.type = ADV_IND;
        adv_params.channel = 0x07;
        adv_params.interval = 0x1A;
        adv_params.timeout = ble_adv_params.general_pair_adv_timeout;
        adv_params.hop_interval = 0x1c;
        adv_params.policy = 0x00;
        adv_data[0x02] = 0x05;
        WARN_log("没有绑定信息，使用非定向广播");
        if (type==1){
            safe_led_control(ble_ch1_led , LED_STATE_FAST_BLINK);
        }
        pxi_gap_s_adv_parameters_set(&adv_params);
    
        _ble_set_adv_data();
    }
    
}


