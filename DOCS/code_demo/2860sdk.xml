// 触摸板手势快捷键回调
static int8_t touch_gesture_shortcut_write_cb(const void* value, uint16_t len){
// 2个字节的BITMAP+N*3个字节，N为开启的自定义手势数量由BITMAP中的1的个数决定，
// 检查参数有效性
    if (value == NULL || len < 2) {
        DEBUG_log("Invalid parameters\n");
        return -1;
    }
     // 假设 data 是一个 int8_t 类型的数组
    const uint8_t* data = (const uint8_t*)value;
    // 解析位图
    uint16_t bitmap = (data[0] << 8) | data[1];
    DEBUG_log("Gesture bitmap: 0x%04X\n", bitmap);

    // 计算位图中1的个数（即开启的手势数量）
    int gesture_count = 0;
    uint16_t temp_bitmap = bitmap;
    while (temp_bitmap) {
        if (temp_bitmap & 0x0001) {
            gesture_count++;
        }
        temp_bitmap >>= 1;
    }
    DEBUG_log("Number of enabled gestures: %d\n", gesture_count);

    // 检查数据长度是否符合预期
    if (len != 2 + gesture_count) {
        DEBUG_log("Data length mismatch, expected: %d, actual: %d\n", 2 + gesture_count, len);
        return -2;
    }

    touch_gesture_switch_bitmap = bitmap;

    // 解析每个开启的手势对应的3字节数据
    int data_index = 2; // 跳过位图的2个字节
    for (int i = 0; i < 16; i++) { // 假设最多支持16种手势
        if (bitmap & (0x8000 >> i)) {
            if (data_index < len) {
                uint8_t key1 = (uint8_t)data[data_index];

                DEBUG_log("Gesture ID: %d, key1: %d\n", i, key1);

                touch_gesture_shortcut[15-i] = key1;
                data_index += 1;
            } else {
                DEBUG_log("Data parsing error, index out of bounds\n");
                return -3;
            }
        }
    }

    SystemConfig.touch_gesture_switch_bitmap = touch_gesture_switch_bitmap;
    SystemConfig.touch_gesture_shortcut[0] = touch_gesture_shortcut[15];
    SystemConfig.touch_gesture_shortcut[1] = touch_gesture_shortcut[14];
    SystemConfig.touch_gesture_shortcut[2] = touch_gesture_shortcut[13];
    SystemConfig.touch_gesture_shortcut[3] = touch_gesture_shortcut[12];
    reset_powerdown_timeout();
    _set_evt(USER_ST, SYS_STORAGE_WRITE);
    return 0;
}
