/// @param *pp 原始数据指针
/// @return 1：有数据 0：无数据
uint8_t unite_filtration(touchpad_data_t *ptp){
    uint8_t is_activate = 0;
    uint8_t i;
    uint8_t temp = 0;
    uint8_t contact_count = ptp -> contact_count;
