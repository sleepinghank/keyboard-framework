{
    // DEBUG_log("battery_query: start\n");
    uint8_t new_level = soft_iic_read_reg(REG_BATTERY_LEVEL);
    // I2C 失败返回 0，0 不是合理电量值（电量为 0 时设备应已关机）
    if (new_level != 0) {
        bat_level = new_level;
    }
    // DEBUG_log("battery_query: bat_level = %d\n", bat_level);
}

