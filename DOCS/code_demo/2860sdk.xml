uint8_t is_matrix_empty()
{
    if (memcmp(_matrix_tmp, _matrix_empty, NUM_OF_COLS) != 0)
        return 0;   // matrix isn't empty
    else
        return 1;   // matrix is empty
}

uint8_t is_bouncing_over()
{
    if (_make_list->head == NULL && _break_list->head == NULL)
        return 1;
    else
        return 0;
}

static uint32_t _count_bit_set(uint8_t num)
{
    uint32_t count = 0;

    while (num)
    {
        count++;
        num &= (num - 1);
    }

    return count;
}

static uint32_t _kb_scan(uint8_t* matrix, uint32_t gkd_en, \
                     uint8_t* ghost_key_detected, \
                     uint32_t* number_of_key_pressed)
{
	uint32_t dly=0;
	uint8_t tmp_matrix [NUM_OF_COLS]={0x00};
    int i,m;
    uint8_t check_matrix=0;

    for(i=0;i<NUM_OF_COLS;i++)
    {
        gpo_config(key_output_io[i],GPO_LOW);
        for(dly = 0 ; dly< 100 ;dly++);

        for(m=0;m<NUM_OF_ROWS;m++)
            tmp_matrix[i] |= (gpi_get_val(key_input_io[m])<<m);

#ifdef CONFIG_UART_ENABLE
        // if (tmp_matrix[i] > 0 ){
        //     DEBUG_log("tmp_matrix[%d] = %02X",i,tmp_matrix[i]);
        // }
#endif
            
        gpi_config(key_output_io[i], GPI_PULL_UP,GPI_NOT_INVERTED);
    }

    //check matrix is same
    for(i=0;i<NUM_OF_COLS;i++)
    {
        if(matrix[i] != tmp_matrix[i])
        {
            check_matrix = 1;
        }
    }

   //ghost key process
    {
        uint8_t ghost = 0, ghost_detect_position = 0;
        uint32_t pressed_count = 0;
        uint32_t tmp;

        for (i = 0; i < NUM_OF_COLS; i++)
        {
            {
                matrix[i] = tmp_matrix[i];
                tmp = _count_bit_set(matrix[i]);

                // ghost key detection
                if (gkd_en && !ghost && tmp > 1)
                {
                    ghost |= ((ghost_detect_position & matrix[i]) != 0);
                    ghost_detect_position |= matrix[i];
                }
                pressed_count += tmp;
            }
        }

        if (ghost_key_detected)
            *ghost_key_detected = ghost;
            // INFO_log("ghost = %d",ghost);

        if (number_of_key_pressed)
            *number_of_key_pressed = pressed_count;
            
        if (ghost ==1){
            return 1;
        }
    }

    if(check_matrix == 0)
        return 0;


    return 1;

}

static key_update_st_t key_matrix_proc()
{
    uint8_t ghost_key_detect = 0;
    uint32_t keydown_cnt = 0;

    if (_kb_scan(_matrix_tmp, 1, &ghost_key_detect, &keydown_cnt) == 1)   // key matrix update
    {
        uint8_t i;

        if (ghost_key_detect == 1 || (keydown_cnt >= QWERTY_KEY_SZ))
        {
            // ghost key process
            ERROR_log("keydown_cnt(%d)", keydown_cnt);
            //_ghost_key_st = 1;
            return GHOST_KEY;
        }

        memcpy(_matrix, _matrix_tmp, NUM_OF_COLS);

        for (i = 0; i < NUM_OF_COLS; i++)
            _matrix_update[i] = _matrix[i] ^ _matrix_old[i];

        memcpy(_matrix_old, _matrix, NUM_OF_COLS);

        //_ghost_key_st = 0;
        return KEY_UPDATE;
    }

    return NO_KEY_UPDATE;
}


