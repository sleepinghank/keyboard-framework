#ifdef multichannel
    static uint8_t LED_DEFINITIONS[] = {ble_ch1_led, ble_ch2_led, ble_ch3_led, power_led, caps_led};
    static uint8_t LED_COUNT = 5;
#else
    static uint8_t LED_DEFINITIONS[] = {ble_ch1_led, caps_led, power_led};
    static uint8_t LED_COUNT = 3;
#endif


void LED_GpioOut(uint32_t io, gpo_value_type val)
{
    safe_led_control(io, val);
}

void LED_init(void)
{
    uint8_t i = 0;
    for(i = 0 ; i < LED_COUNT ; i++)
    {
        LED_SetState(LED_DEFINITIONS[i], LED_EXTINGUISH);
    }
}


void LED_SetState(uint8_t led, uint8_t state)
{
    if (state == LED_LIGHT) {
        LED_GpioOut(led, GPO_HIGH);
    } else if (state == LED_EXTINGUISH) {
        LED_GpioOut(led, GPO_LOW);
    }
}

void LED_SetStateN(uint8_t led, LED_status state,uint8_t flashing)
{
    safe_led_control(led, flashing + 1);
}

// 指示灯直接闪烁
void LED_flicker(void)
{
    safe_led_control(ble_ch1_led, LED_STATE_OFF);
    safe_led_control(caps_led, LED_STATE_OFF);
    safe_led_control(power_led, LED_STATE_OFF);
    safe_led_control(power_led, LED_ALL_BLINK);
}

void Check_led_ble(void)
{
    if (ble_is_connected()){
        DEBUG_log("_device_idx:%d,in LIGHT",_device_idx);
        safe_led_control(ble_ch1_led, LED_STATE_OFF);
    } else if (pairing_state_get() == 0)
    {
        DEBUG_log("_device_idx:%d,in back led",_device_idx);
        safe_led_control(ble_ch1_led, LED_STATE_SLOW_BLINK);
    }
    else{
        DEBUG_log("_device_idx:%d,in pairs led",_device_idx);
        safe_led_control(ble_ch1_led, LED_STATE_FAST_BLINK);//蓝牙灯
    }

}



void LED_power_down(void)
{
    led_control(ble_ch1_led, 0);
    led_control(caps_led, 0);
    led_control(power_led, 0);
}
