            pad_mux_write(UART_TXD, PIN_SEL_UART_TXD0); // uart
            break;
#endif
        case GPIO_CPU_RESET:
            pad_mux_write(i,PIN_SEL_GPIO);
            gpi_config(i, GPI_PULL_UP,GPI_NOT_INVERTED);
        break;
        case GPIO_NPU_RESET:
            pad_mux_write(i,PIN_SEL_GPIO);
            gpo_config(i, GPO_HIGH);
        break;
            // case NUM_LOCK_LED_GPIO:
            // case PWM_LED_GPIO:
            //     pad_mux_write(i, PIN_SEL_GPIO);
            //     gpo_config(i,LED_OFF);
            //     break;
						
        default:
            pad_mux_write(i,PIN_SEL_GPIO);
            gpi_config(i,GPI_PULL_UP,GPI_NOT_INVERTED);
            break;
        }
    }


    // gpi_config(31, GPI_PULL_UP,GPI_INVERTED);

    /* HID Key Out IO*/
    for (i = 0; i < NUM_OF_COLS; i++)
    {
        pad_mux_write(key_output_io[i], PIN_SEL_GPIO);
        gpi_config(key_output_io[i], GPI_PULL_UP,GPI_NOT_INVERTED);
        _col_io_pin_wakeup |= U32BIT(key_output_io[i]);
    }

    /* HID Key In IO*/
    for (i = 0; i < NUM_OF_ROWS; i++)
    {
        pad_mux_write(key_input_io[i], PIN_SEL_GPIO);
        gpi_config(key_input_io[i], GPI_PULL_UP,GPI_INVERTED);
        _io_pin_wakeup |= U32BIT(key_input_io[i]);
    }
    _int_gpio_pin = 0;
    _touch_pin_wakeup |= U32BIT(TOUCH_INT);
}

static void _leave_sleep(void){
    get_kb_rpt();
    _set_evt(SYS_ST, SYS_SLP_WAKEUP);
    INFO_log(("SYS_SLP_WAKEUP!!!!!!!!!!!!!!!!!!!\r\n"));
}

void _gpio_cb(void)
{
    _gpio_wakup_mode(0);

    if (_check_evt(SYS_ST, SYS_POWER_DOWN))
    {
        _clr_evt(SYS_ST, SYS_POWER_DOWN);
        _set_evt(SYS_ST, SYS_PD_WAKEUP);
    }
    else    // Leave Sleep Mode
    {
        _leave_sleep();
    }
}

void _gpio_wakup_mode(uint8_t en)
{
    uint8_t i = 0;
    if (en == 1)
    {
        for (i = 0; i < NUM_OF_COLS; i++)
        {
            pad_mux_write(key_output_io[i], PIN_SEL_GPIO);
            gpo_config(key_output_io[i], GPO_LOW);
        }
        CS_IN();
        for (i = 0; i < NUM_OF_ROWS; i++){
            uint32_t gpio_bit = U32BIT(key_input_io[i]);
            if ((_int_gpio_pin & gpio_bit) == 0) {
                gpi_enable_int(key_input_io[i], LEVEL_TRIGGER, POL_FALLING_LOW, _gpio_cb);
                _int_gpio_pin |= gpio_bit;
            }
        }

        CS_OUT();


    }
    else
    {
        for (i = 0; i < NUM_OF_COLS; i++)
        {
            pad_mux_write(key_output_io[i], PIN_SEL_GPIO);
            gpi_config(key_output_io[i], GPI_PULL_UP,GPI_NOT_INVERTED);
        }

        CS_IN();

        for (i = 0; i < NUM_OF_ROWS; i++){
            uint32_t gpio_bit = U32BIT(key_input_io[i]);
            if ((_int_gpio_pin & gpio_bit) != 0){
                gpi_disable_int(key_input_io[i]);
                _int_gpio_pin &= ~gpio_bit;
            }
        }

        CS_OUT();

    }
}

static void _col_gpio_cb(void)
{
    _col_gpio_wakup_mode(0);

    if (_check_evt(SYS_ST, SYS_POWER_DOWN))
    {
        _clr_evt(SYS_ST, SYS_POWER_DOWN);
        _set_evt(SYS_ST, SYS_PD_WAKEUP);
    }
    else    // Leave Sleep Mode
    {
        _leave_sleep();
    }
}
void _col_gpio_wakup_mode(uint8_t en)
{
    uint8_t i = 0;
    if (en == 1)
    {
        CS_IN();
        for (i = 0; i < NUM_OF_COLS; i++)
        {
            uint32_t gpio_bit = U32BIT(key_output_io[i]);
            if ((_int_gpio_pin & gpio_bit) == 0) {
                pad_mux_write(key_output_io[i], PIN_SEL_GPIO);
                gpi_config(key_output_io[i], GPI_PULL_UP,GPI_NOT_INVERTED);
                gpi_enable_int(key_output_io[i], LEVEL_TRIGGER, POL_FALLING_LOW, _col_gpio_cb);
                _int_gpio_pin |= gpio_bit;
            }
        }
        CS_OUT();


        for (i = 0; i < NUM_OF_ROWS; i++){
            pad_mux_write(key_input_io[i], PIN_SEL_GPIO);
            gpo_config(key_input_io[i], GPO_LOW);
        }

    }
    else
    {

        CS_IN();
        for (i = 0; i < NUM_OF_COLS; i++)
        {
            uint32_t gpio_bit = U32BIT(key_output_io[i]);
            if ((_int_gpio_pin & gpio_bit) != 0) {
                gpi_disable_int(key_output_io[i]);
                _int_gpio_pin &= ~gpio_bit;
            }
        }
        CS_OUT();

        for (i = 0; i < NUM_OF_ROWS; i++)
        {
            pad_mux_write(key_input_io[i], PIN_SEL_GPIO);
            gpi_config(key_input_io[i], GPI_PULL_UP,GPI_INVERTED);
        }
    }
}
