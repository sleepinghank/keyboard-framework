/* 静态全局变量声明 */
volatile uint8_t iic_cb_flag = 0;  // GPIO ISR 设置，主循环读取，必须 volatile

/* 协议配置 */
#define SLAVE_ID 0x50

/* 软件IIC配置结构体 */
struct soft_iic_config {
    int scl;           /* SCL引脚号 */
    int sda;           /* SDA引脚号 */
    uint32_t delay;    /* 延时时间 */
    uint8_t io_pu;     /* 是否启用上拉电阻 */
};

/* IIC配置实例 */
static const struct soft_iic_config soft_iic_cfg[] = {
    {
        .scl = IIC_SCL_PIN,
        .sda = IIC_SDA_PIN,
        .delay = 20,  /* 延时时间，可根据IIC速度要求调整，从5增加到17以降低速度到约10kHz */
        .io_pu = 1    /* 启用上拉电阻 */
    }
};

typedef const int soft_iic_dev;

/* GPIO操作宏定义 */
#define IIC_SCL_H(scl)    \
    gpo_config(scl, GPO_HIGH)

#define IIC_SCL_L(scl)    \
    gpo_config(scl, GPO_LOW)

#define IIC_SDA_DIR(sda, val) \
    do { \
        if (val) { \
            gpi_config(sda, GPI_PULL_UP, GPI_NOT_INVERTED); \
        } else { \
            gpo_config(sda, GPO_LOW); \
        } \
    } while(0)

#define IIC_SDA_H(sda)    \
    gpo_config(sda, GPO_HIGH)

#define IIC_SDA_L(sda)    \
    gpo_config(sda, GPO_LOW)

#define IIC_SDA_READ(sda) \
    gpi_get_val(sda)

#define iic_get_id(iic)     (iic)

/* 内部函数声明 */
static inline uint32_t iic_get_scl(soft_iic_dev iic);
static inline uint32_t iic_get_sda(soft_iic_dev iic);
static inline uint32_t iic_get_delay(soft_iic_dev iic);
static void soft_iic_start(soft_iic_dev iic);
static void soft_iic_stop(soft_iic_dev iic);
static uint8_t soft_iic_tx_byte(soft_iic_dev iic, uint8_t byte);
static uint8_t soft_iic_check_ack(soft_iic_dev iic);
static uint8_t soft_iic_rx_byte(soft_iic_dev iic, uint8_t ack);
static uint8_t soft_iic_write_reg(uint8_t reg_addr, uint8_t val);
static uint8_t soft_iic_read_reg(uint8_t reg_addr);
static void check_power_status(void);

/******************************************************************************
 * @brief 获取IIC设备的SCL引脚号
 * @param iic IIC设备标识
 * @return uint32_t SCL引脚号
 ******************************************************************************/
static inline uint32_t iic_get_scl(soft_iic_dev iic)
{
    uint8_t id = iic_get_id(iic);
    return soft_iic_cfg[id].scl;
}

/******************************************************************************
 * @brief 获取IIC设备的SDA引脚号
 * @param iic IIC设备标识
 * @return uint32_t SDA引脚号
 ******************************************************************************/
static inline uint32_t iic_get_sda(soft_iic_dev iic)
{
    uint8_t id = iic_get_id(iic);
    return soft_iic_cfg[id].sda;
}

/******************************************************************************
 * @brief 获取IIC设备的延时时间
 * @param iic IIC设备标识
 * @return uint32_t 延时时间
 ******************************************************************************/
static inline uint32_t iic_get_delay(soft_iic_dev iic)
{
    uint8_t id = iic_get_id(iic);
    return soft_iic_cfg[id].delay;
}

/******************************************************************************
 * @brief 软件IIC起始信号
 * @details 产生IIC通信的起始条件：SDA从高到低，SCL保持高
 * @param iic IIC设备标识
 * @return None
 ******************************************************************************/
static void soft_iic_start(soft_iic_dev iic)
{
    uint32_t scl, sda, dly_t;

    scl = iic_get_scl(iic);
    sda = iic_get_sda(iic);
    dly_t = iic_get_delay(iic);

    /* 确保SDA和SCL都是高电平 */
    IIC_SDA_H(sda);
    pxi_delay_us(dly_t * 2);
    IIC_SCL_H(scl);
    pxi_delay_us(dly_t * 2);

    /* 开始条件：SDA从高到低，SCL保持高 */
    IIC_SDA_L(sda);
    pxi_delay_us(dly_t * 2);

    /* 然后SCL拉低 */
    IIC_SCL_L(scl);
    pxi_delay_us(dly_t * 2);
}

/******************************************************************************
 * @brief 软件IIC停止信号
 * @details 产生IIC通信的停止条件：SDA从低到高，SCL保持高
 * @param iic IIC设备标识
 * @return None
 ******************************************************************************/
static void soft_iic_stop(soft_iic_dev iic)
{
    uint32_t scl, sda, dly_t;

    scl = iic_get_scl(iic);
    sda = iic_get_sda(iic);
    dly_t = iic_get_delay(iic);

    /* 确保SDA是低电平 */
    IIC_SDA_L(sda);
    pxi_delay_us(dly_t * 2);

    /* SCL拉高 */
    IIC_SCL_H(scl);
    pxi_delay_us(dly_t * 2);

    /* 停止条件：SDA从低到高，SCL保持高 */
    IIC_SDA_H(sda);
    pxi_delay_us(dly_t * 2);

    /* 再次确认SCL和SDA都是高电平 */
    IIC_SCL_H(scl);
    pxi_delay_us(dly_t);
    IIC_SDA_H(sda);
    pxi_delay_us(dly_t);
}

/******************************************************************************
 * @brief 软件IIC发送字节
 * @details 通过软件IIC发送一个字节数据，MSB优先
 * @param iic IIC设备标识
 * @param byte 要发送的字节数据
 * @return uint8_t 发送结果（1成功，0失败）
 ******************************************************************************/
static uint8_t soft_iic_tx_byte(soft_iic_dev iic, uint8_t byte)
{
    uint8_t i, ret;
    uint32_t scl, sda, dly_t;

    scl = iic_get_scl(iic);
    sda = iic_get_sda(iic);
    dly_t = iic_get_delay(iic);

    /* 确保SCL为低电平开始传输 */
    IIC_SCL_L(scl);
    pxi_delay_us(dly_t * 2);

    for (i = 0; i < 8; i++) {  /* MSB FIRST */
        /* 先设置SDA电平，SCL为低 */
        if ((byte << i) & 0x80) {
            IIC_SDA_H(sda);
        } else {
            IIC_SDA_L(sda);
        }
        pxi_delay_us(dly_t * 2);  /* 增加延时 */

        /* 拉高SCL，此时从机读取数据 */
        IIC_SCL_H(scl);
        pxi_delay_us(dly_t * 3);  /* 增加延时 */

        /* 拉低SCL，准备下一位数据 */
        IIC_SCL_L(scl);
        pxi_delay_us(dly_t * 2);  /* 增加延时 */
    }

    /* 释放SDA总线，准备接收ACK */
    IIC_SDA_H(sda);
    pxi_delay_us(dly_t * 2);

    /* 检查ACK */
    ret = soft_iic_check_ack(iic);

    return ret;
}

/******************************************************************************
 * @brief 软件IIC检查ACK信号
 * @details 检查从机是否发送ACK信号，支持重试机制
 * @param iic IIC设备标识
 * @return uint8_t ACK状态（1收到ACK，0未收到ACK）
 ******************************************************************************/
static uint8_t soft_iic_check_ack(soft_iic_dev iic)
{
    uint8_t ack = 0;
    uint32_t scl, sda, dly_t;
    uint8_t retry_count = 0;
    uint8_t read_val = 0;

    scl = iic_get_scl(iic);
    sda = iic_get_sda(iic);
    dly_t = iic_get_delay(iic);

    /* 设置SDA为输入模式，准备读取ACK */
    IIC_SDA_DIR(sda, 1);
    pxi_delay_us(dly_t * 2);

    /* 确保SCL为低电平 */
    IIC_SCL_L(scl);
    pxi_delay_us(dly_t * 2);

    /* 拉高SCL，读取ACK */
    IIC_SCL_H(scl);
    pxi_delay_us(dly_t * 2);

    /* 读取SDA状态，如果为低电平则表示ACK */
    read_val = IIC_SDA_READ(sda);
    ack = (read_val == 0) ? 1 : 0;

    /* 如果没有收到ACK，尝试等待一段时间再次读取（有些设备ACK可能会延迟） */
    if (!ack) {
        /* 多次尝试读取ACK */
        for (retry_count = 0; retry_count < 5; retry_count++) {
            pxi_delay_us(dly_t);
            read_val = IIC_SDA_READ(sda);
            if (read_val == 0) {
                ack = 1;
                break;
            }
        }
    }

    /* 延时确保ACK信号稳定 */
    pxi_delay_us(dly_t * 2);

    /* 拉低SCL，完成ACK周期 */
    IIC_SCL_L(scl);
    pxi_delay_us(dly_t * 2);

    /* 设置SDA为输出模式，准备下一个字节 */
    IIC_SDA_DIR(sda, 0);

    /* 拉低SDA，准备下一个操作 */
    IIC_SDA_L(sda);
    pxi_delay_us(dly_t * 2);

    if (!ack) {
        // DEBUG_log("soft_iic_check_ack: no ACK received\n");
    }

    return ack;
}

/******************************************************************************
 * @brief 软件IIC接收字节
 * @details 通过软件IIC接收一个字节数据，并发送ACK/NACK
 * @param iic IIC设备标识
 * @param ack 是否发送ACK（1发送ACK，0发送NACK）
 * @return uint8_t 接收到的字节数据
 ******************************************************************************/
static uint8_t soft_iic_rx_byte(soft_iic_dev iic, uint8_t ack)
{
    uint8_t byte = 0, i;
    uint32_t scl, sda, dly_t;

    scl = iic_get_scl(iic);
    sda = iic_get_sda(iic);
    dly_t = iic_get_delay(iic);

    /* 设置SDA为输入模式，准备读取数据 */
    IIC_SDA_DIR(sda, 1);
    pxi_delay_us(dly_t * 2);

    /* 确保SCL为低电平 */
    IIC_SCL_L(scl);
    pxi_delay_us(dly_t * 2);

    for (i = 0; i < 8; i++) {
        /* 拉高SCL，准备读取数据 */
        IIC_SCL_H(scl);
        pxi_delay_us(dly_t * 2);

        /* 读取数据位 */
        byte = byte << 1;
        if (IIC_SDA_READ(sda)) {
            byte |= 1;
        }
        pxi_delay_us(dly_t * 2);

        /* 拉低SCL，准备下一位数据 */
        IIC_SCL_L(scl);
        pxi_delay_us(dly_t * 2);
    }

    /* 设置SDA为输出模式，准备发送ACK/NACK */
    IIC_SDA_DIR(sda, 0);
    pxi_delay_us(dly_t);

    if (ack) {
        /* 发送ACK（SDA低电平） */
        IIC_SDA_L(sda);
    } else {
        /* 发送NACK（SDA高电平） */
        IIC_SDA_H(sda);
    }
    pxi_delay_us(dly_t * 2);

    /* 拉高SCL，从机读取ACK/NACK */
    IIC_SCL_H(scl);
    pxi_delay_us(dly_t * 3);

    /* 拉低SCL，完成ACK/NACK周期 */
    IIC_SCL_L(scl);
    pxi_delay_us(dly_t * 2);

    /* 拉低SDA，准备下一个操作 */
    IIC_SDA_L(sda);
    pxi_delay_us(dly_t);

    return byte;
}

/******************************************************************************
 * @brief 软件IIC写寄存器
 * @details 通过软件IIC向指定寄存器写入数据，支持重试机制
 * @param reg_addr 寄存器地址
 * @param val 要写入的值
 * @return None
 ******************************************************************************/
static uint8_t soft_iic_write_reg(uint8_t reg_addr, uint8_t val)
{
    uint8_t retry_count = 0;
    uint8_t success = 0;

    // // DEBUG_log("soft_iic_write_reg: setting val to %d\n", val);

    pad_mux_write(IIC_SCL_PIN, PIN_SEL_GPIO);
    pad_mux_write(IIC_SDA_PIN, PIN_SEL_GPIO);

    /* 临时使用软件IIC控制触摸使能，最多尝试5次 */
    while (retry_count < 5 && !success) {
        /* 配置为输出模式并确保引脚为高电平 */
        gpo_config(IIC_SCL_PIN, GPO_HIGH);
        gpo_config(IIC_SDA_PIN, GPO_HIGH);
        pxi_delay_ms(2);

        /* 尝试写入触摸使能寄存器 */
        soft_iic_start(0);
        pxi_delay_us(20);  /* 额外延时 */

        if (soft_iic_tx_byte(0, SLAVE_ID << 1)) {
            pxi_delay_us(20);  /* 额外延时 */

            if (soft_iic_tx_byte(0, reg_addr)) {
                pxi_delay_us(20);  /* 额外延时 */

                if (soft_iic_tx_byte(0, val)) {
                    success = 1;
                }
            }
        }

        pxi_delay_us(20);  /* 额外延时 */
        soft_iic_stop(0);
        pxi_delay_ms(2);  /* 额外延时 */

        if (success) {
            // // DEBUG_log("soft_iic_write_reg: set val to %d success\n", val);
            break;
        }

        // // DEBUG_log("soft_iic_write_reg: retry %d\n", retry_count);
        retry_count++;
        pxi_delay_ms(2);  /* 增加重试间隔 */
    }
    
    return success;
    // if (!success) {
    //     // // DEBUG_log("soft_iic_write_reg: failed after %d retries\n", retry_count);
    // }
}

/******************************************************************************
 * @brief 软件IIC读寄存器
 * @details 通过软件IIC从指定寄存器读取数据，支持重试机制
 * @param reg_addr 寄存器地址
 * @return uint8_t 读取到的寄存器值
 ******************************************************************************/
static uint8_t soft_iic_read_reg(uint8_t reg_addr)
{
    uint8_t success = 0;
    uint8_t retry_count = 0;
    uint8_t reg_value = 0;

    /* 配置为输出模式并确保引脚为高电平 */
    pad_mux_write(IIC_SCL_PIN, PIN_SEL_GPIO);
    pad_mux_write(IIC_SDA_PIN, PIN_SEL_GPIO);

    while (retry_count < 3 && !success) {
        gpo_config(IIC_SCL_PIN, GPO_HIGH);
        gpo_config(IIC_SDA_PIN, GPO_HIGH);
        //pxi_delay_ms(2);

        soft_iic_start(0);

        if (soft_iic_tx_byte(0, SLAVE_ID << 1)) {

            if (soft_iic_tx_byte(0, reg_addr)) {

                soft_iic_start(0);

                if (soft_iic_tx_byte(0, (SLAVE_ID << 1) | 0x01)) {
                    reg_value = soft_iic_rx_byte(0, 0);
                    success = 1;
                }
            }
        }
        soft_iic_stop(0);
        //pxi_delay_ms(2);

        if (success) {
            // // DEBUG_log("soft_iic_read_reg: get val to %d success\n", reg_value);
            break;
        }

        // // DEBUG_log("soft_iic_read_reg: retry %d\n", retry_count);
        retry_count++;

        // if (!success) {
        //     // // DEBUG_log("soft_iic_read_reg: failed after %d retries\n", retry_count);
        //     retry_count++;
        // }
    }

    return reg_value;
}

/******************************************************************************
 * @brief LED控制函数
 * @details 根据索引控制对应的LED，支持BLE、CAPS、POWER、CHARGE四种LED
 * @param index LED索引（0-3）
 * @param led_value LED控制值
 * @return None
 ******************************************************************************/
uint8_t led_control(uint8_t index, uint8_t led_value)
{
    uint8_t reg_addr = 0;
    uint8_t temp_success = 0;
    /* 参数检查 */
    if (index > 3) {
        // DEBUG_log("led_control: invalid index %d\n", index);
        return 0;
    }

    /* 根据索引选择对应的寄存器地址 */
    switch (index) {
    case 0:
        reg_addr = REG_BLE_LED;
        break;
    case 1:
        reg_addr = REG_CAPS_LED;
        break;
    case 2:
        reg_addr = REG_POWER_LED;
        break;
    case 3:
        reg_addr = REG_CHARGE_LED;
        break;
    default:
        return 0; /* 无效索引 */
    }

    // DEBUG_log("led_control: reg_addr = %d, led_value = %d\n", reg_addr, led_value);
    temp_success = soft_iic_write_reg(reg_addr, led_value);
    return temp_success;
}

