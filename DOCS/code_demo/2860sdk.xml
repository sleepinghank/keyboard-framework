#define OTA_FIRST_MAX_CONN_INTERVAL                                 6              /* 最大连接间隔 (12*1.25ms = 15 ms). */
#define OTA_FIRST_SLAVE_LATENCY                                     6              /* 从属延迟*/
#define OTA_FIRST_CONN_SUP_TIMEOUT                                  200             /* 连接监控超时(300*10ms = 3000ms)*/


#endif

