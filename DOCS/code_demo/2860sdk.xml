<file path="PAR2860/comm/ext_mcu_comm.c">
/**
 * @file cmd_iic.c
 * @brief IIC通信控制模块实现文件
 * @details 该模块负责软件IIC通信、LED控制、触摸控制、RGB控制、电池查询等功能
 * @author Ada
 * @date 2025-09-02
 * @version 1.0
