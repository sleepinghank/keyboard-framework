#ifndef INATECK_ORIGIN_H
#define INATECK_ORIGIN_H

#include "ARMCM0.h"

//---------------------------------------------------------指令表---------------------------------------------------------//
#define ORIGIN_CMD_TOP_LEVEL                               0x82 // 顶层指令

#define ORIGIN_CMD_CHANGE_INDEX                            0x10  // 切换到对应通道
#define ORIGIN_CMD_SERIAL_NUMBER                           0x12  // 读取设备全部信息 并写入唯一标识号
#define ORIGIN_CMD_READ_MOUSE_MOVE                         0x16  // 检测鼠标是否在移动

#define ORIGIN_CMD_NOTIFY_HOT_KEY                          0x18 // 鼠标热键监听
//------------------------------------------------------------END------------------------------------------------------------//

// 设备类型 用于判断设备是否支持move功能
enum _Origin_DeviceType_
{
    Keyboard = 0x01,
    Mouse,
    Touchpad,
    MulKeyboardTouchpad,
};

// origin 设备唯一标识号内存存储地址 len：17
#define ORIGIN_UUID_ADDRESS                                 0x410
typedef struct OriginCmdReq 
{
    uint8_t cmd;         //命令码
    uint8_t sub_cmd; // 子命令
    union {
        uint8_t channel;         //通道号
        uint8_t serial_number[16];   //uuid 序列号
    } u;
} origin_cmd_req;

typedef struct OriginCmdResp 
{
    uint8_t cmd;         //命令码
    uint8_t sub_cmd; // 子命令
    uint8_t error_code; // 错误码
    union {
        uint8_t device_info[46];         //设备信息
        uint8_t is_moved;   //是否移动
        uint8_t hot_key_code;   //热键码值
    } u;
}origin_cmd_resp;


typedef struct _INIT_DEVICE {
    uint8_t valid;
    uint8_t identifier[10];
    uint8_t serial_number[16];
    uint8_t device_type;
    uint8_t channel;
    uint8_t power;
    uint8_t device_name[16];
} INIT_DEVICE, *IINIT_DEVICE;

// 兼容之前的设备
static const uint8_t MX[10] = {105,110,97,116,101,99,107,32,109,120}; // inateck mx

/// @brief 消息处理函数
/// @param * p_cmd 命令指针
/// @param sz 命令数据大小
void _Origin_Command_Processor(uint8_t* p_cmd, uint16_t sz);
/// @brief 检查是否有返回数据
/// @return 1：有返回数据 0：没有返回数据
uint8_t _Origin_Command_Check(void);
/// @brief 获取返回数据
/// @param * p_rsp 返回数据指针
/// @param * p_sz 返回数据大小
void _Origin_Rsp(uint8_t* p_rsp, uint8_t* p_sz);
/// @brief 初始化
void _Origin_init(void);
#endif //INATECK_ORIGIN_H
