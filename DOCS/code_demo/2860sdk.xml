static void del_combo_keys(const uint16_t *keys) {
    uint8_t key_count = 0;
    while (true) {
        uint16_t key = pgm_read_word(&keys[key_count]);
        if (COMBO_END == key) break;
        deactivate(key, _key_code_list);
        key_count++;
    }
}


void combo_init(void){
    uint8_t u8temp;
    for (u8temp = 0; u8temp < number_of_combos; ++u8temp) {
        combo_t *combo = &key_combos[u8temp];
        uint8_t  key_count = 0;
        uint16_t key_index = 65535;
        _find_key_index_and_count(combo->keys, S_FN_KEY, &key_index, &key_count);
        // 存在Fn键 并且按键数量大于1，即为fn组合键
        if ((65535 != key_index)&& key_count > 1)
        {
            combo -> fn_combo = 1;
            
//            DEBUG_log("··········································fn_combo = %d",combo->fn_combo);
        }
        
    }
}

//是否有键盘组合触发了事件
uint8_t active_event = 0;
//是否有 Fn 组合键被激活
uint8_t active_fn_combo = 0;
// 按键事件处理
// 1. 循环key_combos，从_key_code_list中判断是否满足组合键条件
// 2. 满足函数进行按键状态机处理，判断满足状态的事件
// 3. 满足事件后，调用回调函数，从_key_code_list中删除组合键，添加新增的键。
void combo_task(key_update_st_t _keyUpdateSt){
    uint8_t u8temp ;
    uint16_t buf[10] = {0};
    
    if (_keyUpdateSt == GHOST_KEY){
        DEBUG_log("GHOST_KEY");
        return;
    }
    // 清空所有扩展键
    del_all_child(_key_code_list_extend);
    active_event = 0;
    active_fn_combo = 0;
    // 循环所有事件，逐个进行处理
    for (u8temp = 0; u8temp < number_of_combos; ++u8temp) {
        combo_t *combo = &key_combos[u8temp];
        if (combo -> system_type != ALL_SYSTEM){
            // 判断当前系统不触发，直接跳过
            //DEBUG_log("ccombo -> system_type = %d",combo -> system_type);
            if ((combo -> system_type  & keycode_type)== 0) continue;
        }
        // 判断是否触发组合
        apply_combo(u8temp, combo);
        // 按键状态机处理
        button_ticks(combo);

        if (combo -> f1_flag == 1 && combo->event < number_of_event ){
            // 为F1 - F12 特殊键，需要区分 是发功能键还是 F1-F12,如果是发F1-F12 直接不触发事件跳出。
            if (keycode_type == WINDOWS){
							#ifdef FN_LOCK
                if(KeyboardConfig.FN_Lock_flag[_device_idx] == 1 && FN_st == 1){
                    //发F1-F12 默认键码
                    active_fn_combo = 1;
                    continue;
                }
                if ((FN_st == 0 && KeyboardConfig.FN_Lock_flag[_device_idx] == 0) ){
                    continue;
                }
							#endif	
            } else {
                // 只要按下了Fn + F1-F12，就不触发事件
                if (FN_st == 1){
                    active_fn_combo = 1;
                    continue;
                }
            }
        }

        // 判断是否执行事件
        if (combo->event < number_of_event  && combo->cb[combo->event]) {
            //DEBUG_log("combo idx:%d,combo->event = %d",u8temp,combo->event);
            // 事件触发,通知添加新的键
            active_event = 1;
            // 先删除组合键，删除的组合键不再上报，但是还是可以组成组合键
            del_combo_keys(combo->keys);
            // 添加新的键
            add_combo_result(combo,buf);
            // 重置组合键状态
            combo->event = (uint8_t)NONE_PRESS;
        } else if(combo -> active_status == 1) {
            // 组合键激活，但是没有事件，删除组合键
            del_combo_keys(combo->keys);
        }
        if (combo -> active_status == 1 && (combo -> f1_flag == 1|| combo -> fn_combo ==1)){
            active_fn_combo = 1;
        }
    }

    // 全功能Fn，需要判断Fn自定义组合是否触发，触发后，设置combinations_flag。
    if (active_fn_combo == 1)
    {
        combinations_flag = 0;
        // DEBUG_log("......................................combinations_flag = %d",combinations_flag);
    }

}
