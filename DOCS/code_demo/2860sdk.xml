        add_keys[idx++] = KB_S;
    }
    else
    {
        #ifdef INATECK_ORIGIN_ENABLE
        // 热键监听  翻译快捷键
        uint8_t resp[4] = {0x82,0x18,0,0x01};
        ble_tx_data(INATECK_OTA_READ_WRITE_IDX,4, resp);
        #endif
    }
    return idx;
}

static uint8_t voice_assistant(uint16_t* add_keys)
{
    uint8_t idx = 0;
    if(keycode_type == IOS)
    {
        add_keys[idx++] = M_EARTH;
        add_keys[idx++] = KB_S;
    } else if (keycode_type == WINDOWS)
    {
        add_keys[idx++] = KB_L_GUI;
        add_keys[idx++] = KB_H;
    }

    return idx;
}

KeyHandlerFunc func_handlers[FUNC_COUNT] = {
    [DEFAULT_FUNC] = voice_assistant,
    [EVOKE_SIRI] = voice_assistant,
    [BACK_MAINSCREEN] = back_home_screen,
    [APP_SWITCH] = Multi_Task,
    [LOCK_SCREEN] = Lock_Screen3,
    [SEARCH_FUNC] = Search,
    [SCREEN_SHOT] = Print_Screen,
    [COPY_FUNC] = text_copy,
    [PASTE_FUNC] = text_paste,
    [CUT_FUNC] = text_cut,
    [PAUSE_FUNC] = Media_Play_Pause,
    [SILENT_FUNC] = Volume_Mute,
    [BRIGHTNESS_UP] = Bringhness_Up,
    [BRIGHTNESS_DOWN] = Bringhness_Down,
    [PREVIOUS_PAGE] = previous_page,
    [NEXT_PAGE] = next_page,
    [VOLUME_UP] = Volume_Up,
    [VOLUME_DOWN] = Volume_Down,
    [PREVIOUS_ONE] = Media_Previous,
    [NEXT_ONE] = Media_Next,
};

uint8_t Customize_button(uint16_t* add_keys)
{
    uint8_t bit = SystemConfig.ai_key_func_idx & 0x80;
    uint8_t index = SystemConfig.ai_key_func_idx & 0x7F; // 取低7位
    // DEBUG_log("SystemConfig.ai_key_func_idx:%d",SystemConfig.ai_key_func_idx);

    // DEBUG_log("customize BIT:%d,index = %d\r\n",bit, index);
    if(keycode_type != IOS)
    {
        return AI_button(add_keys);
    }
    if (index >= FUNC_COUNT)
    {
        DEBUG_log("customize index Invalid!!!\r\n");
        return false;
    }

    if (bit == 0)
    {
        index = 0;
    }
    if (index >= FUNC_COUNT)
    {
        DEBUG_log("customize index Invalid!!!\r\n");
        return false;
    }
    KeyHandlerFunc handler = func_handlers[index];

    return handler(add_keys);
}
