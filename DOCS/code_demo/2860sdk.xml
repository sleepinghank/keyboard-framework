/// @brief 触摸板写入数据
/// @param addr 写入的寄存器地址
/// @param val 数据
/// @return 1：写入成功 0：写入失败
static uint8_t pct1336_write_reg(uint16_t addr, uint8_t val)
{
    return i2c_master_write_addr_data((i2c_module)0,TOUCH_SLAVE_ID,I2C_MASTER_1BYTE_ADDRESS,addr,&val,0x01);
}
/// @brief 触摸板读取数据
/// @param *p_val 数据指针
/// @return 1：读取成功 0：读取失败
static uint8_t pct1336_read_reg(uint16_t addr, uint8_t * p_val)
{
    return i2c_master_combined_write_read((i2c_module)0,TOUCH_SLAVE_ID,I2C_MASTER_1BYTE_ADDRESS,addr,p_val,0x01);
}
/// @brief 触摸板数据连续读
/// @param addr 读取的寄存器地址
/// @param *p_val 数据指针
/// @param sz 读取数据长度
/// @return 1：读取成功 0：读取失败
static uint8_t pct1336_PTP_read_reg(uint16_t addr, uint8_t * p_val, uint8_t sz)
{
    return i2c_master_combined_write_read((i2c_module)0,TOUCH_SLAVE_ID,I2C_MASTER_1BYTE_ADDRESS,addr,p_val,sz);
}
/// @brief 触摸板写入用户寄存器数据
/// @param bank 访问的bank编号
/// @param addr bank中操作的地址
/// @param val 数据
/// @return 1：写入成功 0：写入失败
int8_t pct1336_write_user_reg(uint8_t bank, uint16_t addr, uint8_t val)
{
	pct1336_write_reg(0x7f,0x06);
    pxi_delay_us(500);
	pct1336_write_reg(0x73,bank);
	pxi_delay_us(500);
	pct1336_write_reg(0x74,addr);
	pxi_delay_us(500);
	pct1336_write_reg(0x75,val);
	pxi_delay_us(500);
	return 1;
}
/// @brief 触摸板读取用户寄存器数据
/// @param bank 访问的bank编号
/// @param addr bank中操作的地址
/// @param * p_val 数据指针
/// @return 1：读取成功 0：读取失败
int8_t pct1336_read_user_reg(uint8_t bank, uint16_t addr, uint8_t * p_val)
{
	pct1336_write_reg(0x7f,0x06);
    pxi_delay_us(500);
	pct1336_write_reg(0x73,bank);
	pxi_delay_us(500);
	pct1336_write_reg(0x74,addr);
	pxi_delay_us(500);
	pct1336_read_reg(0x75, p_val);	
	pxi_delay_us(500);
	return 1;
}

/// @brief 通过INT_LEVEL_CTRL 寄存器检查中断电平状态，判断触控芯片是否正常启动
