#ifndef _DEBUG_LOG_H_
#define _DEBUG_LOG_H_

#include "ARMCM0.h"
#include "debug.h"
#include "config.h"
//---------------------------------------------------------日志输出---------------------------------------------------------//

#define Assert 0     //断言
#define Error  1     //错误
#define Warn   2     //警告
#define Info   3     //信息
#define Debug  4     //调试

#ifdef CONFIG_UART_ENABLE
  //LOG输出等级
#define _OTA_DEBUG_GRADE_ Debug
#else 
#define _OTA_DEBUG_GRADE_  Assert
#endif



//(错误)系统出现问题，需要修复
#if(_OTA_DEBUG_GRADE_ >= Error)
    #define ERROR_log(FMT, ARGS...)    {dbg_printf_sel(DBG_UART_ID,"\r\nERROR:"); dbg_printf_sel(DBG_UART_ID, FMT, ##ARGS);}
    #define ERROR_hex(STR,FMT, ARG)    dbg_hexdump(STR,FMT,ARG)
#else
    #define ERROR_log(...)
    #define ERROR_hex(STR,FMT, ARG)
#endif

