/**
 * @file timer_count.c
 * @brief 轻量级计时器 API 实现
 * @author hank
 * @date 2024
 *
 * @note 此模块封装 timer_task 的 timer_get_system_ms()，提供类似 QMK 的简单计时 API。
 *       用于需要测量时间间隔或检查超时的场景。
 *
 * 使用示例：
 * @code
 * // 测量代码执行时间
 * uint16_t start = timer_read();
 * some_operation();
 * uint16_t elapsed = timer_elapsed(start);  // 获取耗时(ms)
 *
 * // 检查超时
 * uint32_t start32 = timer_read32();
 * while (!condition) {
 *     if (timer_elapsed32(start32) > 5000) {
 *         // 超过 5 秒超时
 *         break;
 *     }
 * }
 * @endcode
 */

#include "timer_count.h"
#include "timer_task.h"

/* ============================ 公共 API ============================ */

/**
 * @brief 读取当前时间 (16 位)
 * @return 当前时间 (ms)，范围 0-65535
 * @note 16 位计数器约 65 秒溢出，适用于短时间测量
 */
uint16_t timer_read(void) {
    return (uint16_t)timer_get_system_ms();
}

/**
 * @brief 读取当前时间 (32 位)
 * @return 当前时间 (ms)，范围 0-4294967295
 * @note 32 位计数器约 49.7 天溢出，适用于长时间测量
 */
uint32_t timer_read32(void) {
    return timer_get_system_ms();
}

/**
 * @brief 计算从 last 到现在的时间差 (16 位)
 * @param last 起始时间点 (由 timer_read() 获取)
 * @return 经过的时间 (ms)，自动处理溢出
 * @note 使用无符号减法自动处理 16 位溢出
 *       适用于 < 32 秒的时间差测量
 */
uint16_t timer_elapsed(uint16_t last) {
    return TIMER_DIFF_16(timer_read(), last);
}

/**
 * @brief 计算从 last 到现在的时间差 (32 位)
 * @param last 起始时间点 (由 timer_read32() 获取)
 * @return 经过的时间 (ms)，自动处理溢出
 * @note 使用无符号减法自动处理 32 位溢出
 *       适用于长时间差测量
 */
uint32_t timer_elapsed32(uint32_t last) {
    return TIMER_DIFF_32(timer_read32(), last);
}

/* ============================ 文件结束 ============================ */
</file>

