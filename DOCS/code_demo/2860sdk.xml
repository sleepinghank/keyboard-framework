        size = 6;

    _misc_ctrl->SS_BURST_NUM = size;

    for (i = 0; i < size; i++)
        _misc_ctrl->SS_ADDR[i] = addr[i];


    _misc_ctrl->SS_BURST_READ = 1;

    while (_misc_ctrl->SS_BURST_READ == 1);

    for (i = 0; i < size; i++)
        data[i] = _misc_ctrl->SS_DATA[i];

