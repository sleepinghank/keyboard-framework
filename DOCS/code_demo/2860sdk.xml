#define ATT_C_CB_LEN (512 + 6)
static uint8_t _att_c_cb[ATT_C_CB_LEN]; //include cb,sz
static uint32_t _cb_write_available;
static uint32_t _cb_read_available;
static uint32_t _cb_write_index = 0;
static uint32_t _cb_read_index = 0;
volatile uint8_t _att_c_ongoing = 0;
volatile uint8_t _att_c_start = 0;

ATT_C_RSP_CALLBACK _att_c_cbfunc;
ATT_C_UNSOLICITED_CALLBACK _att_c_unlicited_cbfunc;

uint8_t att_c_request_execute(uint8_t* pbuf, uint16_t sz);
static void cb_init(void);
static void att_c_evt_handler(struct attc_ble_evt* p_attc);
void att_c_transation_timeout(void* c);




void att_c_transation_timeout(void* c)
{
    DBGPRINTF(("att_c_transation_timeout\r\n"));
    ble_disconnect();
    //pxi_pmu_system_reset();
}


void att_c_start()
{
    cb_init();
    _att_c_start = 1;

    pxi_att_c_set_callback(att_c_evt_handler);
}

void att_c_stop()
{
    cb_init();
    _att_c_start = 0;

    pxi_att_c_set_callback(NULL);
}

static void cb_init()
{
    memset(_att_c_cb, 0x00, ATT_C_CB_LEN);
    _cb_write_available = ATT_C_CB_LEN;
    _cb_read_available = 0;
    _cb_write_index = 0;
    _cb_read_index = 0;
    _att_c_unlicited_cbfunc  = NULL;
    _att_c_cbfunc = NULL;
    _att_c_ongoing = 0;

}

static uint32_t cb_is_full(void)
{
    return (_cb_write_available == 0);
}

static uint32_t cb_is_empty(void)
{
    return (_cb_read_available == 0);
}

static uint32_t cb_size(void)
{
    return _cb_write_available;
}

static uint32_t cb_write(uint8_t* p_data, uint16_t len)
{
    uint32_t remaining_data;

    if (cb_is_full())
    {
        DBGPRINTF(("cb_write_full0\r\n"));
        return 0;
    }

    if (cb_size() < (len + 2))
    {
        DBGPRINTF(("cb_write_full1\r\n"));
        return 0;
    }

    remaining_data = ATT_C_CB_LEN - _cb_write_index;

  
    if ((len + 2) > remaining_data)
    {

        if (remaining_data == 1)
        {
            _att_c_cb[_cb_write_index] = (len >> 8) & 0xFF;
            _att_c_cb[0] = (len >> 0) & 0xFF;
            memcpy(&(_att_c_cb[1]), p_data, len);
        }
        else if (remaining_data >= 2)
        {
            _att_c_cb[_cb_write_index] = (len >> 8) & 0xFF;
            _att_c_cb[_cb_write_index + 1] = (len >> 0) & 0xFF;
            memcpy(&(_att_c_cb[_cb_write_index + 2]), p_data, (remaining_data - 2));
            memcpy(_att_c_cb, p_data + (remaining_data - 2), (len - remaining_data + 2));
        }

    }
    else
    {
        _att_c_cb[_cb_write_index] = (len >> 8) & 0xFF;
        _att_c_cb[_cb_write_index + 1] = (len >> 0) & 0xFF;
        memcpy(&(_att_c_cb[_cb_write_index + 2]), p_data, len);
    }

    _cb_write_index = (_cb_write_index + len + 2) % ATT_C_CB_LEN;

    _cb_write_available -= (len + 2);
    _cb_read_available += (len + 2);

    //DBGPRINTF(("cb_write=%x,%x,%x\r\n", _cb_write_available, _cb_read_available, len));
    pxi_pmu_vote_not_sleep();


    return 1;
}

static uint32_t cb_read(ATT_C_RSP_CALLBACK* cb)//(uint8_t* p_data, uint32_t* p_len)
{
    uint16_t remaining_data;
    uint8_t* p_data = NULL;
    uint16_t len_total;
    uint8_t ret = 0;

    if (cb_is_empty())

    {
        return 0;
    }


    len_total = (_att_c_cb[_cb_read_index] << 8) | (_att_c_cb[(_cb_read_index + 1) % ATT_C_CB_LEN]);

    p_data = (uint8_t*)malloc(len_total);

    if (p_data == NULL)
    {
        DBGPRINTF(("heap size is not enough\r\n"));
        return 0;
    }


    remaining_data = ATT_C_CB_LEN - _cb_read_index;

    if ((len_total + 2) > remaining_data)
    {
        if (remaining_data == 1)
        {
            memcpy(p_data, &_att_c_cb[1], len_total);
        }
        else
        {
            memcpy(p_data, &(_att_c_cb[_cb_read_index + 2]), (remaining_data - 2));
            memcpy(p_data + (remaining_data - 2), _att_c_cb, (len_total - remaining_data + 2));
        }

    }
    else

    {
        memcpy(p_data, &(_att_c_cb[_cb_read_index + 2]), len_total);
    }

    memcpy(cb, p_data, 4);

    if (att_c_request_execute(&p_data[4], len_total - 4)) //do pxi attc
    {
        _cb_read_index = (_cb_read_index + len_total + 2) % ATT_C_CB_LEN;

        _cb_write_available += (len_total + 2);
        _cb_read_available -= (len_total + 2);

        ret = 1;
    }


    free(p_data);
    return ret;
}





static uint8_t att_c_request_execute(uint8_t* pbuf, uint16_t sz)
{
    uint8_t op;
    uint8_t ret = 0;
    op = pbuf[0];


    switch (op)
    {
        case ATT_MTU_REQ:
            DBGPRINTF(("ATT_MTU_REQ:%d\r\n",(pbuf[2] << 8 | pbuf[1])));
            ret = pxi_att_c_mtu_req((pbuf[2] << 8 | pbuf[1]));
            break;

        case ATT_FIND_INFO_REQ:
            ret = pxi_att_c_find_info_req((pbuf[2] << 8 | pbuf[1]), (pbuf[4] << 8 | pbuf[3]));
            break;

        case ATT_FIND_BY_TYPE_VALUE_REQ:
            ret = pxi_att_c_find_by_type_value_req((pbuf[2] << 8 | pbuf[1]), (pbuf[4] << 8 | pbuf[3]), (pbuf[6] << 8 | pbuf[5]), sz - 7, (&pbuf[7]));
            break;

        case ATT_READ_BY_TYPE_REQ:
            ret = pxi_att_c_read_by_type_req((pbuf[2] << 8 | pbuf[1]), (pbuf[4] << 8 | pbuf[3]), sz - 5, (&pbuf[5]));
            break;

        case ATT_READ_REQ:
            ret = pxi_att_c_read_req((pbuf[2] << 8 | pbuf[1]));
            break;

        case ATT_READ_BLOB_REQ:
            ret = pxi_att_c_read_blob_req((pbuf[2] << 8 | pbuf[1]), (pbuf[4] << 8 | pbuf[3]));
            break;

        case ATT_READ_MULTIPLE_REQ:
            ret = pxi_att_c_read_multiple_req(sz - 1, &(pbuf[1]));
            break;

        case ATT_READ_BY_GROUP_TYPE_REQ:
            ret = pxi_att_c_read_by_group_type_req((pbuf[2] << 8 | pbuf[1]), (pbuf[4] << 8 | pbuf[3]), sz - 5, (&pbuf[5]));
            break;

        case ATT_WRITE_REQ:
            ret = pxi_att_c_write_req((pbuf[2] << 8 | pbuf[1]), sz - 3, (&pbuf[3]));
            break;

        case ATT_PREPARE_WRITE_REQ:
            ret = pxi_att_c_prepare_write_req((pbuf[2] << 8 | pbuf[1]), (pbuf[4] << 8 | pbuf[3]), sz - 5, (&pbuf[5]));
            break;

        case ATT_EXECUTE_WRITE_REQ:
            ret = pxi_att_c_execute_write_req(pbuf[1]);
            break;
    }


    return ret;

}




static void att_c_evt_handler(struct attc_ble_evt* p_attc)
{

    uint8_t ret = 0;

    if ((p_attc->attc_code == ATT_HANDLE_VAL_NOTIFICATION) || (p_attc->attc_code == ATT_HANDLE_VAL_INDICATION))
    {
        //dispatch to coresponding handler
        if (_att_c_unlicited_cbfunc != NULL)
        {
            ret = _att_c_unlicited_cbfunc(p_attc);
        }

        if (ret == 0 && (p_attc->attc_code == ATT_HANDLE_VAL_INDICATION))
        {
            att_c_confirmation();
        }


    }
    else
    {

        if (_att_c_ongoing == 1)
        {


            if (_att_c_cbfunc != NULL)
            {
                _att_c_cbfunc(p_attc); //dispatch to data owner
                _att_c_cbfunc = 0;
            }

            _att_c_ongoing = 0;

        }
    }

    pxi_pmu_vote_not_sleep();
}




void att_c_request_push(void)
{
    ATT_C_RSP_CALLBACK _cb;


    if (_att_c_start == 0)
    {
        return;
    }

    CS_IN();

    if (_att_c_ongoing == 0 )
    {


        if (cb_read(&_cb))
        {

            _att_c_ongoing = 1;
            _att_c_cbfunc = _cb;


        }
    }

    CS_OUT();

}


