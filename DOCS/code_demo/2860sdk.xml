// #if TCFG_TOUCHPAD_ENABLE
// 计算特征的数学值
double* compute(double features[N_FEATURES]){
    static double likelihoods[N_FEATURES];
    int i = 0;
    int j = 0;
    double nij;
    for (i = 0; i < N_FEATURES; ++i) {
        double sum = 0.;
        for (j = 0; j < N_FEATURES; ++j) {
            sum +=log(2. * M_PI * sigmas[i][j]);
        }
        nij = -0.5 * sum;
        sum = 0.;
        for (j = 0; j < N_FEATURES; ++j) {
            sum += pow(features[j] - thetas[i][j], 2.) / sigmas[i][j];
        }
        nij -= 0.5*sum;
        likelihoods[i] = log(priors[i]) + nij;
    }
    return likelihoods;
}

// 寻找明确的特征分类
static int findMax(double nums[]) {
    int idx = 0;
    int i = 0;
    for (i = 0; i < N_FEATURES; ++i) {
        idx = nums[i] > nums[idx] ? i : idx;
    }
    return idx;
}

static double logSumExp(double nums[]){
    double max = nums[findMax(nums)];
    double sum = 0.;
    int i = 0 , il = N_FEATURES;
    for (i = 0 , il = N_FEATURES; i < il; i++) {
        sum += exp(nums[i] - max);
    }
    return max - log(sum);
}

