#include "backlight.h"
#include "config.h"
#include "pwm.h"
#include "gpio.h"
#include "debug.h"
#include "debug_log.h"
#include "storage.h"
#include "battery.h"
#include "ext_mcu_comm.h"
#include "sleep.h"
#include "timer_event.h"

//背光灯初始化
void backlight_init(void)
{
    safe_set_rgb_brightness(KeyboardConfig.backlight_brightness);
    safe_set_rgb_color(KeyboardConfig.backlight_color);
    _backlight_flag = 1;
}

// 开机/唤醒后首次电量有效时尝试亮起背光（仅执行一次）
void backlight_init_once(void)
{
    if(is_bat_level_valid() && get_battery_level() >= GPADC_ADC_LOW_BATTERY && \
        KeyboardConfig.backlight_brightness != BACKLIGHT_OFF && \
        _backlight_flag == 0)
    {
        backlight_init();
        reset_backlight_timeout();
    }
}


void backlight_reset(void)
{
    if(_backlight_flag == 0){
        backlight_init();
    }
}

//背光灯反初始化
void backlight_disable(void)
{
    INFO_log("\r\n--------------------Backlight_Disable");

    /* RGB模式：设置亮度为关闭状态 */
    safe_set_rgb_brightness(BACKLIGHT_OFF);
    _backlight_flag = 0;
}

void back_sleep_state(uint8_t state)
{
    DEBUG_log("back_sleep_state=%d\r\n",state);
    if(state == 0)
    {
        if(_backlight_flag != 0){
            backlight_disable();
        }
    } else if (KeyboardConfig.backlight_brightness != BACKLIGHT_OFF ){
        if(state == 1 && _backlight_flag == 0 && is_bat_level_valid() && get_battery_level() > 20)
        {

            backlight_init();
            DBG("\r\nback_sleep_state----backlight_init");
            _backlight_flag = 1;
            reset_backlight_timeout();
        } else if (state == 3 && is_bat_level_valid() && get_battery_level() > 20){
            backlight_init();
            _backlight_flag = 1;
            reset_backlight_timeout();
        }
    }
}

//设置背光灯亮度
void backlight_set_brightness(uint8_t brightness)
{
    safe_set_rgb_brightness(brightness);
}

//设置颜色
void backlight_set_color(uint8_t color)
{
    switch (color) {
        case 1: /* 洋红色 */
            safe_set_rgb_color(RGB_COLOR_PURPLE);
            INFO_log("YELLOW\r\n");
            break;

        case 2: /* 红色 */
            safe_set_rgb_color(RGB_COLOR_RED);
            INFO_log("green\r\n");
            break;

        case 3: /* 黄色 */
            safe_set_rgb_color(RGB_COLOR_YELLOW);
            INFO_log("qing\r\n");
            break;

        case 4: /* 青色 */
            safe_set_rgb_color(RGB_COLOR_CYAN);
            INFO_log("yang red\r\n");
            break;

        case 5: /* 蓝色 */
            safe_set_rgb_color(RGB_COLOR_BLUE);
            INFO_log("red\r\n");
            break;

        case 6: /* 绿色 */
            safe_set_rgb_color(RGB_COLOR_GREEN);
            INFO_log("blue\r\n");
            break;

        case 0: /* 白色 */
        default:
            safe_set_rgb_color(RGB_COLOR_WHITE);
            INFO_log("white\r\n");
            break;
    }
}

// 获取下一个预设亮度级别
static uint8_t get_next_preset_brightness(uint8_t current_brightness) {
    const uint8_t preset_levels[] = {BACKLIGHT_OFF,BACKLIGHT_LOW, BACKLIGHT_MEDIUM, BACKLIGHT_HIGH };
    const uint8_t level_count = sizeof(preset_levels) / sizeof(preset_levels[0]);

    // 如果是自定义亮度，返回最接近的预设值的下一级
    for (uint8_t i = 0; i < level_count; i++) {
        if (current_brightness < preset_levels[i]) {
            return preset_levels[i];
        }
    }
    return BACKLIGHT_OFF; // 如果当前亮度大于所有预设值，返回最低亮度
}

//切换亮度
void backlight_switch_brightness(void)
{
    // 需要根据预设自定义亮度来调整，例如默认亮度为10% 20% 30%。如果我自定义设置为5%的亮度，再次调整亮度时 需要调整到10%
    KeyboardConfig.backlight_brightness = get_next_preset_brightness(KeyboardConfig.backlight_brightness);

    INFO_log("\r\n--------------------KeyboardConfig.backlight_brightness= %d",KeyboardConfig.backlight_brightness);
    backlight_set_color(KeyboardConfig.backlight_color);
    backlight_set_brightness(KeyboardConfig.backlight_brightness);
}

//切换颜色
void backlight_switch_color(void)
{

    if(KeyboardConfig.backlight_brightness == 0)
    {
        return;
    }

    if(KeyboardConfig.backlight_color < 6)KeyboardConfig.backlight_color++;
    else KeyboardConfig.backlight_color = 0;

    INFO_log("\r\n--------------------backlight_color= %d",KeyboardConfig.backlight_color);
    backlight_set_color(KeyboardConfig.backlight_color);
    backlight_set_brightness(KeyboardConfig.backlight_brightness);
}
