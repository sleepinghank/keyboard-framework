#include "storage.h"
#include "Debug_Log.h"
#include "crc16.h"
#include "pxi_par2860_ble_lib.h"
#include "backlight.h"
#include <string.h>
#include "kb_scan.h"
#include "event_flags.h"
#include "Inateck_tag_config.h"
#include "sleep.h"
#include "timer_event.h"

static uint16_t User_lastCrcValue = 0;    // 用户配置CRC值
static uint16_t System_lastCrcValue = 0;   // 系统配置CRC值
//键盘配置
KeyboardConfig_t KeyboardConfig;
//系统配置
SystemConfig_t SystemConfig;

static void Storage_get_params(StorageType_t type, uint16_t *addr, void **config, uint16_t *size, uint16_t **last_crc)
{
    // 新布局: [Header(3)] [CRC_user(2)] [UserConfig] [CRC_sys(2)] [SystemConfig]
    switch(type)
    {
        case STORAGE_USER:
            *addr = USER_STORAGE_ADDR + STORAGE_HEADER_SIZE;
            *config = (void*)&KeyboardConfig;
            *size = sizeof(KeyboardConfig);
            *last_crc = &User_lastCrcValue;
            break;

        case STORAGE_SYSTEM:
            *addr = USER_STORAGE_ADDR + STORAGE_HEADER_SIZE + 2 + sizeof(KeyboardConfig);
            *config = (void*)&SystemConfig;
            *size = sizeof(SystemConfig);
            *last_crc = &System_lastCrcValue;
            break;
    }
}

/**
 * @brief 校验并修正 SystemConfig 中的异常值
 * @param cfg 指向 SystemConfig 的指针
 * @return 1 表示有字段被修正，0 表示全部合法
 */
uint8_t validate_system_config(SystemConfig_t *cfg)
{
    uint8_t fixed = 0;

    // shutdown_time: 0 合法(永不关机)
    // 非0: bit15=1 分钟模式, 分钟数 >= 5 且 <= 1440(24小时)
    //       bit15=0 秒模式, 秒数 >= 300
    if (cfg->shutdown_time != 0) {
        if (cfg->shutdown_time & 0x8000) {
            uint16_t minutes = cfg->shutdown_time & 0x7FFF;
            if (minutes < 5) {
                cfg->shutdown_time = 0x8000 | 5;
                fixed = 1;
            } else if (minutes > 1440) {
                cfg->shutdown_time = 0x8000 | 1440;
                fixed = 1;
            }
        } else {
            if (cfg->shutdown_time < 300) {
                cfg->shutdown_time = 300;
                fixed = 1;
            }
        }
    }

    // led_off_time: 0 合法(永不关闭)
    // 非0: bit15=1 分钟模式, 最大 1440 分钟(24小时)
    //       bit15=0 秒模式, uint16_t 最大 32767 约 9 小时, 无需额外限制
    if (cfg->led_off_time != 0) {
        if (cfg->led_off_time & 0x8000) {
            uint16_t minutes = cfg->led_off_time & 0x7FFF;
            if (minutes > 1440) {
                cfg->led_off_time = 0x8000 | 1440;
                fixed = 1;
            }
        }
    }

    // led_switch: 只能是 0 或 1
    if (cfg->led_switch > 1) {
        cfg->led_switch = 1;
        fixed = 1;
    }

    // ai_key_func_idx: 0xFF 视为无效
    if (cfg->ai_key_func_idx == 0xFF) {
        cfg->ai_key_func_idx = 0;
        fixed = 1;
    }

    return fixed;
}

void Storage_Init(void)
{
    uint8_t need_write = 0;
    uint8_t i = 0;
    if(Storage_read(STORAGE_USER) == 0)
    {
        //初始化用户配置默认值
        KeyboardConfig.backlight_color = 0;
        KeyboardConfig.backlight_brightness = BACKLIGHT_MEDIUM;
        // KeyboardConfig.system_type = IOS;
        // DEBUG_log("User Storage Init Error");
        need_write = 1;
    }

    if(Storage_read(STORAGE_SYSTEM) == 0)
    {
        SystemConfig.shutdown_time = shutdown_time;
        SystemConfig.led_off_time = led_off_time;
        SystemConfig.ai_key_func_idx = ((keyboard_shortcut_bitmap & 0x8000)>>8) & keyboard_shortcut[0][0];
#ifdef CONFIG_ENABLE_TOUCH
        SystemConfig.touch_gesture_switch_bitmap = touch_gesture_switch_bitmap;
        for (i = 0; i < 4; i++)
        {
            SystemConfig.touch_gesture_shortcut[i] = touch_gesture_shortcut[15 - i];
        }
#endif
        need_write = 1;
    } else {
        // 读取成功，执行值域校验
        if (validate_system_config(&SystemConfig)) {
            INFO_log("Storage: SystemConfig validated, some fields fixed");
            need_write = 1;
        }
    }
    if (need_write == 1){
        Storage_write_all(1);
    }
}

void Storage_reset(void)
{
    uint8_t i = 0;
    //初始化用户配置默认值
    KeyboardConfig.backlight_color = 0;
    KeyboardConfig.backlight_brightness = BACKLIGHT_MEDIUM;
    // KeyboardConfig.system_type = IOS;
    set_all_tags_to_default();
    SystemConfig.shutdown_time = shutdown_time;
    SystemConfig.led_off_time = led_off_time;
    SystemConfig.ai_key_func_idx = ((keyboard_shortcut_bitmap & 0x8000)>>8) & keyboard_shortcut[0][0];
#ifdef CONFIG_ENABLE_TOUCH
    SystemConfig.touch_gesture_switch_bitmap = touch_gesture_switch_bitmap;
    for (i = 0; i < 4; i++)
    {
        SystemConfig.touch_gesture_shortcut[i] = touch_gesture_shortcut[15 - i];
    }
#endif
    set_shutdown_time(SystemConfig.shutdown_time);
    set_led_off_time(SystemConfig.led_off_time);
}

void Storage_write_all(uint8_t write_now){
    uint16_t user_crcValue = 0, system_crcValue = 0;
    uint8_t write_buf[55] = {0};  // 增加 3 字节头部空间
    uint16_t write_len = 0;

    DEBUG_log("Storage_write_all......%d", write_now);

    // 计算用户配置的CRC
    user_crcValue = GetQuickCRC16((unsigned char*)&KeyboardConfig, sizeof(KeyboardConfig));
    // 计算系统配置的CRC
    system_crcValue = GetQuickCRC16((unsigned char*)&SystemConfig, sizeof(SystemConfig));

    if ((User_lastCrcValue != user_crcValue) ||
        (System_lastCrcValue != system_crcValue) ||
        write_now == 1)
    {
        // 写入存储头部: Magic + Version
        write_buf[write_len++] = (uint8_t)(STORAGE_MAGIC & 0xFF);
        write_buf[write_len++] = (uint8_t)((STORAGE_MAGIC >> 8) & 0xFF);
        write_buf[write_len++] = STORAGE_VERSION;

        // 写入用户配置的CRC和数据
        write_buf[write_len++] = (uint8_t)(user_crcValue & 0xFF);
        write_buf[write_len++] = (uint8_t)((user_crcValue >> 8) & 0xFF);
        memcpy(&write_buf[write_len], &KeyboardConfig, sizeof(KeyboardConfig));
        write_len += sizeof(KeyboardConfig);

        // 写入系统配置的CRC和数据
        write_buf[write_len++] = (uint8_t)(system_crcValue & 0xFF);
        write_buf[write_len++] = (uint8_t)((system_crcValue >> 8) & 0xFF);
        memcpy(&write_buf[write_len], &SystemConfig, sizeof(SystemConfig));
        write_len += sizeof(SystemConfig);

        // 一次性写入所有数据
        pxi_gap_s_profile_data_write(USER_STORAGE_ADDR, write_len, write_buf);

        // 更新CRC值
        User_lastCrcValue = user_crcValue;
        System_lastCrcValue = system_crcValue;

        DEBUG_log("Storage write all complete, total len: %d", write_len);
    }
    DEBUG_log("backlight_color:%d,ai_key_func_idx:%d", KeyboardConfig.backlight_color,SystemConfig.ai_key_func_idx);
}


//读取存储内容(0 读取失败 1 读取成功)
uint8_t Storage_read(StorageType_t type)
{
    uint16_t crcValue = 0, crc = 0;
    uint16_t read_addr;
    void *config;
    uint16_t config_size;
    uint16_t *last_crc;

    // 先校验存储头部（读取 STORAGE_USER 时触发检查）
    if (type == STORAGE_USER) {
        uint8_t header_buf[STORAGE_HEADER_SIZE];
        uint16_t magic;

        pxi_gap_s_profile_data_read(USER_STORAGE_ADDR, STORAGE_HEADER_SIZE, header_buf);
        magic = header_buf[0] | (header_buf[1] << 8);

        if (magic != STORAGE_MAGIC) {
            ERROR_log("Storage magic error: 0x%04X", magic);
            return 0;
        }
        if (header_buf[2] != STORAGE_VERSION) {
            ERROR_log("Storage version error: %d", header_buf[2]);
            return 0;
        }
    }

    // 获取存储参数（地址已含 header 偏移）
    Storage_get_params(type, &read_addr, &config, &config_size, &last_crc);

    DEBUG_log("Storage_read type:%d......", type);

    pxi_gap_s_profile_data_read(read_addr, 2, (uint8_t*)&crcValue);
    read_addr += 2;

    pxi_gap_s_profile_data_read(read_addr, config_size, (uint8_t*)config);

    crc = GetQuickCRC16((unsigned char*)config, config_size);

    if (crcValue != crc)
    {
        ERROR_log("Storage type:%d CRC error!", type);
        return 0;
    }
    return 1;
}

uint8_t Storage_user_read(void)
{
    return Storage_read(STORAGE_USER);
}
uint8_t Storage_system_read(void)
{
    return Storage_read(STORAGE_SYSTEM);
}
