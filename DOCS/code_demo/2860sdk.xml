void skip_inactive_keys(BtnCallback cb) {
    uint16_t buf[10] = {0};
    uint8_t u8temp;
    uint8_t idx = cb(buf);
    for (u8temp = 0; u8temp < idx; ++u8temp) {
        // DEBUG_log("buf[%d] = %d",u8temp,buf[u8temp]);
        add(buf[u8temp], _key_code_list_extend);
    }
}
