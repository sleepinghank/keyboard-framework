    _uart_1_ctrl->CLK_SEL = 0;       /* 1=32M, 0=16M */

    _uart_1_ctrl->BAUDSEL = baud;
    _uart_1_ctrl->FLOW_EN = UART_RTS_CTS_DISABLE;
    _uart_1_ctrl->RX_INT_MASK = 1;   /* 1=MASK */
    _uart_1_ctrl->TX_INT_MASK = 1;   /* 1=MASK */

