{
    RTC_INT_CMP0 = 1, ///< Alarm 0 interrupt bitmask
    RTC_INT_CMP1 = 2, ///< Alarm 1 interrupt bitmask
    RTC_INT_TICK = 4, ///< Tick interrupt bitmask
    RTC_INT_ALL  = 7, ///< All interrupt mask

