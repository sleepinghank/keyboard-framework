//

#include "inateck_origin.h"
#include "event_flags.h"
#include "config.h"
#include "debug.h"
#include "ble.h"
#include "Inateck_ProductInfo.h"
#include "kb_para_profile.h"
#include <string.h>

#if (ORIGIN_DEVICE_TYPE == Mouse || ORIGIN_DEVICE_TYPE == MulKeyboardTouchpad)
extern uint8_t switch_target_device_idx;//蓝牙信道
extern uint8_t _device_idx;//蓝牙信道
#ifdef CONFIG_ENABLE_TOUCH
extern uint16_t scan_time; // 触摸板活跃标志
#else
uint16_t scan_time = 0;
#endif
#endif

#ifdef  CONFIG_ENABLE_ADC
extern uint8_t get_battery_level(void);
#endif


origin_cmd_resp origin_resp;
uint8_t resp_len = 0;

uint8_t serial_number[17];
static INIT_DEVICE origin_device_init;


/// @brief 设置序列号
/// @param *in_buf 序列号
/// @return 1：设置成功 0：设置失败
uint8_t set_serial_number(uint8_t *in_buf){
    if (serial_number[16] == 1) {
        //初始化过，拒绝写入
        return 0;
    }
    DBGHEXDUMP("buffer -> ",in_buf,16);
    pxi_gap_s_profile_data_read(ORIGIN_UUID_ADDRESS, 17, serial_number);
    if (serial_number[16] != 1) {
        //未初始化过，允许写入
        memcpy(&serial_number, in_buf, 16);
        serial_number[16] = 1;
        pxi_gap_s_profile_data_write(ORIGIN_UUID_ADDRESS, 17, serial_number);
        return 1;
    }
    return 0;
}

/// @brief 获取序列号等信息
/// @param *out_buf 返回的数据指针
/// @return 1：获取成功 0：获取失败
uint8_t get_serial_number(uint8_t *out_buf) {
    if (origin_device_init.valid != 1) {
        if (serial_number[16] != 1){
            pxi_gap_s_profile_data_read(ORIGIN_UUID_ADDRESS, 17, serial_number);
            DBGHEXDUMP("serial number -> ",serial_number,17);
            if (serial_number[16] != 1) {
                //没有写入序列号，直接返回
                memset(&origin_device_init,0,sizeof(INIT_DEVICE));
                return 0;
            }
        }
        //初始化所有信息
        memcpy(&origin_device_init.serial_number, serial_number, 16);
        memcpy(&origin_device_init.identifier, MX, sizeof(MX));
        origin_device_init.device_type = ORIGIN_DEVICE_TYPE; // 
        origin_device_init.valid = 1;
        memcpy(&origin_device_init.device_name,ProductModel,sizeof(ProductModel));
    }
    //更新信道和电量
    origin_device_init.channel = _device_idx;
    #ifdef  CONFIG_ENABLE_ADC
    origin_device_init.power = get_battery_level();
    #else
    origin_device_init.power = 255;
    #endif
    memcpy(out_buf, &origin_device_init, sizeof(INIT_DEVICE));
    return 1;
}

void _Origin_init(void){
    memset(&serial_number, 0, sizeof(serial_number));
    memset(&origin_resp, 0, sizeof(origin_resp));
    resp_len = 0;
}
void _Origin_Command_Processor(uint8_t* p_cmd, uint16_t sz){
    origin_cmd_req rec_data;
    {
        uint8_t buffer[39] = {0};
        memcpy((uint8_t *)&rec_data, p_cmd, sz);
        if (rec_data.cmd != ORIGIN_CMD_TOP_LEVEL){
            return;
        }
        DBG("code:%d\r\n",rec_data.sub_cmd);
        switch (rec_data.sub_cmd)
        {
            // 是否是可移动指针设备
            #if (ORIGIN_DEVICE_TYPE == Mouse || ORIGIN_DEVICE_TYPE == MulKeyboardTouchpad)

            #ifdef multichannel // 是否支持多通道
            case ORIGIN_CMD_CHANGE_INDEX:
                //  切换到对应通道
                switch_target_device_idx = rec_data.u.channel % MAXIMUM_NUM_OF_BOND_DEVICES;//蓝牙信道
                _set_evt(USER_ST,SYS_SWITCH_CHANNEL);
                ble_disconnect();
                break;
            #endif
            case ORIGIN_CMD_READ_MOUSE_MOVE:
                // 检测光标是否在移动
                origin_resp.cmd = ORIGIN_CMD_TOP_LEVEL + 1;
                origin_resp.sub_cmd = ORIGIN_CMD_READ_MOUSE_MOVE + 1;
                origin_resp.error_code = 0;
                if (scan_time > 0){
                    origin_resp.u.is_moved = 1;
                } else {
                    origin_resp.u.is_moved = 0;
                }
                resp_len = 4;
                break;
            #endif
            case ORIGIN_CMD_SERIAL_NUMBER:
                // 写入唯一标识号，并读取设备全部信息
                set_serial_number(rec_data.u.serial_number);
                get_serial_number(buffer);
                origin_resp.cmd = ORIGIN_CMD_TOP_LEVEL + 1;
                origin_resp.sub_cmd = ORIGIN_CMD_SERIAL_NUMBER + 1;
                origin_resp.error_code = 0;
                memcpy(&origin_resp.u.device_info, buffer, sizeof(INIT_DEVICE));
                resp_len = 49;
                break;
            default:
                DBG("ERR_NOT_SUPPORTED"); // 指令不支持
                break;
        }
    }
}

uint8_t _Origin_Command_Check(void){
    DBG("_Origin_Command_Check:%d\r\n",resp_len);
    if (resp_len > 0){
        return 1;
    }
    return 0;
}

void _Origin_Rsp(uint8_t* p_rsp, uint8_t* p_sz){
    memcpy(p_rsp, &origin_resp,  resp_len);
    *p_sz = resp_len;
}
</file>

