/// @brief 根据X 轴 从大到小排序 冒泡排序
static void bubble_sort(contact_data_t arr[], int len) {
    int i, j;
    contact_data_t temp;
    for (i = 0; i < len - 1; i++){
        for (j = 0; j < len - 1 - i; j++){
            if (arr[j].x < arr[j + 1].x) {
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

