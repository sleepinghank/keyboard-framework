        _misc_ctrl->R_CPOL = 1;
        _misc_ctrl->R_CPHA = 0;
        break;

    case HID_SPI_MASTER_MODE_2:

        _misc_ctrl->R_CPOL = 0;
        _misc_ctrl->R_CPHA = 1;
