<file path="PAR2860/keyboard/kb_hid_report.c">
#include <string.h>
#include "queue.h"
#include "kb_scan.h"
#include "ble.h"
//#include "HID_OVER_GATT_KEYBOARD_OTA_Profile_PTP_MS.h"
#include "HID_OVER_GATT_KEYBOARD_OTA_Profile_PTP.h"
#include "event_flags.h"
#include "timer_event.h"
#include "keycode.h"
#include "kb_hid_report.h"
#include "sleep.h"


void _keyboard_hid_init(void)
{
    init_queue();
    keyboard_init();
}

static uint8_t _kb_data(void)
{
    uint8_t tx_data = 0;
    uint8_t buf[KEYBOARD_REPORT_SZ + 1] = {0};

    if (_check_evt(SYS_ST, SYS_PASSKEYKEY))
        return (tx_data = 1);

    if (!ble_check_notify_enabled())
    {
        if ((my_kb_rpt.mkey_report.update == 1) && (queue_buf_full() == 0))
        {
            buf[0] = MEDIA_KEY_REPORT_SZ;
            memcpy(&buf[1], (uint8_t*)&my_kb_rpt.mkey_report.media_key, \
                   MEDIA_KEY_REPORT_SZ);
            memcpy((uint8_t*)&last_que_kb_rpt.mkey_report.media_key, \
                   (uint8_t*)&my_kb_rpt.mkey_report.media_key, \
                   MEDIA_KEY_REPORT_SZ);
            en_queue(buf, buf[0] + 1);
        }

        if ((my_kb_rpt.nkey_report.update == 1) && (queue_buf_full() == 0))
        {
            buf[0] = KEYBOARD_REPORT_SZ;
            memcpy(&buf[1], my_kb_rpt.nkey_report.normal_keys, \
                   KEYBOARD_REPORT_SZ);
            memcpy(last_que_kb_rpt.nkey_report.normal_keys, \
                   my_kb_rpt.nkey_report.normal_keys, KEYBOARD_REPORT_SZ);
            en_queue(buf, buf[0] + 1);
        }

        tx_data = 1;
    }
    else
    {
        if (queue_buf_empty() == 0)     //queue not empty
        {
            if ((my_kb_rpt.mkey_report.update == 1) && (queue_buf_full() == 0))
            {
                buf[0] = MEDIA_KEY_REPORT_SZ;
                memcpy(&buf[1], (uint8_t*)&my_kb_rpt.mkey_report.media_key, \
                       MEDIA_KEY_REPORT_SZ);
                memcpy((uint8_t*)&last_que_kb_rpt.mkey_report.media_key, \
                       (uint8_t*)&my_kb_rpt.mkey_report.media_key, \
                       MEDIA_KEY_REPORT_SZ);
                en_queue(buf, buf[0] + 1);
            }

            if ((my_kb_rpt.nkey_report.update == 1) && (queue_buf_full() == 0))
            {
                buf[0] = KEYBOARD_REPORT_SZ;
                memcpy(&buf[1], my_kb_rpt.nkey_report.normal_keys, \
                       KEYBOARD_REPORT_SZ);
                memcpy(last_que_kb_rpt.nkey_report.normal_keys, \
                       my_kb_rpt.nkey_report.normal_keys, \
                       KEYBOARD_REPORT_SZ);
                en_queue(buf, buf[0] + 1);
            }

            while (1)
            {
                if (queue_buf_empty() == 1) //queue empty
                {
                    if (memcmp((uint8_t*)&last_que_kb_rpt.mkey_report.media_key, \
                               (uint8_t*) &old_kb_rpt.mkey_report.media_key, \
                               MEDIA_KEY_REPORT_SZ) != 0)
                    {
                        kb_tx_data(HOTKEY_INPUT_REPORT_IDX, \
                                    MEDIA_KEY_REPORT_SZ, \
                                    (uint8_t*)&old_kb_rpt.mkey_report.media_key);

                    }

                    if (memcmp(last_que_kb_rpt.nkey_report.normal_keys, \
                               old_kb_rpt.nkey_report.normal_keys, \
                               KEYBOARD_REPORT_SZ) != 0)
                    {
                        kb_tx_data(ble_get_report_idx(), \
                                    KEYBOARD_REPORT_SZ, \
                                    old_kb_rpt.nkey_report.normal_keys);
                    }

                    break;
                }

                //patch for lose key
                if (notify_enable_flag == 0)
                    break;

                if(pxi_gap_s_get_available_fifo_sz()>2)     //reserve 2 buf for LL
                {
                    if (de_queue(buf) == 1)
                    {
                        if (buf[0] == MEDIA_KEY_REPORT_SZ)
                        {
                            kb_tx_data(HOTKEY_INPUT_REPORT_IDX, \
                                        MEDIA_KEY_REPORT_SZ,  &buf[1]);
                        }
                        else if (buf[0] == KEYBOARD_REPORT_SZ)
                        {
                            uint8_t ret=ble_tx_data(ble_get_report_idx(), \
                                                    KEYBOARD_REPORT_SZ,  &buf[1]);
                        }
                    }
                }
                else
                    break;

            }

            tx_data = 1;
        }
        else    //queue empty
        {
            if (my_kb_rpt.mkey_report.update == 1)
            {
                kb_tx_data(HOTKEY_INPUT_REPORT_IDX, MEDIA_KEY_REPORT_SZ, \
                            (uint8_t*)&my_kb_rpt.mkey_report.media_key);

                tx_data = 1;
            }

            if (my_kb_rpt.nkey_report.update == 1)
            {
                kb_tx_data(ble_get_report_idx(), KEYBOARD_REPORT_SZ, \
                            my_kb_rpt.nkey_report.normal_keys);

                tx_data = 1;
            }

            if ((memcmp((uint8_t*)&my_kb_rpt.nkey_report.normal_keys, \
                        keybuf_null, KEYBOARD_REPORT_SZ) != 0)
                    || memcmp((uint8_t*)&my_kb_rpt.mkey_report.media_key, \
                              keybuf_null, MEDIA_KEY_REPORT_SZ) != 0)
                tx_data = 1;
        }
    }

    return tx_data;
}

uint8_t _check_keyboard_data(void)
{
    uint8_t keyboard_st;

        keyboard_st = _kb_data();

    return keyboard_st;
}
</file>

