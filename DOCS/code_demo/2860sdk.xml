void _ble_evt_task(void)
{
    if (_check_evt(BLE_ST, BLE_ADV_END))
    {
        
        //ble广播结束进入深度睡眠
        _clr_evt(BLE_ST, BLE_ADV_END);
#ifdef POLLING_BLEADV_ENABLE
        if (direct_adv_st == 0 || direct_adv_cnt >= 39) {
            direct_adv_cnt=0;
            _set_evt(SYS_ST, SYS_POWER_DOWN);
        } else {
            direct_adv_cnt++;
            ble_alternating_adv_start();
        }
#else
        // 如果是回连结束，默认进入广播30s
        if (pairing_state_get() == NO_PAIR )
        {
            ble_adv_params.general_pair_adv_timeout = DISCONN_RECONN_ADV_TIMEOUT;
            ble_adv_params.swift_pair_adv_timeout = DISCONN_RECONN_ADV_TIMEOUT;
            ble_resetting_channel();
        }
        else 
        {
            _set_evt(SYS_ST, SYS_POWER_DOWN);
        }
#endif
    }

    if (_check_evt(BLE_ST, BLE_CONNECTED))
    {
        //蓝牙连接成功
        _clr_evt(BLE_ST, BLE_CONNECTED);
        INFO_log(("HID - BLE_CONNECTED"));

#ifdef BLE_RECONNECT_IN_ERR
        // 如果是从回连状态恢复，取消回连超时定时器
        if ((disconnect_sleep_bit & 0x80) == 0x80) {
            if (disconnect_reconnect_timer_id != TIMER_ID_INVALID) {
                u_timer_clear(disconnect_reconnect_timer_id);
                disconnect_reconnect_timer_id = TIMER_ID_INVALID;
                INFO_log("Reconnect success, cancel timeout timer");
            }
            disconnect_sleep_bit &= ~0x80;  // 清除回连等待标志
        }
#endif

        led_control(ble_ch1_led, 0);
        // 重置广播参数
        ble_adv_params_init();
        if(my_leds.caps_lock == 1)
        {
            LED_SetState(caps_led , LED_LIGHT);
        }

#ifdef KEYCODE_BKLED
        back_sleep_state(BACKLIGHT_SET_ON);
#endif

#ifdef CONFIG_ENABLE_TOUCH

        touch_flag = 1;
        connect_isolation_count = KEYBOARD_CNT_MS(500);
        _set_evt(USER_ST, SYS_CHECK_TOUCH_STATUS);
#endif

        reset_sleep_timeout();
        reset_powerdown_timeout();
        sleep_flag = 0;
    }

    if (_check_evt(BLE_ST, BLE_DISCONNECTED))
    {
        //ble 连接断开
        _clr_evt(BLE_ST, BLE_DISCONNECTED);
        #ifdef POLLING_BLEADV_ENABLE
        direct_adv_cnt=0;
        direct_adv_st=0;
        has_bond_adv=0;
        #endif
        //LED_SetState (caps_led , LED_EXTINGUISH);？？？
        LED_init();
        reset_powerdown_timeout();
        INFO_log(("HID - BLE_DISCONNECTED"));

#ifdef CONFIG_32K_XTAL
        //Patch for avoid clock switch to lpo
        pxi_sys_32k_xosc_init(SYSTEM_32K_XOSC_MODULE_1);
        pxi_sys_32k_clock_set(SYSTEM_32K_CLOCK_XOSC);
#endif

        if (_check_evt(SYS_ST, SYS_PAIRING))
        {
            _clr_evt(SYS_ST, SYS_PAIRING); 
            WARN_log(("重新配对"));
            IOS_Pair_flag = 0;
            ble_adv_params_init();
            ble_resetting_channel();
            safe_led_control(ble_ch1_led , LED_STATE_FAST_BLINK);
            // #ifdef CONFIG_ENABLE_TOUCH
            // touch_flag = 1;
            // #endif
            // _set_evt(USER_ST, SYS_CHECK_TOUCH_STATUS);//？？？
        }
        else if (_check_evt(USER_ST,SYS_SWITCH_CHANNEL))
        {
            _clr_evt(USER_ST,SYS_SWITCH_CHANNEL);   
            ble_switch_channel();
            Check_led_ble();
            WARN_log(("SYS_SWITCH_CHANNEL"));
        }
        else{
            
            if (sleep_flag == 1 || keycode_type == MAC){
                _set_evt(SYS_ST, SYS_POWER_DOWN);
                sleep_flag = 0;
            } else {
                #ifdef BLE_RECONNECT_IN_ERR//设备端断开蓝牙的广播机制
                if((disconnect_sleep_bit & 0x01) != 0x00)//异常断开延迟关机尝试回连
                {
                    disconnect_sleep_bit |= 0x80;
                    disconnet_wake_up();
                } else {
                    _set_evt(SYS_ST, SYS_POWER_DOWN);
                }
                #else
                    ble_switch_channel();
                    Check_led_ble();
                #endif
            }
           
        }
        notify_enable_flag = 0;
        
    }

    if (_check_evt(BLE_ST, BLE_NOTIFY_ENABLE))
    {
        _clr_evt(BLE_ST, BLE_NOTIFY_ENABLE);

        DEBUG_log("HID - BLE_NOTIFY_ENABLE");
        check_pair_state  = 0;

    }

    if (_check_evt(BLE_ST, BLE_LATENCY_DISABLE))
        _clr_evt(BLE_ST, BLE_LATENCY_DISABLE);

    if (_check_evt(BLE_ST, BLE_START_ENC))
    {
        DEBUG_log("BLE_START_ENC");
        _clr_evt(BLE_ST, BLE_START_ENC);
    }
    // if (_check_evt(BLE_ST, BLE_PASSKEY_REQ))
    // {
    //     _clr_evt(BLE_ST, BLE_PASSKEY_REQ);

    //     _set_evt(SYS_ST, SYS_PASSKEYKEY);

    //     DEBUG_log(("HID - BLE_PASSKEY_REQ"));
    // }
    if (_check_evt(USER_ST, SYS_IDENTIFY_SYSTEM))
    {
        DBG("HID - SYS_IDENTIFY_SYSTEM\r\n");
        _clr_evt(USER_ST, SYS_IDENTIFY_SYSTEM);
        current_system_type = keycode_type;
        // if (KeyboardConfig.system_type != keycode_type){
        //     DEBUG_log("KeyboardConfig.system_type:%d,keycode_type:%d",KeyboardConfig.system_type,keycode_type);
        //     KeyboardConfig.system_type = keycode_type;
        //     u_timer_out_soft(storage_write_cb, 500, 1);
        // }
    }

}

void _sys_evt_task(void)
{
    // if (_check_evt(SYS_ST, SYS_TIMER))
    // {
    //     _clr_evt(SYS_ST, SYS_TIMER);
    //     _sys_timer_task();

    // }

    // if (_check_evt(SYS_ST, SYS_SLP_TIMER))
    // {
		
    //     _clr_evt(SYS_ST, SYS_SLP_TIMER);
    //     // _sleep_timer_task(); // 已迁移到 timer_task，不再需要手动调用
    // }

    if (_check_evt(SYS_ST, SYS_SLP_WAKEUP))
    {
        _clr_evt(SYS_ST, SYS_SLP_WAKEUP);

        _slp_wakeup_task();

    }

    if (_check_evt(SYS_ST, SYS_PD_WAKEUP))
    {
        _clr_evt(SYS_ST, SYS_PD_WAKEUP);

        _pd_wakeup_task();
    }
    if(_check_evt(SYS_ST, SYS_RESET_DEFAULT))
    {
        DEBUG_log(("SYS_RESET_DEFAULT \n" ));
        DBGPRINTF(("addr_before[%02X:%02X:%02X:%02X:%02X:%02X]\r\n",
            _dev_addr.addr[0], _dev_addr.addr[1], _dev_addr.addr[2],
            _dev_addr.addr[3], _dev_addr.addr[4], _dev_addr.addr[5]));
        _clr_evt(SYS_ST, SYS_RESET_DEFAULT);
        //删除所有绑定信息
        pxi_bm_s_bond_info_delete_all();
        IOS_Pair_flag = 0;
        _factory_reset_pending = 1;
        // 重置变量
        Storage_reset();
        _set_evt(USER_ST, SYS_STORAGE_WRITE);
        #ifdef KEYCODE_BKLED
        //重置背光灯
        back_sleep_state(3);
        #endif

        // 重置灯
        LED_init();
        //重置触摸板
        #ifdef CONFIG_ENABLE_TOUCH
        touch_flag = 1;
        // Removed: migrated to timer_task (touch_timeout_timer_id)
        check_touch_lock(); //这里的逻辑很奇怪，重启触控板应该统一实现方式
        #endif
        //重置通道
        // key_switch_channel(0);
        // _device_idx = switch_target_device_idx;
        _device_idx = 0;
#ifdef KEYCODE_BKLED
        push_backlight_change();
#endif
        //LED闪烁3次
        LED_flicker();
        _set_evt(SYS_ST, SYS_PAIRING);
        ble_disconnect();
    }
    if(_check_evt(USER_ST , SYS_STORAGE_WRITE))
    {
        DEBUG_log("User_Storage_Write");
        _clr_evt(USER_ST , SYS_STORAGE_WRITE);
        __disable_irq();
        Storage_write_all(1);
        __enable_irq();
    }
    #ifdef CONFIG_ENABLE_TOUCH
    if(_check_evt(USER_ST, SYS_CHECK_TOUCH_STATUS))
    {
        _clr_evt(USER_ST, SYS_CHECK_TOUCH_STATUS);
        
        check_touch_status();
    }
    #endif
}

void _sys_evt_pmu_task(void)
{
    if (_check_evt(SYS_ST, SYS_LOW_POWER))
    {
        _clr_evt(SYS_ST, SYS_LOW_POWER);

        INFO_log((" SYS_LOW_POWER"));
        _touch_pin_wakeup = 0x0000;
        if((ota_check() != 1) && (_OTA_GetStartFlag() != 1))
        _system_power_down();
    }

    if (_check_evt(SYS_ST, SYS_ENTER_SLA_LCY))
    {
        if (ble_slave_check_latency_on() == 0)
        {
            INFO_log("SYS_ENTER_SLA_LCY\n");
            ble_slave_latency_on();

            {
                struct gap_wakeup_config pw_cfg;
                memset(&pw_cfg,0,sizeof(pw_cfg));
                pw_cfg.wakeup_type = SLEEP_WAKEUP;
                pw_cfg.timer_wakeup_en = 1;
                pw_cfg.gpi_wakeup_en = 1;
                pw_cfg.gpi_wakeup_cfg = (_io_pin_wakeup|_touch_pin_wakeup);
                pxi_pmu_wakeup_config(&pw_cfg);
            }
        }
        _clr_evt(SYS_ST, SYS_ENTER_SLA_LCY);
    }

    if (_check_evt(SYS_ST, SYS_LEAVE_SLA_LCY))
    {
        if (ble_slave_check_latency_on() == 1)
        {
            INFO_log("SYS_LEAVE_SLA_LCY");
            ble_slave_latency_off();

            {
                struct gap_wakeup_config pw_cfg;
                memset(&pw_cfg,0,sizeof(pw_cfg));
                pw_cfg.wakeup_type = SLEEP_WAKEUP;
                pw_cfg.timer_wakeup_en = 1;
                pw_cfg.gpi_wakeup_en = 1;
                pw_cfg.gpi_wakeup_cfg = _touch_pin_wakeup;
                pxi_pmu_wakeup_config(&pw_cfg);
            }
        }
        _clr_evt(SYS_ST, SYS_LEAVE_SLA_LCY);
    }

    if (_check_evt(SYS_ST, SYS_POWER_DOWN))
    {
        CS_IN();
        LED_power_down();
        pxi_delay_ms(5);
        touch_able_control(0);
        pxi_delay_ms(5);
        #ifdef KEYCODE_BKLED
        set_rgb_brightness(0);
        #endif
        pxi_delay_ms(5);
        CS_OUT();

        _system_power_down();
    }
    else
    {
        /* Idle Mode */
        if (_check_idle() == 1)
        {
            DEBUG_log("SYS_IDLE");
            CS_IN();

            pxi_system_sleep();

            CS_OUT();
        }
    }

}
