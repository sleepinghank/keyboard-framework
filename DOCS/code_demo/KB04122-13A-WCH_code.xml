/// @brief 重启触摸板流程，等待触摸板重启完成，定时10ms执行一次，50次后返回失败
/// @return 1：重启成功，0：未就绪 继续循环，-1：重启失败，错误
void resume_touch_callback(void)
{
	touch_read_reg(0x70, &state); 

	if ((state&0x01 ) == 0x01){
		// DBGPRINTF(("Reg init\r\n"));
		state = 0;
		// 手动初始化触摸板寄存器 最好写入触摸板固件 
		
		for(; user_reg_idx < TOUCH_REG_ARRAY_SZ ; user_reg_idx++){
			state ++;
			if (state == 10){
				break;
			}
			
			touch_write_user_reg(TOUCH_REG_INIT[user_reg_idx][0], TOUCH_REG_INIT[user_reg_idx][1], TOUCH_REG_INIT[user_reg_idx][2]);
		}
		if (user_reg_idx == TOUCH_REG_ARRAY_SZ){
			PRINT("Reg init end\r\n");
			resume_touch_end();
			// u_timer_disable(1);
			tmos_stop_task(touch_taskID, TOUCH_REG_INIT_EVT);
			return;
		}
		
		return;
	}
	if (++cnt == 50){
		tmos_stop_task(touch_taskID, TOUCH_REG_INIT_EVT);
		PRINT("touch resume fail\r\n");
		touch_en = 0;
		return;
	}
	return;
}


