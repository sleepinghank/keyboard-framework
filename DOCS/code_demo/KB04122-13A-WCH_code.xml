/*********************************************************************
 * @fn      GPIOA_IRQHandler
 *
 * @brief   GPIOA中断函数，说明被唤醒了
 *
 * @return  none
 */
__INTERRUPT
__HIGH_CODE
void GPIOA_IRQHandler( void )
{
    //PRINT("GPIOA_IRQHandler %x\n",R16_PA_INT_IF);
    if(GPIOA_ReadITFlagBit(GPIO_Pin_3))//触摸板
    {
        GPIOA_ClearITFlagBit(GPIO_Pin_3);
        _touch_int_flag=1;
        tmos_set_event(touch_taskID, TOUCH_INI_EVT);//如果不能在中断服务函数中使用tmos调度，需要改成标志位，在主循环检测
    }
    if(GPIOA_ReadITFlagBit(GPIO_Pin_2))//电源键
    {
        GPIOA_ClearITFlagBit(GPIO_Pin_2);
        key_scan_flag=1;
        tmos_start_task(power_key_task_id, POWER_KEY_DEBOUNCE_EVT, POWER_KEY_DEBOUNCE_MS);
        
        // 如果系统处于休眠状态，触发完整唤醒流程（类似矩阵按键唤醒）
        if(access_state.sleep_en || access_state.deep_sleep_flag || access_state.idel_sleep_flag)
        {
            peripheral_sleep_update(); // 这会唤醒系统并重新启动休眠计时器
        }
    }
    if(GPIOA_ReadITFlagBit(KEY_ROW_MASK_A) )//矩阵行
    {
        GPIOA_ClearITFlagBit(KEY_ROW_MASK_A);
        key_scan_flag = 1;
    }
}

