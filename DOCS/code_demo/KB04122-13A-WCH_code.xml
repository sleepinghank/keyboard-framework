/*********************************************************************
 * @fn      keyboard_fn_press_timeout
 *
 * @brief   keyboard_fn_press_timeout
 *
 * @return  none
 */
uint8_t flag_z = reset_skip_wait;
void keyboard_fn_press_timeout(uint8_t key)
{
    PRINT("p t %x\n",key);
    switch(key)
    {
        case 0x45://F12
        {
            if(work_mode==MODE_BT)
            {
                PRINT("重新配对");
                access_pairing_process(CTL_MODE_BLE_1);
            }
            break;
        }
        case 0x1F://02
        {
            if(work_mode==MODE_BT)
            {
                access_pairing_process(CTL_MODE_BLE_2);
            }
            break;
        }
        case 0x20://03
        {
            if(work_mode==MODE_BT)
            {
                access_pairing_process(CTL_MODE_BLE_3);
            }
            break;
        }
        case 0x21://04
        {
            if(work_mode==MODE_2_4G)
            {
                //长按3s后进入2.4G配对状态
                nvs_flash_info.rf_device_id = RF_ROLE_ID_INVALD;
                tmos_memset(nvs_flash_info.peer_mac, 0, 6);
                nvs_flash_store();
                RF_ReStart();
            }
            break;
        }
        case 0x29://esc
        {
            // 按住FN＋ESC键5秒，在开启了背光灯的模式下，整体背光闪烁三次，恢复键盘出厂设置，恢复参数：配对信息，灯光效果，WIN锁，需要恢复到初始程序状态
            key_win_lock = FALSE;
//            nvs_flash_info.led_mode = LED_MODE_ON;
//            nvs_flash_info.led_light = LED_LIGHT_50;
//            nvs_flash_info.rf_device_id = RF_ROLE_ID_INVALD;
//            nvs_flash_info.ble_bond_flag = 0;
//            nvs_flash_info.ble_mac_flag = 0;
//            tmos_memset(nvs_flash_info.peer_mac, 0, 6);
//            nvs_flash_store();
//            RF_ReStart();

            EEPROM_ERASE(RESET_SKIP_WAIT_ADDR, EEPROM_PAGE_SIZE);
            EEPROM_WRITE(RESET_SKIP_WAIT_ADDR, &flag_z, sizeof(uint8_t));//按键触发复位写入该标志位

            EEPROM_ERASE(NVS_FLASH_INFO_ADDRESS, EEPROM_PAGE_SIZE);
            EEPROM_ERASE(BLE_SNV_ADDR+0x100, EEPROM_PAGE_SIZE);
            EEPROM_ERASE(BLE_SNV_ADDR+0x200, EEPROM_PAGE_SIZE);
            EEPROM_ERASE(BLE_SNV_ADDR+0x300, EEPROM_PAGE_SIZE);
            EEPROM_ERASE(BLE_SNV_ADDR+0x400, EEPROM_PAGE_SIZE);
            EEPROM_ERASE(BLE_SNV_ADDR, EEPROM_PAGE_SIZE);
            // if(nvs_flash_info.led_onoff)
            // {
            //     led_blink_range = LED_BLINK_ALL;
                tmos_clear_event(keyboard_taskID, KEYBOARD_LED_TIMEOUT_EVENT);
                tmos_start_task(keyboard_taskID, KEYBOARD_LED_TIMEOUT_EVENT, RESET_LED_BLINK_TIMEOUT);
                tmos_start_reload_task(keyboard_taskID, KEYBOARD_LED_BLINK_EVENT, RESET_LED_BLINK_INTERVAL);
            // }

            tmos_start_task(keyboard_taskID, KEYBOARD_RESET_EVENT, RESET_LED_BLINK_TIMEOUT+100);

            break;
        }
    }
}

