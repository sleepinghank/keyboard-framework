uint8_t pass_flag = 0;
uint8_t touch_button_flag = 0;
/// @brief 获取触摸板数据，（与发送数据交替执行）
/// @return 1:有数据，0：无数据
// __INTERRUPT
// __HIGH_CODE
static void ProcessGetPTPData(void)
{
    
    uint8_t status;
    uint8_t u8tmp, cnt = 0,contact_id;
    uint8_t temp = 0xff;
    memset((uint8_t*)&motion,0x00, 4);
    motion_btn = 0;
    // if (data_status == 1){
    //     touch_write_reg(0x71,0x00);
    //     return 0;
    // }
    touch_read_reg(0x71, &status);
    if ((status&(EVENT_TOUCH|EVENT_GEST|EVENT_BTN)) != 0 )
    {
        if (((status&EVENT_TOUCH)!=0)&&(PTP_SelRpt & 0x01)) {
            // 获取触摸原始数据
            u8tmp = touch_read_PTP_Report(&original_reports);
            // TOUCH_MANAGER_PRINT("touch_read_PTP_Report%d",u8tmp);
            if (u8tmp == 0){   
                if (touch_noout_flag == 0x81){
                    touch_noout_flag = 0;
                    if (ptp_reports.button == 1){
                        ptp_reports.button = 0;
                        ptp_reports.button1 = 0;
                        motion_btn = 1;
                    }
                }
                // touch_write_reg(0x71,0x00);
                return;
            }
            cnt = original_reports.contact_count;

            // #ifdef CONFIG_UART_ENABLE
            // {
            //     uint8_t i;
            //     for(i=0;i<4;i++)
            //     {
            //         TOUCH_MANAGER_PRINT("%d %x %x %d %d %d ",original_reports.contacts[i].contact_id,original_reports.contacts[i].tip,original_reports.contacts[i].confidence,
            //         original_reports.contacts[i].x,original_reports.contacts[i].y,original_reports.contacts[i].size);
            //     }
            //     TOUCH_MANAGER_PRINT("**************************");
            // }
            // #endif
            if (cnt == 1){
                if (Pre_Tip[original_reports.contacts[0].contact_id] == 1 || original_reports.contacts[0].tip == 0){

                } else if (((original_reports.contacts[0].x > SPECIAL_EDGE_X_MAX) || (original_reports.contacts[0].x < SPECIAL_EDGE_X_MIN)) && original_reports.contacts[0].size < 6) {
                    original_reports.contacts[0].tip = 0;
                    original_reports.contacts[0].confidence = 0;
                    original_reports.contacts[0].contact_id = 0;
                    original_reports.contacts[0].x = 0;
                    original_reports.contacts[0].y = 0;
                    original_reports.contact_count --;
                    cnt --;
                }

            }

            // if (ptp_reports.button == 0){
            //     // if (cnt != 2 || (abs(original_reports.contacts[0].x - original_reports.contacts[1].x) > 1250)){
            //     pass_flag = unite_filtration(&original_reports);
            //     // }
            // }
            cnt = original_reports.contact_count;
            ptp_reports.contactCnt = cnt;

            for(u8tmp=0; u8tmp<cnt; u8tmp++)
            {
                uint16_t y_offset = original_reports.contacts[u8tmp].y;

                contact_id = original_reports.contacts[u8tmp].contact_id;
                ptp_reports.finger_rpt[u8tmp].tip=original_reports.contacts[u8tmp].tip;
                ptp_reports.finger_rpt[u8tmp].confidence=original_reports.contacts[u8tmp].confidence;
                ptp_reports.finger_rpt[u8tmp].contactID= contact_id;
                
            //    if (sys_state == IOS){
                    if (y_offset == 0 && ptp_reports.finger_rpt[u8tmp].confidence == 0 && ptp_reports.finger_rpt[u8tmp].tip == 0){
                        y_offset = 0;
                    } else {
                        y_offset = TOUCHPAD_MAX_Y - y_offset;
                    }
                // }
                
                ptp_reports.finger_rpt[u8tmp].x_l8 = (original_reports.contacts[u8tmp].x) & 0xff;
                ptp_reports.finger_rpt[u8tmp].x_m4 = (original_reports.contacts[u8tmp].x >> 8) & 0x0f ;
                ptp_reports.finger_rpt[u8tmp].y_l4 = (y_offset)&0x0f;
                ptp_reports.finger_rpt[u8tmp].y_m8 = (y_offset)>>4;
                
                // 不能从无置信度到有置信度，否则会导致数据错误
                if (Pre_Tip[contact_id] == 1 && Pre_Confidence[contact_id] == 0){
                    ptp_reports.finger_rpt[u8tmp].confidence = 0;
                }

                // 判断数据是否有变更，用于判断是否需要发送数据
                if((((ptp_reports.finger_rpt[u8tmp].x_l8 != 0) ||
                        (ptp_reports.finger_rpt[u8tmp].x_m4!=0)||
                        (ptp_reports.finger_rpt[u8tmp].y_l4!=0)||
                        (ptp_reports.finger_rpt[u8tmp].y_m8!=0)) && ptp_reports.finger_rpt[u8tmp].tip == 1)||
                        ((ptp_reports.finger_rpt[u8tmp].tip != Pre_Tip[contact_id]) && (Pre_Tip[contact_id]==1))) {
                    motion[u8tmp] = 1;
                    // TOUCH_MANAGER_PRINT("motion[%d] id:%d,:%d\r\n",u8tmp,contact_id,motion[u8tmp]);
                    // 判断有上报数据即为有触摸
                    touch_noout_flag = 1;
                }
            }

            memset(&Pre_Tip,0,sizeof(Pre_Tip));
            memset(&Pre_Confidence,0,sizeof(Pre_Confidence));
            // 用于 contact_id 去重和排序
            temp = 0xff;
            for (u8tmp = 0; u8tmp < TP_MAX_FINGER_COUNT; u8tmp++) {
                if (u8tmp < cnt){
                    contact_id = ptp_reports.finger_rpt[u8tmp].contactID;
                    Pre_Tip[contact_id] = ptp_reports.finger_rpt[u8tmp].tip;
                    Pre_Confidence[contact_id] = ptp_reports.finger_rpt[u8tmp].confidence;
                } else {
                    // 从低往高取空闲id，清空位置
                    contact_id = LOW1BIT(temp);
                    ptp_reports.finger_rpt[u8tmp].contactID= contact_id;
                    ptp_reports.finger_rpt[u8tmp].tip = 0;
                    ptp_reports.finger_rpt[u8tmp].confidence= 0;
                    ptp_reports.finger_rpt[u8tmp].x_l8= 0;
                    ptp_reports.finger_rpt[u8tmp].x_m4 = 0;
                    ptp_reports.finger_rpt[u8tmp].y_l4= 0;
                    ptp_reports.finger_rpt[u8tmp].y_m8= 0;
                }
                temp &= ~(BIT(contact_id));
            }
        }
            // 触摸板按键有效 并且声明了报告按钮状态
        if ((flag_touchz & EVENT_BTN)!=0 ) 
        {
            motion_btn = 1;
            if((flag_touchz & 0x01) == 1) // 1: L-button press, 8: R-button press
            {
                touch_button_flag = 5;
                //DBG("down flag_touchz3 %d\n",flag_touchz);
                if (work_sys == SYS_MAC)//解决双指容易被识别为单指
                {
                    PRINT("cnt:%d, scan_time:%d",cnt, scan_time);
                    if (cnt == 2 && scan_time < 2000){
                        ptp_reports.button = 0;
                        ptp_reports.button1 = 1;
                        left2right_button_flag = 1;
                    } else {
                        ptp_reports.button=1;
                        ptp_reports.button1 = 0;
                        memcpy(&pre_contact, &original_reports.contacts[0], sizeof(CONTACT));
                    }
                } 
                else 
                {
                    ptp_reports.button = 1;
                }
                _touch_button_repeat_flag = 1;
                flag_touchz &= ~EVENT_BTN; // 清除按键事件标志
                _touch_button_repeat_count =0;
            }else if((flag_touchz & 0x01) == 0  && touch_button_flag == 0) // 2: L-button release, 16: R-button release
                {
                //DBG("up flag_touchz=%d\r\n",flag_touchz);
                if (work_sys == SYS_MAC)
                {
                    ptp_reports.button=0;
                } 
                else 
                    {
                    ptp_reports.button=0;
                    ptp_reports.button1=0;
                }
                _touch_button_repeat_flag = 0;
                flag_touchz &= ~EVENT_BTN; // 清除按键事件标志
                _touch_button_repeat_count =0;
            }
        }
       if (ptp_reports.button==1 && cnt == 1 && pre_contact.tip == 1 && is_contin_press == 0)
       {
            if (original_reports.contacts[0].tip == 1 && original_reports.contacts[0].contact_id == pre_contact.contact_id)
            {
                if (abs(original_reports.contacts[0].x - pre_contact.x) > 50 || abs(original_reports.contacts[0].y - pre_contact.y) > 25)
                {
                    is_contin_press = 1;
                }
            }
        }
        if (is_contin_press == 1){
            // 持续保持按钮状态
            ptp_reports.button= 1;
        }
        if (Pre_Tip[0] == 0 && Pre_Tip[1] == 0 &&Pre_Tip[2] == 0 &&Pre_Tip[3] == 0&&Pre_Tip[4] == 0&&Pre_Tip[5] == 0){
            ptp_reports.button=0;
            ptp_reports.button1=0;
            _touch_button_repeat_flag = 0;
            motion_btn = 0;
            // 所有手指离开时 释放按钮
            is_contin_press = 0;
            touch_noout_flag |= 0x80;
            memset(&pre_contact, 0, sizeof(CONTACT));
        }
        // 当双指触发了右键时，需要发一次左键，防止卡死。
        if (ptp_reports.button == 0 && ptp_reports.button1 == 0){
            if (left2right_button_flag == 1){
                left2right_button_flag = 0;
                ptp_reports.button = 1;
            } else if (touch_noout_flag == 0x81){
                // 所有手指离开时,并且没有触发右键，判断为全部离开
                // TOUCH_MANAGER_PRINT("All fingers leave\r\n");
                touch_noout_flag = 0;
                if (ptp_reports.button == 1){
                    ptp_reports.button = 0;
                    motion_btn = 1;
                }
            }
        }
        // 用于判断是否存在不符合的值
        if (has_no_confidence() > 0){
            memset(&Pre_Confidence,0,sizeof(Pre_Confidence));
            ptp_reports.finger_rpt[0].confidence = 0;
            ptp_reports.finger_rpt[1].confidence = 0;
            ptp_reports.finger_rpt[2].confidence = 0;
            ptp_reports.finger_rpt[3].confidence = 0;
        }
        // data_status = 1;
        // touch_write_reg(0x71,0x00);
        return;
    }
    // touch_write_reg(0x71,0x00);
    return ;
}

