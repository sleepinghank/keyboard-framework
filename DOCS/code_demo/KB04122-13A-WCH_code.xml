{
    uint8_t  status = 0;
    /* 当前是ImageA，直接编程 */
    status = FLASH_ROM_WRITE(OpAdd, flash_buf, flash_buf_uesd_len);
    if(status)
    {
#if(DEBUG_OTA)
        PRINT("IAP_PROM err \r\n");
