/*********************************************************************
 * @fn      keyscan_process_event
 *
 * @brief   keyboard 事件处理
 *
 * @param   task_id - 任务ID
 * @param   events  - 事件标志
 *
 * @return  未完成事件
 */
uint16_t keyscan_process_event(uint8_t task_id, uint16_t events)
{

    if(events & IDEL_SLEEP_EVENT)
    {
        PRINT("@S\n");
        idel_sleep_flag = TRUE;

        if(work_mode == MODE_BT)
        {
            access_ble_enter_idel_sleep();
        }
        else
        {
            access_enter_idel_sleep();
        }
        return events ^ IDEL_SLEEP_EVENT;
    }

    if(events & DEEP_SLEEP_EVENT)
    {
        PRINT("@Deep_sleep\n");
        deep_sleep_flag = TRUE;

        if(work_mode == MODE_BT)
        {
            access_ble_enter_deep_sleep();
        }
        else
        {
            access_enter_deep_sleep();
        }

        return events ^ DEEP_SLEEP_EVENT;
    }
    return 0;
}

/*******************************************************************************
 * @fn      peripheral_sleep_update
 *
 * @brief   peripheral_sleep_update
 *
 * @return  None.
 */
__HIGH_CODE
void peripheral_sleep_update()//每次调用此函数（按键扫描）都会重新启动计时
{
    if( work_mode != MODE_USB)
    {
        if(idel_sleep_flag||deep_sleep_flag)
        {
            peripheral_exit_sleep();
        }
        if( connect_state == CON_CONNECTED)//已连接
        {
            //tmos_start_task(keyscan_taskID, IDEL_SLEEP_EVENT, IDEL_SLEEP_TIMEOUT);
            tmos_start_task(keyscan_taskID, DEEP_SLEEP_EVENT, DEEP_SLEEP_TIMEOUT);
        }
        else if( connect_state == CON_CONNECTING)//广播等待连接中
        {
            // 刷新休眠计时器
            tmos_start_task(keyscan_taskID, DEEP_SLEEP_EVENT, IDEL_DEEP_SLEEP_TIMEOUT);
            // 刷新LED闪烁任务的超时时间，使其与广播状态同步(需要区分回连还是广播)
            // 这样只要广播还在继续（按键扫描刷新了休眠时间），LED灯语就会一直存在
            tmos_clear_event(keyboard_taskID, KEYBOARD_LED_TIMEOUT_EVENT);
            tmos_start_task(keyboard_taskID, KEYBOARD_LED_TIMEOUT_EVENT, PAIRING_LED_BLINK_TIMEOUT);
            // 确保LED闪烁任务在运行（如果已经运行，会刷新超时时间；如果未运行，会启动它）
            tmos_start_reload_task(keyboard_taskID, KEYBOARD_LED_BLINK_EVENT, PAIRING_LED_BLINK_INTERVAL);
        }
        else //未连接（CON_IDEL）
        {
            tmos_start_task(keyscan_taskID, DEEP_SLEEP_EVENT, IDEL_DEEP_SLEEP_TIMEOUT);
        }
    }
    else //usb模式停止所有睡眠
    {
        tmos_stop_task(keyscan_taskID, IDEL_SLEEP_EVENT);
        tmos_stop_task(keyscan_taskID, DEEP_SLEEP_EVENT);
    }
}

/*******************************************************************************
 * @fn      peripheral_enter_sleep
 *
 * @brief   peripheral_enter_sleep
 *
 * @return  None.
 */
const uint32_t KEY_ROW_MASK_A = (GPIO_Pin_0 | GPIO_Pin_1 | GPIO_Pin_4 | GPIO_Pin_5 | GPIO_Pin_6 | GPIO_Pin_8 | GPIO_Pin_9);
void peripheral_enter_sleep()//拉低所有列，读取行，中断在行上
{
    PWMX_LED_ALL_OFF();
    VBAT_CHECK_DISABLE();
    //PILOT_LED_ALL_SHUTDOWN();
    ADC_DisablePower();

    // GPIOB_ModeCfg(GPIO_Pin_23, GPIO_ModeIN_PD);
    GPIOA_ModeCfg(GPIO_Pin_12, GPIO_ModeIN_PD);//PA14 pwm
    GPIOA_ModeCfg(GPIO_Pin_13, GPIO_ModeIN_PD);//PA14 pwm
    GPIOA_ModeCfg(GPIO_Pin_14, GPIO_ModeIN_PD);//PA14 adc
    GPIOA_ModeCfg(GPIO_Pin_15, GPIO_ModeIN_PD);//PA15 白灯
    GPIOB_ModeCfg(GPIO_Pin_22, GPIO_ModeIN_PD);  // PB23 红灯

    GPIOB_ModeCfg(GPIO_Pin_22, GPIO_ModeIN_PD);  // PB22 boot引脚
    GPIOA_ModeCfg(GPIO_Pin_10, GPIO_ModeIN_PD);//PA10 未使用的32k晶振引脚
    GPIOA_ModeCfg(GPIO_Pin_11, GPIO_ModeIN_PU);//PA11 未使用的32k晶振引脚

    GPIOB_ModeCfg(GPIO_Pin_10, GPIO_ModeIN_PD);  // PB10 USB引脚
    GPIOB_ModeCfg(GPIO_Pin_11, GPIO_ModeIN_PD);  // PB11 USB引脚

    GPIOB_SetBits(KEY_C_0|KEY_C_1|KEY_C_2|KEY_C_3|KEY_C_4|KEY_C_5
    |KEY_C_6|KEY_C_7|KEY_C_8|KEY_C_9|KEY_C_10|KEY_C_12|KEY_C_14|KEY_C_15|KEY_C_16);       
    GPIOA_SetBits(KEY_C_11);
    GPIOB_ModeCfg(KEY_C_0|KEY_C_1|KEY_C_2|KEY_C_3|KEY_C_4|KEY_C_5
    |KEY_C_6|KEY_C_7|KEY_C_8|KEY_C_9|KEY_C_10|KEY_C_12|KEY_C_14|KEY_C_15|KEY_C_16,GPIO_ModeOut_PP_5mA);
    GPIOA_ModeCfg(KEY_C_11,GPIO_ModeOut_PP_5mA);
    
    for(uint8_t i = 0; i < KEY_TABLE_C; i++)
    {
        if(KEY_C_INDEX[i])
        {
            if(KEY_C_PORT[i] == 1)
            {
                GPIOB_ResetBits(KEY_C_INDEX[i]);
            }
            else
            {
                GPIOA_ResetBits(KEY_C_INDEX[i]);
            }
        }
    }
    //清除矩阵行上的中断标志位
    GPIOA_ClearITFlagBit(KEY_ROW_MASK_A);
    GPIOB_ClearITFlagBit(GPIO_Pin_9);
    //清除电源键PA2上的中断标志位
    GPIOA_ClearITFlagBit(GPIO_Pin_2);

    // 确保PA2为输入上拉模式（用于唤醒，睡眠前必须确认GPIO模式正确）
    GPIOA_ModeCfg(GPIO_Pin_2, GPIO_ModeIN_PU);
    // 配置PA2中断模式为下降沿触发（用于从休眠中唤醒）
    GPIOA_ITModeCfg(GPIO_Pin_2, GPIO_ITMode_FallEdge);
    // // 显式使能PA2中断（某些芯片需要在配置中断模式后手动使能中断）
    // R16_PA_INT_EN |= GPIO_Pin_2;
    
    for(uint8_t j = 0; j < KEY_TABLE_R; j++)
    {
        if( KEY_R_INDEX[j])
        {
            if(KEY_R_PORT[j] == 0)  // GPIOA
            {
                GPIOA_ITModeCfg(KEY_R_INDEX[j], GPIO_ITMode_FallEdge );
 
            }
            else  // GPIOB
            {
                GPIOB_ITModeCfg(KEY_R_INDEX[j], GPIO_ITMode_FallEdge );

            }
        }
    }
    PFIC_ClearPendingIRQ(GPIO_A_IRQn);
    PFIC_ClearPendingIRQ(GPIO_B_IRQn);
    PFIC_EnableIRQ(GPIO_A_IRQn);
    PFIC_EnableIRQ(GPIO_B_IRQn);
    PWR_PeriphWakeUpCfg(ENABLE, RB_SLP_GPIO_WAKE, Long_Delay);
    
}

