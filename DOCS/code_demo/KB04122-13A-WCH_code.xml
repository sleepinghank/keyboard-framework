 */
__attribute__((__aligned__(4))) uint32_t MEM_BUF[BLE_MEMHEAP_SIZE / 4];


__attribute__((used))
__HIGH_CODE
void process_main( void )
{
    while(1)
    {
        TMOS_SystemProcess();
        peripheral_process();
    }
}

uint8_t spike = FALSE;
static void check_skip_led_flag(void)
{
    uint8_t flag = 0x00;
    EEPROM_READ(RESET_SKIP_WAIT_ADDR, &flag, 1);

    if(flag == reset_skip_wait)
    {
        spike = TRUE;  
        EEPROM_ERASE(RESET_SKIP_WAIT_ADDR, EEPROM_PAGE_SIZE); // 清零，避免后续启动跳过
    }
}

static void power_key_wait_3s(void)
{
    const uint16_t SAMPLE_MS = 10;           // 采样间隔10ms
    const uint16_t LONG_PRESS_MS = 3000;     // 需要持续按下3秒
    uint16_t pressed_ms = 0;                 // 累计按下时间
    PRINT("等待电源键按下3秒...\n");
    while(1)
    {
        if (!GPIOA_ReadPortPin(GPIO_Pin_2))
        {
            pressed_ms += SAMPLE_MS;
            if (pressed_ms >= LONG_PRESS_MS)
            {
                PRINT("电源键长按3秒开机成功\n");
                return; 
            }
        }
        else
        {
            if (pressed_ms > 0)
            {
                PRINT("电源键松开重新等待3秒长按\n");
                pressed_ms = 0;
            }
        }   
        mDelaymS(SAMPLE_MS);
    }
}

/*******************************************************************************
* Function Name  : main
* Description    : 主函数
* Input          : None
* Output         : None
* Return         : None
*******************************************************************************/
int main( void )
{
    //电源相关
#if(defined(DCDC_ENABLE)) && (DCDC_ENABLE == TRUE)
    PWR_DCDCCfg(ENABLE);
#endif
    //时钟相关
    HSECFG_Capacitance(HSECap_18p);//负载电容配置
    HSECFG_Current(HSE_RCur_100);//晶振的驱动电流
    SetSysClock( CLK_SOURCE_HSE_PLL_78MHz );//设置系统时钟源和频率
    SysTick_Config(0xFFFFFFFF);//系统滴答定时器，tmos所需基准时间片
    PFIC_DisableIRQ(SysTick_IRQn);//禁用系统滴答定时器中断
    mDelaymS(2);
    //GPIO配置 0输入1输出
    R32_PA_DIR &= 0;
    R32_PB_DIR &= 0;//io方向
    R32_PA_PU |= 0xFF7FFFFF;//去掉复位脚PB23配置
    R32_PB_PU |= 0xFFF7F3FF;//上拉使能，除了usb的引脚PB11,PB10,去掉PB19

    //GPIOA_ModeCfg(GPIO_Pin_11, GPIO_ModeIN_PU);//触摸板开关，芯片上电默认拉高，触摸板不上电
    GPIOB_ModeCfg(GPIO_Pin_23, GPIO_ModeIN_PD);//复位引脚，需要用来控制红灯
    //日志相关
#ifdef DEBUG
    GPIOPinRemap(ENABLE,RB_PIN_UART1);//串口带“_”的是映射引脚需要开启
    GPIOB_SetBits( GPIO_Pin_13 );
    GPIOB_ModeCfg( GPIO_Pin_13, GPIO_ModeOut_PP_5mA );
    UART1_DefInit( );
    UART1_BaudRateCfg( 115200 );
#endif

    PRINT("main-----\n");

    //引脚？不知道干嘛了，15引脚是什么模式选择，用不上先注释
    // GPIOB_ModeCfg( (1<<22), GPIO_ModeIN_PU );
    // GPIOB_ModeCfg( (1<<15), GPIO_ModeIN_PU );
