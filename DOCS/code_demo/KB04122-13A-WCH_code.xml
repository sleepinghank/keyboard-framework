#include "CH58x_common.h"
#include "power_key.h"
#include "keyscan.h"    
#include "hidkbd.h"     
#include "usb.h"        
#include "rf.h"         
#include "peripheral.h"
#include "keyboard.h"
#include "access.h" 

// 电源按键引脚PA2,配置为上拉模式，该按键按下会拉低PA2
uint8_t power_key_task_id = 0;
volatile power_key_state_t power_key_state = POWER_KEY_IDLE;
volatile uint8_t pa2_isr_pending = 0;
volatile uint8_t long_fired = 0;

extern uint8_t sys_data_byte[2+1];
extern uint8_t key_data_byte[8+1+1];
extern uint8_t work_mode;
extern uint8_t work_sys;
extern uint8_t trans_ble_send_data(uint8_t *pData, uint8_t len);
extern uint8_t trans_send_data(uint8_t *pData, uint8_t len);

static void send_lock_screen_release(void)//锁屏键释放
{
    PRINT("send_lock_screen_release\n");
    sys_data_byte[1] = 0x00;
    sys_data_byte[2] = 0x00;
//            trans_send_data(sys_data_byte,2+1);
    if(work_mode == MODE_BT)
    {
        trans_ble_send_data(sys_data_byte,2+1);
    }
    else
    {
        trans_send_data(sys_data_byte,2+1);
    }
}

static void send_lock_screen_combo(void)//锁屏键发送
{
    PRINT("send_lock_screen_combo\n");
    sys_data_byte[1] = 0x30;
    sys_data_byte[2] = 0x00;
//                trans_send_data(sys_data_byte,2+1);
    if(work_mode == MODE_BT)
    {
        trans_ble_send_data(sys_data_byte,2+1);
    }
    else
    {
        trans_send_data(sys_data_byte,2+1);
    }

}

void do_power_off(void)//关机函数
{
    PRINT("POWER OFF");
    GPIOB_ModeCfg(GPIO_Pin_19, GPIO_ModeIN_PD);
    mDelaymS(100);
}

void power_key_init(void)
{
    power_key_task_id = TMOS_ProcessEventRegister(power_key_process);
    
    GPIOA_ModeCfg(GPIO_Pin_2, GPIO_ModeIN_PU);
    
    GPIOA_ITModeCfg(GPIO_Pin_2, GPIO_ITMode_FallEdge);
    
    GPIOA_ClearITFlagBit(GPIO_Pin_2);
    
    R16_PA_INT_EN |= GPIO_Pin_2;
    
    PFIC_ClearPendingIRQ(GPIO_A_IRQn);
    PFIC_EnableIRQ(GPIO_A_IRQn);
    
    PRINT("power_key_init done, PA2 configured\n");
}

void power_key_resume(void)
{
    // 恢复power_key中断配置（唤醒后调用）
    GPIOA_ModeCfg(GPIO_Pin_2, GPIO_ModeIN_PU);
    
    GPIOA_ITModeCfg(GPIO_Pin_2, GPIO_ITMode_FallEdge);
    
    GPIOA_ClearITFlagBit(GPIO_Pin_2);
    
    R16_PA_INT_EN |= GPIO_Pin_2;
    
    PFIC_ClearPendingIRQ(GPIO_A_IRQn);
    PFIC_EnableIRQ(GPIO_A_IRQn);
    
    // 重置状态，防止唤醒时按键状态异常
    power_key_state = POWER_KEY_IDLE;
    long_fired = 0;
    
    PRINT("power_key_resume done, PA2 restored\n");
}

uint16_t power_key_process(uint8_t taskId, uint16_t events)
{
    if (events & POWER_KEY_DEBOUNCE_EVT)//中断触发后，去抖动事件
    {
        pa2_isr_pending = 0;
        PRINT("PowerKey: DEBOUNCE_EVT, state=%d\n", power_key_state);

        if (power_key_state == POWER_KEY_IDLE)
        {
            if (!GPIOA_ReadPortPin(GPIO_Pin_2))//如果pa2仍然为低电平判定为按下
            {
                power_key_state = POWER_KEY_PRESSED;
                long_fired = 0;
                tmos_start_task(power_key_task_id, POWER_KEY_LONGPRESS_EVT, POWER_KEY_LONGPRESS_MS);//三秒后触发长按事件
                PRINT("PowerKey: pressed, task_id=%d\n", power_key_task_id);
                GPIOA_ITModeCfg(GPIO_Pin_2, GPIO_ITMode_RiseEdge);//配置pa2为上升沿触发

                peripheral_sleep_update();//唤醒系统并重新启动休眠计时器
                backlight_wakeup();//唤醒背光

            }
            else
            {
                PRINT("PowerKey: idle but pin is high, ignoring\n");
            }

            R16_PA_INT_EN |= GPIO_Pin_2;
        }
        else if (power_key_state == POWER_KEY_PRESSED)//被上升沿中断触发
        {
            if (GPIOA_ReadPortPin(GPIO_Pin_2))//如果pa2为高电平判定为释放
            {
                PRINT("PowerKey: released\n");

                if (!long_fired)
                {

                    send_lock_screen_combo();
                }
                tmos_start_task(power_key_task_id, POWER_KEY_RELEASE_EVT, 500);//200ms后释放
                power_key_state = POWER_KEY_IDLE;
                long_fired = 0;
                GPIOA_ITModeCfg(GPIO_Pin_2, GPIO_ITMode_FallEdge);
            }

            R16_PA_INT_EN |= GPIO_Pin_2;
        }
        return (events ^ POWER_KEY_DEBOUNCE_EVT);
    }

    if (events & POWER_KEY_LONGPRESS_EVT)
    {
        if (power_key_state == POWER_KEY_PRESSED && !GPIOA_ReadPortPin(GPIO_Pin_2))//3秒后仍然为按下状态
        {

            long_fired = 1;
            PRINT("PowerKey: longpress 3s, power off\n");
            do_power_off();
        }
        return (events ^ POWER_KEY_LONGPRESS_EVT);
    }

    if (events & POWER_KEY_RELEASE_EVT)
    {
        send_lock_screen_release();
        return (events ^ POWER_KEY_RELEASE_EVT);
    }

    return 0;
}
