             {
                 trans_send_data(key_data_byte, 8+1+1);
             }  
             break;             
        }
        case 0xE5:// SHIFT
        {
         //背光亮度加 所有模式下有效（0%-25%-50%-75%-100%默认）
            //调至极限值时（注意是达到极限值时闪烁，不是超出档位再提示），
            //指示灯闪烁3 次指示（备注：只是单独指示灯提示）
            nvs_flash_info.led_light++;
            nvs_flash_info.led_light%=LED_LIGHT_MAX;
            nvs_flash_store();
            tmos_set_event(keyboard_taskID, KEYBOARD_BACKLIGHT_UPDATE_EVENT);
            break;
        }
        case 0x28:// ENTER
        {
            if(nvs_flash_info.led_onoff&&nvs_flash_info.led_light>0)
            {
                    tmos_stop_task(keyboard_taskID, KEYBOARD_LED_BLINK_EVENT);
                    led_now++;
                    if(led_now > 7) {
                        led_now = 1;
                    }
                    switch(led_now)
                    {
                        case 1:
                            led_blink_range = LED_BLINK_R6;
                            break;
                        case 2:
                            led_blink_range = LED_BLINK_R3;
                            break;
                        case 3:
                            led_blink_range = LED_BLINK_R5;
                            break;
                        case 4:
                            led_blink_range = LED_BLINK_R4;
                            break;
                        case 5:
                            led_blink_range = LED_BLINK_R1;
                            break; 
                        case 6:
                            led_blink_range = LED_BLINK_R2;
                            break;
                        case 7:
                            led_blink_range = LED_BLINK_ALL;
                            break;        
                    }
                    
                  
                    
                    nvs_flash_info.led_blink_range = led_blink_range;
                    nvs_flash_store();
                    
                    tmos_set_event(keyboard_taskID, KEYBOARD_BACKLIGHT_UPDATE_EVENT);
            }
             break;
        }
        case 0xE7://KB_R_GUI - 组合键触发电量指示灯闪烁
        {
            // 如果当前是自动低电压警告，先停止
            if(vbat_led_num == 5 || vbat_led_num == 6)
            {
                GPIOB_ModeCfg(GPIO_Pin_23, GPIO_ModeIN_PD);
                tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT);
                tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_TIMEOUT_EVENT);
                vbat_led_blink_count = 0;
                vbat_led_blink_state = 0;
            }
            // 获取电量信息并设置vbat_led_num
            keyboard_get_batt_info();
            // 启动红灯闪烁任务
            if(vbat_led_num > 0 && vbat_led_num <= 4)
            {
                // 停止之前的闪烁任务（如果存在）
                tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT);
                tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_TIMEOUT_EVENT);
                // 重置闪烁状态
                vbat_led_blink_count = 0;
                vbat_led_blink_state = 0;
                // 启动闪烁任务（立即开始第一次闪烁）
                tmos_set_event(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT);
                // 启动超时保护任务
                tmos_start_task(keyboard_taskID, KEYBOARD_VBAT_LED_TIMEOUT_EVENT, VBAT_LED_BLINK_TIMEOUT);
            }
            break;
        }
        case 0xF0://FN键单独按下（MAC模式）地球键
        {
            {
                sys_data_byte[1] = 0x9D;
                sys_data_byte[2] = 0x02;
//                trans_send_data(sys_data_byte,2+1);
                if(work_mode == MODE_BT)
                {
                    trans_ble_send_data(sys_data_byte,2+1);
                }
                else
                {
                    trans_send_data(sys_data_byte,2+1);
                }
            }
            break;
        }
    }
}

/*********************************************************************
 * @fn      keyboard_fn_press
 *
 * @brief   keyboard_fn_press
 *
 * @return  none
 */
void keyboard_fn_release(uint8_t key)
{
    PRINT("r %x\n",key);
    switch(key)
    {
        case 0x1E://01
        {
            if(work_mode==MODE_BT)
            {
                //如果在对应模式下短按FN+对应数字键，则数字键这一行（对应R1这行）灯闪烁2s，频率为1Hz
                access_ctl_process(CTL_MODE_BLE_1);
            }
            break;
        }
        case 0x1F://02
        {
            if(work_mode==MODE_BT)
            {
                //如果在对应模式下短按FN+对应数字键，则数字键这一行（对应R1这行）灯闪烁2s，频率为1Hz
                access_ctl_process(CTL_MODE_BLE_2);
            }
            break;
        }
        case 0x20://03
        {
            if(work_mode==MODE_BT)
            {
                //如果在对应模式下短按FN+对应数字键，则数字键这一行（对应R1这行）灯闪烁2s，频率为1Hz
                access_ctl_process(CTL_MODE_BLE_3);
            }
            break;
        }
        case 0x21://04
        {
            if(work_mode==MODE_2_4G)
            {

            }
            break;
        }
        case 0x3A://F1
        case 0x3B://F2
        case 0x3C://F3
        case 0x3D://F4
        case 0x3E://F5
        case 0x3F://F6
        case 0x40://F7
        case 0x41://F8
        case 0x42://F9
        case 0x43://F10
        case 0x44://F11
        case 0x45://F12
        case 0xF0://FN
        {
            sys_data_byte[1] = 0x00;
            sys_data_byte[2] = 0x00;
//            trans_send_data(sys_data_byte,2+1);
            if(work_mode == MODE_BT)
            {
                trans_ble_send_data(sys_data_byte,2+1);
            }
            else
            {
                trans_send_data(sys_data_byte,2+1);
            }
            break;
        }
    }
}

