void touch_Sleep(void)
{
	uint8_t val;
	// return;
#ifdef CONFIG_DEBUG_MSG
	//DBGPRINTF((">> touch_Sleep\r\n"));
#endif
	touch_write_reg(0x7f,0x06);

	touch_read_reg(0x7c,&val);

	if((val & 0x01) == 0x00)
	{
		touch_write_reg(0x7c,val | 0x01);

		while(1)
		{
			touch_read_reg(0x7c,&val);

			if((val & 0x10) == 0x00)
				break;
		}
	}

	touch_write_reg(0x7B,0x01);

	touch_write_reg(0x7A,0xAA);    //suspend
	touch_en = 0;
}

void touch_Resume(void)
{
	touch_en = 1;
	touch_write_reg(0x7A,0xDD);    //resume
}

