#define REG_RESUME_CODE   0x7A
#define RESUME_CODE       0xBB
#define REG_BOOT_STATUS   0x70
#define RESUME_RETRY_MAX  50

void touch_resume_flow(void)
{
    uint8_t i = 0;
    uint8_t boot_status = 0xFF;

    // 1. 写 resume code
    touch_write_reg(REG_RESUME_CODE, RESUME_CODE);

    // 2. 轮询 boot ready
    for(i = 0; i < RESUME_RETRY_MAX; i++)
    {
        mDelaymS(10); // 延时10ms

       	touch_read_reg(REG_BOOT_STATUS,&boot_status);

        if((boot_status & 0x01) == 0) // boot ready status[0] == 0
        {
            // 进入Active Mode
            PRINT("Resume success, enter Active Mode\n");
            return ;
        }
    }

    // 超过最大次数仍未ready
    PRINT("Resume failed, boot status: 0x%02X\n", boot_status);
    return;
}

#define REG_SLEEP_CTRL     0x7C
#define REG_SLEEP_STATUS   0x7C
#define REG_HOST_RESET     0x7B
#define REG_SW_RESET       0x7A

#define SW_RESET_CODE1     0xAA
#define SW_RESET_CODE2     0xBB

#define RESET_RETRY_MAX    100

int software_reset_flow(void)
{
    uint8_t i = 0;
    uint8_t sleep_status = 0;

    // 1. 禁用deep-sleep模式
	PRINT("there");
    touch_write_reg(REG_SLEEP_CTRL, 0x01);

    // 2. 轮询SLEEP_STATUS[4] == 1
    for(i = 0; i < RESET_RETRY_MAX; i++)
    {
        mDelaymS(10); // 延时10ms

        touch_read_reg(REG_SLEEP_STATUS,&sleep_status);
		PRINT("sleep_status:0x%02X\r\n",sleep_status);
        if(sleep_status & 0x10) // SLEEP_STATUS[4] == 1
        {
            break;
        }
    }

    if(i >= RESET_RETRY_MAX)
    {
        PRINT("Software reset failed: SLEEP_STATUS[4] not set\n");
        return -1;
    }

    // 3. 使能host reset
    touch_write_reg(REG_HOST_RESET, 0x00);

    // 4. 写software reset code 1
    touch_write_reg(REG_SW_RESET, SW_RESET_CODE1);

    // 5. 延时10ms
    mDelaymS(10);

    // 6. 写software reset code 2
    touch_write_reg(REG_SW_RESET, SW_RESET_CODE2);

    // 7. 复位流程结束
    //printf("Software reset flow finished.\n");
    return 0;
}

