uint8_t touch_read_PTP_Report(TOUCHPAD_EVENT *pp)
{
	uint8_t read_len;
	uint8_t ptp_data[6*TP_MAX_FINGER_COUNT]= {0};
	uint8_t TP_Count = 0, i,size= 0;
	touch_read_reg(0x01, (uint8_t*)&TP_Count);
	if(TP_Count <= 0){
		return 0;
	}
		
	memset(pp, 0x00, sizeof(TOUCHPAD_EVENT));
	
	pp->contact_count = TP_Count;

	read_len = 6*TP_Count;
	PTP_read_reg(0x80|0x02, &ptp_data[0], read_len);

	for (i = 0; i < TP_Count; i++)
	{	
		pp->contacts[i].tip  = ((ptp_data[i*6])&0x01);
		pp->contacts[i].confidence  = ((ptp_data[i*6])&0x02)>>1;
		pp->contacts[i].contact_id= (ptp_data[i*6+1]&0x07);
		pp->contacts[i].x  = ((ptp_data[i*6+3])<<8)+(ptp_data[i*6+2]);
		pp->contacts[i].y  = ((ptp_data[i*6+5])<<8)+(ptp_data[i*6+4]);	
		// 单独获取触摸大小
		// touch_read_reg(0x20 + i * 12, (uint8_t*)&size);
		pp->contacts[i].size = size;
	}
	return 1;
}

