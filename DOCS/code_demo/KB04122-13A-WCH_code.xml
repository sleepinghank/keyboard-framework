/// @return 1 存在无效数据，0 不存在无效数据
uint8_t has_no_confidence(void){
    uint8_t temp = 0;
    for (temp = 0; temp < TP_MAX_FINGER_COUNT; temp++)
    {
        if (ptp_reports.finger_rpt[temp].confidence == 0 && ptp_reports.finger_rpt[temp].tip == 1)
        {
            return 1;
        }
    }
    return 0;
}
/// @brief 根据X 轴 从大到小排序 冒泡排序
void bubble_sort(CONTACT arr[], int len) {
    int i, j;
    CONTACT temp;
    for (i = 0; i < len - 1; i++){
        for (j = 0; j < len - 1 - i; j++){
            if (arr[j].x < arr[j + 1].x) {
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}
