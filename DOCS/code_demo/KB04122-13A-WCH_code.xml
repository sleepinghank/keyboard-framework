int8_t touch_write_reg(uint8_t reg, uint8_t val)
{
    uint8_t buf[2];
    buf[0] = reg;   // 寄存器地址
    buf[1] = val;   // 要写入的数据
    // 设备地址右移一位，i2c_write_to会自动加上R/W位
    return i2c_write_to(TOUCH_SLAVE_ID, buf, 2, true, true) == 0;
}

int8_t touch_read_reg(uint8_t addr, uint8_t * p_val)
{
 // 第一步：写寄存器地址，不发STOP
    int ret = i2c_write_to(TOUCH_SLAVE_ID, &addr, 1, true, false);
    if(ret != 0) return 0;

    // 第二步：读数据，发STOP
    ret = i2c_read_from(TOUCH_SLAVE_ID, p_val, 1, true, 10);
    return (ret > 0);
   
}

int8_t PTP_read_reg(uint8_t addr, uint8_t * p_val, uint8_t sz)
{
    // 第一步：写寄存器地址，不发STOP
    int ret = i2c_write_to(TOUCH_SLAVE_ID, &addr, 1, true, false);
    if(ret != 0) return 0;

    // 第二步：连续读sz字节，发STOP
    ret = i2c_read_from(TOUCH_SLAVE_ID, p_val, sz, true, 10);
    return (ret > 0);
}


uint8_t touch_write_user_reg(uint8_t bank, uint8_t addr, uint8_t val)
{
	touch_write_reg(0x7f,0x06);
    mDelayuS(500);
	touch_write_reg(0x73,bank);
	mDelayuS(500);
	touch_write_reg(0x74,addr);
	mDelayuS(500);
	touch_write_reg(0x75,val);
	mDelayuS(500);
	return 1;
}

uint8_t touch_read_user_reg(uint8_t bank, uint8_t addr, uint8_t * p_val)
{
	touch_write_reg(0x7f,0x06);
    mDelayuS(500);
	touch_write_reg(0x73,bank);
	mDelayuS(500);
	touch_write_reg(0x74,addr);
	mDelayuS(500);
	touch_read_reg(0x75, p_val);	
	mDelayuS(500);
	return 1;
}


uint8_t touch_read_motion(uint8_t *p_type, uint8_t *p_deltaX, uint8_t *p_deltaY, uint8_t *p_deltaZ,uint8_t *b_type)
{
	uint8_t status;
	uint8_t deltaX_l, deltaY_l, deltaX_h, deltaY_h;

	//touch_write_reg(0x7F,0x06); 
	touch_read_reg(0x71, &status);
//	//DBGPRINTF((">>0x71 : %02x\r\n", status));
	if (status != 0 )
	{
		//touch_write_reg(0x7F,0x06);
		touch_read_reg(0x6A, b_type);
		touch_read_reg(0x60, p_type);
		////DBGPRINTF((">> gestrue type: 0x%02x\r\n", p_type));
    	touch_read_reg(0x62, (uint8_t*)&deltaX_l);
		touch_read_reg(0x63, (uint8_t*)&deltaX_h);
		touch_read_reg(0x64, (uint8_t*)&deltaY_l);
		touch_read_reg(0x65, (uint8_t*)&deltaY_h);
		//touch_read_reg(0x66, (uint8_t*)&deltaZ_l);
		//touch_read_reg(0x67, (uint8_t*)&deltaZ_h);
											   
