/*********************************************************************
 * @fn      keyscan_scan
 *
 * @brief   keyscan_scan
 *
 * @return  none
 */
__HIGH_CODE
void keyscan_scan()
{
    //return;
    uint8_t i,j,k=0;
    uint8_t class_key_report_flag=0;
    uint8_t all_key_report_flag=0;
    uint8_t fx_key_report_flag=0;
    uint8_t fn_or_key_flag=0;;
//    uint32_t sys_cnt=0;
//    uint32_t sys_cnt_1=0;
//    sys_cnt = SYS_GetSysTickCnt();
    key_press_time++;
    // 采样
    for(i=0; i<KEY_TABLE_C; i++)//遍历所有列
    {
        //GPIOB_ResetBits(KEY_R_INDEX[i]);
        if(KEY_C_PORT[i] == 1) //分组拉低列
        {

            GPIOB_ModeCfg(KEY_C_INDEX[i],GPIO_ModeOut_PP_5mA);
            GPIOB_ResetBits(KEY_C_INDEX[i]);
        }
        else  // GPIOB
        {
            GPIOA_ModeCfg(KEY_C_INDEX[i],GPIO_ModeOut_PP_5mA);
            GPIOA_ResetBits(KEY_C_INDEX[i]);
        }
        //KEY_DETECTE_DELAY();//延时等待列电平稳定
        for(j=0; j<KEY_TABLE_R; j++)//在当前列遍历读取所有行
        {
            k = i*KEY_TABLE_R+j;//计算当前按键在矩阵中的索引
            uint16_t col_state;
            if(KEY_R_PORT[j] == 0)  // 分组读取行电平
            {
                col_state = GPIOA_ReadPortPin(KEY_R_INDEX[j]);
            }
            else  // GPIOB
            {
                col_state = GPIOB_ReadPortPin(KEY_R_INDEX[j]);
            }
            // if(!GPIOA_ReadPortPin(KEY_C_INDEX[j]))
            if(!col_state)//如果行电平为低，则表示按键被按下
            {
            //    if(KEY_TABLE[k]<0xF0)
            //        PRINT("Press: i=%d,j=%d,k=%d, KEY_TABLE[%d]=0x%02X, KEY_MAC_TABLE[%d]=0x%02X\n",
            //              i, j, k, k, KEY_TABLE[k], k, KEY_MAC_TABLE[k]);
                if(work_sys == SYS_WIN)
                {
                    key_data_scan_new[k] = KEY_TABLE[k];//将当前按键状态设置为按下
                }
                else
                {
                    key_data_scan_new[k] = KEY_MAC_TABLE[k];//将当前按键状态设置为按下 填入键值
                }
            }
            else//如果行电平为高，则表示按键未被按下
            {
                key_data_scan_new[k] = 0;//将当前按键状态设置为未按下
            }
        }
        // GPIOB_SetBits(KEY_R_0|KEY_R_1|KEY_R_2|KEY_R_3|KEY_R_4|KEY_R_5
        //     |KEY_R_6|KEY_R_7);
    //     GPIOA_SetBits(KEY_C_11);
    //     GPIOB_SetBits(KEY_C_0|KEY_C_1|KEY_C_2|KEY_C_3|KEY_C_4|KEY_C_5
    // |KEY_C_6|KEY_C_7|KEY_C_8|KEY_C_9|KEY_C_10|KEY_C_12|KEY_C_14|KEY_C_15|KEY_C_16);
      if(KEY_C_PORT[i] == 1) //分组恢复当前列
        {
            GPIOB_ModeCfg(KEY_C_INDEX[i], GPIO_ModeIN_PU);
        }
        else  // GPIOB
        {
            GPIOA_ModeCfg(KEY_C_INDEX[i], GPIO_ModeIN_PU);
        }
    }
    // 过滤
    if(key_scan_filter_count >= key_scan_filter_count_max)
    {
        key_scan_filter_count = 0;
        if(key_scan_filter_count_max)
        {
            if(!tmos_memcmp(key_data_scan_filter, key_data_scan_new, KEY_TABLE_R*KEY_TABLE_C))//如果相同则无抖动进入数据处理
            {
                peripheral_sleep_update();
                return;//如果不同则判定为抖动，return
            }
        }
    }
    else
    {
        if(key_scan_filter_count)//如果采样过滤次数大于1的判断
        {
            if(!tmos_memcmp(key_data_scan_filter, key_data_scan_new, KEY_TABLE_R*KEY_TABLE_C))
            {
                key_scan_filter_count = 0;
                peripheral_sleep_update();
                return;
            }
        }
        tmos_memcpy(key_data_scan_filter, key_data_scan_new, KEY_TABLE_R*KEY_TABLE_C);//将第一次扫描得到复制到过滤器用于比较
        key_scan_filter_count++;
        return;
    }

    // 处理数据
    if(!tmos_memcmp(key_data_scan_old, key_data_scan_new, KEY_TABLE_R*KEY_TABLE_C))
    {
        uint8_t key_byte_index=2+1;//前一字节为帧头
        {   //触摸板按键扫描
            uint8_t prev = key_data_scan_old[121];
            uint8_t curr = key_data_scan_new[121];
            if(prev == 0 && curr != 0)
            {
              // 刚刚按下
               if ((flag_touchz & 0x01) != 0x01)
               {
                    //  DEBUG_log("0x41");
                    flag_touchz = 0x41;
               }
            } 
            else if(prev != 0 && curr == 0) 
            {
              // 刚刚松开
              if ((flag_touchz & 0x01) != 0x00)
              {
                flag_touchz = 0x40;
                //  DEBUG_log("0x40");
              }
            }
        }
        tmos_memcpy(key_data_scan_old, key_data_scan_new, KEY_TABLE_R*KEY_TABLE_C);//保存本次扫描结果到 key_data_scan_old，用于下次比较（变化检测）
        tmos_memset(&key_data_byte[1], 0, 8);
        tmos_memset(&key_data_bit[1], 0, 15);//清空按键报告缓冲区
        peripheral_sleep_update();
        
        // 按键唤醒背光
        backlight_wakeup();
        // 先检查当前模式
        // if(key_data_scan_new[TABLE_IDX_SW_BLE])
        // {
        //     // SW_BLE
        //     if( work_mode != MODE_BT)
        //     {
        //         PRINT("MODE_BT\n");
        //         DelayMs(10);
        //         SYS_ResetExecute();
        //     }
        // }
        // else if(key_data_scan_new[TABLE_IDX_SW_24G])
        // {
        //     // SW_24G
        //     if( work_mode != MODE_2_4G)
        //     {
        //         PRINT("MODE_2_4G\n");
        //         DelayMs(10);
        //         SYS_ResetExecute();
        //     }
        // }
        // else
        // {
        //     if( work_mode != MODE_USB)
        //     {
        //         PRINT("MODE_USB\n");
        //         DelayMs(10);
        //         SYS_ResetExecute();
        //     }
        // }

        for(i=0; i<KEY_TABLE_R*KEY_TABLE_C; i++)
        {
            if (key_data_scan_new[i] == TOUCH_BUTTON)//清除触摸板按键
            {
                key_data_scan_new[i] = 0;
                key_data_scan_byte[i] = 0;
                key_data_scan_bit[i] = 0;
                continue;
            }
            if(key_data_scan_new[i] < key_data_scan_byte[i])    // 筛选标准键盘按键
            {
                //释放的按键
                if(key_data_scan_byte[i]<0xE0)
                {
                    key_byte_num--;
                }
                key_data_scan_byte[i] = 0;
                class_key_report_flag = 1;
            }
            else if((key_data_scan_new[i] == key_data_scan_byte[i]) && key_data_scan_new[i])
            {
                //为释放的按键，添加到按键列表
                if(key_data_scan_byte[i]<0xE0)
                {
                    key_data_byte[key_byte_index] = key_data_scan_new[i];
                    key_byte_index++;
                }
                else
                {
                    key_data_byte[0+1] |= 1<<(key_data_scan_byte[i]&0x0F);
                }
                key_data_scan_new[i] = 0;
            }
            else // 筛选全键盘按键
            {
                if(key_data_scan_new[i] < key_data_scan_bit[i])
                {
                    //释放的按键
                    key_data_scan_bit[i] = 0;
                    all_key_report_flag = 1;
                }
                else if((key_data_scan_new[i] == key_data_scan_bit[i]) && key_data_scan_new[i])
                {
                    //未释放的按键，添加到按键列表
                    key_data_bit[(key_data_scan_new[i]-4)/8+1] |= 1<<((key_data_scan_new[i]-4)%8);
                    key_data_scan_new[i] = 0;
                }
                else //筛选fn的按键
                {
                    if(key_data_scan_new[i] < key_data_scan_fx[i])
                    {
                        //释放的按键
//                        PRINT("FN-%x\n",key_data_scan_fx[i]);
                        if(key_data_scan_fx[i]==0xF0)
                        {
                            key_fn_flag = 0;
                            key_data_byte[9] = 0x00;
                            if(work_sys == SYS_MAC)
                            {
                                uint8_t has_other_key = 0;
                                // 检查是否有其他键同时按下（通过key_data_scan_fx数组）
                                for(uint8_t j = 0; j < KEY_TABLE_R*KEY_TABLE_C; j++)
                                {
                                    if(j != i && key_data_scan_fx[j] != 0 && key_data_scan_fx[j] != 0xF0)
                                    {
                                        // 有其他键与FN键组合按下
                                        has_other_key = 1;
                                        break;
                                    }
                                }
                                
                                // 如果没有其他键，FN键单独按下，触发组合键功能
                                if(!has_other_key)
                                {
                                    keyboard_fn_press(0xF0);
                                }
                                
                                class_key_report_flag = 1;
                            }
                        }
                        // else if(key_data_scan_fx[i]==0xFA)
                        // {
                        //     // EC11释放
                        //     //EC11_release();//Ӧ���ò���
                        // }
                        // 不考虑循环一轮的情况，太长了
                        if(KEY_TIMER_TABLE[i] )
                        {
                            // 若列表内值为0则表示已经进入了超时，不触发松开
                            if(key_timer_list[KEY_TIMER_TABLE[i]-1])
                            {
                                key_timer_list[KEY_TIMER_TABLE[i]-1] = 0;
                                //短按松开
                                keyboard_fn_release(key_data_scan_fx[i]);
                            }
                        }
                        else
                        {
                            //短按松开
                            keyboard_fn_release(key_data_scan_fx[i]);
                        }
                        key_data_scan_fx[i] = 0;
                    }
                    else if((key_data_scan_new[i] == key_data_scan_fx[i]) && key_data_scan_new[i])
                    {
                        //未释放的按键
                        key_data_scan_new[i] = 0;
                    }
                    else if(key_data_scan_new[i])
                    {
                        // 到这里说明按键未新按下，添加到按键列表
                        if(key_data_scan_new[i]<0xE0)
                        {
                            // 判断当前是否是mac模式
                            if(KEY_FXX_TABLE[i])
                            {
                                fn_or_key_flag = (work_sys == SYS_MAC)?(1):(key_fn_flag);//修改不论fn是否按下都发组合键，将!key_fn_flag改为1
                            }
                            else
                            {
                                fn_or_key_flag = key_fn_flag;
                            }

                            if(KEY_FN_TABLE[i] && fn_or_key_flag)
                            {
                                key_data_scan_fx[i] = key_data_scan_new[i];
                                
                                if(KEY_TIMER_TABLE[i])
                                {
                                    key_timer_list[KEY_TIMER_TABLE[i]-1] = key_press_time;
                                }
                                keyboard_fn_press(key_data_scan_new[i]);
//                                PRINT("FN+%x\n",key_data_scan_fx[i]);
                            }
                            else
                            {
                                if(key_byte_num<KEY_BYTE_NUM_MAX)
                                {
                                    key_byte_num++;
                                    key_data_scan_byte[i] = key_data_scan_new[i];
                                    key_data_byte[key_byte_index] = key_data_scan_new[i];
                                    key_byte_index++;
                                    class_key_report_flag = 1;
                                }
                                else
                                {
                                    key_data_bit[(key_data_scan_new[i]-4)/8+1] |= 1<<((key_data_scan_new[i]-4)%8);
                                    key_data_scan_bit[i] = key_data_scan_new[i];
                                    all_key_report_flag = 1;
                                }
                            }
                        }
                        else if(key_data_scan_new[i]<0xF0)
                        {
                            if(KEY_FN_TABLE[i] && key_fn_flag)
                            {
                                // fn+win没有长按，所以不判断
                                key_data_scan_fx[i] = key_data_scan_new[i];
                                keyboard_fn_press(key_data_scan_new[i]);
//                                PRINT("FN+%x\n",key_data_scan_fx[i]);
                            }
                            else
                            {
                                if(key_win_lock && (work_sys == SYS_WIN)
                                    && ((key_data_scan_new[i] == 0xE3)||(key_data_scan_new[i] == 0xE7)))
                                {
                                    //此时win已锁，且按了win键，不做处理
                                }
                                else
                                {
                                    key_data_scan_byte[i] = key_data_scan_new[i];
                                    key_data_byte[0+1] |= 1<<(key_data_scan_byte[i]&0x0F);
                                    class_key_report_flag = 1;
                                }
                            }
                        }
                        else
                        {
                            // 判断是否是FN按下
                            if(key_data_scan_new[i]==0xF0)
                            {
//                                PRINT("FN+%x\n",key_data_scan_fx[i]);
                                key_fn_flag = 1;
                                key_data_scan_fx[i] = key_data_scan_new[i];//�������еļ�ֵ����fn������
                                if(work_sys == SYS_MAC)
                                {
                                    key_data_byte[9] = 0x02;
                                    class_key_report_flag = 1;
                                }
                                else
                                {
                                    key_data_byte[9] = 0x00;
                                }
                            }
                            // else if(key_data_scan_new[i]==0xFA)
                            // {
                            //     // EC11按下
                            //     EC11_press();
                            //     key_data_scan_fx[i] = key_data_scan_new[i];
                            // }
                        }
                    }
                }
            }
        }
        if(class_key_report_flag)
        {
//            trans_send_data(key_data_byte,8+1+1);
            if(work_mode == MODE_BT)
            {
                trans_ble_send_data(key_data_byte,8+1+1);
            }
            else
            {
                trans_send_data(key_data_byte,8+1+1);
            }
        }
        if(all_key_report_flag)
        {
//            trans_send_data(key_data_bit,15+1);
            if(work_mode == MODE_BT)
            {
                trans_ble_send_data(key_data_byte,8+1+1);
            }
            else
            {
                trans_send_data(key_data_byte,8+1+1);
            }
        }
//        sys_cnt_1 = SYS_GetSysTickCnt();
//        PRINT("%d \n",(sys_cnt_1-sys_cnt)/60);
//        PRINT("nml %x %x %x %x %x %x %x %x\n",key_data_byte[0],key_data_byte[1],key_data_byte[2],key_data_byte[3],key_data_byte[4],key_data_byte[5],key_data_byte[6],key_data_byte[7]);
//        PRINT("all %x %x %x %x %x %x %x %x %x %x %x %x %x %x %x\n",
//            key_data_bit[0],key_data_bit[1],key_data_bit[2],key_data_bit[3],key_data_bit[4],key_data_bit[5],key_data_bit[6],key_data_bit[7]
//           ,key_data_bit[8],key_data_bit[9],key_data_bit[10],key_data_bit[11],key_data_bit[12],key_data_bit[13],key_data_bit[14]);
    }
    // 长按计时筛选
    for(i=0; i<KEY_TIMEOUT_NUM; i++)
    {
        if(key_timer_list[i])
        {
            if(((key_press_time - key_timer_list[i])/KEY_SCAN_FREQ)>KEY_TIMEOUT_LIST[i])
            {
                keyboard_fn_press_timeout(KEY_TIMEOUT_TABLE[i]);
                key_timer_list[i] = 0;
            }
        }
    }
}

