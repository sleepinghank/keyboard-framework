/// @brief 发送触摸数据
/// @return 0:无数据发送 1:有数据发送
// __INTERRUPT
// __HIGH_CODE
void ProcessPTPData(void)
{
    // PRINT("ProcessPTPData\r\n");
    // if (data_status == 0){
        ProcessGetPTPData();
    //     return 0;
    // }
    
    if(motion[0] ||motion[1] || motion[2] ||motion[3]||(ptp_reports.button==1)||(motion_btn ==1))
    {
        // TOUCH_MANAGER_PRINT("0:%d,1:%d,2:%d,3:%d,button:%d,motion_btn:%d\r\n",motion[0],motion[1],motion[2],motion[3],ptp_reports.button,motion_btn);
        scan_time += 100;
        ptp_reports.scantime_l8= (uint8_t)(scan_time&0x00ff);
        ptp_reports.scantime_m8= (uint8_t)((scan_time&0xff00)>>8);
        send_touch_data();
        #ifdef MCS_GESTURE
        if (ptp_reports.contactCnt == 1 && SystemConfig.touch_gesture_switch_bitmap > 0){
            if (scan_time % 200 == 0){
                touch_arr[touch_idx].x = (double)(( (uint16_t)(ptp_reports.finger_rpt[0].x_m4 & 0x0F) << 8 ) | (ptp_reports.finger_rpt[0].x_l8 & 0xFF));
                touch_arr[touch_idx].y = (double)(
                    ( (uint16_t)(ptp_reports.finger_rpt[0].y_m8 & 0xFF) << 4 ) |
                    (ptp_reports.finger_rpt[0].y_l4 & 0x0F)
                );
                if (keycode_type == IOS){
                    touch_arr[touch_idx].y = TOUCHPAD_MAX_Y - touch_arr[touch_idx].y;
                }
                touch_idx++;
                if (touch_idx >= 100){
                    touch_idx = 0;
                }
            }
        } else {
            touch_idx = 0;
        }
        #endif
        touch_count = 2;
    }
    if (Pre_Tip[0] == 0 && Pre_Tip[1] == 0 &&Pre_Tip[2] == 0 &&Pre_Tip[3] == 0&&Pre_Tip[4] == 0&&Pre_Tip[5] == 0 && ptp_reports.button == 0 && ptp_reports.button1 == 0){
        scan_time = 0;
        if (pass_flag == 0){
            memset(touch_datas, 0, sizeof(touch_datas));
        }
        #ifdef MCS_GESTURE
        gesture_judgment();
        touch_idx = 0;
        #endif
    }
    touch_write_reg(0x71,0x00);

    // data_status = 0;
    return;
}


