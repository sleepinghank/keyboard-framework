 */

#define EC11_SEND_RELEASE_DELAY_TIME            100
/*********************************************************************
 * GLOBAL TYPEDEFS
 */
uint8_t idel_time=0;
uint8_t release_flag=0;
/*********************************************************************
 * @fn      EC11_init
 *
