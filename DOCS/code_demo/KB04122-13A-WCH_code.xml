        tmos_stop_task(rfTaskID, RF_REPORT_DISCONNECT_EVENT);

    }
    else
    {
        RF_set_con_status(RF_CON_PAIRING);
        if( !(pSta->role&1) )
        {
            // 当前为接收端（dongle）
        }
        else
        {
            // 当前为发送端（鼠标）
        }
