/*********************************************************************
 * @fn      PWM_SAVE
 *
 * @brief   PWM_SAVE
 *
 * @return  none
 */
void PWM_SAVE()
{
    R32_PWM_RAM_SAFE_FLAG = PWM_RAM_SAFE_FLAG;
    R32_PWM_CONTROL_RAM = R32_PWM_CONTROL;
    R32_PWM4_7_DATA_RAM = R32_PWM4_7_DATA;
    R32_PWM8_11_DATA_RAM = R32_PWM8_11_DATA;
}

/*********************************************************************
 * @fn      backlight_wakeup
 *
 * @brief   backlight_wakeup
 *
 * @return  none
 */
void backlight_wakeup()//背光唤醒
{
    if(nvs_flash_info.led_onoff &&(vbat_led_num != 5 && vbat_led_num != 6))
    {

        PWMX_ACTOUT(nvs_flash_info.led_blink_range, nvs_flash_info.led_light*6, High_Level, ENABLE);
        PWM_SAVE();
        tmos_clear_event(keyboard_taskID, KEYBOARD_BACKLIGHT_TIMEOUT_EVENT);
        tmos_start_task(keyboard_taskID, KEYBOARD_BACKLIGHT_TIMEOUT_EVENT, BACKLIGHT_TIMEOUT);
    }
}

/*********************************************************************
 * @fn      backlight_start_timeout
 *
 * @brief   backlight_start_timeout
 *
 * @return  none
 */
void backlight_start_timeout()//背光超时关闭
{
    if(nvs_flash_info.led_onoff)
    {
        tmos_clear_event(keyboard_taskID, KEYBOARD_BACKLIGHT_TIMEOUT_EVENT);
        tmos_start_task(keyboard_taskID, KEYBOARD_BACKLIGHT_TIMEOUT_EVENT, BACKLIGHT_TIMEOUT);//5秒之后关闭背光
    }
}

/*********************************************************************
 * @fn      red_led_off
 *
 * @brief   red_led_off
 *
 * @return  none
 */
void red_led_off()
{
    GPIOB_ModeCfg(GPIO_Pin_23, GPIO_ModeIN_PD);
    tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT);
    tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_TIMEOUT_EVENT);
    vbat_led_blink_count = 0;
    vbat_led_blink_state = 0;
}

