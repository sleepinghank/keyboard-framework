/******************************************************************************/
/* 头文件包含 */
#include "peripheral.h"
#include "CONFIG.h"
#include "power_key.h"

/*********************************************************************
 * GLOBAL TYPEDEFS
 */

// // 开启了背光灯的模式下，整体背光闪烁三次
#define RESET_LED_BLINK_INTERVAL            1600*1/2
#define RESET_LED_BLINK_TIMEOUT             (1600*3 - 100)

// 背光超时时间
#define BACKLIGHT_TIMEOUT                   1600*5

// 电量指示灯闪烁参数
#define VBAT_LED_BLINK_ON_TIME              1600*1/2   // 亮的时间：500ms
#define VBAT_LED_BLINK_OFF_TIME             1600*1/2   // 灭的时间：500ms
#define VBAT_LED_BLINK_TIMEOUT              1600*10    // 总超时时间：10秒（防止异常）



uint8_t keyboard_taskID=0;
uint8_t vbat_info=0;
uint8_t vbat_led_num=0;
static uint8_t vbat_led_blink_count = 0;      // 当前已闪烁次数
static uint8_t vbat_led_blink_state = 0;      // 闪烁状态：0=灭，1=亮



uint32_t pilot_led_states = 0;

uint8_t led_blink_range=LED_BLINK_ALL;

signed short RoughCalib_Value = 0; // ADC粗调偏差值

connect_status_t connect_state=CON_IDEL;

/*********************************************************************
 * GLOBAL TYPEDEFS
 */
uint8_t keyboard_get_batt_info(void);
/*********************************************************************
 * @fn      keyboard_process_event
 *
 * @brief   keyboard 事件处理
 *
 * @param   task_id - 任务ID
 * @param   events  - 事件标志
 *
 * @return  未完成事件
 */
uint16_t keyboard_process_event(uint8_t task_id, uint16_t events)
{
    if(events & KEYBOARD_LED_BLINK_EVENT)//LED闪烁任务
    {
        {
           // PRINT("唤醒之后是否成功调用此任务\n");
            GPIOA_InverseBits(GPIO_Pin_15);
            GPIOA_ModeCfg(GPIO_Pin_15, GPIO_ModeOut_PP_5mA);//白灯
        }
        return events ^ KEYBOARD_LED_BLINK_EVENT;
    }

    if(events & KEYBOARD_BACKLIGHT_UPDATE_EVENT)//背光更新任务
    {
        //tmos_stop_task(keyboard_taskID, KEYBOARD_LED_BLINK_EVENT);
        if(nvs_flash_info.led_onoff &&(vbat_led_num != 5 && vbat_led_num != 6))//电量正常时，开启背光
        {
            PWMX_ACTOUT(LED_BLINK_ALL, nvs_flash_info.led_light*6, High_Level, DISABLE);
            PRINT("light %d\n",nvs_flash_info.led_light);
            PWMX_ACTOUT(nvs_flash_info.led_blink_range, nvs_flash_info.led_light*6, High_Level, ENABLE);
        }
        else
        {
            PWMX_ACTOUT(LED_BLINK_ALL, nvs_flash_info.led_light*6, High_Level, DISABLE);
        }
        PWM_SAVE();
        return events ^ KEYBOARD_BACKLIGHT_UPDATE_EVENT;
    }

    if(events & KEYBOARD_VBAT_INFO_EVENT)//电池电量采集与低电警告任务
    {
        vbat_info = keyboard_get_batt_info();
        //PRINT("bat： %d%%\n",vbat_info);
        // 如果检测到低电压警告，自动启动闪烁  除了启动闪烁还需要关闭背光pwm使能
        if(vbat_led_num == 5 || vbat_led_num == 6)
        {
            // 如果当前没有在闪烁，则启动闪烁
            if(vbat_led_blink_state == 0 && vbat_led_blink_count == 0)
            {
                tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT);
                tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_TIMEOUT_EVENT);
                vbat_led_blink_count = 0;
                vbat_led_blink_state = 0;
                tmos_set_event(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT);

                PWMX_ACTOUT(LED_BLINK_ALL, nvs_flash_info.led_light*6, High_Level, DISABLE);
                
                // 如果是严重低电压，启动2秒关机定时器
                if(vbat_led_num == 6)
                {
                    tmos_start_task(keyboard_taskID, KEYBOARD_VBAT_LED_TIMEOUT_EVENT, MS1_TO_SYSTEM_TIME(2000));
                }
            }
        }
        else
        {
            // 电压恢复正常，停止闪烁
            if(vbat_led_blink_state != 0 || vbat_led_blink_count != 0)
            {
                GPIOB_ModeCfg(GPIO_Pin_23, GPIO_ModeIN_PD);
                tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT);
                tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_TIMEOUT_EVENT);
                vbat_led_blink_count = 0;
                vbat_led_blink_state = 0;
            }
        }
        return events ^ KEYBOARD_VBAT_INFO_EVENT;
    }

    if(events & KEYBOARD_RESET_EVENT)//复位任务
    {
        SYS_ResetExecute();
        return events ^ KEYBOARD_RESET_EVENT;
    }

    if(events & KEYBOARD_BACKLIGHT_TIMEOUT_EVENT)//背光超时任务
    {
        if(nvs_flash_info.led_onoff)
        {
            PWMX_ACTOUT(LED_BLINK_ALL, nvs_flash_info.led_light*6, High_Level, DISABLE);//关闭背光
            PWM_SAVE();
        }
        return events ^ KEYBOARD_BACKLIGHT_TIMEOUT_EVENT;
    }

    if(events & KEYBOARD_LED_TIMEOUT_EVENT)//LED超时任务
    {
        tmos_stop_task(keyboard_taskID, KEYBOARD_LED_BLINK_EVENT);
        PRINT("白灯灭\n");
        GPIOA_ModeCfg(GPIO_Pin_15, GPIO_ModeIN_PD);//白灯灭
        return events ^ KEYBOARD_LED_TIMEOUT_EVENT;
    }

    if(events & KEYBOARD_VBAT_LED_BLINK_EVENT)//电量检测灯闪烁
    {
            // 持续闪烁模式（vbat_led_num == 5 或 6）
        if(vbat_led_num == 5 || vbat_led_num == 6)
        {
            GPIOB_ModeCfg(GPIO_Pin_23, GPIO_ModeOut_PP_5mA);
            
            if(vbat_led_blink_state == 0) // 当前是灭的状态，需要点亮
            {
                GPIOB_SetBits(GPIO_Pin_23);
                vbat_led_blink_state = 1;
                tmos_start_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT, VBAT_LED_BLINK_ON_TIME);
            }
            else // 当前是亮的状态，需要熄灭
            {
                GPIOB_ResetBits(GPIO_Pin_23);
                vbat_led_blink_state = 0;
                // 持续闪烁模式：不累加计数，永远继续闪烁
                tmos_start_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT, VBAT_LED_BLINK_OFF_TIME);
            }
            return events ^ KEYBOARD_VBAT_LED_BLINK_EVENT;
        }

        if(vbat_led_num == 0 || vbat_led_num > 4)
        {
            // 无效的电量值，直接恢复GPIO并返回
            GPIOB_ModeCfg(GPIO_Pin_23, GPIO_ModeIN_PD);
            tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT);
            tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_TIMEOUT_EVENT);
            vbat_led_blink_count = 0;
            vbat_led_blink_state = 0;
            return events ^ KEYBOARD_VBAT_LED_BLINK_EVENT;
        }

        // 配置GPIO为输出模式
        GPIOB_ModeCfg(GPIO_Pin_23, GPIO_ModeOut_PP_5mA);

        if(vbat_led_blink_state == 0) // 当前是灭的状态，需要点亮
        {
            // 点亮红灯（高电平）
            GPIOB_SetBits(GPIO_Pin_23);
            vbat_led_blink_state = 1;
            // 设置下次事件为灭（经过亮的时间后）
            tmos_start_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT, VBAT_LED_BLINK_ON_TIME);
        }
        else // 当前是亮的状态，需要熄灭
        {
            // 熄灭红灯（低电平）
            GPIOB_ResetBits(GPIO_Pin_23);
            vbat_led_blink_state = 0;
            vbat_led_blink_count++; // 完成一次闪烁（亮+灭）

            // 检查是否完成所有闪烁
            if(vbat_led_blink_count >= vbat_led_num)
            {
                // 闪烁完成，恢复GPIO为下拉输入模式
                GPIOB_ModeCfg(GPIO_Pin_23, GPIO_ModeIN_PD);
                // 停止所有相关任务
                tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT);
                tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_TIMEOUT_EVENT);
                // 重置状态
                vbat_led_blink_count = 0;
                vbat_led_blink_state = 0;
            }
            else
            {
                // 还有闪烁未完成，设置下次事件为亮（经过灭的时间后）
                tmos_start_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT, VBAT_LED_BLINK_OFF_TIME);
            }
        }
        return events ^ KEYBOARD_VBAT_LED_BLINK_EVENT;
    }

    if(events & KEYBOARD_VBAT_LED_TIMEOUT_EVENT)//电量指示灯闪烁超时
    {
        // 如果是严重低电压模式（vbat_led_num == 6），执行关机
        if(vbat_led_num == 6)
        {
            PRINT("Low battery, power off\n");
            // 调用关机函数
            do_power_off();
            return events ^ KEYBOARD_VBAT_LED_TIMEOUT_EVENT;
        }
        
        // 超时保护：强制结束闪烁并恢复GPIO
        GPIOB_ModeCfg(GPIO_Pin_23, GPIO_ModeIN_PD);
        tmos_stop_task(keyboard_taskID, KEYBOARD_VBAT_LED_BLINK_EVENT);
        vbat_led_blink_count = 0;
        vbat_led_blink_state = 0;
        PRINT("VBAT LED timeout\n");
        return events ^ KEYBOARD_VBAT_LED_TIMEOUT_EVENT;
    }
    
    return 0;
}
