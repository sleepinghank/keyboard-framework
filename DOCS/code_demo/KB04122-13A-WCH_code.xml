/// @brief PCT1336通信测试函数
void PCT1336_Communication_Test(void)
{
    uint8_t test_val =0;
    uint8_t retry_count = 0;
    uint8_t test_success = 0;
    
    TOUCH_MANAGER_PRINT("=== PCT1336 ===\n");
    
    // 测试1: 读取状态寄存器0x70
    for(retry_count = 0; retry_count < 3; retry_count++) {
        if(touch_read_reg(0x70, &test_val) == 1) {
            TOUCH_MANAGER_PRINT(" success: 0x%02X\n", test_val);
            test_success = 1;
            break;
        } else {
            TOUCH_MANAGER_PRINT(" error%d/3\n", retry_count + 1);
            mDelaymS(10);
        }
    }
    
    // 测试2: 读取设备ID寄存器
    if(test_success) {
        if(touch_read_reg(0x71, &test_val) == 1) {
            TOUCH_MANAGER_PRINT("success: 0x%02X\n", test_val);
        } else {
            TOUCH_MANAGER_PRINT("error\n");
        }
    }
    
    // 测试3: 写入测试寄存器
    if(test_success) {
        if(touch_write_reg(0x72, 0xBB) == 1) {
            TOUCH_MANAGER_PRINT("success\n");
            // 读取验证
            if(touch_read_reg(0x72, &test_val) == 1) {
                TOUCH_MANAGER_PRINT("success: 0x%02X\n", test_val);
            }
        } else {
            TOUCH_MANAGER_PRINT("error\n");
        }
    }
    
    if(test_success) {
        TOUCH_MANAGER_PRINT("=== PCT1336 success===\n");
    } else {
        TOUCH_MANAGER_PRINT("=== PCT1336 error ===\n");
    }
}

