/*********************************************************************
 * @fn      USB_Wake_up
 *
 * @brief   USB_Wake_up
 *
 * @return  none
 */
void USB_Wake_up( void )
{
    R16_PIN_CONFIG &= ~RB_UDP_PU_EN;         // USB上拉电阻
    R8_UDEV_CTRL |= RB_UD_LOW_SPEED;
    mDelaymS(8);
    R8_UDEV_CTRL &= ~RB_UD_LOW_SPEED;
    R16_PIN_CONFIG |= RB_UDP_PU_EN;         // USB上拉电阻
}

