/*******************************************************************************
 * @fn          RF_LowPower
 *
 * @brief       启动睡眠
 *
 * @param       time  -  睡眠的时间
 *
 * @return      none.
 */
__HIGH_CODE
void RF_LowPower(uint32_t time)
{
#if(defined(HAL_SLEEP)) && (HAL_SLEEP == TRUE)
    uint32_t  time_curr,time_set;
    unsigned long irq_status;

    sys_safe_access_enable();
    R8_RTC_MODE_CTRL &= ~RB_RTC_TRIG_EN;  // 触发模式
    sys_safe_access_disable();              //
    SYS_DisableAllIrq(&irq_status);

    time_curr = RTC_GetCycle32k();
    if( time >= RTC_MAX_COUNT - time_curr )
    {
        time_set = time - (RTC_MAX_COUNT - time_curr);
    }
    else
    {
        time_set = time + time_curr;
    }

    RTC_SetTignTime(time_set);
    gSleepFlag = TRUE;
    SYS_RecoverIrq(irq_status);
    sys_safe_access_enable();
    R8_RTC_MODE_CTRL |= RB_RTC_TRIG_EN;  // 触发模式
    sys_safe_access_disable();              //

//     LOW POWER-SLEEP模式
    LowPower_Sleep(RB_PWR_RAM96K | RB_PWR_EXTEND | RB_XT_PRE_EN );
    HSECFG_Current(HSE_RCur_100); // 降为额定电流(低功耗函数中提升了HSE偏置电流)
#endif
}

/*******************************************************************************
 * @fn      RF_ProcessEvent
 *
 * @brief   RF层系统任务处理
 *
 * @param   None.
 *
 * @return  None.
 */
tmosEvents RF_ProcessEvent( tmosTaskID task_id, tmosEvents events )
{
    if( events & SYS_EVENT_MSG )
    {
        uint8_t * msgPtr;

        msgPtr = tmos_msg_receive( task_id );
        if( msgPtr )
        {
            /* De-allocate */
            tmos_msg_deallocate( msgPtr );
        }
        return events ^ SYS_EVENT_MSG;
    }

    if( events & RF_START_BOUND_EVENT )
    {
        rfBoundDevice_t bound;

//        gRetry = 0;
        tmos_memset( &bound, 0, sizeof(rfBoundDevice_t) );
        PRINT("start tx mode\n");
        bound.devType = DEVICE_KEYBOARD_TYPE;
        bound.deviceId = DEVICE_KEYBOARD; // RF_ROLE_ID_INVALD表示由dongle端决定ID号，也可指定ID号
        bound.timeout = 150;
        bound.speed = 8;
//        bound.calVal = 21;
        tmos_memcpy(bound.OwnInfo, self_mac, 6);
        tmos_memcpy(bound.PeerInfo, nvs_flash_info.peer_mac, 6);
        bound.rfBoundCB = rfRoleBoundProcess;
//        RFBound_Start8kDevice( &bound );
        RFBound_StartDevice( &bound );
        RF_set_con_status(RF_CON_PAIRING);
        return events ^ RF_START_BOUND_EVENT;
    }

    if( events & RF_SLEEP_TRIGGER_EVENT )
    {
        tmos_start_task( rfTaskID, RF_SLEEP_EVENT, MS1_TO_SYSTEM_TIME( 1000 ) );
        return events ^ RF_SLEEP_TRIGGER_EVENT;
    }

    if( events & RF_SLEEP_EVENT )
    {
        if(deep_sleep_flag)
        {
            PRINT("deep s\n");
            RFRole_Shut();
            peripheral_enter_sleep();
            PWR_PeriphWakeUpCfg( DISABLE, RB_SLP_RTC_WAKE, Long_Delay );
//            LowPower_Sleep( RB_PWR_RAM96K | RB_PWR_RAM32K | RB_PWR_EXTEND ); //只保留24+2K SRAM 供电
//            HSECFG_Current(HSE_RCur_100); // 降为额定电流(低功耗函数中提升了HSE偏置电流)
            LowPower_Shutdown(0);
            SYS_ResetExecute();
            RFIP_WakeUpRegInit();
            rfDMADescInit();
            RFRole_FastInit( &conf );
            PWR_PeriphWakeUpCfg( ENABLE, RB_SLP_RTC_WAKE, Long_Delay );
            tmos_set_event( rfTaskID, RF_START_BOUND_EVENT );
        }
        else if(idel_sleep_flag)
        {
            PRINT( "g %x\r\n",gRetry );
            if(gRetry)
            {
                gRetry = 0;
                RFRole_Shut();
                peripheral_enter_sleep();
                RF_LowPower(MS_TO_RTC(80));
//                PWR_PeriphWakeUpCfg( DISABLE, RB_SLP_RTC_WAKE, Long_Delay );
//                PWR_PeriphWakeUpCfg( ENABLE, RB_SLP_GPIO_WAKE, Long_Delay );
//                LowPower_Sleep(RB_PWR_RAM96K | RB_PWR_EXTEND | RB_XT_PRE_EN );
//                rfDMADescInit();
//                RFRole_FastInit( &conf );
//                PWR_PeriphWakeUpCfg( ENABLE, RB_SLP_RTC_WAKE, Long_Delay );
//                tmos_set_event( rfTaskID, RF_START_BOUND_EVENT );
            }
            else if(!RF_check_con_status(RF_CON_CONNECTED))
            {
                RFRole_Shut();
                peripheral_enter_sleep();
                PWR_PeriphWakeUpCfg( DISABLE, RB_SLP_RTC_WAKE, Long_Delay );
                LowPower_Shutdown(RB_PWR_RAM96K);
                SYS_ResetExecute();
                RFIP_WakeUpRegInit();
                PWR_PeriphWakeUpCfg( ENABLE, RB_SLP_RTC_WAKE, Long_Delay );
                PRINT("w\n");
            }
        }

        return events ^ RF_SLEEP_EVENT;
    }

    if( events & RF_RECV_PROCESS_EVENT )
    {
        uint8_t len;
        uint8_t *pData;
        pData = rf_get_data(&len);
        if(pData)
        {
//            PRINT("P D%x\n", pData[0]);
            if(pData[0] == RF_DATA_IAP)
            {
                peripheral_sleep_update();
//                OTA_USB_IAPWriteData(&pData[1], len-1);
                OTA_USB_IAPWriteData(&pData[2], len-2);
            }
            else if(pData[0] == RF_DATA_LED)
            {
//                peripheral_pilot_led_receive(pData[1]);
                PRINT("led %x\n",pData[1]);
                peripheral_pilot_led_receive(pData[1]);
            }
            else if(pData[0] == RF_DATA_MANUFACTURER)
            {
                PRINT("MANUFACTURER %x\n",pData[2]);
                peripheral_sleep_update();
            }
            else if(pData[0] == RF_DATA_SLEEP)
            {
//                PRINT("SLEEP %x\n",pData[1]);
//                if( pData[1] == ENTER_SLEEP)
//                {
//                    TMR0_Disable();
//                    RF_enter_deep_sleep();
//                }
                PRINT("SLEEP %x\n",pData[2]);
                if( pData[2] == ENTER_SLEEP)
                {
                    deep_sleep_flag = 1;
                    tmos_start_task( rfTaskID, RF_SLEEP_EVENT, 160 );
                }
            }
            else {
              PRINT("??? %x\n",pData[0]);
            }
            rf_delete_data();
            tmos_set_event( rfTaskID, RF_RECV_PROCESS_EVENT );
        }
    }

    if( events & RF_REPORT_DISCONNECT_EVENT )
    {
//        PRINT( "REPORT disconnect.\n" );
        peripheral_sleep_update();
        peripheral_disconnected_cb();
        return events ^ RF_REPORT_DISCONNECT_EVENT;
    }

    if( events & RF_TEST_TX_EVENT )
    {
        PRINT(" %d %d\n", gTxCount,rssi_sum/(int32_t)gTxCount );
        gErrCount = 0;
        gTxCount = 0;
        rssi_sum = 0;
        return events ^ RF_TEST_TX_EVENT;
    }

    if( events & RF_TEST_RX_EVENT )
    {
        PRINT( "rx count-%d\n", gRxCount );
        PRINT( "rssi=%d\n", rssi );
        gRxCount = 0;
        return events ^ RF_TEST_RX_EVENT;
    }
    return 0;
}

/*******************************************************************************
 * @fn      RF_ReStart
 *
 * @brief   RF重新初始化
 *
 * @param   None.
 *
 * @return  None.
 */
void RF_ReStart( void )
{
    RFRole_Shut();
    RFRole_FastInit( &conf );
    peripheral_disconnected_cb();
    tmos_set_event( rfTaskID, RF_START_BOUND_EVENT );
    if(tmos_isbufset(nvs_flash_info.peer_mac, 0, 6))
    {
        peripheral_pairing_cb();
    }
    else {
        peripheral_connecting_cb();
    }
}


void RF_enter_idel_sleep( void )
{
    idel_sleep_flag = 1;
    tmos_set_event( rfTaskID, RF_SLEEP_EVENT );
}

void RF_enter_deep_sleep( void )
{
    deep_sleep_flag = 1;
    tmos_set_event( rfTaskID, RF_SLEEP_EVENT );
}

void RF_weakup( void )
{
    deep_sleep_flag = 0;
    idel_sleep_flag = 0;
    tmos_stop_task( rfTaskID, RF_SLEEP_EVENT );
    if(!RF_check_con_status(RF_CON_CONNECTED))
    {
        RFRole_Shut();
        RFRole_FastInit( &conf );
        tmos_set_event( rfTaskID, RF_START_BOUND_EVENT );
    }
}

void access_enter_idel_sleep( void )
{
    tmos_set_event( rfTaskID, RF_SLEEP_EVENT );
}

void access_enter_deep_sleep( void )
{
    tmos_set_event( rfTaskID, RF_SLEEP_EVENT );
}

__HIGH_CODE
void access_weakup( void )
{
    if((work_mode == MODE_2_4G)&&(!RF_check_con_status(RF_CON_CONNECTED)) && (deep_sleep_flag))
    {
        tmos_set_event( rfTaskID, RF_START_BOUND_EVENT );
    }
}

/*******************************************************************************
 * @fn      RF_stop
 *
 * @brief   RF_stop
 *
 * @param   None.
 *
 * @return  None.
 */
void RF_stop( void )
{
    RFRole_Shut();
    RF_Init();
    RF_set_con_status(RF_CON_IDEL);
}


/*******************************************************************************
 * @fn      RF_Init
 *
 * @brief   RF应用层初始化
 *
 * @param   None.
 *
 * @return  None.
 */
void RF_Init( void )
{
    rfTaskID = TMOS_ProcessEventRegister( RF_ProcessEvent );

    PRINT( "rf mode----------- Tx -----------\n" );
    PRINT( "%s\n", VER_LIB );
    GetMACAddress(self_mac);

    gErrContinue = 0;
    gErrCount = 0;
    gTxCount = 0;
    gRxCount = 0;
    gTestCount = 0;
    gTestData = 0;
    rfDMADescInit();
    {
        conf.TxPower = LL_TX_POWEER_4_DBM;
        conf.pTx = DMATxDscrTab;
        conf.pRx = DMARxDscrTab;
        conf.rfProcessCB = RF_ProcessCallBack;
        conf.processMask = RF_STATE_RX | RF_STATE_RBU | RF_STATE_TX_IDLE | RF_STATE_RX_RETRY  | RF_STATE_MAP_UPDATE;
//        conf.processMask = RF_STATE_RX | RF_STATE_RBU | RF_STATE_TX_IDLE | RF_STATE_RX_RETRY;
        PRINT( "RFRole_FastInit\n");
        RFRole_FastInit( &conf );

        // 初始RF参数，两端需配置相同才能连接

        gParm.accessAddress = 0x71437247;
//        gParm.accessAddress = 0x71764567;
        gParm.crcInit = 0x555555;
        gParm.frequency = 16;
        gParm.properties = PHY_MODE;
        gParm.rxMaxLen = RF_RX_BUF_SZE+PKT_ACK_LEN;
        PRINT("properties=%x\n",gParm.properties);
        PRINT( "RFRole_SetParam\n");
        RFRole_SetParam( &gParm );

    }
//    PFIC_EnableIRQ( BLEB_IRQn );
//    PFIC_EnableIRQ( BLEL_IRQn );
    PRINT( "******* f=%d\n", gParm.frequency );
    tmos_set_event( rfTaskID, RF_START_BOUND_EVENT );
//    peripheral_connecting_cb();
    RF_set_con_status(RF_CON_IDEL);
}


