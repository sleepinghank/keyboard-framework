#include "CONFIG.h"

#include "motton_detection.h"
#include <math.h>

void initWindow(SlidingWindow* win) {
    win->head = 0;
    win->count = 0;
    win->motion_trigger_count = 0;
    win->is_currently_moving = 0;

    // 初始化状态历史
    win->state_head = 0;
    win->state_count = 0;
    for (int i = 0; i < STATE_WINDOW_SIZE; i++) {
        win->state_history[i] = 1; // 初始为静止
    }

    win->last_std_x = win->last_std_y = win->last_std_z = 0.0f;
    win->last_slope_x = win->last_slope_y = win->last_slope_z = 0.0f;
    win->last_consistency_x = win->last_consistency_y = win->last_consistency_z = 0.0f;
}

// ================= 记录当前窗口状态到历史 =================
void record_state_history(SlidingWindow *win, int current_state) {
    win->state_history[win->state_head] = current_state;
    win->state_head = (win->state_head + 1) % STATE_WINDOW_SIZE;
    if (win->state_count < STATE_WINDOW_SIZE) {
        win->state_count++;
    }
}

// ================= 检查是否应提高阈值：最近状态中≥60%为静止 =================
int should_increase_thresholds(SlidingWindow *win) {
    if (win->state_count < 10) return 0; // 数据不足，不启用增强

    int stationary_count = 0;
    for (int i = 0; i < win->state_count; i++) {
        if (win->state_history[i] == 0) {
            stationary_count++;
        }
    }

    // 如果静止状态 ≥ 60%
    float ratio = (float)stationary_count / win->state_count;
    return (ratio >= 0.6f);
}

void addData(SlidingWindow* win, int x, int y, int z) {
    win->buffer[win->head].x = x;
    win->buffer[win->head].y = y;
    win->buffer[win->head].z = z;
    win->head = (win->head + 1) % WINDOW_SIZE;
    if (win->count < WINDOW_SIZE) {
        win->count++;
    }
}

// ================= 判断窗口是否满 =================
int is_window_full(SlidingWindow *win) {
    return win->count == WINDOW_SIZE;
}

// ================= 计算单轴线性回归斜率 =================
float calculate_slope(int *data, int n) {
    if (n < 2) return 0.0f;

    float sum_x = 0, sum_y = 0, sum_xy = 0, sum_xx = 0;
    for (int i = 0; i < n; i++) {
        sum_x += i;
        sum_y += data[i];
        sum_xy += i * data[i];
        sum_xx += i * i;
    }

    float denominator = (n * sum_xx - sum_x * sum_x);
    if (fabs(denominator) < 1e-6) return 0.0f;

    float slope = (n * sum_xy - sum_x * sum_y) / denominator;
    return slope;
}

// ================= 计算单轴趋势一致性 =================
float calculate_consistency(int *data, int n) {
    if (n < 2) return 0.5f;

    int positive = 0, negative = 0;
    for (int i = 1; i < n; i++) {
        if (data[i] > data[i-1]) positive++;
        else if (data[i] < data[i-1]) negative++;
    }

    int total = positive + negative;
    if (total == 0) return 0.5f;

    float ratio = (positive > negative) ? (float)positive / total : (float)negative / total;
    return ratio;
}

// ================= 计算标准差 =================
float calculate_std(int *data, int n) {
    if (n <= 1) return 0.0f;

    float sum = 0.0f;
    for (int i = 0; i < n; i++) {
        sum += data[i];
    }
    float mean = sum / n;

    float variance = 0.0f;
    for (int i = 0; i < n; i++) {
        float diff = data[i] - mean;
        variance += diff * diff;
    }
    variance /= (n - 1);

    return sqrtf(variance);
}

// ================= 分析数据特征以优化参数 =================
void analyze_data_characteristics(int data[][3], int len) {
    if (len < WINDOW_SIZE) return;

    // printf("分析数据特征以优化检测参数...\n");

    float all_std_x = 0, all_std_y = 0, all_std_z = 0;
    float all_slope_x = 0, all_slope_y = 0, all_slope_z = 0;
    float all_cons_x = 0, all_cons_y = 0, all_cons_z = 0;
    int window_count = 0;

    int step = (len - WINDOW_SIZE + 1) / 10;
    if (step < 1) step = 1;

    for (int start = 0; start < len - WINDOW_SIZE + 1; start += step) {
        int x_data[WINDOW_SIZE], y_data[WINDOW_SIZE], z_data[WINDOW_SIZE];

        for (int i = 0; i < WINDOW_SIZE; i++) {
            x_data[i] = data[start + i][0];
            y_data[i] = data[start + i][1];
            z_data[i] = data[start + i][2];
        }

        float std_x = calculate_std(x_data, WINDOW_SIZE);
        float std_y = calculate_std(y_data, WINDOW_SIZE);
        float std_z = calculate_std(z_data, WINDOW_SIZE);

        float slope_x = fabs(calculate_slope(x_data, WINDOW_SIZE));
        float slope_y = fabs(calculate_slope(y_data, WINDOW_SIZE));
        float slope_z = fabs(calculate_slope(z_data, WINDOW_SIZE));

        float cons_x = calculate_consistency(x_data, WINDOW_SIZE);
        float cons_y = calculate_consistency(y_data, WINDOW_SIZE);
        float cons_z = calculate_consistency(z_data, WINDOW_SIZE);

        all_std_x += std_x;
        all_std_y += std_y;
        all_std_z += std_z;

        all_slope_x += slope_x;
        all_slope_y += slope_y;
        all_slope_z += slope_z;

        all_cons_x += cons_x;
        all_cons_y += cons_y;
        all_cons_z += cons_z;

        window_count++;
    }

    if (window_count > 0) {
        all_std_x /= window_count;
        all_std_y /= window_count;
        all_std_z /= window_count;

        all_slope_x /= window_count;
        all_slope_y /= window_count;
        all_slope_z /= window_count;

        all_cons_x /= window_count;
        all_cons_y /= window_count;
        all_cons_z /= window_count;

        // printf("数据特征分析结果:\n");
        // printf("平均标准差: X=%.2f, Y=%.2f, Z=%.2f\n", all_std_x, all_std_y, all_std_z);
        // printf("平均斜率绝对值: X=%.3f, Y=%.3f, Z=%.3f\n", all_slope_x, all_slope_y, all_slope_z);
        // printf("平均趋势一致性: X=%.3f, Y=%.3f, Z=%.3f\n", all_cons_x, all_cons_y, all_cons_z);

        // // 根据分析结果建议参数
        // printf("\n建议参数:\n");
        // printf("- 标准差阈值: %.2f (当前: 基于规则判断)\n", fmaxf(3.0f, fmaxf(fmaxf(all_std_x, all_std_y), all_std_z) * 0.7f));
        // printf("- 趋势一致性阈值: %.2f (当前: 0.67)\n", 0.60f);
        // printf("- 斜率阈值: %.3f (当前: 0.28)\n", fmaxf(0.3f, fmaxf(fmaxf(all_slope_x, all_slope_y), all_slope_z) * 0.8f));
    }
}

// ================= 打印窗口统计信息 =================
void print_window_stats(SlidingWindow *win, float std_x, float std_y, float std_z,
                        float slope_x, float slope_y, float slope_z,
                        float cons_x, float cons_y, float cons_z) {
    // printf("窗口统计: Std(X,Y,Z): %.2f,%.2f,%.2f ", std_x, std_y, std_z);
    // printf("Slope(X,Y,Z): %.3f,%.3f,%.3f ", slope_x, slope_y, slope_z);
    // printf("Cons(X,Y,Z): %.3f,%.3f,%.3f\n", cons_x, cons_y, cons_z);
}

// ================= 计算当前窗口的运动得分 =================
float calculate_motion_score(SlidingWindow *win) {
    if (!is_window_full(win)) return 0.0f;

    int x_data[WINDOW_SIZE], y_data[WINDOW_SIZE], z_data[WINDOW_SIZE];

    for (int i = 0; i < WINDOW_SIZE; i++) {
        int idx = (win->head + i) % WINDOW_SIZE;
        x_data[i] = win->buffer[idx].x;
        y_data[i] = win->buffer[idx].y;
        z_data[i] = win->buffer[idx].z;
    }

    // 计算各轴的标准差
    float std_x = calculate_std(x_data, WINDOW_SIZE);
    float std_y = calculate_std(y_data, WINDOW_SIZE);
    float std_z = calculate_std(z_data, WINDOW_SIZE);

    // 计算各轴的斜率
    float slope_x = fabs(calculate_slope(x_data, WINDOW_SIZE));
    float slope_y = fabs(calculate_slope(y_data, WINDOW_SIZE));
    float slope_z = fabs(calculate_slope(z_data, WINDOW_SIZE));

    // 计算各轴的趋势一致性
    float cons_x = calculate_consistency(x_data, WINDOW_SIZE);
    float cons_y = calculate_consistency(y_data, WINDOW_SIZE);
    float cons_z = calculate_consistency(z_data, WINDOW_SIZE);

    // 保存统计信息用于调试
    win->last_std_x = std_x;
    win->last_std_y = std_y;
    win->last_std_z = std_z;
    win->last_slope_x = slope_x;
    win->last_slope_y = slope_y;
    win->last_slope_z = slope_z;
    win->last_consistency_x = cons_x;
    win->last_consistency_y = cons_y;
    win->last_consistency_z = cons_z;

    // **关键优化：解决静止数据误报问题**

    // 规则1: 严格的核心检测条件（提高阈值）
    if ((slope_x > 0.4f && cons_x > 0.7f && std_x > 4.0f) ||
        (slope_y > 0.4f && cons_y > 0.7f && std_y > 4.0f) ||
        (slope_z > 0.4f && cons_z > 0.7f && std_z > 4.0f)) {
        return 1.0f;
    }

    // 规则2: 如果标准差都很小，直接判定为静止
    if (std_x < 3.0f && std_y < 3.0f && std_z < 3.0f) {
        return 0.0f;
    }

    // 规则3: 如果斜率都很小，即使标准差较大，也可能是噪声
    if (slope_x < 0.3f && slope_y < 0.3f && slope_z < 0.3f) {
        return 0.0f;
    }

    // 规则4: 综合评分（更严格的权重分配）
    float max_std = fmaxf(fmaxf(std_x, std_y), std_z);
    float max_slope = fmaxf(fmaxf(slope_x, slope_y), slope_z);
    float max_consistency = fmaxf(fmaxf(cons_x, cons_y), cons_z);

    // 调整权重，更重视斜率和一致性
    float composite_score = (max_std / 15.0f) * 0.3f +
                            (max_slope / 0.8f) * 0.4f +
                            max_consistency * 0.3f;

    // 规则5: 如果平均一致性很低，认为是随机噪声
    float avg_consistency = (cons_x + cons_y + cons_z) / 3.0f;
    if (avg_consistency < 0.55f) {
        composite_score *= 0.3f; // 更强的噪声抑制
    }

    // 规则6: 如果各轴数据变化不一致，可能是噪声
    float std_range = fmaxf(fmaxf(std_x, std_y), std_z) - fminf(fminf(std_x, std_y), std_z);
    if (std_range > 8.0f && avg_consistency < 0.6f) {
        composite_score *= 0.5f;
    }

    if (composite_score > 1.0f) composite_score = 1.0f;
    if (composite_score < 0.0f) composite_score = 0.0f;

    return composite_score;
}

// 检测状态（1表示运动，0表示静止）
BOOL detectMotion(SlidingWindow* win) {
    if (!is_window_full(win)) {
        return TRUE;
    }

    // 动态调整阈值：如果历史中大部分是静止的，提高运动检测门槛，避免噪声影响
    float current_threshold = MOTION_THRESHOLD;
    int current_confirm_count = MOTION_CONFIRM_COUNT;

    if (should_increase_thresholds(win)) {
        current_threshold = MOTION_THRESHOLD * 1.30f;     // 提高30%
        current_confirm_count = MOTION_CONFIRM_COUNT + 1; // 增加1次确认
        // 可选：限制最大值避免过度敏感
        if (current_threshold > 0.7f) current_threshold = 0.7f;
        if (current_confirm_count > 4) current_confirm_count = 4;
    }

    float score = calculate_motion_score(win);
    int trigger = (score > current_threshold);

    // 使用动态确认次数
    if (trigger) {
        win->motion_trigger_count++;
        if (win->motion_trigger_count >= current_confirm_count) {
            win->is_currently_moving = 1;
        }
    } else {
        if (win->is_currently_moving) {
            win->motion_trigger_count--;
            if (win->motion_trigger_count <= 0) { // 更快的释放
                win->is_currently_moving = 0;
                win->motion_trigger_count = 0;
            }
        } else {
            win->motion_trigger_count = 0;
        }
    }

    // 记录当前窗口的最终状态到历史
    record_state_history(win, win->is_currently_moving);

    if (win->is_currently_moving!=0) {
        return TRUE;
    }

    return FALSE;
}
