// 获取充电状态检测的adc值
uint16_t get_charge_voltage(void){
    uint16_t voltage = 0;
    float adc_val = 0;
    static uint16_t last_charge_voltage = 0xffff;  // 上次的有效值，初始化为无效值
    static uint16_t last_charge_voltage_result = 0;  // 上次的结果缓存（用于并发调用时返回）

    // ================ 并发保护：尝试获取锁 ================
    // 注意：get_charge_voltage 使用 mode 2，与 calculate_charging_state 使用相同的ADC通道
    // 因此需要使用相同的互斥锁，避免ADC硬件冲突
    if (!charging_state_try_lock()) {
        // 如果正在执行，返回上次的结果，避免并发冲突
        return last_charge_voltage_result;
    }

    if(charge_buf_idx == 0xff){
        uint8_t retry_count = 0;
        const uint8_t MAX_RETRY_PER_SAMPLE = 3;  // 每个样本最多重试3次，防止无限循环
        
        for(uint8_t i = 0; i < FILTER_N; i++){
            voltage = get_adc_value(2);
            // 检查是否被取消或无效值
            if (voltage == ADC_CANCELED_VALUE || voltage == ADC_INVALID_VALUE) {
                // 如果被取消，使用上次的有效值（如果存在），否则重试
                if (last_charge_voltage != 0xffff) {
                    voltage = last_charge_voltage;
                    retry_count = 0;  // 重置重试计数
                } else {
                    // 如果没有上次值，重试本次采样
                    retry_count++;
                    if (retry_count < MAX_RETRY_PER_SAMPLE) {
                        i--;  // 回退索引，重新采样
                        continue;
                    } else {
                        // 超过最大重试次数，使用默认值（0表示未充电）
                        voltage = 0;
                        retry_count = 0;  // 重置重试计数
                    }
                }
            } else {
                last_charge_voltage = voltage;  // 更新上次有效值
                retry_count = 0;  // 成功获取，重置重试计数
            }
            charge_buf[i] = voltage;
            for(uint16_t a = 0; a < 500; a++);
        }
        charge_buf_idx = FILTER_N - 1;
    } else {
        charge_buf_idx++;
        if(charge_buf_idx >= FILTER_N){
            charge_buf_idx = 0;
        }
        voltage = get_adc_value(2);
        // 检查是否被取消或无效值
        if (voltage == ADC_CANCELED_VALUE || voltage == ADC_INVALID_VALUE) {
            // 如果被取消，使用上次的有效值（如果存在），否则使用缓冲区中的旧值
            if (last_charge_voltage != 0xffff) {
                voltage = last_charge_voltage;
            } else {
                // 如果没有上次值，使用缓冲区中对应位置的上一个值
                uint8_t prev_idx = (charge_buf_idx == 0) ? (FILTER_N - 1) : (charge_buf_idx - 1);
                voltage = charge_buf[prev_idx];
            }
        } else {
            last_charge_voltage = voltage;  // 更新上次有效值
        }
        charge_buf[charge_buf_idx] = voltage;
    }

    // 检查是否在采样过程中收到新请求
    if (charging_state_cancel_requested) {
        // 被取消，立即释放锁并返回，让新请求执行
        charging_state_unlock();
        return last_charge_voltage_result;
    }

    voltage = filter(charge_buf,FILTER_N);
    adc_val = voltage;
    voltage = (uint16_t)adc_val;
    
    // 更新缓存结果
    last_charge_voltage_result = voltage;
    
    // ================ 释放锁 ================
    charging_state_unlock();

    return voltage;
}

uint8_t convert_voltage_to_percentage(uint16_t voltage){

    uint8_t i = 0, level = 0;
    // 容量初始化
    for (i = 0; i < 21; i++)
    {
        if(voltage >= VOLTAGE_TO_CAPACITY_TABLE[i])
        {
            level = 100 - (i * 5);
            if (i != 0){
                level += (uint8_t)(voltage - VOLTAGE_TO_CAPACITY_TABLE[i])*5/(VOLTAGE_TO_CAPACITY_TABLE[i-1] - VOLTAGE_TO_CAPACITY_TABLE[i]);
        
                break;
            }
        }
    }

    return level;   
}

uint32_t calculate_remaining_capacity(uint8_t percentage){
    return (BATTERY_CAPACITY_MAS * percentage) / 100;
}

// 根据剩余容量计算百分比
uint8_t calculate_capacity_percentage(uint32_t remaining_capacity){
    // 检查除零风险（虽然BATTERY_CAPACITY_MAS是常量，但为了安全还是检查）
    if (BATTERY_CAPACITY_MAS == 0) {
        return 0;
    }
    return (uint8_t)((uint32_t)(remaining_capacity * 100 + BATTERY_CAPACITY_MAS / 2) / BATTERY_CAPACITY_MAS);
}

uint16_t calculate_voltage(uint32_t remaining_capacity){
    uint8_t i;
    uint16_t voltage;
    uint8_t percentage = (remaining_capacity * 100) / BATTERY_CAPACITY_MAS;
    // 根据电量百分比查表获取对应电压值
    for (i = 20; i > 0; i--)
    {
        if (percentage >= i * 5)
        {
            voltage = VOLTAGE_TO_CAPACITY_TABLE[20-i];
            if (i == 20)
            {
                break;
            }
            voltage += (VOLTAGE_TO_CAPACITY_TABLE[19-i]-VOLTAGE_TO_CAPACITY_TABLE[20-i]) * (percentage - (100 - i * 5)) / 100;
            break;
        }
    }

    // 如果电量为0，返回最低电压值
    if (i == 0)
    {
        voltage = VOLTAGE_TO_CAPACITY_TABLE[20];
    }

    return voltage;
}

// 添加最小二乘法计算斜率的函数
float calculate_voltage_slope(uint16_t *buf, uint8_t length) {
    // 检查输入参数
    if (buf == NULL || length < 2) {
        return 0.0f;
    }
    
    float sum_x = 0;    // Σx
    float sum_y = 0;    // Σy
    float sum_xy = 0;   // Σ(xy)
    float sum_xx = 0;   // Σ(x²)
    
    // 计算各项和
    for (uint8_t i = 0; i < length; i++) {
        sum_x += i;
        sum_y += buf[i];
        sum_xy += i * buf[i];
        sum_xx += i * i;
    }
    
    // 计算斜率 k = (n*Σ(xy) - Σx*Σy) / (n*Σ(x²) - (Σx)²)
    float n = length;
    float denominator = (n * sum_xx - sum_x * sum_x);
    
    // 检查除零风险
    if (fabsf(denominator) < 1e-6f) {
        return 0.0f;
    }
    
    float slope = (n * sum_xy - sum_x * sum_y) / denominator;
    
    return slope;
}

uint8_t calculate_charging_state(uint8_t type){
    static uint8_t ChargingDetection = 0;
    uint16_t voltage = 0;

    // ================ 并发保护：尝试获取锁 ================
    if (!charging_state_try_lock()) {
        // 如果正在执行，设置取消标志后返回上次的结果
        // 当前执行会检测到取消标志并立即退出
        return last_charging_detection_result;
    }

    #ifdef CHARGING_DETECTION
    voltage = get_adc_value(2);
    
    // 检查是否被取消或无效值（ADC读取返回特殊值表示被取消或无效）
    if (voltage == ADC_CANCELED_VALUE || voltage == ADC_INVALID_VALUE || charging_state_cancel_requested) {
        // 被取消或无效值，立即释放锁并返回，让新请求执行
        charging_state_unlock();
        return last_charging_detection_result;
    }

    // PRINT("get_charge_voltage is 1222222 %d\r\n", voltage);
    // 550mv 充电 1.185V充满 3.3V没充电 
    // power_st 1 未充电 2 充电中 3 充满电
    // 注意：voltage 现在保证是有效值（>= 1200 或 <= 3000）
    if(voltage >= 3000){
        ChargingDetection = 0; // 未充电
        power_st = 1;
        charging_completed_cnt = 0;
        last_completed_cnt = 0;
    }
    else if(voltage > 1200 && voltage < 3000){
        uint8_t cnt_th = charging_completed_cnt_th;
        if (sleepModeFlag == 3) {
            cnt_th=2;
        }
        if (charging_completed_cnt >= cnt_th){
            ChargingDetection = 2;// 充满电
            power_st = 3;
        }else {
            charging_completed_cnt++;
            ChargingDetection = 1; // 充电中
            power_st = 2;
        }
    }
    else if(voltage <=1200){
        ChargingDetection = 1; // 充电中
        charging_completed_cnt = 0;
        power_st = 2;
    }
    else{
        ChargingDetection = 0; // 未充电
        charging_completed_cnt = 0;
        last_completed_cnt = 0;
        power_st = 1;
    }
    #else
    static uint16_t last_voltages[3] = {0xffff,0xffff,0xffff};

    if(anti_jump_change > 0)anti_jump_change--;//防止电压跳变
    else
    {
        // 计算电压变化趋势，
        float voltage_slope = calculate_voltage_slope(voltage_buf, FILTER_N);

        // 设定斜率阈值，根据实际情况调整
        const float CHARGING_SLOPE_THRESHOLD = 0.5;    // 充电斜率阈值
        const float DISCHARGING_SLOPE_THRESHOLD = -0.4; // 放电斜率阈值

        uint16_t  a = calculate_voltage(batteryState.remainingCapacityMas);
        uint16_t now_v = voltage_buf[voltage_buf_idx] * 10; // 将0.01V单位转换为mV单位
        // 根据斜率判断充放电状态，斜率可以代表一定的整体趋势。
        if (voltage_slope > CHARGING_SLOPE_THRESHOLD || now_v > 425) {
            int16_t diff = now_v - a;
            // 接近满电时，电压差比较小，并且只有在完全充满的情况电池自身电压才能达到420
            if (diff >= 12 ||(now_v > 425 && diff >= 5)) {
                ChargingDetection = 1; // 充电
                power_st = 2;
                DBG("Charging detected (slope analysis). Slope: %.2f\n", voltage_slope);
            }
        } else if (voltage_slope < DISCHARGING_SLOPE_THRESHOLD && batteryState.voltageMv <= last_voltages[0]) {
            ChargingDetection = 0; // 放电
            power_st = 1;
        }
        // 如果既不满足充电条件也不满足放电条件，保持当前状态不变
        // ChargingDetection 和 power_st 保持上次的值
        // 更新电压历史记录
        last_voltages[0] = last_voltages[1];
        last_voltages[1] = last_voltages[2];
        last_voltages[2] = batteryState.voltageMv;
    }
    #endif

    uint8_t current_percentage = get_bat_level();
    if (power_st == 3 && current_percentage < 100) {
        // 硬件检测到充满，但电量未到100%，强制设置为充电中，启动平滑过渡
        power_st = 2;  // 强制设置为充电中
    }
    
    // 更新缓存结果（在保存状态之前）
    last_charging_detection_result = ChargingDetection;
    
    // 检查是否在状态判断过程中收到新请求
    // 注意：只有电量到100%时才保存充满状态，确保充满绿灯只有在电量到100%时才亮起
    if (charging_state_cancel_requested) {
        // 如果检测到充满状态且电量已到100%，先保存状态，再取消（确保充满灯效能亮起）
        // 注意：如果电量未到100%，power_st 已经被强制设置为2，不会保存充满状态
        if (power_st == 3 && current_percentage >= 100) {
            // 充满状态且电量已到100%，必须保存，不能丢失
            setBattInfo(current_percentage, power_st);
        }
        // 被取消，立即释放锁并返回，让新请求执行
        charging_state_unlock();
        return last_charging_detection_result;
    }
    
    // 正常情况：保存状态
    setBattInfo(current_percentage, power_st);
    
    // ================ 释放锁 ================
    charging_state_unlock();
    
    return ChargingDetection;
}


uint16_t calculate_power_consumption(void)
{
    uint16_t current_power_usage = 0;
    current_power_usage = 10; // 当前用电量
    anti_jump_change = 10; // 防止电压跳变
    if(start_find_flag == 1)
    {
        current_power_usage = 90;
    }
    else if (sleepModeFlag == 1) {
        current_power_usage = 3;
    }
    else if (sleepModeFlag == 2) {
        current_power_usage = 2;
    }
    else if (sleepModeFlag == 3) {
        current_power_usage = 1;
    }
    return current_power_usage;
}

int16_t calculate_current_power_usage(uint8_t charging_state){
    // 根据充电状态返回电量变化值
    if (charging_state == 1) {
        // 充电状态
        if (batteryState.percentageRemaining < 45) {
            // 恒流充电
            return constant_current;
        } else if (batteryState.percentageRemaining < 90) {
            // 恒压充电
            return constant_voltage;
        } else {
            // 涓流充电
            return trickle_charge;
        }
    } 
    else if(charging_state == 0) {
        // 放电状态
        return (-calculate_power_consumption());
    }
    return 0;
}


