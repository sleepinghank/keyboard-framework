// 检查充电状态
void checkChargingStatus(){
    battery_level_detection(0);
    if(get_bat_status() == 1){
        // 未充电
        // 1、先关灯
        set_led_status(LED_MODE_CHARGING,0);
        set_led_status(LED_MODE_CHARGED,0);
        led_state.need_update = 1;
        // 2、led扫描
        restartLedScanTask();
        // 3、如果产生中断后检测不是充电状态且不是按键开机的状态下，直接拉低开机保持使能脚
        if(hasAlready==0){
            GPIO_SetSystemPower(0);
        }else {
            startBatteryTask(100);
        }
    }else
    {
        // 充电中/充满
        // 1、关闭低电闪烁，先亮充电红灯
        set_led_status(LED_MODE_LOW_BAT_BLINK,0);
        set_led_status(LED_MODE_CHARGED,0);
        set_led_status(LED_MODE_CHARGING,1);  // 充电中
        led_state.need_update = 1;
        // 2、开机保持
        GPIO_SetSystemPower(1);
        // 3、led扫描
        restartLedScanTask();
        startBatteryTask(100);
    }
}

