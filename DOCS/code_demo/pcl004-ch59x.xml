void ledScan(void) {
    // 1. 休眠模式特殊处理
    LedMode_e new_mode = LED_MODE_NONE;
    if (sleepModeFlag!=0) {
        // 休眠模式优先级扫描
        for (size_t i = 0; i < ARRAY_SIZE(sleep_priority_modes); i++) {
            LedMode_e mode = sleep_priority_modes[i];
            if (mode < LED_MODE_COUNT && (led_status_flags & flag_masks[mode])) {
                new_mode = mode;
                break;
            }
        }
        // 深度休眠时跳过蓝牙回连，并清除标志位
        if (new_mode == LED_MODE_BLE_RECONNECT && sleepModeFlag == 3) {
            led_status_flags &= ~flag_masks[LED_MODE_BLE_RECONNECT];
            new_mode = LED_MODE_NONE;
        }

        if(new_mode!=LED_MODE_NONE)
        {
            if(GPIO_ReadPentipStatus()==0)
            {
                // 灯与笔头的电源控制为同一路
                GPIO_OpenPentip();
            }
        } else {
            // 无模式时关闭笔头电源
            if(pwm_status!=0){
                closePentip();
            }
            stopLedScanTask();
        }
    } 
    // 2. 正常模式优先级扫描
    else {
        for (size_t i = 0; i < ARRAY_SIZE(priority_map); i++) {
            LedMode_e mode = priority_map[i];
            if (mode < LED_MODE_COUNT && (led_status_flags & flag_masks[mode])) {
                new_mode = mode;
                break;
            }
        }
    }
    
    // 3. 模式切换处理
    if (new_mode != led_state.mode) {
        switch_led_mode(new_mode);
        // 模式切换后直接返回，确保状态稳定
        return;
    }
    
    // 4. 无模式时关闭LED
    if (led_state.mode == LED_MODE_NONE) {
        set_led_color(LED_OFF);
        return;
    }
    
    // 5. 动态禁用检查
    const LedModeConfig_t* cfg = &mode_config[led_state.mode];
    if (led_state.dynamic_disable && led_state.max_active_count > 0) {
        if (++led_state.active_count >= led_state.max_active_count) {
            disable_current_mode();
            return;
        }
    }
    
    // 6. 模式执行逻辑
    if (cfg->off_ticks == 0) {  // 常亮模式
        set_led_color(cfg->color);
    } else {                   // 闪烁模式
        if (handle_blink_mode(cfg)) {
            return;  // 模式已变更
        }
    }
}

// 设置led灯状态
void set_led_status(LedMode_e mode, uint8_t enable) {
    if (mode >= LED_MODE_COUNT) return;
    
    if (enable) {
        led_status_flags |= flag_masks[mode];
    } else {
        led_status_flags &= ~flag_masks[mode];
        if (led_state.mode == mode) {
            disable_current_mode();  // 立即切换模式
        }
    }
}

