// 冒泡排序函数：对无符号16位整型数组进行升序排序
// 参数：
//   arr[] - 待排序的数组
//   len   - 数组长度（元素个数）
void bubble_sort2(uint16_t arr[], uint8_t len) {
    uint8_t i, j;
    uint16_t temp;
    // 外层循环控制排序轮数（共 len-1 轮）
    for (i = 0; i < len - 1; i++) {
        // 内层循环在每轮中将最大值“冒泡”到未排序部分的末尾
        for (j = 0; j < len - 1 - i; j++) {
            if (arr[j] > arr[j + 1]) {
                // 交换相邻元素
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

// 中位值平均滤波函数（带剔除极值的滑动平均滤波）
// 适用于抑制突发性干扰，保留数据稳定性
// 参数：
//   buf[]    - 输入原始数据缓冲区
//   length   - 缓冲区中有效数据的个数（应 ≤ FILTER_N）
// 返回值：
//   滤波后的16位无符号整数值
uint16_t filter(uint16_t *buf, uint8_t length) {
    // 若数据量太少，无法有效滤波，直接返回第一个值
    if (length < 3) {
        return buf[0];
    }

    // 创建临时数组，避免修改原始输入数据
    uint16_t temp[FILTER_N];
    memcpy(temp, buf, length * sizeof(uint16_t));

    // 对临时数组进行升序排序，便于后续剔除极值
    bubble_sort2(temp, length);

    // 计算需要剔除的极值数量（首尾各剔除约 1/6 的数据）
    uint8_t remove_count = length / 6;
    if (remove_count < 1) {
        remove_count = 1;  // 至少剔除1个最大值和1个最小值
    }

    // 对中间有效数据求和并计数
    uint32_t sum = 0;
    uint8_t valid_count = 0;

    // 从 remove_count 到 length - remove_count - 1 的区间为有效数据段
    for (uint8_t i = remove_count; i < length - remove_count; i++) {
        sum += temp[i];
        valid_count++;
    }

    // 计算平均值（+valid_count/2 实现四舍五入）
    return (uint16_t)((sum + (valid_count >> 1)) / valid_count);
}

