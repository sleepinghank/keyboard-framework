#endif

#include "CONFIG.h"

// ================= 配置参数 =================
#define WINDOW_SIZE             18      // 数据滑动窗口大小
#define STATE_WINDOW_SIZE       15      // 状态滑动窗口大小
#define MOTION_THRESHOLD        0.5f  // 提高运动判定阈值，减少误报
#define MOTION_CONFIRM_COUNT    3  // 增加确认运动需要的连续触发次数
#define MOTION_RELEASE_COUNT    2  // 减少释放运动状态需要的连续非触发次数

// ================= 数据结构 =================
typedef struct {
    int x; 
    int y;
    int z;
} Point3D;

typedef struct {
    Point3D buffer[WINDOW_SIZE]; // 环形缓冲区
    int head;                    // 写入位置
    int count;                   // 当前有效点数

    int motion_trigger_count;    // 运动触发计数器
