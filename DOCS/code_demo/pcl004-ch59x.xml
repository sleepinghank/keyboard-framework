{
    uint8_t i=0;
    ota_jump_flag_t ota_flag =   OTA_Storage_Read_Jump_Flag();

    PRINT("ota_flag1111 = %d\r\n", (uint8_t)ota_flag);

    if(ota_flag == OTA_JUMP_FLAG_AUTO)
    {
        hasAlready = 1;
        OTA_Storage_Write_Jump_Flag(OTA_JUMP_FLAG_SUCCESS);
        PRINT("OTA_JUMP_FLAG_AUTO...\r\n");
    }else 
    {
        while(1)
        {
            // 读取开关机按键状态
            if(GPIO_GetPowerKeyStatus()==0){
                hasAlready = 1;
                PRINT("Read Charge GPIO is low level \r\n");
                break;
            }
            // 读取充电检测GPIO状态,充电状态 (0:未充电, 1:充电中)
            if (GPIO_ReadChargeStatus()==1){
                PRINT("Read Charge GPIO is low level \r\n");
                break;
            }
            DelayMs(2);
        }
    }

    GPIO_SetSystemPower(1);
}

