extern void ble_disconnect();
// 关机
void shutdown(void)
{
    // 插着充电器关机
    if(get_bat_status() != 1)
    {
        led_status_flags = 0;
        led_state.mode = LED_MODE_NONE;
        led_state.need_update = 1;
        closePentip();

        GPIO_OpenPentip();
        
        // 停止运动检测
        stopMotionTask();
        // 开始led扫描
        startLedScanTask();

        set_led_status(LED_MODE_BLE_PAIRING,0);
        set_led_status(LED_MODE_BLE_RECONNECT,0);
        // 如果插着充电器关机，当前是充满状态
        if(get_bat_status()==3)
        {
            set_led_status(LED_MODE_CHARGING,0);
            set_led_status(LED_MODE_CHARGED,1);
        }
        else
        {
            // 如果插着充电器关机，当前是未充满状态
            set_led_status(LED_MODE_CHARGED,0);
            set_led_status(LED_MODE_CHARGING,1);
        }
        
        // 关闭陀螺仪
        SL_SC7A20H_POWER_DOWN();
        // 停止按键任务
        stopReporTask();
        // 释放按钮
        isInitBtn = 0;
        release_btn();
        // 按键中断唤醒
        _gpio_wakup_source();

        if(nvs_flash_info.find_flag !=0)
        {
            
            sleepModeFlag = 3;
            // disableAdvertising();
            if(ble_is_connected()==1)
            {
                // 更新连接参数
                update_conn_pamm();
            }
            else if (ble_is_advertising()==1) {
                // 关闭并重新广播
                disableAdvertising();
            }
            else {
                // 开始慢广播
                restartDevLowAdvertising();
            }
        }else {
            sleepModeFlag= 3;
            hasHighAdv = 0;
            ble_disconnect();
            disableAdvertising();
            hasAlready = 0;
        }
    }
    else
    {
        // 关闭led灯
        close_led();
        // 关闭笔头
        closePentip();
        // 停止扫描按键
        stopReporTask();
        // 停止运动检测
        stopMotionTask();
        // 停止led扫描
        stopLedScanTask();
        // 如果开启了查找进入低功耗
        if(nvs_flash_info.find_flag !=0)
        {
            // isTurnedOff = 1;
            sleepModeFlag = 3;
            isInitBtn = 0;
            release_btn();
            // disableAdvertising();
            // 关闭陀螺仪
            SL_SC7A20H_POWER_DOWN();
            _gpio_wakup_source();
            if(ble_is_connected()==1)
            {
                // 更新连接参数
                update_conn_pamm();
            }
            else if (ble_is_advertising()==1) {
                // 关闭并重新广播
                disableAdvertising();
            }
            else {
                // 开始慢广播
                restartDevLowAdvertising();
            }
        }
        else {
            // 关闭中断
            PFIC_DisableIRQ(GPIO_B_IRQn);
            PFIC_DisableIRQ(GPIO_A_IRQn);
            tmos_stop_task(userTaskId, START_BATTERY_EVT);
            // PFIC_DisableIRQ(GPIO_A_IRQn);
            // 未开启查找直接关机
            GPIOB_ResetBits(GPIO_Pin_10);
            LowPower_Shutdown(0);
        }
    }
}

// idle计时，5秒未动作则进入低功耗
void _idle_timer_task(){
    // 如果是广播中（非慢广播）进入idle计时
    if(advertisingMode!=1&&sleepModeFlag == 0&&hasAlready != 0)
    {
       if (_idle_cnt >= _idle_cnt_th){
            PRINT("_idle_timer_task \n");
            set_led_status(LED_MODE_LOW_BAT_BLINK,0);
            sleepModeFlag = 1;
            _slp_cnt = 0;
            if(get_bat_status()==1)
            {
                closePentip();
            }
        }else {
            _idle_cnt++;
        } 
    }
}

// 休眠计时
void _sleep_timer_task(void)
{
    if(sleepModeFlag==1)
    {
        if (_slp_cnt >= _slp_cnt_th)
        {
            sleepModeFlag = 2;
            _pd_cnt=0;
            _idle_mode();
        }else{
            _slp_cnt++;
        }
    }
}

// 关机计时
void _power_timer_task(void)
{
    if (sleepModeFlag == 2) {
        if (_pd_cnt >= _pd_cnt_th)
        {
            // 如果开启查找且已经进入低功耗则不进行处理
            shutdown();
            
        }else{
            _pd_cnt++;
        }
    }
}


// 设置关机时间的函数
void set_shutdown_time(uint16_t time) {
    // 设置永不关机标志
    never_power_down_flag = (time == 0) ? 1 : 0;
    
    // 计算关机计数阈值
    if (time & 0x8000) {
        // 如果关机分钟小于10分钟则设置为10分钟
        if ((time & 0x7fff) < 10) {
            time = 10;
        }
        // 最高位为1表示分钟
        _pd_cnt_th = (uint32_t)((uint64_t)(((time & 0x7fff) * 60)/BATTERY_CHECK)-_slp_cnt_th);
    } else {
        // 如果关机秒小于10分钟则设置为10分钟
        if (time < 10 * 60) {
            time = 10 * 60;
        }
        // 最高位为0表示秒
        _pd_cnt_th = (uint32_t)((time/BATTERY_CHECK)-_slp_cnt_th);
    }
}

// 设置休眠时间的函数
void set_sleep_time(uint16_t time) {
    // 计算关机计数阈值
    if (time & 0x8000) {
        // 如果关机分钟小于1分钟则设置为1分钟
        if ((time & 0x7fff) < 1) {
            time = 1;
        }
        // 最高位为1表示分钟
        _slp_cnt_th = (uint32_t)((uint64_t)(((time & 0x7fff) * 60)-(IDLE_TIMER/1000))/BATTERY_CHECK);
    } else {
        // 如果关机秒小于30秒钟则设置为30秒钟
        if (time < 30) {
            time = 30;
        }
        // 最高位为0表示秒
        _slp_cnt_th = (uint32_t)(ceil((time-(IDLE_TIMER/1000))/BATTERY_CHECK));
    }
}

