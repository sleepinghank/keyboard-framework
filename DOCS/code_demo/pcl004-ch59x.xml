void check_low_battery(void){
    if (batteryState.percentageRemaining > LOW_BATTERY_WARN_PCT)
    {
        // 关闭低电闪烁
        set_led_status(LED_MODE_LOW_BAT_BLINK,0);
        // PRINT("Low electric stop\r\n");
    } 
    if (batteryState.isCharging == 0 && batteryState.percentageRemaining < LOW_BATTERY_SHUTDOWN_PCT)
    {
        // 低电关机
        // uint8_t chargingState = calculate_charging_state(1);
        if(get_bat_status() == 1){
            set_led_status(LED_MODE_LOW_BAT_SHUTDOWN_BLINK,1);
            startLowBatShutdownTask(970);
        }else {
        
        }
        
        // PRINT("Low electric power down \r\n");
    }
    if (batteryState.isCharging == 0 && batteryState.percentageRemaining <= LOW_BATTERY_WARN_PCT)
    {
        // 低电闪烁
        // uint8_t chargingState = calculate_charging_state(1);
        if(power_st==1&&sleepModeFlag==0)
        {
            set_led_status(LED_MODE_LOW_BAT_BLINK,1);
        }
        else {
