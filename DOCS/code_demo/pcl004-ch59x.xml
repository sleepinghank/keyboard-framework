#include "CONFIG.h"
#include "motton_detection.h"
#include "sc7a20e.h"
#include "gpio_ops.h"
#include <math.h>

/* 初始化寄存器配置数组定义 */
#define SC7A20E_INIT_REG_NUM 11  // 初始化寄存器数量

static uint8_t SC7A20E_INIT_REG[SC7A20E_INIT_REG_NUM*3]=
{
    0x1F, 0x00, 0x00,  // 模式控制: OSR=000, DLPF[1]=0, HR=0 (00000000b)
    0x20, 0x47, 0x00,  // CTRL_REG1: 50Hz ODR, XYZ使能 (01010111b)
    0x23, 0x18, 0x00,  // CTRL_REG4: ±4g量程, BDU禁用, 小端模式, DLPF[0]=1 (00011000b)
    0x24, 0x08, 0x00,  // CTRL_REG5: 锁存中断1 (00001000b)
    0x21, 0x01, 0x00,  // CTRL_REG2: 中断1高通滤波使能 (00000001b)
    0x30, 0x7F, 0x00,  // 所有方向检测使能
    0x32, 0x02, 0x00,  // 中断阈值
    0x33, 0x01, 0x00,  // 持续时间
    0x22, 0xC0, 0x00,  // I1_AOI1 使能
    0x25, 0x00, 0x00,  // 禁止中断2
    0x2E, 0x00, 0x00,  // 禁用FIFO
};

// 创建运动检测状态结构体
SlidingWindow window;


/*引脚初始化*/
void IIC_Init()
{
    // 使用新的GPIO操作函数
    GPIO_I2cInit();
    SDA_HIGH();
    SCL_HIGH();
}

/* 精确延时（适配系统时钟）*/
static void I2C_Delay(void) {
    for(volatile uint32_t i = 8; i; i--); // 60MHz下约1μs
}

int I2C_Start(void)
{
    uint32_t timeout = I2C_TIMEOUT;
    SDA_HIGH();
    SCL_HIGH();
    // 等待总线空闲
    while(READ_SDA == 0) {
        if(timeout-- == 0){
            // PRINT("READ_SDA 111\n");
            return 0;
        }
        I2C_Delay();
    }

    SDA_LOW();                // SDA拉低
    I2C_Delay();
    SCL_LOW();                // SCL拉低
    return 1; 
}

/**
  * @brief  I2C停止 结束信号：SCL为高电平时，SDA由低电平转变为高电平
  * @param  无
  * @retval 无
  */
void I2C_Stop()
{
    SCL_LOW();
    SDA_LOW();
    I2C_Delay();

    SCL_HIGH();
    // 确保SCL释放
    while(READ_SCL == 0) {
        SCL_HIGH();
        I2C_Delay();
    }

    SDA_HIGH();
    I2C_Delay();
}

void I2C_Ack(void)
{    
    SDA_LOW();
    I2C_Delay();
    SCL_HIGH();
    I2C_Delay();
    SCL_LOW();
    SDA_HIGH();               // 释放SDA
}   

void I2C_NAck(void)
{    
    SDA_HIGH();               // SDA保持高电平（NACK）
    I2C_Delay();
    SCL_HIGH();
    I2C_Delay();
    SCL_LOW();
} 

uint8_t I2C_WaitAck(void)      //返回为:=1有ACK,=0无ACK
{
    uint32_t timeout = I2C_TIMEOUT;
    uint8_t ack = 0;
    
    SDA_IN();
    SCL_LOW();
    I2C_Delay();
    
    SCL_HIGH();
    while(READ_SCL == 0) { // 确保SCL释放
        SCL_HIGH();
        I2C_Delay();
        if(timeout-- == 0){
            // PRINT("READ_SDA 222 \n");
            break;
        }
    }
    
    ack = !READ_SDA;
    SCL_LOW();
    SDA_OUT();
    return ack;
}

uint8_t I2C_SendByte(uint8_t data)  //数据从高位到低位//
{
    for(uint8_t i = 8; i; i--) {
        SCL_LOW();
        if (data & 0x80)
            SDA_HIGH();      // 发送高位
        else
            SDA_LOW();
        data <<= 1;
        I2C_Delay();
        
        SCL_HIGH();
        uint32_t timeout = I2C_TIMEOUT;
        while(READ_SCL == 0) { // 确保时钟展开
            SCL_HIGH();
            I2C_Delay();
            if(timeout-- == 0){
                // PRINT("READ_SDA 3333 \n");
                return 0;
            }
        }
    }
    SCL_LOW();
    return I2C_WaitAck();
}  

uint8_t I2C_ReadByte(uint8_t ack)  //数据从高位到低位//
{ 
    uint8_t data = 0;
    
    SDA_IN();
    for(uint8_t i = 8; i; i--) {
        data <<= 1;
        SCL_LOW();
        I2C_Delay();
        
        SCL_HIGH();
        uint32_t timeout = I2C_TIMEOUT;
        while(READ_SCL == 0) {
            SCL_HIGH();
            I2C_Delay();
            if(timeout-- == 0){
                // PRINT("READ_SDA 4444 \n");
                break;
            }
        }
        
        if(READ_SDA) data |= 0x01;
    }
    ack ? I2C_Ack() : I2C_NAck();
    return data;
}

/*********************************************************************
 * @fn      I2C_WriteReg
 *
 * @brief   写入寄存器
 *
 * @param   reg - 寄存器地址
 *          data - 要写入的数据
 *
 * @return  0 - 成功, 1 - 失败
 */
uint8_t I2C_WriteReg(uint8_t addr,uint8_t reg, uint8_t data)
{
    I2C_Start();
    
    if(!I2C_SendByte(addr << 1)) goto error;
    if(!I2C_SendByte(reg)) goto error;
    if(!I2C_SendByte(data)) goto error;
    
    I2C_Stop();
    return 0;

error:
    I2C_Stop();
    return 1;
}
/*********************************************************************
 * @fn      I2C_ReadReg
 *
 * @brief   读取寄存器
 *
 * @param   reg - 寄存器地址
 *          len - 要读取的数据长度
 *          buf - 数据缓冲区
 *
 * @return  0 - 成功, 1 - 失败
 */
uint8_t I2C_ReadReg(uint8_t addr,uint8_t reg, uint8_t len, uint8_t *buf)
{
    I2C_Start();
    
    if(!I2C_SendByte(addr << 1)) goto error;
    if(!I2C_SendByte(reg)) goto error;
    
    if(!I2C_Start()) goto error;
    if(!I2C_SendByte((addr << 1) | 0x01)) goto error;
    
    while(len--) {
        *buf++ = I2C_ReadByte(len > 0);
    }
    
    I2C_Stop();
    return 0;

error:
    I2C_Stop();
    return 1;
}

