        {
            temp += p[i];
        }
        if(temp==nvs_flash_info.check_sum)
        {
            return TRUE;
        }
    }
    else if(type == 2)
    {
        p = (uint8_t*)&nvs_flash_device_info;
        for(i=0; i<sizeof(nvs_flash_device_info_t)-1; i++)
        {
            temp += p[i];
        }
        if(temp==nvs_flash_device_info.check_sum)
        {
            return TRUE;
