static void nvs_flash_padding_check_sum(uint8_t type)
{
    uint8_t i;
    uint8_t *p;
    if(type == 1)
    {
        p = (uint8_t*)&nvs_flash_info;
        nvs_flash_info.check_sum=0;
        for(i=0; i<sizeof(nvs_flash_info_t)-1; i++)
        {
            nvs_flash_info.check_sum += p[i];
        } 
    }
    else if(type == 2)
    {
        p = (uint8_t*)&nvs_flash_device_info;
        nvs_flash_device_info.check_sum=0;
        for(i=0; i<sizeof(nvs_flash_device_info_t)-1; i++)
        {
            nvs_flash_device_info.check_sum += p[i];
        } 
    }
    else if(type == 3)
    {
        p = (uint8_t*)&nvs_flash_firmware_info;
        nvs_flash_firmware_info.check_sum=0;
        for(i=0; i<sizeof(nvs_flash_firmware_info_t)-1; i++)
        {
            nvs_flash_firmware_info.check_sum += p[i];
        } 
    }
    
}

/*********************************************************************
