uint8_t SL_SC7A20H_SOFT_RESET(void)
{
	uint8_t SL_Read_Reg  = 0xff;
	
	I2C_WriteReg(SC7A20E_ADDR, 0x23, 0x80);//FLAG
	sl_delay(100);
	I2C_WriteReg(SC7A20E_ADDR, 0x24, 0x80);//BOOT
	I2C_WriteReg(SC7A20E_ADDR, 0x68, 0xA5);//SOFT_RESET
	sl_delay(200);
	I2C_ReadReg(SC7A20E_ADDR, 0x23, 1,&SL_Read_Reg);//close aoi1 function
