/*********************************************************************
 * @fn      SC7A20E_Init
 *
 * @brief   初始化SC7A20E
 * 
 * @param   callback - 加速度变化率超过阈值时的回调函数
 *          callback_param - 传递给回调函数的参数
 *
 * @return  0x28 - 初始化成功
 *          0    - 芯片ID错误
 *          -2   - IIC通信错误
 */
int8_t SC7A20E_Init(void (*callback)(uint8_t axis, int16_t value, void *param), void *callback_param)
{
    // PRINT("Read SC7A20E_Init\n");
    uint8_t i;
    uint8_t id1, id2;
    uint8_t Check_Flag=0;

    // 保存回调函数和参数
    SC7A20E_ChangeCallback = callback;
    SC7A20E_CallbackParam = callback_param;

    PRINT("Read IIC_Init\n");

    // 读取芯片ID进行验证
    I2C_ReadReg(SC7A20E_ADDR,SC7A20E_WHO_AM_I, 1, &id1);

    I2C_ReadReg(SC7A20E_ADDR,SC7A20E_WHO_AM_I2, 1, &id2);

    PRINT("SC7A20E_WHO_AM_I is == %d SC7A20E_WHO_AM_I2 is == %d \n",id1,id2);
    // PRINT("SC7A20E_WHO_AM_I is == %d \n",id1);

    // if((id1 != SC7A20E_ID1) || (id2 != SC7A20E_ID2))
    if(id1 != SC7A20E_ID1)
    {
       PRINT("SC7A20E failed id1: %d, id2: %d\n", id1, id2);
        return -1; // ID验证失败
    }

    Check_Flag = SL_SC7A20H_POWER_DOWN();

    if(Check_Flag==1)
	{
		Check_Flag= SL_SC7A20H_SOFT_RESET();

        if (Check_Flag!=1) {
            return -4;
        }
        // 写入初始化配置
        for(i = 0; i < SC7A20E_INIT_REG_NUM; i++)
        {
            I2C_WriteReg(SC7A20E_ADDR,SC7A20E_INIT_REG[3*i], SC7A20E_INIT_REG[3*i+1]);
        }

        sl_delay(1);
        
        // 读回配置值进行验证
        for(i = 0; i < SC7A20E_INIT_REG_NUM; i++)
        {
            I2C_ReadReg(SC7A20E_ADDR,SC7A20E_INIT_REG[3*i], 1, &SC7A20E_INIT_REG[3*i+2]);
        }
        
        // 验证配置是否成功
        for(i = 0; i < SC7A20E_INIT_REG_NUM; i++)
        {
            if(SC7A20E_INIT_REG[3*i+1] != SC7A20E_INIT_REG[3*i+2])
            {
                PRINT("SC7A20E init failed %d val %d nnnjj %d \n", i,SC7A20E_INIT_REG[3*i+1],SC7A20E_INIT_REG[3*i+2]);
                return -3; // IIC通信错误
            }
        }
        

        // 配置上拉模式
        I2C_WriteReg(SC7A20E_ADDR,0x57, 0x00);//SDO和I2C上拉
	}
    else 
    {
        return -2;
    }
    PRINT("SC7A20E init ok\n");
    initWindow(&window);
    return id1; // 返回芯片ID，初始化成功
}

/*********************************************************************
 * @fn      SC7A20E_MonitorAccelChange
 *
 * @brief   监测加速度数据变化率，超过阈值时触发回调
 *
 */
void SC7A20E_MonitorAccelChange(int16_t *x, int16_t *y, int16_t *z, int16_t *pitch, int16_t *roll)
{
    static int16_t x_buffer = 0;
    static int16_t y_buffer = 0;
    static int16_t z_buffer = 0;

    uint8_t new_x_low, new_x_high,new_y_low, new_y_high,new_z_low, new_z_high = 0;

    I2C_ReadReg(SC7A20E_ADDR,0x62, 1, &new_x_low);
    I2C_ReadReg(SC7A20E_ADDR,0x61, 1, &new_x_high);

    I2C_ReadReg(SC7A20E_ADDR,0x64, 1, &new_y_low);
    I2C_ReadReg(SC7A20E_ADDR,0x63, 1, &new_y_high);
    
    I2C_ReadReg(SC7A20E_ADDR,0x66, 1, &new_z_low);
    I2C_ReadReg(SC7A20E_ADDR,0x65, 1, &new_z_high);

    *x =(signed short)((new_x_high<<8)+new_x_low)>>4;//12bit
	*y =(signed short)((new_y_high<<8)+new_y_low)>>4;//12bit
	*z =(signed short)((new_z_high<<8)+new_z_low)>>4;//12bit
}

/*********************************************************************
