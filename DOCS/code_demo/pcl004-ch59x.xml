 *
 * @return  0 - 成功, 1 - 失败
 */
uint8_t MCP4017T_SetWiperPosition(uint8_t position) {
    if(position > 127) {
        // 错误处理: 抽头位置必须在0到127之间
        return 1;
    }
    // 发送数据到MCP4017T
    I2C_WriteReg(0x2F, 0x00, position);
    return 0;
}

