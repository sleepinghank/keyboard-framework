// 函数指针表用于高效设置LED
static void (* const led_funcs[])(void) = {
    [LED_OFF]   = close_led,
    [LED_RED]   = red_led,
    [LED_GREEN] = green_led,
    [LED_BLUE]  = blue_led,
    [LED_WHITE] = white_led 
};

void set_led_color(LedColor_e color) {
    // 快速跳过检查
    if (color == led_state.color && !led_state.need_update) 
        return;
    
    // 安全执行函数
    if (color < ARRAY_SIZE(led_funcs) && led_funcs[color]) {
        led_funcs[color]();
    } else {
        close_led();  // 异常情况关闭LED
    }
    
    led_state.color = color;
    led_state.need_update = 0;  // 重置更新标志
}

// 统一的模式切换函数
void switch_led_mode(LedMode_e new_mode) {
    // 模式未变化时跳过
    if (new_mode == led_state.mode && !led_state.need_update) 
        return;
    
    // 安全模式检查
    if (new_mode >= LED_MODE_COUNT) 
        new_mode = LED_MODE_NONE;
    
    const LedModeConfig_t* cfg = &mode_config[new_mode];
    
    led_state = (LedState_t){
        .mode = new_mode,
        .color = LED_OFF,  // 强制颜色更新
        .counter = 0,
        .need_update = 1,
        .blink_count = 0,
        .max_blink_count = cfg->max_blink_count,
        .auto_disable = cfg->auto_disable,
        .active_count = 0,
        .max_active_count = cfg->max_active_count,
        .dynamic_disable = cfg->dynamic_disable
    };
    
    // 常亮模式立即生效
    if (cfg->off_ticks == 0) {
        set_led_color(cfg->color);
    }
}

// 禁用当前模式
void disable_current_mode(void) {
    // 清除当前模式标志位
    if (led_state.mode < LED_MODE_COUNT) {
        led_status_flags &= ~flag_masks[led_state.mode];
    }
    
    // 寻找最高优先级有效模式（根据当前模式选择正确的优先级表）
    LedMode_e new_mode = LED_MODE_NONE;
    const LedMode_e* priority_list;
    size_t priority_size;
    
    if (sleepModeFlag != 0) {
        // 休眠模式使用休眠优先级表
        priority_list = sleep_priority_modes;
        priority_size = ARRAY_SIZE(sleep_priority_modes);
    } else {
        // 正常模式使用正常优先级表
        priority_list = priority_map;
        priority_size = ARRAY_SIZE(priority_map);
    }
    
    for (size_t i = 0; i < priority_size; i++) {
        LedMode_e mode = priority_list[i];
        if (mode < LED_MODE_COUNT && (led_status_flags & flag_masks[mode])) {
            new_mode = mode;
            break;
        }
    }
    
    // 深度休眠时跳过蓝牙回连，并清除标志位
    if (new_mode == LED_MODE_BLE_RECONNECT && sleepModeFlag == 3) {
        led_status_flags &= ~flag_masks[LED_MODE_BLE_RECONNECT];
        new_mode = LED_MODE_NONE;
    }
    
    switch_led_mode(new_mode);
}

// 处理闪烁模式
int handle_blink_mode(const LedModeConfig_t* cfg) {
    uint16_t total_ticks = cfg->on_ticks + cfg->off_ticks;
    uint16_t counter = led_state.counter;
    
    // 计算目标颜色
    LedColor_e target_color = (counter < cfg->on_ticks) ? cfg->color : LED_OFF;
    
    // 颜色变化或强制更新时设置LED
    if (target_color != led_state.color || led_state.need_update) {
        set_led_color(target_color);
    }
    
    // 更新计数器
    if (++counter >= total_ticks) {
        counter = 0;
        
        // 闪烁计数检查
        if (led_state.auto_disable && led_state.max_blink_count > 0) {
            if (++led_state.blink_count >= led_state.max_blink_count) {
                disable_current_mode();
                return 1;  // 模式已禁用
            }
        }
    }
    led_state.counter = counter;
    return 0;
}

