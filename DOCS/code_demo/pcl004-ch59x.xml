{
    // 使用新的GPIO操作函数
    return GPIO_ReadButton(button_id);
}
extern uint8_t find_enable;
extern uint8_t sleepModeFlag;
extern uint8_t hasHighAdv;
// extern uint8_t isTurnedOff;
uint8_t btnAfterOperate(){
    uint8_t sleeping = 0;
    PRINT("sleepModeFlag111 is %d \n",sleepModeFlag);
    if(sleepModeFlag!=0)
    {
        sleeping=1;
    }

    _clean_sleep_timer();
    // if (isTurnedOff!=0) {
    //     isTurnedOff=0;
    //     hidDevInitialAdvertising();
    //     return 1;
    // }
    
    // 蜂鸣器
    if(start_find_flag == 1)
    {
        start_find_flag = 0;
        find_enable = 0;
        change_find_status();
        push_start_find_status_change();
        return 1;
    }
    
    if (!ble_is_connected()) {
        
        // 正在广播但是是慢广播
        if(ble_is_advertising()&&advertisingMode!=1)
        {
            hasHighAdv = 1;
            hidDevInitialAdvertising();
        }
        else if(!ble_is_advertising())
        {
            // 未广播
            // hasHighAdv = 1;
            hidDevInitialAdvertising();
        }
        return 1;
    }
    if(sleeping!=0)
    {
        return 1;   
    }
    return 0;
}

// 单击
void power_btn_single_click(void* btn)
{
    PRINT("power_btn_single_click index is \n");
    if(hasAlready == 0)
    {
        rePowerKeyStart();
    }
    else
    {
        
        if(btnAfterOperate() == 1)
        {
            return;
        }
        
        uint8_t bit = nvs_flash_info.single_click_func_idx & 0x80;
        uint8_t index = nvs_flash_info.single_click_func_idx & 0x7F;

        if (index >= FUNC_COUNT)
        {
            return ;
        }

        if (bit == 0)
        {
            index = 6;
        }

        if (index >= FUNC_COUNT)
        {
            return ;
        }

        KeyHandlerFunc handler = func_handlers[index];
        
        handler(); 
    }
	// PRINT("power_btn_single_click index is %d\n",fIndex);
}

// 双击
void power_btn_double_click(void* btn)
{
    if(hasAlready == 0)
    {
        rePowerKeyStart();
    }
    else
    {
        // 关闭蜂鸣器
        if(btnAfterOperate() == 1)
        {
            return;
        }

        uint8_t bit = nvs_flash_info.double_click_func_idx & 0x80;
        uint8_t index = nvs_flash_info.double_click_func_idx & 0x7F;

        if (index >= FUNC_COUNT)
        {
            return ;
        }

        if (bit == 0)
        {
            index = 2;
        }

        if (index >= FUNC_COUNT)
        {
            return ;
        }

        KeyHandlerFunc handler = func_handlers[index];
        
        handler();
    }
}

