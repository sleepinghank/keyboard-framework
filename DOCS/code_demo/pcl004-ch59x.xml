void otaNotify(uint8_t *pValue, uint16_t len)
{
    if (ble_is_connected()==1) {
        attHandleValueNoti_t noti;
        noti.len = len;
        noti.pValue = GATT_bm_alloc(hidEmuConnHandle, ATT_HANDLE_VALUE_NOTI, noti.len, NULL, 0);
        tmos_memcpy(noti.pValue, pValue, noti.len);
        if(SimpleProfile_Notify(hidEmuConnHandle, &noti) != SUCCESS)
        {
            GATT_bm_free((gattMsg_t *)&noti, ATT_HANDLE_VALUE_NOTI);
        }   
    }
}

