 */
static hidRptMap_t *hidDevRptByCccdHandle(uint16_t handle)
{
    uint8_t      i;
    hidRptMap_t *p = pHidDevRptTbl;

    for(i = hidDevRptTblLen; i > 0; i--, p++)
    {
        if(p->cccdHandle == handle)
        {
            return p;
        }
    }

    return NULL;
}

/*********************************************************************
