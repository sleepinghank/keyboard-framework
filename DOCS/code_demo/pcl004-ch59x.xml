// 用户任务初始化
uint16_t UserTask_ProcessEvent(uint8_t task_id, uint16_t events)
{
    if(events & SYS_EVENT_MSG)
    { // 处理HAL层消息，调用tmos_msg_receive读取消息，处理完成后删除消息。
        uint8_t *msgPtr;
        msgPtr = tmos_msg_receive(task_id);
        if(msgPtr)
        {
            /* De-allocate */
            tmos_msg_deallocate(msgPtr);
        }
        return events ^ SYS_EVENT_MSG;
    }
    if(events & START_RESET_DEFAULT_EVT)
    {
        // 恢复出厂
        // led_status_flags = 0;
        // led_state.mode = LED_MODE_NONE;
        // led_state.need_update = 1;
        PRINT("_current_addr is %d \n",_current_addr);
        #if(defined(BLE_MAC)) && (BLE_MAC == TRUE)
            _current_addr++;
        #endif
        find_flag = 0;
        start_find_flag = 0;
        
        // 重置变量
        nvs_flash_info.current_addr = _current_addr;
        nvs_flash_reset();
        PRINT("_current_addr22 is %d \n",_current_addr);

        gain_position = nvs_flash_info.gain_level;

        nvs_flash_store();

        OTA_Storage_Write_Jump_Flag(OTA_JUMP_FLAG_INVALID);
        mDelaymS(100);

        jumpIAP();

        
        return (events ^ START_RESET_DEFAULT_EVT);
    }

    if(events & START_BATTERY_EVT)
    {
        // 电量和充电状态
        battery_level_detection(0);
        if(sleepModeFlag == 1)
        {
            _sleep_timer_task();
        }
        else if (sleepModeFlag == 2) 
        {
            _power_timer_task();
        }

        if(sleepModeFlag == 3)
        {
            tmos_start_task(userTaskId, START_BATTERY_EVT, MS1_TO_SYSTEM_TIME(LOW_BATTERY_CHECK_TIMER));
        }
        else
        {
            tmos_start_task(userTaskId, START_BATTERY_EVT, MS1_TO_SYSTEM_TIME(BATTERY_CHECK_TIMER));
        }
        return (events ^ START_BATTERY_EVT);
    }

    if(events & START_BATTERY_INIT_EVT)
    {
        // 电量初始化
        battery_init();
        tmos_start_task(userTaskId, START_BATTERY_EVT, MS1_TO_SYSTEM_TIME(500));
        return (events ^ START_BATTERY_INIT_EVT);
    }

    if(events & START_IRQ_CHECK_EVT)
    {
        checkChargingStatus();
        // 
        // 检测充电状态
        // calculate_charging_state(2);
        // battery_level_detection(0);
        // 如果产生中断后检测不是充电状态且不是按键开机的状态下，直接拉低开机保持使能脚
        // if(get_bat_status() == 1)
        // {
        //     if(hasAlready==0){
        //         GPIO_SetSystemPower(0);
        //     }
        // }else {
        //     GPIO_SetSystemPower(1);
        // }
        return (events ^ START_IRQ_CHECK_EVT);
    }
    if(events & START_BTN_WAKE_CHECK_EVT)
    {
        // 开关机键中断逻辑
        _gpio_int_wakup();
        _clean_sleep_timer();
        return (events ^ START_BTN_WAKE_CHECK_EVT);
    }

    if(events & START_STORAGE_WRITE_EVT)
    {
        // 存储
        nvs_flash_store();
        return (events ^ START_STORAGE_WRITE_EVT);
    }

    if(events & START_LOW_BAT_SHUTDOWM_EVT)
    {
        // 关机
        if(_OTA_GetStartFlag()!=1){
            // 关闭中断
            PFIC_DisableIRQ(GPIO_B_IRQn);
            // PFIC_DisableIRQ(GPIO_A_IRQn);
            GPIOB_ResetBits(GPIO_Pin_10);
            LowPower_Shutdown(0);
        }
        return (events ^ START_LOW_BAT_SHUTDOWM_EVT);
    }
    if(events & START_SHUTDOWM_EVT)
    {
        // 关机灯效停止
        set_led_status(LED_MODE_SHUTDOWN_BLINK,0);
        // 关机
        shutdownBefore();
        
        return (events ^ START_SHUTDOWM_EVT);
    }
    if(events & START_REPORT_EVT)
    {
        // 按键处理
        if (GPIOB_ReadPortPin(GPIO_Pin_11)!=0&&isInitBtn==0) {
            isInitBtn=1;
            power_btn_init();
            PRINT("isInitBtnsss1s \r\n");
        }
        if (isInitBtn == 1) {
            button_ticks();
        }
        tmos_start_task(userTaskId, START_REPORT_EVT, MS1_TO_SYSTEM_TIME(REPORT_TIMER));
        return (events ^ START_REPORT_EVT);
    }
    if(events & START_LED_SCAN_EVT)
    {
        ledScan();
        tmos_start_task(userTaskId, START_LED_SCAN_EVT, MS1_TO_SYSTEM_TIME(25));
        return (events ^ START_LED_SCAN_EVT); 
    }
    if(events & START_MOTION_EVT)
    {
        // 陀螺仪
        uint8_t SL_Read_Reg2 = 0;
        BOOL isMoving=0;

        SL_Read_Reg2 = SL_SC7A20H_Get_Init_Source();

        isMoving = processMotionDetection();
        if(SL_Read_Reg2!=0&&isMoving==0){
            isMoving = 1;
        }

        if(isMoving!=0)
        {
            PRINT("State MOTION %d isMoving %d\n",SL_Read_Reg2,isMoving);
            _clean_sleep_timer();
        }
        else {
            _idle_timer_task();
        }
        tmos_start_task(userTaskId, START_MOTION_EVT, MS1_TO_SYSTEM_TIME(MOTION_DETECTION_TIMER));
        return (events ^ START_MOTION_EVT);
    }
    
    if(events & OTA_FLASH_ERASE_EVT)
    {
        // OTA Flash擦除处理
        uint8_t ret = OTA_EraseSector_Process();
        if(ret == SUCCESS)
        {
            // 擦除完成，不需要继续处理
            return (events ^ OTA_FLASH_ERASE_EVT);
        }
        else if(ret == FAILURE)
        {
            // 擦除失败，停止处理
            return (events ^ OTA_FLASH_ERASE_EVT);
        }
        else
        {
            // 继续擦除下一个扇区
            tmos_start_task(userTaskId, OTA_FLASH_ERASE_EVT, MS1_TO_SYSTEM_TIME(1));
            return (events ^ OTA_FLASH_ERASE_EVT);
        }
    }
    
    if(events & APP_SCHEDULED_TASK_EVT)
    {

        // OTA定时任务处理（每秒调用一次）
        uint8_t flag = _OTA_ScheduledTask();
        if(flag == 1)
        {
            // 重新启动定时任务，每秒执行一次
            tmos_start_task(userTaskId, APP_SCHEDULED_TASK_EVT, MS1_TO_SYSTEM_TIME(1000));
        }
        else{
            tmos_stop_task(userTaskId, APP_SCHEDULED_TASK_EVT);
            return (events ^ APP_SCHEDULED_TASK_EVT);
        }
        return (events ^ APP_SCHEDULED_TASK_EVT);
    }
    // 丢弃未知事件
    return 0;
}

// 初始化用户任务
void user_tack_Init(void)
{
    sleepModeFlag = 0;
    _idle_cnt = 0;
    _slp_cnt =0;
    _pd_cnt=0;
    // led_status_flags = 0;
    userTaskId = TMOS_ProcessEventRegister(UserTask_ProcessEvent);

    // Setup a delayed profile startup
    tmos_set_event(userTaskId, START_REPORT_EVT);
    tmos_set_event(userTaskId, START_LED_SCAN_EVT);

    tmos_start_task(userTaskId, START_BATTERY_INIT_EVT, MS1_TO_SYSTEM_TIME(1000));
    
    // 启动OTA定时任务，每秒执行一次
    tmos_start_task(userTaskId, APP_SCHEDULED_TASK_EVT, MS1_TO_SYSTEM_TIME(1000));
    PRINT("user_tack_Init \n");
}
