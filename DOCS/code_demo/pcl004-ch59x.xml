// 获取adc检测值
static uint16_t get_adc_value(uint8_t mode)
{
    #define TOTAL_SAMPLES 12    // 总采样次数
    #define SKIP_FIRST 1        // 跳过第一次
    #define SKIP_EXTREMES 2     // 跳过极值（最大值+最小值）
    #define VALID_SAMPLES (TOTAL_SAMPLES - SKIP_FIRST - SKIP_EXTREMES) // 有效样本数
    #define UINT16_MAX_VAL  65535U
    #define ADC_CANCELED_VALUE  0xFFFF  // 特殊值：表示ADC读取被取消
    #define ADC_INVALID_VALUE   0xFFFE  // 特殊值：表示无效值（电压过低等）
    
    uint16_t adcBuff[TOTAL_SAMPLES];
    uint32_t sum = 0;
    uint16_t min_val, max_val;
    uint8_t min_idx, max_idx;

    // 启动ADC
    gpadc_start(mode);

    // 采集数据（支持取消机制）
    uint8_t samples_collected = 0;
    for(uint8_t i = 0; i < TOTAL_SAMPLES; i++)
    {
        // 检查是否需要取消（根据 mode 检查对应的取消标志）
        // mode 1/3: 对应 get_battery_voltage，检查 battery_voltage_cancel_requested
        // mode 2: 对应 calculate_charging_state，检查 charging_state_cancel_requested
        uint8_t should_cancel = 0;
        if ((mode == 1 || mode == 3) && battery_voltage_cancel_requested) {
            should_cancel = 1;
        } else if (mode == 2 && charging_state_cancel_requested) {
            should_cancel = 1;
        }
        
        if (should_cancel) {
            // 收到新请求，取消当前读取
            GPIO_AdcDeInit();  // 清理ADC硬件
            return ADC_CANCELED_VALUE;  // 返回特殊值表示被取消
        }
        
        uint16_t calibrated_value = 0;
        uint16_t adc_raw = ADC_ExcutSingleConver();
        if(mode==1||mode==3)
        {
            calibrated_value = adc_raw + RoughCalib_ADC;
        }else {
            calibrated_value = adc_raw + RoughCalib_Charge;
        }
        // uint16_t calibrated_value = adc_raw + (mode == 1 ? RoughCalib_ADC : RoughCalib_Charge);
        adcBuff[i] = calibrated_value;
        samples_collected++;
    }
    
    // 如果收集的样本不足（被取消），返回特殊值
    if (samples_collected < TOTAL_SAMPLES) {
        return ADC_CANCELED_VALUE;
    }

    // 从第二次数据开始寻找极值（跳过第一次）
    min_val = max_val = adcBuff[SKIP_FIRST];
    min_idx = max_idx = SKIP_FIRST;
    
    for(uint8_t i = SKIP_FIRST + 1; i < TOTAL_SAMPLES; i++)
    {
        if (adcBuff[i] < min_val)
        {
            min_val = adcBuff[i];
            min_idx = i;
        }
        if (adcBuff[i] > max_val)
        {
            max_val = adcBuff[i];
            max_idx = i;
        }
    }

    // 计算有效数据的平均值
    for(uint8_t i = SKIP_FIRST; i < TOTAL_SAMPLES; i++)
    {
        if (i != min_idx && i != max_idx)
        {
            sum += adcBuff[i];
        }
    }

    uint32_t average_value = sum / VALID_SAMPLES;
    // 电压转换
    if(mode == 1)
    {
        if (average_value < 1005) {
            return ADC_INVALID_VALUE;  // 返回特殊值表示无效值或电压过低
        }
        // 电池电压模式：根据实际测量数据修正
        // 实际测量数据：ADC = 629 * 电压(V) + 1005
        // 反推：电压(V) = (ADC - 1005) / 629
        // 转换为mV：电压(mV) = (ADC - 1005) / 629 * 1000
        float voltage_v = (average_value - 1005.0f) / 629.0f;
        float voltage_mv = voltage_v * 1000.0f;
        uint32_t voltage_mv_u32 = (uint32_t)voltage_mv;
        if (voltage_mv_u32 > UINT16_MAX_VAL) {
            return UINT16_MAX_VAL;  // 防止溢出
        }

        return (uint16_t)voltage_mv;
    }
    else
    {
        if (average_value > UINT16_MAX_VAL) {
            return UINT16_MAX_VAL;  // 防止溢出
        }
        // 充电电压模式：直接使用ADC值
        return (uint16_t)average_value;
    }
}


static uint16_t voltage_buf[FILTER_N];
static uint16_t charge_buf[FILTER_N];
static uint8_t voltage_buf_idx = 0xff;
static uint8_t charge_buf_idx = 0xff;
static uint16_t last_voltage = 0xffff;

// 获取电池电压
uint16_t get_battery_voltage(void){
    uint16_t voltage = 0;
    float adc_val = 0;

    // ================ 并发保护：尝试获取锁 ================
    if (!battery_voltage_try_lock()) {
        // 如果正在执行，返回上次的结果，避免并发冲突
        // 如果上次结果为0（无效），返回一个默认值（例如300，表示3.00V）
        return (last_battery_voltage_result != 0) ? last_battery_voltage_result : 390;
    }

    if(voltage_buf_idx == 0xff){
        uint8_t retry_count = 0;
        const uint8_t MAX_RETRY_PER_SAMPLE = 3;  // 每个样本最多重试3次，防止无限循环
        
        for(uint8_t i = 0; i < FILTER_N; i++){
            voltage = get_adc_value(1);
            // 检查是否被取消或无效值
            if (voltage == ADC_CANCELED_VALUE || voltage == ADC_INVALID_VALUE) {
                // 如果被取消，使用上次的有效值（如果存在），否则重试
                if (last_voltage != 0xffff) {
                    voltage = last_voltage * 10;  // 转换回mV单位
                    retry_count = 0;  // 重置重试计数
                } else {
                    // 如果没有上次值，重试本次采样
                    retry_count++;
                    if (retry_count < MAX_RETRY_PER_SAMPLE) {
                        i--;  // 回退索引，重新采样
                        continue;
                    } else {
                        // 超过最大重试次数，使用默认值（3000mV = 3.00V）
                        voltage = 3900;
                        retry_count = 0;  // 重置重试计数
                    }
                }
            } else {
                retry_count = 0;  // 成功获取，重置重试计数
            }
            voltage_buf[i] = voltage;
            for(uint16_t a = 0; a < 500; a++);
        }
        voltage_buf_idx = FILTER_N - 1;
    } else {
        voltage_buf_idx++;
        if(voltage_buf_idx >= FILTER_N){
            voltage_buf_idx = 0;
        }
        voltage = get_adc_value(1);
        // 检查是否被取消或无效值
        if (voltage == ADC_CANCELED_VALUE || voltage == ADC_INVALID_VALUE) {
            // 如果被取消，使用上次的有效值（如果存在），否则使用缓冲区中的旧值
            if (last_voltage != 0xffff) {
                voltage = last_voltage * 10;  // 转换回mV单位
            } else {
                // 如果没有上次值，使用缓冲区中对应位置的上一个值
                uint8_t prev_idx = (voltage_buf_idx == 0) ? (FILTER_N - 1) : (voltage_buf_idx - 1);
                voltage = voltage_buf[prev_idx];
            }
        }
        voltage_buf[voltage_buf_idx] = voltage;
    }

    // 检查是否在采样过程中收到新请求
    if (battery_voltage_cancel_requested) {
        // 被取消，立即释放锁并返回，让新请求执行
        battery_voltage_unlock();
        // 如果上次结果为0（无效），返回一个默认值（例如300，表示3.00V）
        return (last_battery_voltage_result != 0) ? last_battery_voltage_result : 390;
    }

    voltage = filter(voltage_buf,FILTER_N);

    // 现在get_adc_value已经直接返回电压值(mV)，需要转换为0.01V单位以提供小数点后两位精度
    // 例如：3000mV = 3.00V，返回300 (300/100 = 3.00V)
    voltage = voltage / 10; // 将mV转换为0.01V单位

    if(GET_DIFFERENCE(last_voltage, voltage) > 2)
    {
        last_voltage = voltage;
    }
    
    // 更新缓存结果
    last_battery_voltage_result = last_voltage;
    
    // ================ 释放锁 ================
    battery_voltage_unlock();
    
    return last_voltage;
}
