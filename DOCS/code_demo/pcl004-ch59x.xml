    }
    if (batteryState.isCharging != 0){
        set_led_status(LED_MODE_LOW_BAT_BLINK,0);
    }
}

void battery_init(void){
    // 获取电池电压并存入batteryState
    batteryState.voltageMv = get_battery_voltage(); // 将0.01V单位转换为mV单位
    // PRINT("Initial battery voltage: %d mV\n", batteryState.voltageMv);

    if (batteryState.voltageMv != 0xffff) {
        // 使用convert_voltage_to_percentage方法计算电量百分比
        uint8_t currentLevel = convert_voltage_to_percentage(batteryState.voltageMv);
        // PRINT("Calculated current level: %d%%\n", currentLevel);

        // PRINT("Calculated remaining_capacity_mas: %d \n", nvs_flash_info.remaining_capacity_mas);
        // 计算历史电量百分比
        uint8_t historicalPercentage = (uint8_t)((nvs_flash_info.remaining_capacity_mas * 100) / BATTERY_CAPACITY_MAS);
        // PRINT("Historical percentage: %d%%\n", historicalPercentage);

        // 充电开机直接使用使用历史电量
        if (hasAlready != 1) {
            batteryState.remainingCapacityMas = nvs_flash_info.remaining_capacity_mas;
            batteryState.percentageRemaining = (uint8_t)historicalPercentage;
        }
        else 
        {
            // 按键开机通过计算
            // 如果计算的电量与电压表对应的电量差异过大，或电量异常，则重置电量
            if (GET_DIFFERENCE(historicalPercentage, currentLevel) >= 5 ||
                nvs_flash_info.remaining_capacity_mas == 0 ||
                nvs_flash_info.remaining_capacity_mas > BATTERY_CAPACITY_MAS) {
                // 如果电量异常或差异过大，重置电量状态
                batteryState.remainingCapacityMas = (uint32_t)((uint64_t)BATTERY_CAPACITY_MAS * currentLevel / 100);
                batteryState.percentageRemaining = (uint8_t)currentLevel;
                // PRINT("Resetting battery state: remainingCapacityMas = %d, percentageRemaining = %d%%\n",
                    // batteryState.remainingCapacityMas, batteryState.percentageRemaining);

                // 使用当前电压对应的电量百分比重新初始化电量状态
                nvs_flash_info.remaining_capacity_mas = batteryState.remainingCapacityMas;
                startStorageTask(1);
                // PRINT("Battery state reset and saved to storage.\n");
            } else {
                // 使用历史电量
                batteryState.remainingCapacityMas = nvs_flash_info.remaining_capacity_mas;
                batteryState.percentageRemaining = (uint8_t)historicalPercentage;
                // PRINT("Using historical battery state: remainingCapacityMas = %d, percentageRemaining = %d%%\n",
                //     batteryState.remainingCapacityMas, batteryState.percentageRemaining);
            }
        }
    } else {
        // PRINT("Failed to read battery voltage.\n");
    }
}

/**
 * @brief 处理充满状态时的电量平滑过渡
 * @param current_percentage 当前电量百分比
 * @return 平滑过渡后的电量百分比
 * 
 * 实现逻辑：
 * - 正常模式（sleepModeFlag != 3）：每4次调用增加2%（即每8秒增加2%）
 * - sleepModeFlag == 3：每次调用增加3%左右
 */
static uint8_t smooth_charge_to_full(uint8_t current_percentage) {
    // 如果当前电量已经达到或超过100%，直接返回100%
    if (current_percentage >= 100) {
        smooth_call_counter = 0;
        return 100;
    }
    
    uint8_t new_percentage = current_percentage;
    
    if (sleepModeFlag == 3) {
        // sleepModeFlag == 3：每次调用增加3%左右
        new_percentage = current_percentage + SMOOTH_CHARGE_TO_FULL_STEP_SLEEP3;
    } else {
        // 正常模式：每4次调用增加1%
        smooth_call_counter++;
        if (smooth_call_counter >= SMOOTH_CHARGE_TO_FULL_COUNT_NORMAL) {
            // 每4次调用，增加1%
            new_percentage = current_percentage + SMOOTH_CHARGE_TO_FULL_STEP_NORMAL;
            smooth_call_counter = 0;  // 重置计数器
        } else {
            // 未达到4次，保持当前电量
            new_percentage = current_percentage;
        }
    }
    
    // 确保不超过100%
    if (new_percentage > 100) {
        new_percentage = 100;
    }
    
    // 如果已达到100%，停止平滑过渡
    if (new_percentage >= 100) {
        smooth_call_counter = 0;
        return 100;
    }
    
    return new_percentage;
}

uint16_t _adc_value_temp = 0x3ff;
void battery_level_detection(uint16_t threshold){
    uint16_t adc_value = 0;
    static uint16_t bi_timer = 0;

    bi_timer++;

    if (bi_timer < threshold)
        return;

    bi_timer = 0;
    adc_value = get_battery_voltage(); // 将0.01V单位转换为mV单位
    // PRINT("voltageMv:%d\r\n",batteryState.voltageMv);
    // 1. 判断充电状态
    uint8_t chargingState = calculate_charging_state(1);
    GPIO_AdcDeInit();
    // 设置为io中断，下降沿触发
    GPIO_AdcIRQ(chargingState);
    
    batteryState.isCharging = chargingState;

    // if(_adc_value_temp != adc_value)
    // {
    //     _adc_value_temp = adc_value;
    //     batteryState.voltageMv = _adc_value_temp;
    // }

    if(chargingState==0)
    {
        last_completed_cnt = 0;
        // 检测状态变化，如果从充电状态变为未充电状态，立即通知状态变化
        if(last_charging_state!=0)
        {
            
            // 重置延迟计数器
            discharge_voltage_delay_counter = DISCHARGE_VOLTAGE_DELAY_COUNT;
            // 立即通知状态变化，确保状态更新及时
            uint8_t newLevel = get_bat_level();
            setBattInfo(newLevel,power_st);
        }

        if (discharge_voltage_delay_counter > 0) {
            discharge_voltage_delay_counter--;
            voltage_buf_idx = 0xff;  // 重置索引，下次调用get_battery_voltage时会重新初始化滑动窗口
            last_voltage = 0xffff;   // 重置上次电压值，避免平滑处理影响
            // 延迟期间也需要通知状态，确保状态更新及时
            uint8_t newLevel = get_bat_level();
            setBattInfo(newLevel,power_st);
            last_charging_state = chargingState;
            check_low_battery();
            return;
        }
        
        // if (adc_value > _adc_value_temp){
        //     if ((adc_value - _adc_value_temp) < 10){
        //         uint8_t newLevel = get_bat_level();
        //         setBattInfo(newLevel,power_st);
        //         last_charging_state = chargingState;
        //         check_low_battery();
        //         return;
        //     }
        // }

        if(_adc_value_temp != adc_value)
        {
            _adc_value_temp = adc_value;
            batteryState.voltageMv = _adc_value_temp;
        }
        
        uint8_t currentLevel = convert_voltage_to_percentage(batteryState.voltageMv);
        if (currentLevel>batteryState.percentageRemaining) {
            uint8_t newLevel = get_bat_level();
            batteryState.remainingCapacityMas = (uint32_t)((uint64_t)BATTERY_CAPACITY_MAS * newLevel / 100);
            batteryState.percentageRemaining = (uint8_t)newLevel;
            nvs_flash_info.remaining_capacity_mas = batteryState.remainingCapacityMas;
            batteryState.percentageRemaining = newLevel;
            setBattInfo(newLevel,power_st);
            last_charging_state = chargingState;
            check_low_battery();
            startStorageTask(1);
            return;
        }

        if(currentLevel != batteryState.percentageRemaining) {
            uint8_t currentLevel = convert_voltage_to_percentage(batteryState.voltageMv);
            batteryState.remainingCapacityMas = (uint32_t)((uint64_t)BATTERY_CAPACITY_MAS * currentLevel / 100);
            batteryState.percentageRemaining = (uint8_t)currentLevel;
            nvs_flash_info.remaining_capacity_mas = batteryState.remainingCapacityMas;
            batteryState.percentageRemaining = currentLevel;
            uint8_t newLevel = get_bat_level();
            setBattInfo(newLevel,power_st);
            startStorageTask(1);
        }    
    }else {
        // =============== 充电状态处理（chargingState != 0）===============
    
        // 1. 检测充电状态变化：从非充电 → 充电，重置计数器
        if (last_charging_state == 0 && chargingState != 0) {
            charge_level_update_counter = 0;
            uint8_t newLevel = get_bat_level();
            setBattInfo(newLevel, power_st);
        }

        // 2. 始终累加剩余容量（反映真实充电过程）
        int16_t powerUsage = calculate_current_power_usage(chargingState);
        int32_t capacity_delta = 0;
        
        if (sleepModeFlag == 3) {
            capacity_delta = (int32_t)powerUsage * 60;   // 快充模式时间因子
        } else {
            capacity_delta = (int32_t)powerUsage * BATTERY_CHECK;
        }
        
        // 检查溢出/下溢风险
        int64_t new_capacity = (int64_t)batteryState.remainingCapacityMas + capacity_delta;
        if (new_capacity > BATTERY_CAPACITY_MAS) {
            batteryState.remainingCapacityMas = BATTERY_CAPACITY_MAS;
        } else if (new_capacity < 0) {
            batteryState.remainingCapacityMas = 0;
        } else {
            batteryState.remainingCapacityMas = (uint32_t)new_capacity;
        }

        // 4. 计算理论电量百分比（不直接使用）
        uint8_t theoreticalPercent = calculate_capacity_percentage(batteryState.remainingCapacityMas);

        // 5. 特殊处理：如果当前显示电量已是100%，但还在充电中 → 强制设为99%
        if (batteryState.percentageRemaining >= 100 && chargingState == 1) {
            batteryState.percentageRemaining = 99;
            batteryState.remainingCapacityMas = (uint32_t)((uint64_t)BATTERY_CAPACITY_MAS * 99 / 100);
            nvs_flash_info.remaining_capacity_mas = batteryState.remainingCapacityMas;
            uint8_t newLevel = get_bat_level();
            setBattInfo(newLevel, power_st);
            startStorageTask(1);
            last_charging_state = chargingState;
            check_low_battery();
            return;
        }

        // 如果硬件已报告充满（power_st == 3），但显示电量 < 100%，启动平滑过渡
        if (chargingState == 2 && batteryState.percentageRemaining <= 100) {
            uint8_t smoothed = smooth_charge_to_full(batteryState.percentageRemaining);
            if (smoothed != batteryState.percentageRemaining) {
                batteryState.percentageRemaining = smoothed;
                batteryState.remainingCapacityMas = (uint32_t)((uint64_t)BATTERY_CAPACITY_MAS * smoothed / 100);
                nvs_flash_info.remaining_capacity_mas = batteryState.remainingCapacityMas;
                setBattInfo(smoothed, power_st);
                startStorageTask(1);
            }
            // 即使未变化，也要确保状态同步
            last_charging_state = chargingState;
            check_low_battery();
            return; // 提前返回，避免后续逻辑覆盖
        }

        // 6. 根据 sleepModeFlag 决定电量更新策略
        uint8_t shouldUpdateDisplay = 0;
        uint8_t newDisplayPercent = batteryState.percentageRemaining;

        if (sleepModeFlag == 3) {
            // 快充模式：每次调用都允许更新，但限制步长
            shouldUpdateDisplay = 1;
            if (theoreticalPercent > batteryState.percentageRemaining + MAX_PERCENTAGE_CHANGE_SLEEP3) {
                newDisplayPercent = batteryState.percentageRemaining + MAX_PERCENTAGE_CHANGE_SLEEP3;
            } else {
                newDisplayPercent = theoreticalPercent;
            }
        } else {
            // 正常模式：受 CHARGE_LEVEL_UPDATE_INTERVAL 控制
            charge_level_update_counter++;
            if (charge_level_update_counter >= CHARGE_LEVEL_UPDATE_INTERVAL) {
                shouldUpdateDisplay = 1;
                // 限制每次最多 +1%
                if (theoreticalPercent > batteryState.percentageRemaining + 1) {
                    newDisplayPercent = batteryState.percentageRemaining + 1;
                } else {
                    newDisplayPercent = theoreticalPercent;
                }
                charge_level_update_counter = 0; // 重置计数器
            }
        }

        // 7. 如果需要更新显示电量
        if (shouldUpdateDisplay==1) {
            // 防止显示 100% 但实际未充满（硬件未报满）
            if (newDisplayPercent >= 100) {
                if (chargingState == 2) {
                    // 硬件已报告充满（ChargingDetection=2），允许设为100%
                    newDisplayPercent = 100;
                    power_st = 3;  // 强制设置为充满，确保充满灯能亮起
                    batteryState.remainingCapacityMas = BATTERY_CAPACITY_MAS;
                } else {
                    // 仍在充电中，最多显示99%
                    newDisplayPercent = 99;
                }
            } else {
                // 未到100%，保持充电中状态
                if (chargingState == 2) {
                    power_st = 2; // 强制为充电中，等待平滑到100%
                }
            }

            // 更新状态
            batteryState.percentageRemaining = newDisplayPercent;
            // batteryState.remainingCapacityMas = (uint32_t)((uint64_t)BATTERY_CAPACITY_MAS * newDisplayPercent / 100);
            nvs_flash_info.remaining_capacity_mas = batteryState.remainingCapacityMas;

            uint8_t newLevel = get_bat_level();
            setBattInfo(newLevel, power_st);
            startStorageTask(1);
        } else {
            // 即使不更新显示，也要检查状态是否变化（如充满标志）
            if (last_charging_state != chargingState) {
                uint8_t newLevel = get_bat_level();
                setBattInfo(newLevel, power_st);
            }
        }
    }
    last_charging_state = chargingState;
    check_low_battery();
}

void battery_reset(void) {
    batteryState.voltageMv = get_battery_voltage(); // 将0.01V单位转换为mV单位
    uint8_t currentLevel = convert_voltage_to_percentage(batteryState.voltageMv);
    batteryState.remainingCapacityMas = (uint32_t)((uint64_t)BATTERY_CAPACITY_MAS * currentLevel / 100);
    batteryState.percentageRemaining = (uint8_t)currentLevel;
    nvs_flash_info.remaining_capacity_mas = batteryState.remainingCapacityMas;
    startStorageTask(1);
}


uint8_t check_bat_level(void)
{
    return batteryState.percentageRemaining;
}
