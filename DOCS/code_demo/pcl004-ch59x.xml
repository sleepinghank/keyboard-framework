//写入存储(write_now = 1 立即写入 write_now = 0 有变化才写入)
void Storage_write(uint8_t write_now)
{
    uint16_t crcValue = 0;
    uint16_t write_addr = 0;
    uint8_t write_buf[50] = {0};
    uint8_t write_len = 0;

    //计算CRC
    crcValue = GetQuickCRC16((unsigned char*)&PencilConfig, sizeof(PencilConfig));

    if ((Storage_lastCrcValue != crcValue) || write_now == 1)
    {

        write_addr = WRITE_STORAGE_ADDR;
        //写入CRC
        write_buf[write_len++] = (uint8_t)(crcValue & 0xFF);
        write_buf[write_len++] = (uint8_t)((crcValue >> 8) & 0xFF);

        memcpy(&write_buf[write_len], (uint8_t*)&PencilConfig, sizeof(PencilConfig));
        write_len += sizeof(PencilConfig);
        
        // todo 写入存储
        // pxi_gap_s_profile_data_write(write_addr, write_len, write_buf);
        Storage_lastCrcValue = crcValue;
    }
}


//读取存储内容(0 读取失败 1 读取成功)
uint8_t Storage_read(void)
{
    uint16_t crcValue = 0,crc = 0;
    uint16_t read_addr = 0;
    
    read_addr = WRITE_STORAGE_ADDR;

    //todo 读取CRC
    // pxi_gap_s_profile_data_read(read_addr, 2, (uint8_t*)&crcValue);
    read_addr += 2;

    //todo 读取存储
    // pxi_gap_s_profile_data_read(read_addr, sizeof(PencilConfig), (uint8_t*)&PencilConfig);

    //计算CRC
    crc = GetQuickCRC16((unsigned char*)&PencilConfig, sizeof(PencilConfig));
    //CRC校验
    if (crcValue != crc)
    {
        PRINT("CRC error!!!");
        return 0;
    }else
    {
        PRINT("CRC ok!!!");
        return 1;
    }
    
}
