    uint8_t tmp1;
    uint8_t tmp2;
    uint8_t _addr_1_base;

    GetMACAddress(MacAddr);

    _addr_1_base = MacAddr[2];

    tmp1 = ((_addr_1_base & 0x1f) + ((_current_addr + inc) & 0x1f)) & 0x1f;
    tmp2 = (((_addr_1_base >> 5) & 0x07) + _device_idx) & 0x07;
    
    MacAddr[2]=tmp1 | (tmp2 << 5);
