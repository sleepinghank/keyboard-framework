// 长按关机
void power_btn_long_press(void* btn)
{
    PRINT("power_btn_long_press \n");
    startShutdownTask();
}

// 按键初始化
void power_btn_init(void){

    button_init(&power_btn, read_button_GPIO, 0, POWER_BTN_ID);
    // 单击
    button_attach(&power_btn, SINGLE_CLICK,     power_btn_single_click);
    // 双击
	button_attach(&power_btn, DOUBLE_CLICK,     power_btn_double_click);
    // 三击
    button_attach(&power_btn, TRIPLE_CLICK,     power_btn_triple_click);
    // 长按
	button_attach(&power_btn, LONG_PRESS_START, power_btn_long_press);
    button_attach(&power_btn, LONG_PRESS_HOLD, power_btn_long_press);
    button_start(&power_btn);
}
