void hidSendUpReport(uint8_t mode){
    if (ble_is_connected()==1) {
        if (mode==2) {
            uint8_t mCode[2] = {0x00};
            hidSendKbdHotReport(mCode);
        }else {
            uint8_t nCode[8] = {0x00};
            hidSendKbdReport(nCode);
        }
    }
}

// 发送热键
void hidSendHotKeyReport(uint16_t mKeycode){
    if (ble_is_connected()==1) {
        uint8_t mCode[2] = {0x00};
        mCode[0]=(mKeycode & 0xFF);
        mCode[1]=((mKeycode >> 8) & 0xFF);
        hidSendKbdHotReport(mCode);
    }
}

void hidSendReport(uint8_t *buf,uint16_t mKeycode){
    if (ble_is_connected()==1) {
        // 先发送媒体键
        if (mKeycode!=0) {
            hidSendHotKeyReport(mKeycode);
        }

        // 再发送普通键
        hidSendKbdReport(buf);

        // 抬起媒体键
        if (mKeycode!=0) {
            hidSendUpReport(2);
        }

        // 抬起普通键
        hidSendUpReport(1);
    }
}

